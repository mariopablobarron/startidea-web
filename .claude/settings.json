{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(ssh *:*)",
      "Bash(scp *:*)",
      "Bash(docker:*)",
      "Bash(npm publish:*)",
      "Bash(git push * --force:*)",
      "Bash(git push origin main:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/node_modules/**)",
      "Read(**/dist/**)"
    ]
  }
}
