# Variables de entorno para producción de startidea-web.
#
# Copia este fichero como `infra/.env.production` (no versionado) y
# rellénalo con los valores reales. Después se carga al regenerar el
# docker-compose con `docker compose --env-file .env.production up -d`.
#
# El fichero real (con valores) NUNCA se commitea — está en .gitignore.

# Imagen — la pone Coolify automáticamente al hacer Deploy (sha del git commit).
IMAGE_TAG=latest

# Acceso al panel /admin/knowledge (header de admin token).
ADMIN_TOKEN=

# OpenRouter — asistente IA en /api/chat.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Bot Telegram para form de contacto y "Pasar al equipo" del asistente.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OAuth Google para módulo SEO en /admin/seo (GA4 + GSC).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://startidea.es/admin/google/callback

# Cifrado de refresh tokens en SQLite del módulo SEO.
# Generar con: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Ruta de la SQLite del módulo SEO (volumen montado).
SEO_DB_PATH=/app/data/seo.db
