---
import Base from '@/layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { blogPostingSchema, breadcrumbList, faqPageSchema, SITE_URL } from '@/lib/jsonld';
import NotasRelacionadas from '@/components/NotasRelacionadas.astro';

export async function getStaticPaths() {
  const notas = await getCollection('notas', ({ data }) => !data.draft);
  // Ordenadas por fecha desc para construir prev/next
  notas.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  return notas.map((nota, i) => ({
    params: { slug: nota.slug },
    props: {
      nota,
      prev: notas[i + 1] ?? null,
      next: notas[i - 1] ?? null,
    },
  }));
}

interface Props {
  nota: CollectionEntry<'notas'>;
  prev: CollectionEntry<'notas'> | null;
  next: CollectionEntry<'notas'> | null;
}

const { nota, prev, next } = Astro.props;
const { Content } = await nota.render();

// ─── Detección de tema "financiación/subvenciones" ───────────────────────
// Para mostrar un CTA comercial específico antes del newsletter (más
// relevante que el genérico y mejor conversión que "suscríbete").
// Notas de fundraising privado (socios, donantes, base social): aunque su
// categoría sea "Financiación", su siguiente paso natural es el servicio
// /fundraising, NO el CTA de tramitación de subvenciones. Se detectan por tag
// de captación y tienen prioridad sobre isFinanciacion.
const isFundraising = (nota.data.tags ?? []).some(t =>
  ['fundraising', 'captación de fondos', 'captación', 'base social', 'socios', 'donaciones'].includes(t),
);

// Notas de producción audiovisual (vídeo, documental, podcast): su siguiente paso
// natural es el servicio /audiovisual, aunque su categoría sea "Comunicación".
const isAudiovisual = (nota.data.tags ?? []).some(t =>
  ['audiovisual', 'vídeo', 'video', 'documental', 'podcast', 'producción audiovisual'].includes(t),
);

const isFinanciacion =
  !isFundraising && !isAudiovisual &&
  (nota.data.category === 'Financiación' ||
    (nota.data.tags ?? []).some(t =>
      ['subvenciones', 'financiación', 'fondos', 'BDNS', 'ayudas'].includes(t),
    ));

// Enlazado interno hacia páginas-dinero: cada nota (no-financiación) apunta a su
// servicio relacionado según categoría. Refuerza la autoridad temática hacia
// donde se convierte y da al lector el siguiente paso natural.
const SERVICIO_POR_CATEGORIA: Record<string, { label: string; href: string }> = {
  'Comunicación': { label: 'Comunicación estratégica y marketing social', href: '/comunicacion' },
  'Estrategia':   { label: 'Consultoría e innovación social', href: '/consultoria' },
  'Agencia':      { label: 'Consultoría e innovación social', href: '/consultoria' },
};
const FUNDRAISING_SERVICE = { label: 'Fundraising para ONG y entidades sociales', href: '/fundraising' };
const AUDIOVISUAL_SERVICE = { label: 'Producción audiovisual y podcast', href: '/audiovisual' };
const servicioRel = isFundraising
  ? FUNDRAISING_SERVICE
  : isAudiovisual
    ? AUDIOVISUAL_SERVICE
    : !isFinanciacion
      ? (SERVICIO_POR_CATEGORIA[nota.data.category ?? ''] ?? null)
      : null;

const fmtDate = new Intl.DateTimeFormat('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(nota.data.pubDate);

// Tiempo de lectura estimado (200 wpm)
const words = nota.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.round(words / 200));

const notaUrl = `${SITE_URL}/notas/${nota.slug}`;
const jsonLd = [
  blogPostingSchema({
    url: notaUrl,
    title: nota.data.title,
    description: nota.data.description,
    datePublished: nota.data.pubDate,
    dateModified: nota.data.updatedDate,
    authorName: nota.data.author,
    authorRole: nota.data.authorRole,
    image: `${SITE_URL}/og/notas/${nota.slug}.png`,
    keywords: nota.data.tags,
  }),
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Notas', url: `${SITE_URL}/notas` },
    { name: nota.data.title, url: notaUrl },
  ]),
  // FAQPage opcional. Si la nota define faqs en su frontmatter, generamos
  // el schema → activa Featured Snippets en Google y sube CTR ~3×.
  // El content schema usa { question, answer }; faqPageSchema espera { q, a }.
  ...(nota.data.faqs && nota.data.faqs.length > 0
    ? [faqPageSchema(nota.data.faqs.map(f => ({ q: f.question, a: f.answer })))]
    : []),
];
---

<Base
  title={`${nota.data.title} — Notas · Startidea`}
  description={nota.data.description}
  ogSlug={`notas/${nota.slug}`}
  jsonLd={jsonLd}
>
  <article>
    <!-- Cabecera -->
    <header class="border-b border-ink/15 bg-paper py-16 md:py-24 lg:py-28">
      <div class="container-narrow">
        <nav class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute" aria-label="Migas">
          <a href="/notas" class="link-underline hover:text-ink">Notas</a>
          <span aria-hidden="true">/</span>
          <span>{fmtDate}</span>
        </nav>

        <h1 class="mt-8 font-display text-display-lg leading-[1.0] text-ink md:text-display-xl">
          {nota.data.title}
        </h1>

        <p class="mt-8 max-w-measure text-lede text-ink/80">
          {nota.data.description}
        </p>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-ink/15 pt-6 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
          <span>{nota.data.author}</span>
          <span aria-hidden="true">·</span>
          <span>{nota.data.authorRole}</span>
          <span aria-hidden="true">·</span>
          <span>~ {readingTime} min de lectura</span>
          {nota.data.audience !== 'Todas' && (
            <>
              <span aria-hidden="true">·</span>
              <span class="text-magenta">Para {nota.data.audience.toLowerCase()}</span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Cuerpo del artículo -->
    <section class="bg-paper py-16 md:py-24">
      <div class="container-narrow">
        {nota.data.tldr && (
          <aside class="mb-12 border-l-2 border-magenta bg-paper-warm p-6 md:p-8" aria-label="Respuesta corta">
            <p class="label text-magenta">— En corto</p>
            <p class="mt-3 max-w-measure text-lg leading-relaxed text-ink/85">{nota.data.tldr}</p>
          </aside>
        )}
        <div class="prose-editorial">
          <Content />
        </div>

        <!-- Tags -->
        {nota.data.tags.length > 0 && (
          <div class="mt-16 border-t border-ink/15 pt-8">
            <span class="label">— Etiquetas</span>
            <ul class="mt-4 flex flex-wrap gap-2">
              {nota.data.tags.map((tag) => (
                <li class="border border-ink/30 px-3 py-1 font-mono text-xs uppercase tracking-wider text-ink/85">
                  #{tag}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>

    <!-- Navegación entre notas -->
    {(prev || next) && (
      <section class="bg-paper-warm py-16 md:py-20">
        <div class="container-narrow">
          <div class="grid gap-px border-2 border-ink/15 bg-ink/15 sm:grid-cols-2">
            {prev ? (
              <a href={`/notas/${prev.slug}`} class="group flex flex-col gap-3 bg-paper-warm p-6 transition-colors hover:bg-paper">
                <span class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">← Nota anterior</span>
                <span class="font-display text-xl leading-tight text-ink transition-colors group-hover:text-magenta md:text-2xl">{prev.data.title}</span>
              </a>
            ) : <div class="bg-paper-warm p-6"></div>}
            {next ? (
              <a href={`/notas/${next.slug}`} class="group flex flex-col gap-3 bg-paper-warm p-6 text-right transition-colors hover:bg-paper">
                <span class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">Nota siguiente →</span>
                <span class="font-display text-xl leading-tight text-ink transition-colors group-hover:text-magenta md:text-2xl">{next.data.title}</span>
              </a>
            ) : <div class="bg-paper-warm p-6"></div>}
          </div>
        </div>
      </section>
    )}

    <!-- Notas relacionadas de la misma categoría -->
    {nota.data.category && (
      <NotasRelacionadas category={nota.data.category} exclude={nota.slug} />
    )}

    <!-- CTA comercial específico para notas de financiación/subvenciones -->
    {isFinanciacion && (
      <section class="border-y border-magenta/30 bg-paper-warm py-14 md:py-16">
        <div class="container-narrow">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
            <div class="md:col-span-7">
              <span class="font-mono text-[10px] uppercase tracking-widest text-magenta">
                — Si esta lectura te ha hecho pensar en alguna convocatoria
              </span>
              <h2 class="mt-3 font-display text-2xl md:text-3xl text-ink leading-tight">
                Pídele a Startidea un análisis de viabilidad <em class="italic text-magenta">sin coste.</em>
              </h2>
              <p class="mt-4 text-ink/70 leading-relaxed text-sm md:text-base">
                Cuéntanos qué convocatoria os interesa o qué proyecto queréis
                financiar. En 24–48h te enviamos el diagnóstico de encaje —
                si tiene sentido presentarse, qué documentación necesitáis y
                qué probabilidad real de éxito vemos. <strong class="text-ink">Sin compromiso, sin coste.</strong>
              </p>
              <p class="mt-3 text-xs text-ink/50 leading-relaxed">
                Si después decides que Startidea presente la convocatoria, comisión 12% solo si se concede.
              </p>
            </div>
            <div class="md:col-span-5 flex flex-col gap-3">
              <a href={`/subvenciones/presentar/nuevo?utm_source=nota&utm_medium=cta-financiacion&utm_campaign=${nota.slug}`}
                 class="inline-block bg-magenta text-paper px-5 py-3 font-mono text-[11px] uppercase tracking-widest hover:bg-ink transition-colors text-center">
                Pedir análisis gratis →
              </a>
              <a href="/subvenciones/catalogo"
                 class="inline-block border-2 border-ink bg-paper text-ink px-5 py-3 font-mono text-[11px] uppercase tracking-widest hover:border-magenta hover:text-magenta transition-colors text-center">
                Ver catálogo de convocatorias →
              </a>
              <a href={`/subvenciones/crear-alerta?utm_source=nota&utm_medium=cta-copiloto&utm_campaign=${nota.slug}`}
                 class="text-center font-mono text-[10px] uppercase tracking-widest text-ink/40 hover:text-magenta">
                · O activa el Copiloto Autónomo (gratis) ·
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Servicio relacionado (enlazado interno → página-dinero) para notas no-financiación -->
    {servicioRel && (
      <section class="border-y border-ink/15 bg-paper-warm py-12">
        <div class="container-narrow flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <span class="font-mono text-[10px] uppercase tracking-widest text-magenta">— Servicio relacionado</span>
            <p class="mt-2 font-display text-xl leading-tight text-ink md:text-2xl">{servicioRel.label}</p>
          </div>
          <a href={servicioRel.href}
             class="inline-block self-start whitespace-nowrap border-2 border-ink bg-paper px-5 py-3 font-mono text-[11px] uppercase tracking-widest text-ink transition-colors hover:border-magenta hover:text-magenta md:self-auto">
            Ver el servicio →
          </a>
        </div>
      </section>
    )}

    <!-- CTA final + suscripción -->
    <section class="bg-ink py-20 text-paper md:py-24">
      <div class="container-narrow">
        <span class="label !text-paper/60">— Una nota al mes</span>
        <h2 class="mt-4 font-display text-display-md leading-tight text-paper">
          Si te ha resonado, <em class="italic text-magenta">no te pierdas la próxima</em>.
        </h2>
        <p class="mt-5 max-w-measure text-lede text-paper/85">
          Una al mes. Cinco minutos. Sin tracking pixels.
        </p>

        <form
          class="mt-10 flex flex-col gap-3"
          action="https://buttondown.email/api/emails/embed-subscribe/startidea"
          method="post"
          target="popupwindow"
          onsubmit="window.stTrack && window.stTrack('newsletter_subscribe', { placement: 'nota', page_path: location.pathname }); window.open('https://buttondown.email/startidea', 'popupwindow')"
        >
          <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch">
            <label class="sr-only" for="nota-newsletter-email">Tu email</label>
            <input
              id="nota-newsletter-email"
              type="email"
              name="email"
              required
              placeholder="tu@email.com"
              autocomplete="email"
              class="flex-1 border border-paper bg-ink px-4 py-3 font-mono text-sm text-paper placeholder:text-paper/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
            />
            <button type="submit" class="btn !bg-paper !text-ink !border-paper hover:!bg-magenta hover:!text-paper hover:!border-magenta">
              Suscribirme
              <span aria-hidden="true">→</span>
            </button>
          </div>
          <label class="flex items-start gap-3 text-xs leading-relaxed text-paper/80">
            <input type="checkbox" name="consent" required
              class="mt-0.5 h-4 w-4 flex-shrink-0 border-paper bg-ink text-magenta focus:ring-magenta" />
            <span>Acepto recibir la newsletter mensual y la <a href="/privacidad" class="link-underline text-paper">política de privacidad</a>. Te puedes dar de baja en cualquier momento desde el propio email.</span>
          </label>
        </form>
      </div>
    </section>
  </article>
</Base>
