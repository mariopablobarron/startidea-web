---
// Home recortada — feedback cliente 7-may: "la página es muy larga, yo
// recortaría cosas". Pasamos de 20 secciones a 11. Lo retirado se mantiene
// vivo en páginas dedicadas (no se borra el contenido):
//
//   - DiagnosticosHome → vive en /laboratorio/fundraising
//   - RecursosHome     → vive en /notas y en el footer
//   - LogosClientes    → consolidado dentro de HanConfiado (eran dos bloques
//                        haciendo lo mismo: pared de marcas)
//   - Membresias       → vive en /sobre (sección de credibilidad)
//   - VideoManifiesto  → fusionado dentro de Manifesto
//   - Fundador         → vive en /sobre
//
// Flujo narrativo: gancho → quiénes son → qué hacen → cómo → prueba social
// → cómo empezar.
import Base from '@/layouts/Base.astro';
import Hero from '@/components/Hero.astro';
import CtaConversion from '@/components/CtaConversion.astro';
import LogosBanner from '@/components/LogosBanner.astro';
import MetricasHero from '@/components/MetricasHero.astro';
import ParaQuien from '@/components/ParaQuien.astro';
import Ecosistema from '@/components/Ecosistema.astro';
import MerchPromo from '@/components/MerchPromo.astro';
import ComoTrabajamos from '@/components/ComoTrabajamos.astro';
import HanConfiado from '@/components/HanConfiado.astro';
import Casos from '@/components/Casos.astro';
import PresupuestoHome from '@/components/PresupuestoHome.astro';
import Testimonios from '@/components/Testimonios.astro';
import Manifesto from '@/components/Manifesto.astro';
import GranadaSocialFeed from '@/components/GranadaSocialFeed.astro';
import CtaFinal from '@/components/CtaFinal.astro';
import { organizationSchema, websiteSchema, localBusinessSchema } from '@/lib/jsonld';
---

<Base
  title="Startidea — Innovación social que se nota"
  description="Estrategia, comunicación y herramientas digitales para organizaciones que existen para algo más. Tercer sector, instituciones y empresas con propósito."
  jsonLd={[organizationSchema(), websiteSchema(), localBusinessSchema()]}
>
  <!-- 1. Gancho -->
  <Hero />
  <CtaConversion />

  <!-- 2. Social proof inmediato — banda de logos reconocibles -->
  <LogosBanner />

  <!-- 3. Quién — credibilidad rápida -->
  <MetricasHero />
  <ParaQuien />

  <!-- 3. Qué — servicios + método -->
  <Ecosistema />

  <!-- 3.5 Promo TodoMerchandising — único producto B2B online del ecosistema.
       Insertado justo después de Ecosistema porque el visitante acaba de
       leer "una de las 4 propiedades es Merchandising" y aquí lo aterrizamos
       con CTA directo al catálogo. -->
  <MerchPromo />

  <ComoTrabajamos />

  <!-- 4. Prueba social — quién ha confiado + casos -->
  <HanConfiado />
  <Casos />

  <!-- 5. Cómo empezar -->
  <PresupuestoHome />

  <!-- 6. Voz / Manifiesto (con video integrado) -->
  <Testimonios />
  <Manifesto />

  <!-- 7. Ventana al medio editorial — Granada Social en directo -->
  <GranadaSocialFeed />

  <!-- 8. Integración Google APIs — declaración pública del propósito de
       la app OAuth Startidea (requisito de Google OAuth Verification:
       la homepage debe explicar el propósito de la solicitud). -->
  <section class="bg-paper-warm py-12 md:py-16" aria-labelledby="integ-google">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 gap-y-6 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label">— Integraciones</span>
        </div>
        <div class="col-span-12 lg:col-span-9">
          <h2 id="integ-google" class="font-display text-2xl leading-tight text-ink md:text-3xl">
            Startidea también es <em class="italic text-magenta">aplicación OAuth</em> de Google.
          </h2>
          <p class="mt-4 max-w-measure text-ink/80">
            Para acompañar a sus clientes en el posicionamiento SEO de sus webs, Startidea se conecta —con permiso explícito y solo de lectura— a Google Analytics 4 y Google Search Console de las propiedades que cada cliente autoriza. Los datos se utilizan únicamente para producir los informes editoriales internos de Startidea, no se comparten con terceros y se eliminan a petición.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/integraciones-google" class="btn-text text-sm">
              Detalle de datos, finalidad y derechos <span aria-hidden="true">→</span>
            </a>
            <a href="/privacidad" class="btn-text text-sm">
              Política de privacidad <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. CTA cierre -->
  <CtaFinal />
</Base>
