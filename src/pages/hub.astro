---
import Base from '@/layouts/Base.astro';
import OtrosServicios from '@/components/OtrosServicios.astro';

const espacios = [
  {
    num: '01',
    name: 'Coworking',
    body: 'Plazas flexibles por día, semana o mes. WiFi de fibra, café, impresora, sala de descanso. Para concentrarse o para conectar — el ritmo lo eliges tú.',
  },
  {
    num: '02',
    name: 'Salas de reuniones y formación',
    body: 'Tres salas modulables con proyector y pantalla grande. Reservas por horas. Pensadas para que un grupo se concentre, no para que tres personas se distraigan.',
  },
  {
    num: '03',
    name: 'Estudio de podcast y radio',
    body: 'Cabina insonorizada, mesa de mezclas, micrófonos profesionales. Alquiler por horas o producción completa con nuestro equipo audiovisual.',
  },
  {
    num: '04',
    name: 'Despachos privados',
    body: 'Para equipos pequeños que necesitan dirección física propia. Acceso 24/7, mobiliario incluido, contrato mensual.',
  },
];

const incluido = [
  'WiFi de fibra simétrica',
  'Café, té e infusiones',
  'Sala de descanso y office',
  'Impresora multifunción',
  'Proyector y pantalla grande en salas',
  'Espacio inclusivo y accesible',
  'Comunidad de profesionales con propósito',
  'Acceso a la programación cultural del Hub',
];
---

<Base
  title="Hub Startidea — Espacios y Comunidad · Granada"
  description="Coworking, salas de reuniones, estudio de podcast y despachos privados en pleno centro de Granada. Espacio diseñado para conectar a profesionales y proyectos con propósito."
  ogSlug="page/hub"
>
  <!-- Hero -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24 lg:py-28">
    <div class="container-x">
      <span class="label">— Hub Startidea</span>
      <h1 class="mt-4 font-display text-display-xl leading-[0.96] text-ink">
        Trabajar acompañado.<br/>
        <em class="italic text-magenta">Sin perder el foco.</em>
      </h1>
      <p class="mt-8 max-w-measure text-lede text-ink/80">
        Espacio físico en pleno centro de Granada para profesionales, organizaciones y proyectos que quieren trabajar con foco y conectar con personas afines. Coworking, salas, estudio de podcast y despachos privados — todo bajo el mismo techo.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="https://hubstartidea.es" target="_blank" rel="noopener" class="btn">
          Ver precios y reservar
          <span aria-hidden="true">↗</span>
        </a>
        <a href="/contacto" class="btn-ghost">
          Hablar con Startidea
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Espacios -->
  <section class="bg-paper-warm py-20 md:py-28">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label">— Espacios</span>
        </div>
        <div class="col-span-12 mt-6 lg:col-span-9 lg:mt-0">
          <h2 class="font-display text-display-md leading-tight text-ink">
            Cuatro maneras <em class="italic text-magenta">de usar el Hub</em>.
          </h2>

          <ol class="mt-12 grid gap-px border-2 border-ink/15 bg-ink/15 md:grid-cols-2">
            {espacios.map((e) => (
              <li class="bg-paper-warm p-8">
                <span class="num-edit text-5xl md:text-6xl">{e.num}</span>
                <h3 class="mt-4 font-display text-2xl leading-tight text-ink md:text-3xl">{e.name}</h3>
                <p class="mt-4 text-sm leading-relaxed text-ink/80">{e.body}</p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Incluido -->
  <section class="bg-paper py-20 md:py-28">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label">— Incluido</span>
        </div>
        <div class="col-span-12 mt-6 lg:col-span-9 lg:mt-0">
          <h2 class="font-display text-display-md leading-tight text-ink">
            Lo que <em class="italic text-magenta">viene de serie</em>.
          </h2>

          <ul class="mt-10 grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-2">
            {incluido.map((i) => (
              <li class="flex items-baseline gap-3 border-b border-ink/10 py-3">
                <span class="font-mono text-xs text-magenta">▸</span>
                <span class="text-ink/85">{i}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA externa -->
  <section class="bg-ink py-24 text-paper md:py-32">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8">
        <div class="col-span-12 lg:col-span-9 lg:col-start-2">
          <span class="label !text-paper/60">— Reservas y precios</span>
          <h2 class="mt-4 font-display text-display-lg leading-[1.02] text-paper">
            Calendario y tarifas en<br/>
            <a href="https://hubstartidea.es" target="_blank" rel="noopener" class="italic text-magenta hover:underline">
              hubstartidea.es ↗
            </a>
          </h2>
          <p class="mt-8 max-w-measure text-paper/80">
            Disponibilidad en tiempo real, reserva de plaza, salas y estudio. Si prefieres venir a verlo antes, escríbenos y concertamos una visita.
          </p>
          <div class="mt-12 flex flex-wrap gap-4">
            <a href="https://hubstartidea.es" target="_blank" rel="noopener" class="btn !bg-paper !text-ink !border-paper hover:!bg-magenta hover:!text-paper hover:!border-magenta">
              Ir a hubstartidea.es
              <span aria-hidden="true">↗</span>
            </a>
            <a href="/contacto" class="btn-ghost !text-paper !border-paper hover:!bg-paper hover:!text-ink">
              Concertar visita
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <OtrosServicios current="hub" />
</Base>
