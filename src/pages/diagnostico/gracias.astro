---
// /diagnostico/gracias — Página de confirmación post-formulario.
//
// Sirve a dos wizards:
//   - /diagnostico/nuevo  → llega sin query (kind=diagnostico por defecto)
//   - /presupuesto/nuevo  → llega con ?kind=presupuesto
//
// El mensaje + CTAs se ajustan según kind vía JS (página estática para
// mantener perf — no requiere SSR).

import Base from '@/layouts/Base.astro';
---

<Base
  title="Recibido — Startidea"
  description="Gracias por enviar tu formulario. Startidea revisará tus respuestas y te contactará en las próximas 48 horas laborales."
  ogSlug="page/diagnostico-gracias"
  noindex={true}
>
  <section class="border-b border-ink/15 bg-paper py-20 md:py-28 lg:py-32">
    <div class="container-x">
      <span class="label" id="kind-label">— Recibido</span>
      <h1 class="mt-4 font-display text-display-xl leading-[0.96] text-ink">
        Gracias.<br/>
        <em class="italic text-magenta" id="kind-headline">Startidea te llama pronto.</em>
      </h1>
      <p class="mt-8 max-w-measure text-lede text-ink/80" id="kind-intro">
        Startidea ha recibido tu diagnóstico. El equipo lo lee, prepara una primera lectura y te contacta en las próximas <strong>48 horas laborales</strong> para concretar la llamada.
      </p>

      <!-- Trust signals: 3 micro-datos verificables -->
      <ul class="mt-10 grid max-w-2xl grid-cols-1 gap-px border-2 border-ink/15 bg-ink/15 sm:grid-cols-3">
        <li class="bg-paper p-4">
          <p class="font-display text-2xl font-extrabold text-ink">15 años</p>
          <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink-mute">de práctica desde Granada</p>
        </li>
        <li class="bg-paper p-4">
          <p class="font-display text-2xl font-extrabold text-ink">48h</p>
          <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink-mute">respuesta laboral garantizada</p>
        </li>
        <li class="bg-paper p-4">
          <p class="font-display text-2xl font-extrabold text-magenta">0€</p>
          <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink-mute">primera llamada sin coste</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Primera lectura personalizada (solo si llega desde /diagnostico/nuevo con datos en sessionStorage) -->
  <section id="first-read" class="hidden border-b border-ink/15 bg-paper py-14 md:py-20">
    <div class="container-x">
      <span class="label">— Tu primera lectura</span>
      <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
        Esto es lo que <em class="italic text-magenta">vemos de entrada</em>.
      </h2>
      <div id="first-read-body" class="mt-6 max-w-measure space-y-3 text-ink/85"></div>
      <p class="mt-6 text-xs text-ink-mute">
        Lectura automática a partir de tus respuestas, no un análisis todavía. En la llamada la afinamos con contexto real.
      </p>
    </div>
  </section>

  <!-- 4 acciones útiles post-conversión -->
  <section class="bg-paper-warm py-16 md:py-20">
    <div class="container-x">
      <span class="label">— Mientras llega tu respuesta</span>
      <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
        Cuatro cosas <em class="italic text-magenta">útiles ahora</em>.
      </h2>

      <ol class="mt-12 grid grid-cols-1 gap-px border-2 border-ink/15 bg-ink/15 md:grid-cols-2">
        <li class="bg-paper p-6 md:p-8">
          <span class="font-mono text-[10px] uppercase tracking-widest text-magenta">01 · Buscar ayudas</span>
          <h3 class="mt-3 font-display text-xl text-ink">Mira si hay una convocatoria abierta para ti</h3>
          <p class="mt-3 text-sm text-ink/75">
            Buscador unificado con 1.900+ convocatorias en vivo (BDNS + CDTI + IDAE + Andalucía TRADE). Filtra por finalidad, beneficiario o CCAA y descubre qué hay sobre la mesa esta semana.
          </p>
          <a href="/subvenciones" class="btn-text mt-4 text-sm">
            Buscar convocatorias <span aria-hidden="true">→</span>
          </a>
        </li>
        <li class="bg-paper p-6 md:p-8">
          <span class="font-mono text-[10px] uppercase tracking-widest text-magenta">02 · Leer casos reales</span>
          <h3 class="mt-3 font-display text-xl text-ink">Cómo trabaja Startidea con organizaciones como la tuya</h3>
          <p class="mt-3 text-sm text-ink/75">
            Casos publicados con autorización: Down Granada, Aldaima, Proyecto Hombre, Tres Mil Millones de Latidos. Cada caso con métricas, timeline y testimonio del cliente.
          </p>
          <a href="/casos" class="btn-text mt-4 text-sm">
            Ver casos <span aria-hidden="true">→</span>
          </a>
        </li>
        <li class="bg-paper p-6 md:p-8">
          <span class="font-mono text-[10px] uppercase tracking-widest text-magenta">03 · Leer las notas</span>
          <h3 class="mt-3 font-display text-xl text-ink">Lo que se piensa cuando se piensa Startidea</h3>
          <p class="mt-3 text-sm text-ink/75">
            Notas editoriales sobre fundraising, comunicación, impacto social y financiación pública. Sin clickbait. Pensadas para directoras y patronatos del tercer sector.
          </p>
          <a href="/notas" class="btn-text mt-4 text-sm">
            Leer notas <span aria-hidden="true">→</span>
          </a>
        </li>
        <li class="bg-paper p-6 md:p-8">
          <span class="font-mono text-[10px] uppercase tracking-widest text-magenta">04 · Acelerar</span>
          <h3 class="mt-3 font-display text-xl text-ink">¿Necesitas hablar antes de 48 horas?</h3>
          <p class="mt-3 text-sm text-ink/75">
            Si tu caso es urgente (plazo de convocatoria que cierra esta semana, decisión de patronato inminente), escribe directamente y se acelera la respuesta.
          </p>
          <a href="mailto:hola@startidea.es?subject=Urgente%20-%20diagn%C3%B3stico%20recibido" class="btn-text mt-4 text-sm">
            Escribir directamente <span aria-hidden="true">→</span>
          </a>
        </li>
      </ol>
    </div>
  </section>

  <!-- Pie informativo -->
  <section class="bg-paper py-10 md:py-12">
    <div class="container-x">
      <p class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">
        ¿Necesitas modificar algo de lo que enviaste?
        <a href="mailto:hola@startidea.es" class="text-ink hover:text-magenta">hola@startidea.es</a>
      </p>
    </div>
  </section>
</Base>

<script>
  // Adapta el mensaje superior según kind (diagnostico|presupuesto).
  // /presupuesto/nuevo redirige a /diagnostico/gracias?kind=presupuesto.
  const params = new URLSearchParams(window.location.search);
  const kind = params.get('kind') ?? 'diagnostico';
  const label = document.getElementById('kind-label');
  const headline = document.getElementById('kind-headline');
  const intro = document.getElementById('kind-intro');

  if (kind === 'presupuesto') {
    if (label) label.textContent = '— Briefing recibido';
    if (headline) headline.textContent = 'Startidea te envía cifras pronto.';
    if (intro) {
      intro.innerHTML =
        'Startidea ha recibido tu briefing. El equipo lo analiza, calcula alcance y presupuesto, y te responde con una propuesta clara en las próximas <strong>48 horas laborales</strong>.';
    }
    document.title = 'Presupuesto recibido — Startidea';
  }

  // Tracking analítico (Umami + GA4 via stTrack)
  type W = Window & { stTrack?: (e: string, p?: Record<string, unknown>) => void };
  const w = window;
  if (typeof w.stTrack === 'function') {
    w.stTrack('form_submit', { form_type: kind });
  }

  // ─── Primera lectura personalizada ─────────────────────────────
  // Lee el resumen que /diagnostico/nuevo dejó en sessionStorage, genera
  // 3-4 frases con reglas simples (sin backend, sin IA) y las muestra.
  // Se borra tras leerlo: es de un solo uso, ligado a este envío concreto.
  type DiagResult = {
    audience?: string;
    subType?: string;
    stage?: string;
    services?: string[];
    legalStatus?: string;
    fundingMix?: string;
    captationGoal?: string;
    asePresent?: boolean;
    inst_committee?: string;
    emp_funding?: string;
    collaborationModel?: string;
    timeframe?: string;
  };

  function buildFirstRead(r: DiagResult): string[] {
    const lines: string[] = [];

    const subtypeLabels: Record<string, string> = {
      pyme: 'una PYME', 'gran-empresa': 'una gran empresa', startup: 'una startup', autonomo: 'un autónomo/a con propósito',
      eclesial: 'una institución eclesial', publica: 'una institución pública', educativa: 'una institución educativa', sanitaria: 'una institución sanitaria',
      asociacion: 'una asociación', fundacion: 'una fundación', 'cooperativa-social': 'una cooperativa social', ong: 'una ONG', red: 'una red/federación',
      idea: 'una idea en formación', mvp: 'un MVP en marcha', validacion: 'un proyecto validando con primeros clientes', escalado: 'un proyecto escalando',
    };
    const stageLabels: Record<string, string> = {
      idea: 'en fase de idea', lanzamiento: 'recién lanzada', consolidado: 'ya consolidada', replanteamiento: 'en replanteamiento estratégico',
    };

    const subtype = r.subType ? subtypeLabels[r.subType] ?? r.subType : null;
    const stage = r.stage ? stageLabels[r.stage] : null;
    if (subtype) {
      lines.push(`Nos escribís como ${subtype}${stage ? `, ${stage}` : ''}. Eso ya adapta por dónde empezaríamos.`);
    }

    if (r.audience === 'entidad-social') {
      if (r.legalStatus === 'tramite') {
        lines.push('Estáis en trámite de constitución: mientras se resuelve, conviene construir la narrativa de "socio fundador" en vez de vender ya la deducción fiscal, que solo aplica una vez esté reconocida la utilidad pública.');
      } else if (r.legalStatus === 'constituida') {
        lines.push('Ya estáis constituidos: eso permite hablar desde ya de deducción fiscal como palanca de captación, no solo de causa.');
      } else if (r.legalStatus === 'no-formalizada') {
        lines.push('Aún sin formalizar: antes de invertir en captación masiva, conviene cerrar la parte legal para no perder el primer impulso de confianza de quien done.');
      }
      if (r.captationGoal) {
        lines.push(`Tenéis ya un objetivo concreto ("${r.captationGoal}") — eso facilita mucho calcular si el modelo es rentable antes de arrancar.`);
      }
    } else if (r.audience === 'empresa') {
      if (r.asePresent === true) {
        lines.push('Ya tenéis programa de propósito activo: es terreno fértil para contar una historia real, no una campaña de imagen.');
      } else if (r.asePresent === false) {
        lines.push('Sin programa de propósito activo todavía: antes de comunicar "impacto" conviene decidir si de verdad queréis construirlo, o centrar el mensaje en otro sitio.');
      }
    } else if (r.audience === 'institucion') {
      if (r.inst_committee === 'no') {
        lines.push('Sin comité ni área de comunicación interna: probablemente el primer cuello de botella no es la falta de ideas, sino quién decide y con qué rapidez.');
      } else if (r.inst_committee === 'informal') {
        lines.push('Tenéis comunicación interna informal: formalizar quién decide qué acelera cualquier cosa que hagamos juntos.');
      }
    } else if (r.audience === 'emprendedor') {
      if (r.emp_funding === 'ninguna' || r.emp_funding === 'propia') {
        lines.push('Sin financiación externa todavía: tiene sentido priorizar acciones baratas y medibles antes que campañas de gran alcance.');
      }
    }

    const modelLabels: Record<string, string> = {
      puntual: 'un proyecto puntual', recurrente: 'una colaboración recurrente', exito: 'un modelo por resultados/éxito',
    };
    if (r.collaborationModel && modelLabels[r.collaborationModel]) {
      lines.push(`Preferís ${modelLabels[r.collaborationModel]}${r.collaborationModel === 'exito' ? ' — para esto lo primero que hay que acordar en la llamada es qué cuenta como "éxito" y cómo se mide' : ''}.`);
    } else if (r.collaborationModel === 'no-claro') {
      lines.push('No tenéis claro aún el modelo de colaboración — normal, es justo lo primero que resolvemos en la llamada.');
    }

    return lines;
  }

  try {
    const raw = sessionStorage.getItem('st_diag_result');
    if (raw) {
      sessionStorage.removeItem('st_diag_result');
      const result = JSON.parse(raw) as DiagResult;
      const lines = buildFirstRead(result);
      if (lines.length) {
        const section = document.getElementById('first-read');
        const body = document.getElementById('first-read-body');
        if (body) {
          body.innerHTML = lines.map((l) => `<p>${l}</p>`).join('');
        }
        section?.classList.remove('hidden');
      }
    }
  } catch {
    // JSON corrupto o sessionStorage no disponible — se omite sin romper la página
  }
</script>
