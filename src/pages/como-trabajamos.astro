---
import Base from '@/layouts/Base.astro';

const ejes = [
  {
    id: 'estrategia',
    num: '01',
    tag: 'Estrategia',
    title: 'La pregunta antes que la respuesta.',
    diagnosis: 'Demasiadas organizaciones contratan ejecución sin haber decidido qué intentan mover. Hacemos lo contrario: paramos, miramos, decidimos. Y luego ejecutamos.',
    body: [
      'Trabajo de fondo: análisis de posicionamiento, plan de comunicación a 12-24 meses, arquitectura de marca, frameworks de medición de impacto, plan de captación de fondos.',
      'Si la estrategia no aguanta una conversación incómoda con tu patronato, no sirve. Por eso la presentamos defendiendo cada decisión y dejando claro el coste de cada alternativa.',
    ],
    capacities: [
      'Plan estratégico de comunicación',
      'Arquitectura de marca y revisión de identidad',
      'Diagnóstico de propósito y narrativa',
      'Plan de captación de fondos',
      'Frameworks de medición de impacto',
    ],
    deliverables: [
      'Documento estratégico ejecutivo (60-100 págs)',
      'Plan de acción 12 meses con calendario y presupuestos',
      'Workshop de validación con junta directiva',
    ],
  },
  {
    id: 'comunicacion',
    num: '02',
    tag: 'Comunicación',
    title: 'Contar bien lo que importa.',
    diagnosis: 'El sector con propósito está lleno de buenas intenciones mal contadas. Cambiamos la narrativa, no solo la estética.',
    body: [
      'Producción editorial, audiovisual y de campañas. De la memoria anual al podcast institucional. De la web de proyecto al dossier para donantes. Sobriedad cuando toca, audacia cuando suma.',
      'Tenemos estudio propio de podcast y producción audiovisual en Granada. Trabajamos con guion, dirección y postproducción in-house — eso significa más control, plazos más cortos y coherencia editorial.',
    ],
    capacities: [
      'Memorias y reporting de impacto',
      'Producción audiovisual: documental, institucional, social',
      'Podcast (estudio propio)',
      'Campañas integradas multicanal',
      'Dirección creativa y editorial',
      'Comunicación digital y redes sociales',
    ],
    deliverables: [
      'Memoria anual editorial (digital + papel)',
      'Serie de 6-12 episodios de podcast',
      'Campaña 360º con plan de medios',
      'Plan editorial de redes a 6 meses',
    ],
  },
  {
    id: 'producto-digital',
    num: '03',
    tag: 'Producto digital',
    title: 'Plataformas que aguantan.',
    diagnosis: 'No vivimos en WordPress por defecto. Cuando el proyecto exige una plataforma seria, la construimos en serio.',
    body: [
      'Webs editoriales, intranets, plataformas de gestión, herramientas a medida. Stack moderno (Next.js, React, Astro), infraestructura propia, performance medible.',
      'Cuando lo correcto es una web de WordPress bien hecha, también lo decimos y lo entregamos. La elección tecnológica se hace contra el problema, no contra la moda.',
    ],
    capacities: [
      'Webs institucionales y editoriales',
      'Plataformas a medida (intranets, gestión de socios, comunidades)',
      'Migraciones tecnológicas sin pérdida SEO',
      'Auditorías de producto digital',
      'Accesibilidad WCAG 2.1 AA',
    ],
    deliverables: [
      'Web responsive performance > 95',
      'Documentación técnica de mantenimiento',
      'Capacitación de equipo interno',
      'Soporte 6-12 meses post-lanzamiento',
    ],
  },
];

const proceso = [
  { step: '01', title: 'Diagnóstico (30 min)', body: 'Llamada gratuita. Tú cuentas el reto y te decimos honestamente si encaja con lo que hacemos. Si no, te orientamos hacia quien sí.' },
  { step: '02', title: 'Propuesta', body: 'En una semana: alcance, plazos, equipo asignado, presupuesto cerrado. Sin letra pequeña. Sin "depende".' },
  { step: '03', title: 'Kick-off', body: 'Equipo + un único interlocutor. Roadmap visible para ti todo el tiempo. Reunión semanal de progreso.' },
  { step: '04', title: 'Entrega + acompañamiento', body: 'Lo que entregamos se mide y se revisa. Acompañamos 6-12 meses post-entrega — porque la mejor web sin mantenimiento envejece en seis semanas.' },
];
---

<Base
  title="Cómo trabajamos — Startidea"
  description="Estrategia, comunicación y producto digital bajo el mismo techo. Las tres preguntas se responden juntas o no se responden bien."
  ogSlug="page/como-trabajamos"
>
  <!-- Hero -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24 lg:py-28">
    <div class="container-x">
      <span class="label">— Cómo trabajamos</span>
      <h1 class="mt-4 font-display text-display-xl leading-[0.96] text-ink">
        Las tres<br/>
        <em class="italic text-magenta">preguntas</em>.
      </h1>
      <p class="mt-8 max-w-measure text-lede text-ink/80">
        Toda organización con propósito se enfrenta a tres preguntas que tienen que responderse juntas: qué decisión queremos mover, cómo lo contamos, con qué herramienta lo operamos. Saltarse cualquiera de las tres convierte el trabajo en estética. Lo llamamos <strong class="text-ink">El Método de las Tres Preguntas</strong>, y es la columna vertebral de cómo trabajamos.
      </p>

      <nav class="mt-12 grid gap-4 border-t border-ink/15 pt-8 sm:grid-cols-3" aria-label="Ejes">
        {ejes.map((e, i) => (
          <a href={`#${e.id}`} class="group flex items-baseline gap-4">
            <span class="num-edit text-3xl">{e.num}</span>
            <span class="font-display text-xl text-ink transition-colors group-hover:text-magenta">{e.tag}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Bloque metodología — Las tres preguntas como sistema -->
  <section id="metodo" class="bg-paper-warm py-20 md:py-28">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label">— El método</span>
        </div>
        <div class="col-span-12 mt-6 lg:col-span-9 lg:mt-0">
          <h2 class="font-display text-display-md leading-tight text-ink">
            <em class="italic text-magenta">El Método</em> de las Tres Preguntas.
          </h2>
          <p class="mt-6 max-w-measure text-lede text-ink/80">
            No es una metodología cerrada con copyright. Es una manera de mirar cualquier reto que llega: antes de proponer ejecución, ponemos las tres preguntas sobre la mesa y las defendemos en conversación contigo.
          </p>

          <ol class="mt-12 grid gap-px border-2 border-ink/15 bg-ink/15 sm:grid-cols-3">
            <li class="bg-paper-warm p-8">
              <span class="font-mono text-xs uppercase tracking-widest text-magenta">— Pregunta 01</span>
              <p class="mt-3 font-display text-3xl leading-tight text-ink">
                ¿Qué quieres mover?
              </p>
              <p class="mt-4 text-sm text-ink/75">
                Decisión, comportamiento, percepción. Sin esta respuesta, todo lo demás es decoración.
              </p>
            </li>
            <li class="bg-paper-warm p-8">
              <span class="font-mono text-xs uppercase tracking-widest text-magenta">— Pregunta 02</span>
              <p class="mt-3 font-display text-3xl leading-tight text-ink">
                ¿Cómo lo cuentas?
              </p>
              <p class="mt-4 text-sm text-ink/75">
                Narrativa, tono, soportes. La estética viene a servir a la idea, no al revés.
              </p>
            </li>
            <li class="bg-paper-warm p-8">
              <span class="font-mono text-xs uppercase tracking-widest text-magenta">— Pregunta 03</span>
              <p class="mt-3 font-display text-3xl leading-tight text-ink">
                ¿Con qué lo operas?
              </p>
              <p class="mt-4 text-sm text-ink/75">
                Web, plataforma, sistema, equipo. La herramienta que sostiene la promesa una vez se hace pública.
              </p>
            </li>
          </ol>

          <p class="mt-10 max-w-measure font-display text-xl italic leading-snug text-ink md:text-2xl">
            "Las tres preguntas se responden juntas o no se responden bien."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tres ejes -->
  {ejes.map((eje, i) => (
    <section id={eje.id} class={`relative py-24 md:py-32 ${i % 2 === 0 ? 'bg-paper' : 'bg-paper-warm'}`}>
      <div class="container-x">
        <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
          <div class="col-span-12 lg:col-span-3">
            <div class="flex items-baseline gap-4">
              <span class="num-edit text-7xl">{eje.num}</span>
              <span class="label">{eje.tag}</span>
            </div>
          </div>

          <div class="col-span-12 mt-8 lg:col-span-9 lg:mt-0">
            <h2 class="font-display text-display-lg leading-[1.0] text-ink">{eje.title}</h2>

            <p class="mt-8 max-w-3xl font-display text-2xl italic leading-snug text-ink/55 md:text-3xl">
              {eje.diagnosis}
            </p>

            <div class="mt-12 space-y-5 max-w-measure text-ink/85">
              {eje.body.map((p) => <p>{p}</p>)}
            </div>

            <div class="mt-14 grid gap-12 lg:grid-cols-2">
              <div>
                <span class="label">— Capacidades</span>
                <ul class="mt-4 space-y-2.5">
                  {eje.capacities.map((c) => (
                    <li class="flex items-start gap-3 text-sm text-ink/85">
                      <span class="mt-1.5 inline-block h-px w-3 flex-shrink-0 bg-magenta"></span>
                      <span>{c}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <span class="label">— Lo que entregamos</span>
                <ul class="mt-4 space-y-2.5">
                  {eje.deliverables.map((d) => (
                    <li class="flex items-start gap-3 text-sm text-ink/85">
                      <span class="mt-1.5 inline-block h-px w-3 flex-shrink-0 bg-ink/40"></span>
                      <span>{d}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Proceso -->
  <section class="bg-ink py-24 text-paper md:py-32">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label !text-paper/60">— Proceso</span>
        </div>
        <div class="col-span-12 mt-6 lg:col-span-9">
          <h2 class="font-display text-display-lg leading-[1.02] text-paper">
            Cómo arrancamos<em class="italic text-magenta"> contigo</em>.
          </h2>
          <p class="mt-6 max-w-measure text-lede text-paper/85">
            Un proceso de cuatro pasos, sin teatro. Cada uno con un entregable claro y un coste cerrado. Sin letra pequeña.
          </p>

          <ol class="mt-16 grid gap-px border-2 border-paper/15 bg-paper/15 sm:grid-cols-2 lg:grid-cols-4">
            {proceso.map((p) => (
              <li class="bg-ink p-8">
                <span class="font-display text-5xl text-magenta">{p.step}</span>
                <h3 class="mt-4 font-display text-2xl text-paper">{p.title}</h3>
                <p class="mt-3 text-sm text-paper/80">{p.body}</p>
              </li>
            ))}
          </ol>

          <div class="mt-16 border-t border-paper/15 pt-8">
            <a href="/contacto" class="btn !bg-paper !text-ink !border-paper hover:!bg-magenta hover:!text-paper hover:!border-magenta">
              Empezar por el paso 01
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
