---
// /presupuesto/nuevo — Wizard corto (3 pasos) para captura de leads que
// ya saben qué quieren. Comparte storage con /diagnostico/nuevo (modelo
// Diagnosis del HUB) usando kind="presupuesto".

import Base from "@/layouts/Base.astro";
import { breadcrumbList, SITE_URL } from "@/lib/jsonld";

const jsonLd = [
  breadcrumbList([
    { name: "Inicio", url: `${SITE_URL}/` },
    { name: "Presupuesto", url: `${SITE_URL}/presupuesto` },
    { name: "Nuevo", url: `${SITE_URL}/presupuesto/nuevo` },
  ]),
];

const INTAKE_URL = "https://hub.startidea.tech/api/diagnosticos/intake";
---

<Base
  title="Pedir presupuesto — Startidea"
  description="Tres minutos. Startidea te envía un rango orientativo + propuesta de reunión de 30 minutos."
  ogSlug="page/presupuesto-nuevo"
  noindex={true}
  jsonLd={jsonLd}
>
  <section class="border-b border-ink/15 bg-paper py-12 md:py-16">
    <div class="container-x">
      <span class="label">
        — Presupuesto · paso <span data-step-label>1</span> de 3
      </span>
      <h1 class="mt-4 font-display text-display-lg leading-[0.98] text-ink">
        Tres preguntas. <em class="italic text-magenta">Una cifra.</em>
      </h1>
      <p class="mt-6 max-w-measure text-ink/80">
        Si todavía no sabes qué necesitas exactamente, <a href="/diagnostico/nuevo" class="text-magenta hover:underline">mejor el diagnóstico</a>.
      </p>

      <div class="mt-8 flex max-w-md items-center gap-2" aria-hidden="true">
        <div class="h-1 flex-1 overflow-hidden bg-ink/15">
          <div data-progress class="h-full bg-magenta transition-all duration-300" style="width: 33%"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-paper py-12 md:py-16">
    <div class="container-x">
      <form
        id="presu-form"
        data-intake-url={INTAKE_URL}
        class="max-w-2xl space-y-10"
        novalidate
      >
        <input
          type="text"
          name="honeypot"
          tabindex="-1"
          autocomplete="off"
          class="absolute -left-[9999px]"
          aria-hidden="true"
        />

        <!-- ============ PASO 1: TIPO + SERVICIO ============ -->
        <fieldset data-step="1" class="space-y-8">
          <div>
            <h2 class="font-display text-2xl text-ink">¿Quién y qué?</h2>
          </div>

          <div class="space-y-3">
            <span class="block text-sm font-medium text-ink">Tipo de organización</span>
            <div class="grid grid-cols-2 gap-2 md:grid-cols-4">
              {[
                ["empresa", "Empresa"],
                ["institucion", "Institución"],
                ["entidad-social", "Entidad social"],
                ["emprendedor", "Emprendedor/a"],
              ].map(([v, label]) => (
                <label class="flex cursor-pointer items-center justify-center border border-ink/20 p-3 text-sm hover:border-magenta/60 has-[input:checked]:border-magenta has-[input:checked]:bg-paper-warm has-[input:checked]:font-medium has-[input:checked]:text-magenta">
                  <input type="radio" name="audience" value={v} required class="sr-only" />
                  <span>{label}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="space-y-3">
            <span class="block text-sm font-medium text-ink">¿Qué necesitas?</span>
            <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
              {[
                ["comunicacion", "Comunicación / identidad"],
                ["web", "Diseño y desarrollo web"],
                ["audiovisual", "Audiovisual / podcast"],
                ["fundraising", "Fundraising / subvenciones"],
                ["consultoria", "Consultoría / estrategia"],
                ["otro", "Otro"],
              ].map(([v, label]) => (
                <label class="flex cursor-pointer items-center gap-3 border border-ink/20 p-3 text-sm hover:border-magenta/60 has-[input:checked]:border-magenta has-[input:checked]:bg-paper-warm">
                  <input type="checkbox" name="services" value={v} class="accent-magenta" />
                  <span>{label}</span>
                </label>
              ))}
            </div>
            <p class="text-xs text-ink-mute">Marca uno o varios.</p>
          </div>

          <div class="flex justify-end pt-4">
            <button type="button" data-next class="btn">Siguiente →</button>
          </div>
        </fieldset>

        <!-- ============ PASO 2: BRIEF + PRESUPUESTO + PLAZO ============ -->
        <fieldset data-step="2" class="hidden space-y-8">
          <div>
            <h2 class="font-display text-2xl text-ink">El proyecto</h2>
          </div>

          <div class="space-y-2">
            <label for="challenge" class="block text-sm font-medium text-ink">
              Cuéntanos en una frase qué quieres
            </label>
            <textarea
              id="challenge"
              name="challenge"
              required
              minlength="15"
              maxlength="1500"
              rows="4"
              placeholder="Ej: una web institucional nueva, con CMS para que el equipo la actualice, 5-7 secciones, sin tienda."
              class="w-full resize-y border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none"
            ></textarea>
            <p class="text-xs text-ink-mute">Mínimo 15 caracteres.</p>
          </div>

          <div class="space-y-3">
            <span class="block text-sm font-medium text-ink">Presupuesto orientativo</span>
            <div class="grid grid-cols-2 gap-2 md:grid-cols-4">
              {[
                ["<1k", "< 1.000 €"],
                ["1k-5k", "1k - 5k"],
                ["5k-15k", "5k - 15k"],
                ["15k+", "15k +"],
              ].map(([v, label]) => (
                <label class="flex cursor-pointer items-center justify-center border border-ink/20 p-3 text-sm hover:border-magenta/60 has-[input:checked]:border-magenta has-[input:checked]:bg-paper-warm has-[input:checked]:font-medium has-[input:checked]:text-magenta">
                  <input type="radio" name="budgetRange" value={v} required class="sr-only" />
                  <span>{label}</span>
                </label>
              ))}
            </div>
            <p class="text-xs text-ink-mute">Si no tienes idea, marca el rango que crees que NO debería superarse.</p>
          </div>

          <div class="space-y-3">
            <span class="block text-sm font-medium text-ink">Plazo</span>
            <div class="grid grid-cols-2 gap-2 md:grid-cols-4">
              {[
                ["asap", "Cuanto antes"],
                ["1-3m", "1 - 3 meses"],
                ["3-6m", "3 - 6 meses"],
                ["6m+", "6 meses +"],
              ].map(([v, label]) => (
                <label class="flex cursor-pointer items-center justify-center border border-ink/20 p-3 text-sm hover:border-magenta/60 has-[input:checked]:border-magenta has-[input:checked]:bg-paper-warm has-[input:checked]:font-medium has-[input:checked]:text-magenta">
                  <input type="radio" name="timeframe" value={v} required class="sr-only" />
                  <span>{label}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="flex justify-between pt-4">
            <button type="button" data-prev class="btn-ghost">← Atrás</button>
            <button type="button" data-next class="btn">Siguiente →</button>
          </div>
        </fieldset>

        <!-- ============ PASO 3: CONTACTO ============ -->
        <fieldset data-step="3" class="hidden space-y-8">
          <div>
            <h2 class="font-display text-2xl text-ink">Tu contacto</h2>
            <p class="mt-2 text-sm text-ink-mute">Para enviarte el rango y proponerte llamada de 30 min.</p>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="space-y-2">
              <label for="name" class="block text-sm font-medium text-ink">Tu nombre</label>
              <input type="text" id="name" name="name" required minlength="2" maxlength="100"
                class="w-full border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none" />
            </div>
            <div class="space-y-2">
              <label for="email" class="block text-sm font-medium text-ink">Tu email</label>
              <input type="email" id="email" name="email" required maxlength="200"
                class="w-full border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none" />
            </div>
          </div>

          <div class="space-y-2">
            <label for="organizationName" class="block text-sm font-medium text-ink">Organización o proyecto</label>
            <input type="text" id="organizationName" name="organizationName" required minlength="2" maxlength="150"
              placeholder="Nombre o razón social"
              class="w-full border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none" />
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="space-y-2">
              <label for="phone" class="block text-sm font-medium text-ink">Teléfono (opcional)</label>
              <input type="tel" id="phone" name="phone" maxlength="40"
                class="w-full border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none" />
            </div>
            <div class="space-y-2">
              <label for="website" class="block text-sm font-medium text-ink">Web (opcional)</label>
              <input type="url" id="website" name="website" maxlength="200" placeholder="https://..."
                class="w-full border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none" />
            </div>
          </div>

          <div class="flex justify-between pt-4">
            <button type="button" data-prev class="btn-ghost">← Atrás</button>
            <button type="submit" class="btn">Enviar petición →</button>
          </div>
        </fieldset>

        <div data-status class="hidden border-l-2 border-magenta bg-paper-warm p-4 text-sm"></div>
      </form>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById("presu-form");
  if (!form) throw new Error("form missing");

  const intakeUrl = form.dataset.intakeUrl;
  const steps = Array.from(form.querySelectorAll("fieldset[data-step]"));
  const stepLabel = document.querySelector("[data-step-label]");
  const progress = document.querySelector("[data-progress]");
  const statusBox = form.querySelector("[data-status]");

  let current = 0;
  const total = steps.length;

  function setStep(i: number) {
    current = Math.max(0, Math.min(total - 1, i));
    steps.forEach((s, idx) => s.classList.toggle("hidden", idx !== current));
    if (stepLabel) stepLabel.textContent = String(current + 1);
    if (progress) progress.style.width = `${((current + 1) / total) * 100}%`;
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function validateStep(): string | null {
    const fs = steps[current];
    const required = Array.from(fs.querySelectorAll("[required]"));
    for (const el of required) {
      if (el instanceof HTMLInputElement && el.type === "radio") {
        const groupName = el.name;
        if (!form.querySelector(`input[name='${groupName}']:checked`)) return `Falta elegir: ${groupName}`;
      } else if (!el.value || (el instanceof HTMLInputElement && el.type === "email" && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value))) {
        return `Falta o no es válido: ${el.name || el.id}`;
      } else if ((el).minLength && el.value.length < (el).minLength) {
        return `Muy corto: ${el.name || el.id}`;
      }
    }
    return null;
  }

  form.addEventListener("click", (e) => {
    const t = e.target;
    if (t.matches("[data-next]")) {
      const err = validateStep();
      if (err) { showStatus(err, true); return; }
      hideStatus();
      setStep(current + 1);
    } else if (t.matches("[data-prev]")) {
      hideStatus();
      setStep(current - 1);
    }
  });

  function showStatus(msg: string, isError = false) {
    if (!statusBox) return;
    statusBox.textContent = msg;
    statusBox.className = `border-l-2 p-4 text-sm ${isError ? "border-magenta bg-paper-warm text-magenta" : "border-ink/30 bg-paper-warm text-ink"}`;
    statusBox.classList.remove("hidden");
  }
  function hideStatus() {
    statusBox?.classList.add("hidden");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const err = validateStep();
    if (err) { showStatus(err, true); return; }
    showStatus("Enviando…", false);
    const fd = new FormData(form);
    const data: Record<string, unknown> = { kind: "presupuesto" };
    ["name", "email", "phone", "organizationName", "website", "audience", "challenge", "budgetRange", "timeframe", "honeypot"].forEach((k) => {
      const v = fd.get(k);
      if (typeof v === "string" && v) data[k] = v;
    });
    const services = fd.getAll("services").map(String).filter(Boolean);
    if (services.length) data.answers = { services };
    data.attribution = (window.stAttribution && window.stAttribution()) || {};

    try {
      const r = await fetch(intakeUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const json = await r.json().catch(() => null);
      if (r.ok && json?.ok) {
        window.location.href = "/diagnostico/gracias?kind=presupuesto";
      } else {
        showStatus(`No se pudo enviar (${json?.error ?? r.status}). Inténtalo en unos minutos.`, true);
      }
    } catch {
      showStatus("Error de red. Inténtalo en unos minutos.", true);
    }
  });

  setStep(0);
</script>
