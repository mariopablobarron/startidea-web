<script>
  // ─── Estado de servicios — carga async vía /api/admin/health ──────────────
  // Se ejecuta tras pintar la página para no bloquear el render. Si algún
  // probe tarda 4s o falla, el endpoint lo reporta como down y el badge
  // queda rojo. Cache 10s en cliente para no martillar OpenRouter en refrescos.
  (async () => {
    const widget = document.getElementById('sos-health');
    if (!widget) return;
    const statusEl = document.getElementById('sos-health-status');

    function fmtAgo(epochSec) {
      const days = Math.floor((Date.now() / 1000 - epochSec) / 86400);
      if (days === 0)  return 'hoy';
      if (days === 1)  return 'ayer';
      if (days < 30)   return `hace ${days} d`;
      if (days < 365)  return `hace ${Math.floor(days / 30)} m`;
      return `hace ${Math.floor(days / 365)} a`;
    }

    function setProbe(name, ok, text, errClass) {
      const el = widget.querySelector(`[data-probe="${name}"]`);
      if (!el) return;
      el.textContent = text;
      el.className = ok
        ? 'font-mono text-emerald-700'
        : (errClass ?? 'font-mono text-red-600');
    }

    try {
      const r = await fetch('/api/admin/health', { credentials: 'same-origin' });
      if (!r.ok) throw new Error(`HTTP ${r.status}`);
      const data = await r.json();
      if (!data.ok) throw new Error('unauthorized');

      const { probes, activity } = data;
      const allOk =
        probes.hub_voice?.ok &&
        probes.openrouter?.ok &&
        probes.db?.ok;

      if (statusEl) {
        statusEl.textContent = allOk ? '● Todo OK' : '● Incidencia';
        statusEl.className = allOk
          ? 'font-mono text-[10px] uppercase tracking-widest text-emerald-700'
          : 'font-mono text-[10px] uppercase tracking-widest text-red-600';
      }

      setProbe('hub_voice',
        probes.hub_voice?.ok,
        probes.hub_voice?.ok
          ? `${probes.hub_voice.latency_ms} ms`
          : `down · ${probes.hub_voice?.detail ?? '?'}`);

      setProbe('openrouter',
        probes.openrouter?.ok,
        probes.openrouter?.ok
          ? `${probes.openrouter.latency_ms} ms`
          : `down · ${probes.openrouter?.detail ?? '?'}`);

      setProbe('db',
        probes.db?.ok,
        probes.db?.ok
          ? `${probes.db.size_mb} MB`
          : `error · ${probes.db?.detail ?? '?'}`);

      if (activity?.last_expediente_at) {
        setProbe('last_exp', true, fmtAgo(activity.last_expediente_at), 'font-mono text-ink/70');
      } else {
        setProbe('last_exp', true, 'sin datos', 'font-mono text-ink/40');
      }
    } catch (err) {
      if (statusEl) {
        statusEl.textContent = '● Error';
        statusEl.className = 'font-mono text-[10px] uppercase tracking-widest text-red-600';
      }
      widget.querySelectorAll('[data-probe]').forEach((el) => {
        el.textContent = '—';
        el.className = 'font-mono text-ink/30';
      });
      console.error('[sos-health]', err);
    }
  })();

  // Backup BD — descarga con autenticación
  document.getElementById('backup-link')?.addEventListener('click', async (e) => {
    e.preventDefault();
    const token = document.cookie.split('; ').find(r => r.startsWith('startidea_admin='))?.split('=')[1] ?? '';
    const res = await fetch('/api/admin/backup-db', { headers: { 'x-admin-token': token } });
    if (!res.ok) { alert('Error al generar el backup. ¿Estás autenticado?'); return; }
    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `expedientes-${new Date().toISOString().slice(0,10)}.db`;
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
