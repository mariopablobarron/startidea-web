---
/**
 * /admin — Dashboard principal de administración.
 * Auth: cookie startidea_admin
 */
import Base from '@/layouts/Base.astro';
import { isAdminLoggedIn } from '@/lib/admin-session';
import {
  statsExpedientes,
  statsContratos,
  statsEconomico,
  statsPortalUsers,
  getExpedientesRecibidosSinProcesar,
  getExpedientesRecientes,
} from '@/lib/expedientes-db';

export const prerender = false;

if (!isAdminLoggedIn(Astro.cookies)) {
  return Astro.redirect(`/admin/login?next=${encodeURIComponent('/admin')}`);
}

let stats       = { total: 0, recibido: 0, analizando_ia: 0, docs_listos: 0, entregado: 0, presentado: 0, rechazado: 0 };
let contratos   = { sinEnviar: 0, enviados: 0, aceptados: 0 };
let economico   = { facturadoTotal: 0, pipelineTotal: 0, pendienteFacturar: 0 };
let nPortalUsers = 0;
let urgentes: ReturnType<typeof getExpedientesRecibidosSinProcesar> = [];
let recientes:  ReturnType<typeof getExpedientesRecientes> = [];

try {
  stats        = statsExpedientes() as typeof stats;
  contratos    = statsContratos();
  economico    = statsEconomico();
  nPortalUsers = statsPortalUsers();
  urgentes     = getExpedientesRecibidosSinProcesar();
  recientes    = getExpedientesRecientes(6);
} catch { /* DB vacía todavía */ }

const enProceso = (stats.analizando_ia ?? 0) + (stats.docs_listos ?? 0) + (stats.entregado ?? 0);
const concedidos = stats.presentado ?? 0;

function fmtEur(n: number): string {
  return n.toLocaleString('es-ES', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' €';
}

function fmtDate(ts: number): string {
  return new Date(ts * 1000).toLocaleDateString('es-ES', {
    day: '2-digit', month: 'short', year: 'numeric',
  });
}

const STATUS_LABELS: Record<string, string> = {
  recibido:      '📥 Recibido',
  analizando_ia: '🤖 Analizando',
  docs_listos:   '📄 Docs listos',
  entregado:     '📬 Entregado',
  presentado:    '✅ Presentado',
  rechazado:     '❌ Rechazado',
};

const STATUS_COLORS: Record<string, string> = {
  recibido:      'bg-blue-50 text-blue-800 border-blue-200',
  analizando_ia: 'bg-yellow-50 text-yellow-800 border-yellow-200',
  docs_listos:   'bg-purple-50 text-purple-800 border-purple-200',
  entregado:     'bg-green-50 text-green-800 border-green-200',
  presentado:    'bg-emerald-50 text-emerald-800 border-emerald-200',
  rechazado:     'bg-red-50 text-red-800 border-red-200',
};
---

<Base title="Admin · Startidea" description="">
  <div class="bg-paper-warm min-h-screen">
    <div class="container-x py-10">

      <!-- Header -->
      <div class="mb-8 flex items-center justify-between">
        <div>
          <span class="font-mono text-[11px] uppercase tracking-widest text-ink/40">— Startidea</span>
          <h1 class="mt-1 font-display text-4xl text-ink">Panel de admin</h1>
        </div>
        <a href="/admin/logout" class="font-mono text-[11px] uppercase tracking-widest text-ink/40 hover:text-magenta">
          Cerrar sesión →
        </a>
      </div>

      <!-- ─── KPIs del Copiloto ──────────────────────────── -->
      {stats.total > 0 && (
        <div class="mb-8 space-y-6">

          <!-- KPIs expedientes -->
          <div>
            <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-3">
              Copiloto de Subvenciones — Expedientes
            </p>
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
              <div class="border border-ink/15 bg-paper p-4">
                <p class="font-display text-3xl text-ink">{stats.total}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink/50">Total</p>
              </div>
              <div class="border border-yellow-200 bg-yellow-50/40 p-4">
                <p class="font-display text-3xl text-yellow-700">{enProceso}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-yellow-600">En proceso</p>
              </div>
              <div class="border border-emerald-200 bg-emerald-50/40 p-4">
                <p class="font-display text-3xl text-emerald-700">{concedidos}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-emerald-600">Presentados</p>
              </div>
              <div class="border border-ink/15 bg-paper p-4">
                <p class="font-display text-3xl text-ink">{stats.rechazado ?? 0}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink/50">No concedidos</p>
              </div>
            </div>
          </div>

          <!-- Pipeline económico -->
          {(economico.facturadoTotal > 0 || economico.pipelineTotal > 0) && (
            <div>
              <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-3">
                Pipeline económico (comisión 12%)
              </p>
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                <div class="border-2 border-magenta/30 bg-paper p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-ink/50 mb-1">Facturado</p>
                  <p class="font-display text-2xl text-magenta">{fmtEur(economico.facturadoTotal)}</p>
                  <p class="mt-1 font-mono text-[10px] text-ink/40">Facturas emitidas</p>
                </div>
                <div class="border border-blue-200 bg-blue-50/30 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-blue-600 mb-1">Por facturar</p>
                  <p class="font-display text-2xl text-blue-700">{fmtEur(economico.pipelineTotal)}</p>
                  <p class="mt-1 font-mono text-[10px] text-blue-500">{economico.pendienteFacturar} expediente{economico.pendienteFacturar !== 1 ? 's' : ''} con importe concedido</p>
                </div>
                <div class="border border-ink/10 bg-paper/50 p-4">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-1">Total potencial</p>
                  <p class="font-display text-2xl text-ink">{fmtEur(economico.facturadoTotal + economico.pipelineTotal)}</p>
                  <p class="mt-1 font-mono text-[10px] text-ink/40">Facturado + por facturar</p>
                </div>
              </div>
            </div>
          )}

          <!-- Acciones pendientes -->
          <div>
            <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-3">
              Acciones pendientes
            </p>
            <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
              {urgentes.length > 0 && (
                <a href="/admin/expedientes?status=recibido"
                   class="border border-red-200 bg-red-50/50 p-4 hover:border-magenta transition-colors">
                  <p class="font-display text-2xl text-red-700">{urgentes.length}</p>
                  <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-red-600">
                    ⚠ Sin procesar ({'>'}24h)
                  </p>
                  <p class="mt-1 text-xs text-red-500">Requieren generación con IA</p>
                </a>
              )}
              {contratos.enviados > 0 && (
                <div class="border border-yellow-200 bg-yellow-50/40 p-4">
                  <p class="font-display text-2xl text-yellow-700">{contratos.enviados}</p>
                  <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-yellow-600">Contratos pendientes</p>
                  <p class="mt-1 text-xs text-yellow-500">Enviados pero no firmados</p>
                </div>
              )}
              {economico.pendienteFacturar > 0 && (
                <a href="/admin/expedientes?status=presentado"
                   class="border border-blue-200 bg-blue-50/30 p-4 hover:border-magenta transition-colors">
                  <p class="font-display text-2xl text-blue-700">{economico.pendienteFacturar}</p>
                  <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-blue-600">Facturas por emitir</p>
                  <p class="mt-1 text-xs text-blue-500">Importe concedido sin factura</p>
                </a>
              )}
              {urgentes.length === 0 && contratos.enviados === 0 && economico.pendienteFacturar === 0 && (
                <div class="border border-green-200 bg-green-50/40 p-4">
                  <p class="font-display text-2xl text-green-700">✓</p>
                  <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-green-600">Todo al día</p>
                  <p class="mt-1 text-xs text-green-500">No hay acciones pendientes urgentes</p>
                </div>
              )}
            </div>
          </div>

          <!-- Expedientes recientes -->
          {recientes.length > 0 && (
            <div>
              <div class="flex items-center justify-between mb-3">
                <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40">
                  Expedientes recientes
                </p>
                <a href="/admin/expedientes" class="font-mono text-[11px] uppercase tracking-widest text-magenta hover:underline">
                  Ver todos →
                </a>
              </div>
              <div class="border border-ink/15 bg-paper overflow-hidden">
                <table class="w-full text-sm">
                  <tbody class="divide-y divide-ink/8">
                    {recientes.map((exp) => (
                      <tr class="hover:bg-paper-warm/50 transition-colors">
                        <td class="px-4 py-2.5">
                          <a href={`/admin/expedientes/${exp.id}`} class="font-mono text-xs font-bold text-magenta hover:underline">
                            {exp.id}
                          </a>
                        </td>
                        <td class="px-4 py-2.5 max-w-[200px]">
                          <p class="font-medium text-ink truncate text-xs">{exp.org_nombre}</p>
                          <p class="text-[10px] text-ink/40 truncate">{exp.convocatoria_title ?? 'Sin convocatoria'}</p>
                        </td>
                        <td class="px-4 py-2.5">
                          <span class:list={[
                            'border px-2 py-0.5 font-mono text-[9px] uppercase tracking-wider',
                            STATUS_COLORS[exp.status] ?? 'bg-paper border-ink/20 text-ink',
                          ]}>
                            {STATUS_LABELS[exp.status] ?? exp.status}
                          </span>
                        </td>
                        <td class="px-4 py-2.5 text-[11px] text-ink/40 whitespace-nowrap hidden sm:table-cell">
                          {fmtDate(exp.created_at)}
                        </td>
                        <td class="px-4 py-2.5 text-right">
                          <a href={`/admin/expedientes/${exp.id}`}
                             class="font-mono text-[10px] uppercase tracking-wider text-ink/40 hover:text-magenta">
                            Ver →
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

        </div>
      )}

      <!-- ─── Módulos ─────────────────────────────────────── -->
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">

        <!-- Copiloto de Subvenciones -->
        <a href="/admin/expedientes"
           class="group block border-2 border-magenta/30 bg-paper p-6 transition-colors hover:border-magenta">
          <div class="flex items-start justify-between gap-3">
            <span class="text-3xl" aria-hidden="true">📋</span>
            {stats.total > 0 && (
              <span class="font-mono text-[10px] uppercase tracking-widest text-magenta">
                {stats.total} expedientes
              </span>
            )}
          </div>
          <h2 class="mt-4 font-display text-xl text-ink group-hover:text-magenta">Copiloto de Subvenciones</h2>
          <p class="mt-2 text-sm text-ink/60 leading-relaxed">
            Expedientes, documentos IA, contratos y facturas.
          </p>
          {stats.recibido > 0 && (
            <p class="mt-3 font-mono text-[11px] uppercase tracking-widest text-yellow-700">
              ⚠ {stats.recibido} pendiente{stats.recibido > 1 ? 's' : ''} de procesar
            </p>
          )}
        </a>

        <!-- Portal de clientes -->
        <div class="group block border border-ink/15 bg-paper p-6">
          <div class="flex items-start justify-between gap-2">
            <span class="text-3xl" aria-hidden="true">🏠</span>
            {nPortalUsers > 0 && (
              <span class="font-mono text-[10px] uppercase tracking-widest text-ink/40">
                {nPortalUsers} usuario{nPortalUsers !== 1 ? 's' : ''}
              </span>
            )}
          </div>
          <h2 class="mt-4 font-display text-xl text-ink">Portal de clientes</h2>
          <p class="mt-2 text-sm text-ink/60 leading-relaxed">
            Registro, acceso, expedientes y servicios para clientes.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a href="/admin/portal-usuarios"
               class="font-mono text-[11px] uppercase tracking-widest text-magenta hover:underline">
              Usuarios →
            </a>
            <a href="/portal" target="_blank"
               class="font-mono text-[11px] uppercase tracking-widest text-ink/40 hover:text-magenta">
              Ver portal ↗
            </a>
            <a href="/api/admin/backup-db" id="backup-link"
               class="font-mono text-[11px] uppercase tracking-widest text-ink/30 hover:text-magenta"
               title="Descarga la base de datos completa">
              💾 Backup BD →
            </a>
          </div>
        </div>

        <!-- Leads y diagnósticos -->
        <a href="/admin/leads"
           class="group block border border-ink/15 bg-paper p-6 transition-colors hover:border-magenta">
          <span class="text-3xl" aria-hidden="true">🎯</span>
          <h2 class="mt-4 font-display text-xl text-ink group-hover:text-magenta">Leads y diagnósticos</h2>
          <p class="mt-2 text-sm text-ink/60 leading-relaxed">
            Formularios de diagnóstico y presupuestos recibidos.
          </p>
        </a>

        <!-- Knowledge base -->
        <a href="/admin/knowledge"
           class="group block border border-ink/15 bg-paper p-6 transition-colors hover:border-magenta">
          <span class="text-3xl" aria-hidden="true">🧠</span>
          <h2 class="mt-4 font-display text-xl text-ink group-hover:text-magenta">Knowledge base</h2>
          <p class="mt-2 text-sm text-ink/60 leading-relaxed">
            Base de conocimiento interna del chat IA.
          </p>
        </a>

        <!-- SEO (HUB) -->
        <a href="https://hub.startidea.tech/startidea/admin/seo" target="_blank" rel="noopener"
           class="group block border border-ink/15 bg-paper p-6 transition-colors hover:border-magenta">
          <span class="text-3xl" aria-hidden="true">📈</span>
          <h2 class="mt-4 font-display text-xl text-ink group-hover:text-magenta">SEO Dashboard ↗</h2>
          <p class="mt-2 text-sm text-ink/60 leading-relaxed">
            GA4 + Search Console + agentes IA. En el HUB.
          </p>
        </a>

        <!-- Accesos rápidos -->
        <div class="border border-ink/10 bg-paper/50 p-6">
          <span class="text-3xl" aria-hidden="true">⚡</span>
          <h2 class="mt-4 font-mono text-[11px] uppercase tracking-widest text-ink/50">Accesos rápidos</h2>
          <ul class="mt-3 space-y-2 text-sm">
            <li>
              <a href="/subvenciones/presentar/nuevo" target="_blank"
                 class="text-magenta hover:underline">+ Nuevo expediente →</a>
            </li>
            <li>
              <a href="/subvenciones" target="_blank"
                 class="text-ink/60 hover:text-magenta">Buscador de subvenciones →</a>
            </li>
            <li>
              <a href="/portal" target="_blank"
                 class="text-ink/60 hover:text-magenta">Portal de clientes →</a>
            </li>
            <li>
              <a href="https://coolify.startidea.es" target="_blank" rel="noopener"
                 class="text-ink/60 hover:text-magenta">Coolify panel ↗</a>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </div>
</Base>

<script>
  // Backup BD — descarga con autenticación
  document.getElementById('backup-link')?.addEventListener('click', async (e) => {
    e.preventDefault();
    const token = document.cookie.split('; ').find(r => r.startsWith('startidea_admin='))?.split('=')[1] ?? '';
    const res = await fetch('/api/admin/backup-db', { headers: { 'x-admin-token': token } });
    if (!res.ok) { alert('Error al generar el backup. ¿Estás autenticado?'); return; }
    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `expedientes-${new Date().toISOString().slice(0,10)}.db`;
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
