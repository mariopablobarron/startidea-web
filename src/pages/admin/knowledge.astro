---
export const prerender = false;
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

// Auth básica con token: ?token=XYZ o cookie
const url = Astro.url;
const tokenParam = url.searchParams.get('token') || '';
const cookieToken = Astro.cookies.get('startidea_admin')?.value || '';
const expected = process.env.ADMIN_TOKEN || '';

const authed = !!expected && (tokenParam === expected || cookieToken === expected);

if (authed && tokenParam) {
  Astro.cookies.set('startidea_admin', tokenParam, {
    path: '/',
    httpOnly: true,
    sameSite: 'strict',
    secure: true,
    maxAge: 60 * 60 * 8,
  });
}

let archivos: { id: string; size: number; preview: string }[] = [];
if (authed) {
  try {
    const entries = await getCollection('knowledge');
    entries.sort((a, b) => a.id.localeCompare(b.id));
    archivos = entries.map((e) => ({
      id: e.id,
      size: e.body.length,
      preview: e.body,
    }));
  } catch (err) {
    console.error('[admin/knowledge] error', err);
  }
}

const noTokenConfigured = !expected;
---

<Base
  title="Admin · Knowledge base · Startidea"
  description="Panel admin de Startidea para gestión del conocimiento del asistente IA."
  ogSlug="page/404"
>
  <section class="bg-paper py-16 md:py-24">
    <div class="container-x">
      <span class="label">— Admin · Knowledge base</span>
      <h1 class="mt-4 font-display text-display-md leading-tight text-ink">
        Conocimiento del <em class="italic text-magenta">asistente</em>.
      </h1>

      {noTokenConfigured && (
        <div class="mt-10 border-2 border-magenta bg-paper-warm p-6">
          <p class="font-display text-xl text-magenta">⚠ Falta configurar <code class="font-mono">ADMIN_TOKEN</code> en Coolify.</p>
          <p class="mt-3 max-w-measure text-sm text-ink/85">
            Sin esa variable nadie puede entrar — ni siquiera tú. En Coolify → Secrets → añade <code class="font-mono">ADMIN_TOKEN</code> y reinicia. Después accede a <code class="font-mono">/admin/knowledge?token=TU_TOKEN</code>.
          </p>
        </div>
      )}

      {!authed && !noTokenConfigured && (
        <form method="get" class="mt-10 max-w-md space-y-3">
          <p class="label">— Acceso</p>
          <input
            name="token"
            type="password"
            required
            placeholder="Token admin"
            class="w-full border border-ink bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/75 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
          />
          <button type="submit" class="btn">
            Entrar
            <span aria-hidden="true">→</span>
          </button>
        </form>
      )}

      {authed && (
        <>
          <p class="mt-6 max-w-measure text-sm text-ink/75">
            Estos archivos <code class="font-mono">.md</code> alimentan al asistente IA antes de cada respuesta. Para editarlos, modifica el repo y haz <code class="font-mono">git push</code> — Coolify redespliega y el asistente recarga la knowledge base.
          </p>

          <div class="mt-12 space-y-10">
            {archivos.map((f) => (
              <article class="border-t border-ink/15 pt-6">
                <header class="flex flex-wrap items-baseline justify-between gap-3 border-b border-ink/10 pb-2">
                  <h2 class="font-display text-2xl leading-tight text-ink">
                    <code class="font-mono text-base">{f.id}</code>
                  </h2>
                  <span class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">
                    {f.size.toLocaleString('es-ES')} caracteres
                  </span>
                </header>
                <pre class="mt-4 max-h-[420px] overflow-auto bg-paper-warm p-4 text-xs leading-relaxed text-ink/85">{f.preview}</pre>
              </article>
            ))}
          </div>

          <div class="mt-12 border-t border-ink/15 pt-6 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
            <p>Total de archivos: {archivos.length}</p>
            <p class="mt-2">Para añadir uno nuevo: crea <code class="font-mono">src/content/knowledge/05-mi-tema.md</code> y haz git push.</p>
          </div>
        </>
      )}
    </div>
  </section>
</Base>
