---
/**
 * /admin/auto-copiloto — Panel admin del Auto-copiloto de Subvenciones
 *
 * Muestra todos los perfiles registrados (activos, pausados, pendientes).
 * Permite lanzar campañas manuales para convocatorias fuera de la ventana de 26h.
 * Incluye campaña preconfigurada para BOJA 2026 — Inclusión Social (plazo: 16 jun).
 *
 * Auth: cookie startidea_admin
 */
import Base from '@/layouts/Base.astro';
import { isAdminLoggedIn } from '@/lib/admin-session';
import {
  listAllProfiles,
  statsProfiles,
  listRecentLog,
  statsLog,
} from '@/lib/auto-copiloto-db';
import { statsCopilotoConversion } from '@/lib/expedientes-db';

export const prerender = false;

if (!isAdminLoggedIn(Astro.cookies)) {
  return Astro.redirect(`/admin/login?next=${encodeURIComponent('/admin/auto-copiloto')}`);
}

let profiles: ReturnType<typeof listAllProfiles> = [];
let pStats = { total: 0, active: 0, confirmed: 0, pendingConfirm: 0, paused: 0 };
let recentLog: ReturnType<typeof listRecentLog> = [];
let lStats = { total: 0, enviados: 0, errores: 0, ultimas_24h: 0 };
let convStats = {
  perfilesActivos:           null as number | null,
  expedientesAutogenerados:  0,
  expedientesConversion:     0,
  conversionContratoFirmado: 0,
  conversionPresentados:     0,
  facturadoConversion:       0,
};

try {
  profiles = listAllProfiles();
  pStats   = statsProfiles();
  recentLog = listRecentLog(30);
  lStats   = statsLog();
  convStats = statsCopilotoConversion();
} catch { /* BD vacía */ }

// Tasa de conversión (% de emails enviados que llevaron a expediente real)
const tasaConv = lStats.enviados > 0
  ? Math.round((convStats.expedientesConversion / lStats.enviados) * 100)
  : 0;

function fmtDate(ts: number | null | undefined): string {
  if (!ts) return '—';
  return new Date(ts * 1000).toLocaleDateString('es-ES', {
    day: '2-digit', month: 'short', year: 'numeric',
  });
}

function fmtDateTime(ts: number | null | undefined): string {
  if (!ts) return '—';
  return new Date(ts * 1000).toLocaleString('es-ES', {
    day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit',
  });
}

// BOJA 2026 — Líneas para campaña manual (preconfigured)
// Solo las líneas más relevantes para tercer sector privado (lo que tienen los perfiles)
const BOJA_CAMPAIGNS = [
  {
    id: 'boja-2026-l10',
    label: 'L10 — Mantenimiento entidades privadas de acción social',
    slug: 'boja-2026-inclusion-l10',
    title: 'BOJA 2026 · Línea 10 — Mantenimiento de entidades privadas de acción social (Junta de Andalucía)',
    url: 'https://www.juntadeandalucia.es/boja/2026/99',
    deadline: '2026-06-16',
    finalidades: ['inclusion-social', 'accion-social'],
    amount_eur: null,
    ccaa: 'Andalucía',
    geo_level: 'regional',
    targetOrgTipos: ['asociacion', 'fundacion', 'cooperativa'],
    description: 'Financiación estructural: personal, sede y gastos corrientes. Para entidades privadas sin ánimo de lucro de acción social en Andalucía.',
  },
  {
    id: 'boja-2026-l11',
    label: 'L11 — Programas de acción social para entidades privadas',
    slug: 'boja-2026-inclusion-l11',
    title: 'BOJA 2026 · Línea 11 — Programas de acción social para entidades privadas (Junta de Andalucía)',
    url: 'https://www.juntadeandalucia.es/boja/2026/99',
    deadline: '2026-06-16',
    finalidades: ['inclusion-social', 'pobreza', 'discapacidad', 'menores', 'mayores', 'mujer'],
    amount_eur: null,
    ccaa: 'Andalucía',
    geo_level: 'regional',
    targetOrgTipos: ['asociacion', 'fundacion', 'cooperativa'],
    description: 'Programas concretos de acción social: inclusión, pobreza, discapacidad, menores, mayores, mujer, personas inmigrantes.',
  },
  {
    id: 'boja-2026-l7',
    label: 'L7 — Solidaridad y Garantía Alimentaria (Modal. 1 — comedores)',
    slug: 'boja-2026-inclusion-l7-m1',
    title: 'BOJA 2026 · Línea 7 Modalidad 1 — Solidaridad y Garantía Alimentaria (Junta de Andalucía)',
    url: 'https://www.juntadeandalucia.es/boja/2026/99',
    deadline: '2026-06-16',
    finalidades: ['inclusion-social', 'pobreza', 'accion-social'],
    amount_eur: null,
    ccaa: 'Andalucía',
    geo_level: 'regional',
    targetOrgTipos: ['asociacion', 'fundacion', 'cooperativa'],
    description: 'Financiación de comedores sociales y distribución de alimentos. Plazo general 16 junio.',
  },
];
---

<Base title="Auto-copiloto · Admin · Startidea" description="">
  <div class="bg-paper-warm min-h-screen">
    <div class="container-x py-10">

      <!-- Header -->
      <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
        <div>
          <a href="/admin" class="font-mono text-[11px] uppercase tracking-widest text-ink/40 hover:text-magenta">← Admin</a>
          <h1 class="mt-1 font-display text-4xl text-ink">Auto-copiloto</h1>
          <p class="mt-1 text-sm text-ink/50">Perfiles registrados para detección automática de subvenciones</p>
        </div>
      </div>

      <!-- KPIs perfiles -->
      <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-3">Perfiles</p>
      <div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-5">
        <div class="border border-ink/15 bg-paper p-4 text-center">
          <p class="font-display text-3xl text-ink">{pStats.total}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-ink/40 mt-0.5">Total</p>
        </div>
        <div class="border border-emerald-200 bg-emerald-50/30 p-4 text-center">
          <p class="font-display text-3xl text-emerald-700">{pStats.active}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-emerald-600 mt-0.5">Activos</p>
        </div>
        <div class="border border-blue-200 bg-blue-50/30 p-4 text-center">
          <p class="font-display text-3xl text-blue-700">{pStats.confirmed}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-blue-600 mt-0.5">Confirmados</p>
        </div>
        <div class="border border-yellow-200 bg-yellow-50/30 p-4 text-center">
          <p class="font-display text-3xl text-yellow-700">{pStats.pendingConfirm}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-yellow-600 mt-0.5">Sin confirmar</p>
        </div>
        <div class="border border-ink/10 bg-paper/50 p-4 text-center">
          <p class="font-display text-3xl text-ink/40">{pStats.paused}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-ink/30 mt-0.5">Pausados</p>
        </div>
      </div>

      <!-- KPIs actividad -->
      <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-3">Actividad (envíos automáticos)</p>
      <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="border border-ink/15 bg-paper p-4 text-center">
          <p class="font-display text-3xl text-ink">{lStats.total}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-ink/40 mt-0.5">Total histórico</p>
        </div>
        <div class="border border-emerald-200 bg-emerald-50/30 p-4 text-center">
          <p class="font-display text-3xl text-emerald-700">{lStats.enviados}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-emerald-600 mt-0.5">Emails enviados</p>
        </div>
        <div class="border border-red-200 bg-red-50/30 p-4 text-center">
          <p class="font-display text-3xl text-red-700">{lStats.errores}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-red-600 mt-0.5">Errores</p>
        </div>
        <div class="border border-magenta/30 bg-magenta/5 p-4 text-center">
          <p class="font-display text-3xl text-magenta">{lStats.ultimas_24h}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-magenta mt-0.5">Últimas 24h</p>
        </div>
      </div>

      <!-- Embudo de conversión Copiloto → cliente de pago -->
      <p class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-3">
        💰 Embudo de monetización · Copiloto → Cliente
      </p>
      <div class="mb-10 grid grid-cols-2 gap-3 sm:grid-cols-5">
        <div class="border border-ink/15 bg-paper p-4 text-center">
          <p class="font-display text-3xl text-ink">{lStats.enviados}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-ink/40 mt-0.5">Docs enviados</p>
          <p class="text-[10px] text-ink/30 mt-1">100%</p>
        </div>
        <div class="border border-blue-200 bg-blue-50/30 p-4 text-center">
          <p class="font-display text-3xl text-blue-700">{convStats.expedientesConversion}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-blue-600 mt-0.5">→ Wizard premium</p>
          <p class="text-[10px] text-blue-500 mt-1">{tasaConv}%</p>
        </div>
        <div class="border border-purple-200 bg-purple-50/30 p-4 text-center">
          <p class="font-display text-3xl text-purple-700">{convStats.conversionContratoFirmado}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-purple-600 mt-0.5">Contrato firmado</p>
        </div>
        <div class="border border-emerald-200 bg-emerald-50/30 p-4 text-center">
          <p class="font-display text-3xl text-emerald-700">{convStats.conversionPresentados}</p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-emerald-600 mt-0.5">Presentados</p>
        </div>
        <div class="border-2 border-magenta bg-magenta/5 p-4 text-center">
          <p class="font-display text-3xl text-magenta">
            {convStats.facturadoConversion.toLocaleString('es-ES')} €
          </p>
          <p class="font-mono text-[9px] uppercase tracking-widest text-magenta mt-0.5">Comisión facturada</p>
        </div>
      </div>

      <!-- ─── Campaña BOJA 2026 ─────────────────────────────────────────── -->
      <section class="mb-10">
        <div class="border-2 border-magenta/30 bg-paper p-6">
          <div class="flex flex-wrap items-start justify-between gap-3 mb-5">
            <div>
              <span class="inline-block border border-magenta/30 bg-magenta/5 px-2 py-0.5 font-mono text-[10px] uppercase tracking-widest text-magenta mb-2">
                ⚡ Plazo abierto hasta el 16 junio
              </span>
              <h2 class="font-display text-2xl text-ink">Campaña BOJA 2026 — Inclusión Social</h2>
              <p class="mt-1 text-sm text-ink/60 max-w-prose">
                Las 15 líneas del BOJA nº 99 (26 mayo 2026) quedaron fuera de la ventana de 26h del cron diario.
                Usa las líneas de abajo para enviar los documentos a los perfiles que encajan.
              </p>
            </div>
            <a href="/subvenciones/boja-2026-inclusion-social" target="_blank"
               class="font-mono text-[11px] uppercase tracking-widest text-magenta hover:underline whitespace-nowrap">
              Ver landing →
            </a>
          </div>

          <!-- Líneas BOJA -->
          <div class="space-y-4" id="boja-campaigns">
            {BOJA_CAMPAIGNS.map((camp) => (
              <div class="border border-ink/15 bg-paper-warm p-4" data-campaign={JSON.stringify(camp)}>
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <p class="font-medium text-sm text-ink">{camp.label}</p>
                    <p class="text-xs text-ink/50 mt-0.5">{camp.description}</p>
                    <div class="mt-1.5 flex flex-wrap gap-1.5">
                      {camp.targetOrgTipos.map((t) => (
                        <span class="border border-ink/10 px-1.5 py-0.5 font-mono text-[9px] text-ink/40">{t}</span>
                      ))}
                      <span class="border border-ink/10 px-1.5 py-0.5 font-mono text-[9px] text-ink/40">📍 {camp.ccaa}</span>
                    </div>
                  </div>
                  <div class="flex gap-2 shrink-0">
                    <button
                      class="campaign-dry-btn border border-ink/20 px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-ink/60 hover:border-magenta hover:text-magenta transition-colors"
                      data-id={camp.id}
                    >
                      Ver matches
                    </button>
                    <button
                      class="campaign-send-btn border border-magenta px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-magenta hover:bg-magenta hover:text-white transition-colors"
                      data-id={camp.id}
                    >
                      Enviar →
                    </button>
                  </div>
                </div>
                <!-- Resultados dry run -->
                <div class="campaign-result mt-3 hidden" id={`result-${camp.id}`}></div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ─── Lista de perfiles ──────────────────────────────────────────── -->
      <section>
        <h2 class="font-mono text-[10px] uppercase tracking-widest text-ink/40 mb-4">
          Perfiles registrados — {profiles.length}
        </h2>

        {profiles.length === 0 ? (
          <div class="border border-ink/10 bg-paper p-8 text-center">
            <p class="text-sm text-ink/40">Sin perfiles registrados todavía.</p>
          </div>
        ) : (
          <div class="border border-ink/15 bg-paper overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-ink/10 bg-paper-warm/50">
                  <th class="px-4 py-2 text-left font-mono text-[10px] uppercase tracking-widest text-ink/40">Organización</th>
                  <th class="px-4 py-2 text-left font-mono text-[10px] uppercase tracking-widest text-ink/40 hidden sm:table-cell">Tipo / CCAA</th>
                  <th class="px-4 py-2 text-center font-mono text-[10px] uppercase tracking-widest text-ink/40">Estado</th>
                  <th class="px-4 py-2 text-right font-mono text-[10px] uppercase tracking-widest text-ink/40 hidden md:table-cell">Alta</th>
                  <th class="px-4 py-2 text-right font-mono text-[10px] uppercase tracking-widest text-ink/40 hidden lg:table-cell">Último cron</th>
                  <th class="px-4 py-2"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-ink/8">
                {profiles.map((p) => (
                  <tr class="hover:bg-paper-warm/40 transition-colors">
                    <td class="px-4 py-3">
                      <p class="font-medium text-ink text-xs">{p.org_nombre}</p>
                      <p class="font-mono text-[10px] text-ink/40">{p.email}</p>
                    </td>
                    <td class="px-4 py-3 hidden sm:table-cell">
                      <span class="border border-ink/10 px-1.5 py-0.5 font-mono text-[9px] text-ink/50">{p.org_tipo}</span>
                      {p.ccaa && <span class="ml-1 font-mono text-[9px] text-ink/40">{p.ccaa}</span>}
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class:list={[
                        'inline-block border px-2 py-0.5 font-mono text-[9px] uppercase tracking-wide whitespace-nowrap',
                        p.active && p.confirmed   ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
                        !p.confirmed              ? 'bg-yellow-50 text-yellow-700 border-yellow-200' :
                        'bg-gray-50 text-gray-500 border-gray-200',
                      ]}>
                        {p.active && p.confirmed ? '✅ Activo' : !p.confirmed ? '⏳ Sin confirmar' : '⏸ Pausado'}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-right font-mono text-[10px] text-ink/40 hidden md:table-cell whitespace-nowrap">
                      {fmtDate(p.created_at)}
                    </td>
                    <td class="px-4 py-3 text-right font-mono text-[10px] text-ink/30 hidden lg:table-cell whitespace-nowrap">
                      {p.last_run_at ? fmtDate(p.last_run_at) : 'Nunca'}
                    </td>
                    <td class="px-4 py-3 text-right">
                      <a href={`/admin/crm/${encodeURIComponent(p.email)}`}
                         class="font-mono text-[10px] text-ink/30 hover:text-magenta whitespace-nowrap">
                        Ver →
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>

      <!-- ─── Actividad reciente del Copiloto ──────────────────────────────── -->
      {recentLog.length > 0 && (
        <section class="mt-10">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-mono text-[10px] uppercase tracking-widest text-ink/40">
              Actividad reciente — últimas {recentLog.length} ejecuciones
            </h2>
            <span class="font-mono text-[10px] text-ink/30">
              ✅ enviado · ❌ error · ⏭ skip
            </span>
          </div>

          <div class="border border-ink/15 bg-paper overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-ink/10 bg-paper-warm/50">
                  <th class="px-3 py-2 text-left font-mono text-[10px] uppercase tracking-widest text-ink/40">Cuándo</th>
                  <th class="px-3 py-2 text-left font-mono text-[10px] uppercase tracking-widest text-ink/40">Estado</th>
                  <th class="px-3 py-2 text-left font-mono text-[10px] uppercase tracking-widest text-ink/40">Org / Perfil</th>
                  <th class="px-3 py-2 text-left font-mono text-[10px] uppercase tracking-widest text-ink/40">Convocatoria</th>
                  <th class="px-3 py-2 text-right font-mono text-[10px] uppercase tracking-widest text-ink/40 hidden md:table-cell">Expediente</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-ink/8">
                {recentLog.map((l) => {
                  const icon = l.error ? '❌' : l.sent ? '✅' : '⏭';
                  const color = l.error ? 'text-red-700' : l.sent ? 'text-emerald-700' : 'text-ink/40';
                  return (
                    <tr class="hover:bg-paper-warm/40 transition-colors">
                      <td class="px-3 py-2 font-mono text-[10px] text-ink/40 whitespace-nowrap">
                        {fmtDateTime(l.created_at)}
                      </td>
                      <td class={`px-3 py-2 ${color}`}>
                        <span class="font-mono text-xs">{icon}</span>
                      </td>
                      <td class="px-3 py-2 max-w-[200px]">
                        <p class="text-xs text-ink truncate">{l.org_nombre ?? '— perfil borrado —'}</p>
                        <p class="font-mono text-[10px] text-ink/40 truncate">{l.email ?? ''}</p>
                      </td>
                      <td class="px-3 py-2 max-w-[260px]">
                        <p class="text-xs text-ink/70 truncate">{l.convocatoria_title || l.convocatoria_slug}</p>
                        {l.error && (
                          <p class="font-mono text-[9px] text-red-600 truncate">⚠ {l.error}</p>
                        )}
                      </td>
                      <td class="px-3 py-2 text-right hidden md:table-cell">
                        {l.expediente_id ? (
                          <a href={`/admin/expedientes/${l.expediente_id}`}
                             class="font-mono text-[10px] font-bold text-magenta hover:underline whitespace-nowrap">
                            {l.expediente_id}
                          </a>
                        ) : (
                          <span class="font-mono text-[10px] text-ink/20">—</span>
                        )}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
      )}

    </div>
  </div>
</Base>

<script>
  const adminToken = (() => {
    const raw = document.cookie.split('; ')
      .find(r => r.startsWith('startidea_admin='))
      ?.slice('startidea_admin='.length) ?? '';
    try { return raw ? decodeURIComponent(raw) : ''; } catch { return raw; }
  })();

  // Leer configuración de cada campaña desde el DOM
  const campaignData = {};
  document.querySelectorAll('[data-campaign]').forEach((el) => {
    try {
      const c = JSON.parse(el.dataset.campaign);
      campaignData[c.id] = c;
    } catch { /* ignorar */ }
  });

  // ── Dry run (Ver matches) ─────────────────────────────────────────────────
  document.querySelectorAll('.campaign-dry-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id   = btn.dataset.id;
      const camp = campaignData[id];
      if (!camp) return;

      btn.disabled = true;
      btn.textContent = 'Cargando…';

      const resultEl = document.getElementById(`result-${id}`);

      try {
        const res = await fetch('/api/admin/auto-copiloto/campaign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-admin-token': adminToken },
          body: JSON.stringify({
            convocatoria: {
              slug: camp.slug,
              title: camp.title,
              url: camp.url,
              deadline: camp.deadline,
              finalidades: camp.finalidades,
              amount_eur: camp.amount_eur,
              ccaa: camp.ccaa,
              geo_level: camp.geo_level,
            },
            dryRun: true,
            targetOrgTipos: camp.targetOrgTipos,
            targetCcaa: 'andalucia',
          }),
        });
        const data = await res.json();

        if (!data.ok) throw new Error(data.error ?? 'Error');

        const { matches, total_profiles_evaluated } = data;
        const new_matches = matches.filter(m => !m.already_processed);
        const already_done = matches.filter(m => m.already_processed);

        let html = `<div class="text-xs text-ink/50 mb-2">
          Evaluados: <strong>${total_profiles_evaluated}</strong> perfiles ·
          Matches: <strong>${matches.length}</strong> ·
          Nuevos: <strong>${new_matches.length}</strong> ·
          Ya procesados: <strong>${already_done.length}</strong>
        </div>`;

        if (new_matches.length > 0) {
          html += `<ul class="space-y-1">`;
          for (const m of new_matches) {
            html += `<li class="flex items-center gap-2 text-xs">
              <span class="w-2 h-2 bg-emerald-400 rounded-full shrink-0"></span>
              <strong>${esc(m.org_nombre)}</strong>
              <span class="text-ink/40">${esc(m.email)}</span>
              <span class="font-mono text-[9px] text-ink/30">score ${m.score}</span>
            </li>`;
          }
          html += `</ul>`;
        } else {
          html += `<p class="text-xs text-ink/40 italic">No hay perfiles nuevos que enviar para esta línea.</p>`;
        }

        if (resultEl) {
          resultEl.innerHTML = html;
          resultEl.classList.remove('hidden');
        }
      } catch (err) {
        if (resultEl) {
          resultEl.innerHTML = `<p class="text-xs text-red-600">Error: ${esc(String(err?.message ?? err))}</p>`;
          resultEl.classList.remove('hidden');
        }
      } finally {
        btn.disabled = false;
        btn.textContent = 'Ver matches';
      }
    });
  });

  // ── Enviar campaña ────────────────────────────────────────────────────────
  document.querySelectorAll('.campaign-send-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id   = btn.dataset.id;
      const camp = campaignData[id];
      if (!camp) return;

      const label = camp.label;
      if (!confirm(`¿Confirmar envío de campaña "${label}" a todos los perfiles activos que encajan?\n\nEsto generará documentos con IA y enviará emails.`)) return;

      btn.disabled = true;
      btn.textContent = 'Enviando…';

      const resultEl = document.getElementById(`result-${id}`);

      try {
        const res = await fetch('/api/admin/auto-copiloto/campaign', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-admin-token': adminToken },
          body: JSON.stringify({
            convocatoria: {
              slug: camp.slug,
              title: camp.title,
              url: camp.url,
              deadline: camp.deadline,
              finalidades: camp.finalidades,
              amount_eur: camp.amount_eur,
              ccaa: camp.ccaa,
              geo_level: camp.geo_level,
            },
            dryRun: false,
            targetOrgTipos: camp.targetOrgTipos,
            targetCcaa: 'andalucia',
          }),
        });
        const data = await res.json();

        if (!data.ok) throw new Error(data.error ?? 'Error');

        let html = `<div class="text-xs mb-2">
          <span class="text-emerald-700 font-bold">✅ Enviados: ${data.sent}</span> ·
          <span class="text-ink/50">Omitidos: ${data.skipped}</span> ·
          <span class="${data.errors > 0 ? 'text-red-600' : 'text-ink/40'}">Errores: ${data.errors}</span> ·
          ${data.elapsed_s}s
        </div>`;

        if (data.results?.length > 0) {
          html += `<ul class="space-y-1">`;
          for (const r of data.results) {
            const icon = r.status === 'ok' ? '✅' : r.status === 'skip' ? '⏭' : '❌';
            html += `<li class="text-xs"><span class="mr-1">${icon}</span><strong>${esc(r.profile)}</strong> ${r.detail ? `<span class="text-ink/40">${esc(r.detail)}</span>` : ''}</li>`;
          }
          html += `</ul>`;
        }

        if (resultEl) {
          resultEl.innerHTML = html;
          resultEl.classList.remove('hidden');
        }
      } catch (err) {
        if (resultEl) {
          resultEl.innerHTML = `<p class="text-xs text-red-600">Error: ${esc(String(err?.message ?? err))}</p>`;
          resultEl.classList.remove('hidden');
        }
      } finally {
        btn.disabled = false;
        btn.textContent = 'Enviar →';
      }
    });
  });

  function esc(s) {
    return String(s).replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] ?? c);
  }
</script>
