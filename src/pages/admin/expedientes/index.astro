---
/**
 * /admin/expedientes — Panel de gestión del Copiloto de subvenciones.
 * Auth: cookie startidea_admin
 */
import Base from '@/layouts/Base.astro';
import { isAdminLoggedIn } from '@/lib/admin-session';
import { listExpedientes, statsExpedientes } from '@/lib/expedientes-db';
import type { ExpedienteStatus } from '@/lib/expedientes-db';

export const prerender = false;

if (!isAdminLoggedIn(Astro.cookies)) {
  return Astro.redirect(`/admin/login?next=${encodeURIComponent('/admin/expedientes')}`);
}

const statusFilter = (Astro.url.searchParams.get('status') as ExpedienteStatus | null) ?? undefined;
const page = Math.max(0, Number(Astro.url.searchParams.get('page') ?? 0));
const PAGE_SIZE = 20;

const { items, total } = listExpedientes({ status: statusFilter, limit: PAGE_SIZE, offset: page * PAGE_SIZE });
const stats = statsExpedientes();
const totalPages = Math.ceil(total / PAGE_SIZE);

const STATUS_LABELS: Record<string, string> = {
  recibido:      '📥 Recibido',
  analizando_ia: '🤖 Analizando...',
  docs_listos:   '📄 Docs listos',
  entregado:     '📬 Entregado',
  presentado:    '✅ Presentado',
  rechazado:     '❌ Rechazado',
};

const STATUS_COLORS: Record<string, string> = {
  recibido:      'bg-blue-50 text-blue-800 border-blue-200',
  analizando_ia: 'bg-yellow-50 text-yellow-800 border-yellow-200',
  docs_listos:   'bg-purple-50 text-purple-800 border-purple-200',
  entregado:     'bg-green-50 text-green-800 border-green-200',
  presentado:    'bg-emerald-50 text-emerald-800 border-emerald-200',
  rechazado:     'bg-red-50 text-red-800 border-red-200',
};

function fmtDate(ts: number | null): string {
  if (!ts) return '—';
  return new Date(ts * 1000).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}
---

<Base title="Expedientes · Admin · Startidea" description="">
  <div class="bg-paper-warm min-h-screen">
    <div class="container-x py-10">

      <!-- Header -->
      <div class="mb-8 flex items-center justify-between">
        <div>
          <a href="/admin" class="font-mono text-[11px] uppercase tracking-widest text-ink/50 hover:text-magenta">← Admin</a>
          <h1 class="mt-2 font-display text-3xl text-ink">Copiloto de Subvenciones</h1>
          <p class="mt-1 text-sm text-ink/60">Expedientes gestionados · {stats.total ?? 0} en total</p>
        </div>
        <a href="/subvenciones/presentar/nuevo" target="_blank"
           class="btn text-sm">
          + Nuevo expediente
        </a>
      </div>

      <!-- Estadísticas rápidas -->
      <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {([
          ['total', 'Total'],
          ['recibido', 'Recibidos'],
          ['analizando_ia', 'Analizando'],
          ['docs_listos', 'Docs listos'],
          ['entregado', 'Entregados'],
          ['presentado', 'Presentados'],
        ] as [string, string][]).map(([key, label]) => (
          <a
            href={key === 'total' ? '/admin/expedientes' : `/admin/expedientes?status=${key}`}
            class:list={[
              'border p-4 text-center transition-colors hover:border-magenta',
              statusFilter === key || (key === 'total' && !statusFilter)
                ? 'border-magenta bg-magenta/5'
                : 'border-ink/15 bg-paper',
            ]}
          >
            <p class="font-display text-3xl text-ink">{(stats as any)[key] ?? 0}</p>
            <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink/50">{label}</p>
          </a>
        ))}
      </div>

      <!-- Tabla de expedientes -->
      {items.length === 0 ? (
        <div class="border border-ink/15 bg-paper p-16 text-center">
          <p class="text-ink/50">No hay expedientes{statusFilter ? ` con estado "${statusFilter}"` : ''}.</p>
        </div>
      ) : (
        <div class="border border-ink/15 bg-paper">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-ink/15 bg-paper-warm">
                  <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/50">ID</th>
                  <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/50">Entidad</th>
                  <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/50">Convocatoria</th>
                  <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/50">Estado</th>
                  <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/50">Recibido</th>
                  <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/50">Acción</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-ink/10">
                {items.map((exp) => (
                  <tr class="hover:bg-paper-warm/50 transition-colors">
                    <td class="px-4 py-3">
                      <a href={`/admin/expedientes/${exp.id}`} class="font-mono text-xs font-bold text-magenta hover:underline">
                        {exp.id}
                      </a>
                    </td>
                    <td class="px-4 py-3 max-w-[220px]">
                      <p class="font-medium text-ink truncate">{exp.org_nombre}</p>
                      <p class="text-xs text-ink/50">{exp.org_cif} · {exp.provincia}</p>
                    </td>
                    <td class="px-4 py-3 max-w-[200px]">
                      {exp.convocatoria_slug ? (
                        <a href={`/subvenciones/${exp.convocatoria_slug}`} target="_blank"
                           class="text-xs text-ink/70 hover:text-magenta truncate block">
                          {exp.convocatoria_title ?? exp.convocatoria_slug}
                        </a>
                      ) : (
                        <span class="text-xs text-ink/40 italic">Sin identificar</span>
                      )}
                    </td>
                    <td class="px-4 py-3">
                      <span class:list={[
                        'border px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider',
                        STATUS_COLORS[exp.status] ?? 'bg-paper border-ink/20 text-ink',
                      ]}>
                        {STATUS_LABELS[exp.status] ?? exp.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-xs text-ink/50 whitespace-nowrap">
                      {fmtDate(exp.created_at)}
                    </td>
                    <td class="px-4 py-3">
                      <a href={`/admin/expedientes/${exp.id}`}
                         class="border border-ink/25 px-3 py-1 font-mono text-[11px] uppercase tracking-wider text-ink hover:border-magenta hover:text-magenta transition-colors">
                        Ver →
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Paginación -->
          {totalPages > 1 && (
            <div class="flex items-center justify-between border-t border-ink/15 px-4 py-3">
              <span class="font-mono text-xs text-ink/50">Página {page + 1} de {totalPages}</span>
              <div class="flex gap-2">
                {page > 0 && (
                  <a href={`?${statusFilter ? `status=${statusFilter}&` : ''}page=${page - 1}`}
                     class="border border-ink/25 px-3 py-1 font-mono text-xs hover:border-magenta hover:text-magenta">
                    ← Anterior
                  </a>
                )}
                {page < totalPages - 1 && (
                  <a href={`?${statusFilter ? `status=${statusFilter}&` : ''}page=${page + 1}`}
                     class="border border-ink/25 px-3 py-1 font-mono text-xs hover:border-magenta hover:text-magenta">
                    Siguiente →
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
      )}

    </div>
  </div>
</Base>
