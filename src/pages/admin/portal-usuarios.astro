---
/**
 * /admin/portal-usuarios — Lista de usuarios registrados en el portal.
 * Auth: cookie startidea_admin
 */
import Base from '@/layouts/Base.astro';
import { isAdminLoggedIn } from '@/lib/admin-session';
import { listPortalUsers, getExpedientesByEmail } from '@/lib/expedientes-db';

export const prerender = false;

if (!isAdminLoggedIn(Astro.cookies)) {
  return Astro.redirect(`/admin/login?next=${encodeURIComponent('/admin/portal-usuarios')}`);
}

const usuarios = listPortalUsers(200);

function fmtDate(ts: number): string {
  return new Date(ts * 1000).toLocaleDateString('es-ES', {
    day: '2-digit', month: 'short', year: 'numeric',
  });
}
---

<Base title="Usuarios del portal · Admin · Startidea" description="">
  <div class="bg-paper-warm min-h-screen">
    <div class="container-x py-10">

      <div class="mb-8 flex items-start justify-between gap-4">
        <div>
          <a href="/admin" class="font-mono text-[11px] uppercase tracking-widest text-ink/75 hover:text-magenta">← Admin</a>
          <h1 class="mt-2 font-display text-3xl text-ink">Portal — Usuarios registrados</h1>
          <p class="mt-1 text-sm text-ink/75">{usuarios.length} cuenta{usuarios.length !== 1 ? 's' : ''} activa{usuarios.length !== 1 ? 's' : ''}</p>
        </div>
        <a href="/portal" target="_blank"
           class="btn text-sm">
          Ver portal ↗
        </a>
      </div>

      {usuarios.length === 0 ? (
        <div class="border border-ink/15 bg-paper p-16 text-center">
          <p class="text-ink/75">Aún no hay usuarios registrados en el portal.</p>
          <p class="mt-2 text-sm text-ink/75">Se registrarán en <strong>startidea.es/portal/registro</strong></p>
        </div>
      ) : (
        <div class="border border-ink/15 bg-paper overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-ink/15 bg-paper-warm">
                <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/75">Organización</th>
                <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/75">Representante</th>
                <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/75">Email</th>
                <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/75">Tipo</th>
                <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/75">Provincia</th>
                <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/75">Exped.</th>
                <th class="px-4 py-3 text-left font-mono text-[10px] uppercase tracking-widest text-ink/75">Alta</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-ink/8">
              {usuarios.map((u) => {
                const exps = getExpedientesByEmail(u.email);
                return (
                  <tr class="hover:bg-paper-warm/50 transition-colors">
                    <td class="px-4 py-3 max-w-[200px]">
                      <p class="font-medium text-ink truncate">{u.org_nombre}</p>
                      {u.org_cif && <p class="font-mono text-[10px] text-ink/75">{u.org_cif}</p>}
                    </td>
                    <td class="px-4 py-3 text-ink/80">{u.nombre}</td>
                    <td class="px-4 py-3">
                      <a href={`mailto:${u.email}`} class="text-magenta hover:underline text-xs">
                        {u.email}
                      </a>
                    </td>
                    <td class="px-4 py-3 text-xs text-ink/75">{u.org_tipo || '—'}</td>
                    <td class="px-4 py-3 text-xs text-ink/75">{u.provincia || '—'}</td>
                    <td class="px-4 py-3 text-center">
                      {exps.length > 0 ? (
                        <a href={`/admin/expedientes?email=${encodeURIComponent(u.email)}`}
                           class="font-mono text-[11px] text-magenta font-bold hover:underline">
                          {exps.length}
                        </a>
                      ) : (
                        <span class="font-mono text-[11px] text-ink/30">0</span>
                      )}
                    </td>
                    <td class="px-4 py-3 text-xs text-ink/75 whitespace-nowrap">
                      {fmtDate(u.created_at)}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}

    </div>
  </div>
</Base>
