---
/**
 * /admin/convocatorias-stats
 *
 * Panel privado de estadísticas de consultas a convocatorias.
 * 4 fuentes: widget eligibilidad · expedientes por conv · copiloto por conv · GA4/GSC (link)
 */
import { isAdminLoggedIn } from '../../../lib/admin-session';
import {
  statsEligibilidad,
  statsExpedientesByConv,
  statsCopilotoByConv,
} from '../../../lib/expedientes-db';

export const prerender = false;

if (!isAdminLoggedIn(Astro.cookies)) {
  return Astro.redirect('/admin/login?next=/admin/convocatorias-stats', 302);
}

const eleg   = statsEligibilidad();
const byConv = statsExpedientesByConv();
const byBot  = statsCopilotoByConv();

// Título de línea BOJA (id → etiqueta corta)
const LINE_LABELS: Record<string, string> = {
  L1:  'Personas mayores (individual)',
  L2:  'Discapacidad (individual)',
  L3:  'Investigación SSSS',
  L4:  'Comunidad Gitana',
  L5:  'Discapacidad (institucional)',
  L6:  'Personas inmigrantes',
  L7:  'Solidaridad Alimentaria',
  L8:  'LGTBI',
  L9:  'Participación ciudadana',
  L10: 'Mantenimiento entidades',
  L11: 'Programas acción social',
  L12: 'Voluntariado',
  L13: 'Mayores en universidades',
  L14: 'Mayores (institucional)',
  L16: 'Mujeres ex-tuteladas',
};

const BENEF_LABELS: Record<string, string> = {
  privada:       'Entidad privada sin ánimo de lucro',
  local:         'Entidad local (ayuntamiento, mancomunidad…)',
  institucional: 'Entidad institucional / representativa',
  persona:       'Persona física',
  empresa:       'Empresa mercantil',
  '':            'No detectado',
};

// Formatear fecha relativa
function relDate(ts: number): string {
  const d = new Date(ts * 1000);
  return d.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
}

// Porcentaje
function pct(n: number, total: number): string {
  if (!total) return '0%';
  return `${Math.round((n / total) * 100)}%`;
}

// Datos para mini gráfica de actividad del widget (últimos 30 días)
const diagrama = eleg.porDia;
const maxDia   = Math.max(...diagrama.map(d => d.n), 1);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Estadísticas convocatorias — Admin Startidea</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: system-ui, sans-serif; background: #f8f8f8; }
    .bar-cell { display: inline-block; width: 100%; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">

<!-- Topbar -->
<header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center gap-4 sticky top-0 z-10">
  <a href="/admin" class="text-sm text-gray-500 hover:text-gray-800">← Admin</a>
  <span class="text-gray-300">|</span>
  <h1 class="font-semibold text-gray-900 text-base">📊 Estadísticas — Convocatorias</h1>
  <div class="ml-auto flex gap-3">
    <a href="https://hub.startidea.tech/startidea/admin/seo" target="_blank" rel="noopener"
       class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-violet-600 text-white text-xs font-medium hover:bg-violet-700">
      Ver GA4 + GSC →
    </a>
  </div>
</header>

<main class="max-w-6xl mx-auto px-4 py-8 space-y-10">

  <!-- ───── 1. Widget eligibilidad ──────────────────────────────────────── -->
  <section>
    <h2 class="text-lg font-bold text-gray-900 mb-4">
      🔍 Widget de elegibilidad BOJA 2026
    </h2>

    {eleg.total === 0 ? (
      <div class="bg-white rounded-xl border border-dashed border-gray-300 p-8 text-center text-gray-400">
        <p class="text-3xl mb-2">🌱</p>
        <p class="font-medium">Aún no hay consultas registradas</p>
        <p class="text-sm mt-1">El logging empieza desde ahora — los datos aparecerán en cuanto alguien use el widget.</p>
      </div>
    ) : (
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <p class="text-3xl font-bold text-gray-900">{eleg.total}</p>
          <p class="text-xs text-gray-500 mt-1">Consultas totales</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <p class="text-3xl font-bold text-green-600">{eleg.aplica}</p>
          <p class="text-xs text-gray-500 mt-1">Con líneas aplicables</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <p class="text-3xl font-bold text-red-500">{eleg.noAplica}</p>
          <p class="text-xs text-gray-500 mt-1">Sin encaje BOJA</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <p class="text-3xl font-bold text-violet-600">{pct(eleg.aplica, eleg.total)}</p>
          <p class="text-xs text-gray-500 mt-1">Tasa de elegibilidad</p>
        </div>
      </div>
    )}

    {eleg.total > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

        <!-- Por tipo de entidad -->
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Por tipo de entidad</h3>
          <ul class="space-y-2">
            {eleg.porBeneficiario.map(row => (
              <li class="flex items-center gap-2">
                <div class="flex-1 min-w-0">
                  <div class="flex justify-between text-xs mb-0.5">
                    <span class="text-gray-700 truncate" title={BENEF_LABELS[row.beneficiario] ?? row.beneficiario}>
                      {BENEF_LABELS[row.beneficiario] ?? row.beneficiario}
                    </span>
                    <span class="font-medium text-gray-900 ml-2">{row.n}</span>
                  </div>
                  <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full bg-blue-500 rounded-full"
                         style={`width:${pct(row.n, eleg.total)}`}></div>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Líneas más consultadas -->
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Líneas más aplicables</h3>
          {eleg.porLinea.length === 0 ? (
            <p class="text-xs text-gray-400 italic">Sin datos aún</p>
          ) : (
            <ul class="space-y-2">
              {eleg.porLinea.slice(0, 8).map(row => (
                <li class="flex items-center gap-2">
                  <span class="inline-block w-8 text-center text-xs font-bold bg-green-100 text-green-700 rounded px-1 py-0.5 shrink-0">
                    {row.linea}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="flex justify-between text-xs mb-0.5">
                      <span class="text-gray-700 truncate">{LINE_LABELS[row.linea] ?? row.linea}</span>
                      <span class="font-medium text-gray-900 ml-2">{row.n}</span>
                    </div>
                    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full bg-green-500 rounded-full"
                           style={`width:${pct(row.n, eleg.aplica || 1)}`}></div>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- Actividad últimos 30 días -->
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Actividad — últimos 30 días</h3>
          {diagrama.length === 0 ? (
            <p class="text-xs text-gray-400 italic">Sin actividad reciente</p>
          ) : (
            <div class="flex items-end gap-0.5 h-20">
              {diagrama.map(d => (
                <div
                  title={`${d.dia}: ${d.n} consulta${d.n !== 1 ? 's' : ''}`}
                  class="flex-1 bg-violet-400 rounded-t hover:bg-violet-600 transition-colors cursor-default"
                  style={`height:${Math.round((d.n / maxDia) * 100)}%`}
                ></div>
              ))}
            </div>
          )}
          <p class="text-xs text-gray-400 mt-2 text-center">
            {diagrama.length > 0
              ? `${diagrama[0].dia} → ${diagrama[diagrama.length - 1].dia}`
              : 'Sin datos'}
          </p>
        </div>

      </div>
    )}
  </section>

  <!-- ───── 2. Expedientes por convocatoria ─────────────────────────────── -->
  <section>
    <h2 class="text-lg font-bold text-gray-900 mb-4">
      📋 Expedientes por convocatoria
    </h2>

    {byConv.length === 0 ? (
      <div class="bg-white rounded-xl border border-dashed border-gray-300 p-6 text-center text-gray-400 text-sm">
        No hay expedientes registrados aún.
      </div>
    ) : (
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50 text-xs text-gray-500 font-semibold uppercase tracking-wide">
              <th class="text-left px-4 py-3">Convocatoria</th>
              <th class="text-center px-3 py-3">Total</th>
              <th class="text-center px-3 py-3">En proceso</th>
              <th class="text-center px-3 py-3">Entregados</th>
              <th class="text-center px-3 py-3">Presentados</th>
              <th class="text-center px-3 py-3">Rechazados</th>
              <th class="text-center px-3 py-3">Primer exp.</th>
              <th class="text-center px-3 py-3">Último exp.</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {byConv.map(row => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-medium text-gray-900 max-w-xs">
                  <div class="truncate" title={row.convocatoria_title}>{row.convocatoria_title}</div>
                  {row.convocatoria_slug && (
                    <div class="text-xs text-gray-400 truncate">{row.convocatoria_slug}</div>
                  )}
                </td>
                <td class="px-3 py-3 text-center">
                  <span class="inline-block min-w-[1.5rem] px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 font-bold text-xs">
                    {row.n_expedientes}
                  </span>
                </td>
                <td class="px-3 py-3 text-center text-gray-600">{row.n_recibidos || '—'}</td>
                <td class="px-3 py-3 text-center text-gray-600">{row.n_entregados || '—'}</td>
                <td class="px-3 py-3 text-center">
                  {row.n_presentados > 0
                    ? <span class="text-green-600 font-semibold">{row.n_presentados}</span>
                    : <span class="text-gray-300">—</span>
                  }
                </td>
                <td class="px-3 py-3 text-center">
                  {row.n_rechazados > 0
                    ? <span class="text-red-500">{row.n_rechazados}</span>
                    : <span class="text-gray-300">—</span>
                  }
                </td>
                <td class="px-3 py-3 text-center text-xs text-gray-400">{relDate(row.first_at)}</td>
                <td class="px-3 py-3 text-center text-xs text-gray-400">{relDate(row.last_at)}</td>
              </tr>
            ))}
          </tbody>
          <tfoot class="border-t border-gray-200 bg-gray-50">
            <tr>
              <td class="px-4 py-2 text-xs text-gray-500 font-semibold">
                {byConv.length} convocatoria{byConv.length !== 1 ? 's' : ''} ·
                {byConv.reduce((s, r) => s + r.n_expedientes, 0)} expediente{byConv.reduce((s, r) => s + r.n_expedientes, 0) !== 1 ? 's' : ''} en total
              </td>
              <td colspan="7"></td>
            </tr>
          </tfoot>
        </table>
      </div>
    )}
  </section>

  <!-- ───── 3. Copiloto autónomo por convocatoria ───────────────────────── -->
  <section>
    <h2 class="text-lg font-bold text-gray-900 mb-4">
      🤖 Copiloto autónomo por convocatoria
    </h2>

    {byBot.length === 0 ? (
      <div class="bg-white rounded-xl border border-dashed border-gray-300 p-6 text-center text-gray-400 text-sm">
        El copiloto aún no ha procesado ninguna convocatoria.
      </div>
    ) : (
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50 text-xs text-gray-500 font-semibold uppercase tracking-wide">
              <th class="text-left px-4 py-3">Convocatoria</th>
              <th class="text-center px-3 py-3">Perfiles notificados</th>
              <th class="text-center px-3 py-3">Docs enviados</th>
              <th class="text-center px-3 py-3">Errores</th>
              <th class="text-center px-3 py-3">Tasa envío</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {byBot.map(row => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-medium text-gray-900 max-w-xs">
                  <div class="truncate" title={row.convocatoria_title}>{row.convocatoria_title}</div>
                  <div class="text-xs text-gray-400 truncate">{row.convocatoria_slug}</div>
                </td>
                <td class="px-3 py-3 text-center">
                  <span class="inline-block min-w-[1.5rem] px-2 py-0.5 rounded-full bg-gray-100 text-gray-700 font-bold text-xs">
                    {row.n_profiles}
                  </span>
                </td>
                <td class="px-3 py-3 text-center">
                  <span class="text-green-600 font-semibold">{row.n_sent}</span>
                </td>
                <td class="px-3 py-3 text-center">
                  {row.n_error > 0
                    ? <span class="text-red-500">{row.n_error}</span>
                    : <span class="text-gray-300">0</span>
                  }
                </td>
                <td class="px-3 py-3 text-center text-xs text-gray-600">
                  {pct(row.n_sent, row.n_profiles)}
                </td>
              </tr>
            ))}
          </tbody>
          <tfoot class="border-t border-gray-200 bg-gray-50">
            <tr>
              <td class="px-4 py-2 text-xs text-gray-500 font-semibold">
                {byBot.length} convocatoria{byBot.length !== 1 ? 's' : ''} ·
                {byBot.reduce((s, r) => s + r.n_profiles, 0)} perfiles procesados ·
                {byBot.reduce((s, r) => s + r.n_sent, 0)} emails enviados
              </td>
              <td colspan="4"></td>
            </tr>
          </tfoot>
        </table>
      </div>
    )}
  </section>

  <!-- ───── 4. GA4 + GSC ───────────────────────────────────────────────── -->
  <section>
    <h2 class="text-lg font-bold text-gray-900 mb-4">
      📈 Tráfico orgánico — GA4 + Google Search Console
    </h2>
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <p class="text-sm text-gray-700">
            Los datos de visitas y búsquedas orgánicas de las páginas
            <code class="bg-gray-100 px-1 rounded text-xs">/subvenciones/*</code> están
            sincronizados en el Hub (GA4 + GSC diario 06:00 UTC, analista IA lunes 07:00 UTC).
          </p>
          <p class="text-xs text-gray-400 mt-2">
            Incluye: keywords por página · impresiones · CTR · posición media · variaciones semana a semana.
          </p>
        </div>
        <div class="flex flex-col gap-2 shrink-0">
          <a href="https://hub.startidea.tech/startidea/admin/seo" target="_blank" rel="noopener"
             class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-violet-600 text-white text-sm font-medium hover:bg-violet-700">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Abrir Hub SEO
          </a>
          <a href="https://analytics.google.com" target="_blank" rel="noopener"
             class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-lg border border-gray-300 text-gray-700 text-sm font-medium hover:bg-gray-50">
            Google Analytics
          </a>
        </div>
      </div>

      <!-- Filtros sugeridos para GSC -->
      <div class="mt-5 border-t border-gray-100 pt-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Filtros rápidos en GSC</p>
        <div class="flex flex-wrap gap-2">
          {[
            'boja 2026', 'subvenciones andalucía', 'línea 10', 'línea 11',
            'mantenimiento entidades', 'programas acción social', 'junta andalucía asociaciones',
          ].map(q => (
            <span class="inline-block bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">{q}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

</main>
</body>
</html>
