---
export const prerender = false;
import Base from '@/layouts/Base.astro';
import { isAdmin } from '@/lib/seo/auth';
import { getDb } from '@/lib/seo/db';

const url = Astro.url;
const tokenParam = url.searchParams.get('token') || '';
const cookieToken = Astro.cookies.get('startidea_admin')?.value || '';
const expected = process.env.ADMIN_TOKEN || '';
const authed = !!expected && (tokenParam === expected || cookieToken === expected);

if (authed && tokenParam) {
  Astro.cookies.set('startidea_admin', tokenParam, {
    path: '/', httpOnly: true, sameSite: 'strict', secure: true, maxAge: 60 * 60 * 8,
  });
}

const KIND_LABEL: Record<string, string> = {
  p4_20: 'Posición 4-20',
  low_ctr: 'CTR bajo',
  traffic_drop: 'Caída de tráfico',
  growing_imp: 'Impresiones crecientes',
  cannibalization: 'Canibalización',
  low_conv: 'Baja conversión',
  high_conv_low_traffic: 'Alta conv, poco tráfico',
  content_gap: 'Hueco de contenido',
  title_meta: 'Title/meta',
  internal_linking: 'Enlazado interno',
};

let opportunities: any[] = [];
let lastRun: any = null;
let connections: any[] = [];
let totalsByKind: Array<{ kind: string; n: number }> = [];
let agentOutputs: any[] = [];
let dbError: string | null = null;

if (authed) {
  try {
    const db = getDb();
    opportunities = db.prepare(`
      SELECT id, priority, kind, url, keyword, metric_summary, recommendation, detected_at
      FROM seo_opportunities
      WHERE resolved_at IS NULL
      ORDER BY priority ASC, detected_at DESC
      LIMIT 200
    `).all();
    lastRun = db.prepare(`
      SELECT id, started_at, finished_at, status, ga4_rows_synced,
             gsc_query_rows_synced, gsc_page_rows_synced, opportunities_created, error_message
      FROM seo_agent_runs
      ORDER BY id DESC LIMIT 1
    `).get();
    connections = db.prepare(`
      SELECT id, google_account_email, updated_at FROM google_connections WHERE revoked_at IS NULL
    `).all();
    totalsByKind = db.prepare(`
      SELECT kind, COUNT(*) AS n FROM seo_opportunities WHERE resolved_at IS NULL
      GROUP BY kind ORDER BY n DESC
    `).all();
    agentOutputs = db.prepare(`
      SELECT id, kind, started_at, finished_at, status, input_summary, cost_usd, tokens_used
      FROM seo_agent_outputs
      ORDER BY started_at DESC LIMIT 15
    `).all();
  } catch (err) {
    dbError = (err as Error).message;
  }
}

const fmt = (ts: number | null) =>
  ts ? new Intl.DateTimeFormat('es-ES', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(ts * 1000)) : '—';

const PRIORITY_LABEL = ['', '1 · Alta', '2 · Media-alta', '3 · Media', '4 · Baja', '5 · Mínima'];
const noTokenConfigured = !expected;
---

<Base title="Admin · SEO · Startidea" description="" ogSlug="page/404">
  <section class="bg-paper py-12 md:py-16">
    <div class="container-x">
      <span class="label">— Admin · SEO</span>
      <h1 class="mt-4 font-display text-display-md leading-tight text-ink">
        Oportunidades <em class="italic text-magenta">SEO</em>.
      </h1>

      {noTokenConfigured && (
        <div class="mt-10 border-2 border-magenta bg-paper-warm p-6">
          <p class="font-display text-xl text-magenta">⚠ Falta <code class="font-mono">ADMIN_TOKEN</code> en Coolify.</p>
        </div>
      )}

      {!authed && !noTokenConfigured && (
        <form method="get" class="mt-10 max-w-md space-y-3">
          <p class="label">— Acceso</p>
          <input name="token" type="password" required placeholder="Token admin"
            class="w-full border border-ink bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40" />
          <button type="submit" class="btn">Entrar <span aria-hidden="true">→</span></button>
        </form>
      )}

      {authed && (
        <>
          {dbError && (
            <div class="mt-8 border-2 border-magenta bg-paper-warm p-5">
              <p class="font-display text-lg text-magenta">⚠ Error de DB</p>
              <pre class="mt-2 text-xs">{dbError}</pre>
            </div>
          )}

          <!-- Status barra superior -->
          <div class="mt-10 grid grid-cols-12 gap-x-6 gap-y-4 border-y border-ink/15 py-6">
            <div class="col-span-12 md:col-span-3">
              <span class="label">— Cuentas Google</span>
              <p class="mt-2 font-display text-2xl text-ink">{connections.length}</p>
              <a href="/admin/google/status" class="font-mono text-[11px] uppercase tracking-widest text-ink-mute hover:text-magenta">
                Gestionar →
              </a>
            </div>
            <div class="col-span-12 md:col-span-4">
              <span class="label">— Última sincronización</span>
              <p class="mt-2 font-display text-base text-ink">
                {lastRun ? fmt(lastRun.finished_at || lastRun.started_at) : 'nunca'}
              </p>
              {lastRun && (
                <p class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">
                  Estado: <span class={lastRun.status === 'success' ? 'text-ink' : 'text-magenta'}>{lastRun.status}</span>
                  {lastRun.status === 'success' && (
                    <> · {lastRun.ga4_rows_synced} GA4 · {lastRun.gsc_query_rows_synced + lastRun.gsc_page_rows_synced} GSC</>
                  )}
                </p>
              )}
            </div>
            <div class="col-span-12 md:col-span-5 flex items-end justify-end gap-3">
              <form method="POST" action="/admin/seo/sync">
                <button type="submit" class="btn !py-2.5 text-sm">
                  Sincronizar ahora
                  <span aria-hidden="true">→</span>
                </button>
              </form>
              <a href="/admin/seo/report" class="btn-ghost !py-2.5 text-sm">
                Exportar CSV
                <span aria-hidden="true">↓</span>
              </a>
            </div>
          </div>

          {lastRun?.status === 'failed' && lastRun.error_message && (
            <div class="mt-6 border-2 border-magenta bg-paper-warm p-5">
              <p class="font-display text-lg text-magenta">⚠ La última sincronización falló</p>
              <pre class="mt-2 text-xs whitespace-pre-wrap">{lastRun.error_message}</pre>
            </div>
          )}

          <!-- Resumen por tipo -->
          {totalsByKind.length > 0 && (
            <div class="mt-10 flex flex-wrap gap-2">
              {totalsByKind.map((t) => (
                <span class="border border-ink/30 px-3 py-1 font-mono text-[11px] uppercase tracking-widest text-ink/75">
                  {KIND_LABEL[t.kind] || t.kind}: <strong class="text-ink">{t.n}</strong>
                </span>
              ))}
            </div>
          )}

          <!-- Tabla de oportunidades -->
          <div class="mt-10">
            {opportunities.length === 0 ? (
              <div class="border-t border-ink/15 pt-10">
                <p class="font-display text-2xl text-ink/60">
                  Aún no hay oportunidades. Conecta una cuenta Google y pulsa "Sincronizar ahora".
                </p>
              </div>
            ) : (
              <table class="w-full border-collapse text-sm">
                <thead>
                  <tr class="border-y-2 border-ink/15 text-left">
                    <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">P</th>
                    <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Tipo</th>
                    <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">URL / Keyword</th>
                    <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Métricas</th>
                    <th class="py-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Recomendación</th>
                  </tr>
                </thead>
                <tbody>
                  {opportunities.map((o) => {
                    const m = (() => { try { return JSON.parse(o.metric_summary); } catch { return {}; } })();
                    return (
                      <tr class="border-b border-ink/10 align-top">
                        <td class="py-4 pr-3 font-mono text-xs">
                          <span class={`inline-block border px-1.5 ${o.priority === 1 ? 'border-magenta text-magenta' : 'border-ink/40 text-ink/70'}`}>
                            {o.priority}
                          </span>
                        </td>
                        <td class="py-4 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
                          {KIND_LABEL[o.kind] || o.kind}
                        </td>
                        <td class="py-4 pr-3">
                          {o.url && <p class="font-mono text-xs text-ink/85 break-all">{o.url}</p>}
                          {o.keyword && <p class="font-display text-base text-ink">{o.keyword}</p>}
                        </td>
                        <td class="py-4 pr-3 font-mono text-[11px] text-ink/70">
                          {Object.entries(m).slice(0, 4).map(([k, v]) => (
                            <p>{k}: <strong class="text-ink">{Array.isArray(v) ? v.join(', ').slice(0, 80) : String(v)}</strong></p>
                          ))}
                        </td>
                        <td class="py-4 text-sm text-ink/85">{o.recommendation}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            )}
          </div>

          <!-- Sección Agentes IA -->
          <div class="mt-16 border-t border-ink/15 pt-10">
            <span class="label">— Agentes IA</span>
            <h2 class="mt-3 font-display text-display-md leading-tight text-ink">
              Plan semanal & redacción <em class="italic text-magenta">automatizadas</em>.
            </h2>

            <div class="mt-8 grid gap-8 md:grid-cols-2">
              <!-- Agente A: Analista -->
              <div class="border-2 border-ink p-6">
                <p class="label">— Agente A</p>
                <h3 class="mt-2 font-display text-2xl text-ink">Analista semanal</h3>
                <p class="mt-3 text-sm text-ink/75">Lee las oportunidades y devuelve un plan accionable de la semana con top 5 acciones priorizadas y KPIs a vigilar. Notifica a Telegram.</p>
                <button
                  type="button"
                  id="run-analyst"
                  class="btn mt-5 !py-2.5 text-sm"
                >
                  Generar plan ahora
                  <span aria-hidden="true">→</span>
                </button>
                <p id="analyst-status" class="mt-3 min-h-[20px] font-mono text-[11px] uppercase tracking-widest text-ink-mute"></p>
              </div>

              <!-- Agente B: Redactor -->
              <div class="border-2 border-ink p-6">
                <p class="label">— Agente B</p>
                <h3 class="mt-2 font-display text-2xl text-ink">Redactor de notas</h3>
                <p class="mt-3 text-sm text-ink/75">Genera un draft de nota editorial en <code class="font-mono text-xs">src/content/notas/draft-*.md</code>. Tú revisas, editas, publicas (quitas <code class="font-mono text-xs">draft: true</code>).</p>
                <form id="writer-form" class="mt-5 space-y-3">
                  <input
                    name="keyword"
                    type="text"
                    placeholder="Keyword (vacío = auto-pick)"
                    class="w-full border border-ink bg-paper px-3 py-2 font-mono text-sm placeholder:text-ink/40 focus:border-magenta focus:outline-none"
                  />
                  <select
                    name="audience"
                    class="w-full border border-ink bg-paper px-3 py-2 font-mono text-sm text-ink focus:border-magenta focus:outline-none"
                  >
                    <option value="Todas">Audiencia: Todas</option>
                    <option value="Tercer sector">Tercer sector</option>
                    <option value="Instituciones">Instituciones</option>
                    <option value="Empresas con propósito">Empresas con propósito</option>
                  </select>
                  <textarea
                    name="notes"
                    rows="2"
                    placeholder="Notas para el redactor (opcional)"
                    class="w-full border border-ink bg-paper px-3 py-2 font-mono text-xs text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none"
                  ></textarea>
                  <button type="submit" class="btn !py-2.5 text-sm">
                    Generar draft
                    <span aria-hidden="true">→</span>
                  </button>
                  <p id="writer-status" class="min-h-[20px] font-mono text-[11px] uppercase tracking-widest text-ink-mute"></p>
                </form>
              </div>
            </div>

            <!-- Historial agentes -->
            {agentOutputs.length > 0 && (
              <div class="mt-10">
                <h3 class="font-display text-xl text-ink">Historial</h3>
                <table class="mt-4 w-full border-collapse text-sm">
                  <thead>
                    <tr class="border-y-2 border-ink/15 text-left">
                      <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Cuándo</th>
                      <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Agente</th>
                      <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Input</th>
                      <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Estado</th>
                      <th class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Coste</th>
                      <th class="py-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">Ver</th>
                    </tr>
                  </thead>
                  <tbody>
                    {agentOutputs.map((o: any) => (
                      <tr class="border-b border-ink/10 align-top">
                        <td class="py-3 pr-3 font-mono text-xs text-ink/75">{fmt(o.started_at)}</td>
                        <td class="py-3 pr-3 font-mono text-[11px] uppercase tracking-widest">
                          {o.kind === 'analyst' ? 'Analista' : 'Redactor'}
                        </td>
                        <td class="py-3 pr-3 text-sm text-ink/85">{o.input_summary}</td>
                        <td class="py-3 pr-3 font-mono text-[11px] uppercase">
                          <span class={o.status === 'success' ? 'text-ink' : o.status === 'failed' ? 'text-magenta' : 'text-ink-mute'}>{o.status}</span>
                        </td>
                        <td class="py-3 pr-3 font-mono text-[11px] text-ink/70">{o.cost_usd != null ? `$${o.cost_usd.toFixed(4)}` : '—'}</td>
                        <td class="py-3"><a href={`/admin/seo/agente/${o.id}`} class="link-underline text-sm">Ver →</a></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>

          <div class="mt-12 border-t border-ink/15 pt-6 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
            <p>Top 200 oportunidades · ordenadas por prioridad</p>
            <p class="mt-1">Endpoints: <code>/admin/seo/sync</code> · <code>/admin/seo/report?kind=...</code> · <code>/admin/seo/agent-analyst</code> · <code>/admin/seo/agent-writer</code></p>
          </div>
        </>
      )}
    </div>
  </section>

  <script is:inline define:vars={{ tokenParam: tokenParam || '' }}>
    (function () {
      const $ = (id) => document.getElementById(id);
      const tokenSuffix = tokenParam ? `?token=${encodeURIComponent(tokenParam)}` : '';

      const analystBtn = $('run-analyst');
      const analystStatus = $('analyst-status');
      if (analystBtn) {
        analystBtn.addEventListener('click', async () => {
          analystBtn.setAttribute('disabled', 'true');
          analystStatus.textContent = 'Generando plan…';
          analystStatus.style.color = '';
          try {
            const r = await fetch('/admin/seo/agent-analyst' + tokenSuffix, {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ notifyTelegram: true }),
            });
            const j = await r.json().catch(() => ({}));
            if (r.ok && j.ok) {
              analystStatus.textContent = `OK — run #${j.runId} · ${j.topActionsCount} acciones · $${j.costUsd}`;
              setTimeout(() => { window.location.href = `/admin/seo/agente/${j.runId}${tokenSuffix}`; }, 800);
            } else {
              analystStatus.style.color = '#b42318';
              analystStatus.textContent = `Error: ${j.error || r.status}`;
              analystBtn.removeAttribute('disabled');
            }
          } catch (err) {
            analystStatus.style.color = '#b42318';
            analystStatus.textContent = `Sin conexión: ${err.message}`;
            analystBtn.removeAttribute('disabled');
          }
        });
      }

      const writerForm = $('writer-form');
      const writerStatus = $('writer-status');
      if (writerForm) {
        writerForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const submit = writerForm.querySelector('button[type=submit]');
          submit.setAttribute('disabled', 'true');
          writerStatus.style.color = '';
          writerStatus.textContent = 'Redactando draft…';
          const data = new FormData(writerForm);
          try {
            const r = await fetch('/admin/seo/agent-writer' + tokenSuffix, {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({
                keyword: (data.get('keyword') || '').toString().trim() || undefined,
                audience: (data.get('audience') || 'Todas').toString(),
                notes: (data.get('notes') || '').toString().trim() || undefined,
              }),
            });
            const j = await r.json().catch(() => ({}));
            if (r.ok && j.ok) {
              writerStatus.textContent = `OK — "${j.title}" (${j.words} palabras) · $${j.costUsd}`;
              setTimeout(() => { window.location.href = `/admin/seo/agente/${j.runId}${tokenSuffix}`; }, 1200);
            } else {
              writerStatus.style.color = '#b42318';
              writerStatus.textContent = `Error: ${j.error || r.status}`;
              submit.removeAttribute('disabled');
            }
          } catch (err) {
            writerStatus.style.color = '#b42318';
            writerStatus.textContent = `Sin conexión: ${err.message}`;
            submit.removeAttribute('disabled');
          }
        });
      }
    })();
  </script>
</Base>
