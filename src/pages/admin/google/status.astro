---
export const prerender = false;
import Base from '@/layouts/Base.astro';
import { listActiveConnections } from '@/lib/seo/GoogleOAuthService';
import { isAdmin } from '@/lib/seo/auth';

const url = Astro.url;
const tokenParam = url.searchParams.get('token') || '';
const cookieToken = Astro.cookies.get('startidea_admin')?.value || '';
const expected = process.env.ADMIN_TOKEN || '';
const authed = !!expected && (tokenParam === expected || cookieToken === expected);

if (authed && tokenParam) {
  Astro.cookies.set('startidea_admin', tokenParam, {
    path: '/', httpOnly: true, sameSite: 'strict', secure: true, maxAge: 60 * 60 * 8,
  });
}

const noTokenConfigured = !expected;
const ok = url.searchParams.get('ok') === '1';
const justConnectedEmail = url.searchParams.get('email') || '';

let connections: ReturnType<typeof listActiveConnections> = [];
let dbError: string | null = null;
if (authed) {
  try {
    connections = listActiveConnections();
  } catch (err) {
    dbError = (err as Error).message;
  }
}

const fmt = (ts: number) =>
  new Intl.DateTimeFormat('es-ES', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(ts * 1000));
---

<Base title="Admin · Conexión Google · Startidea" description="" ogSlug="page/404">
  <section class="bg-paper py-16 md:py-24">
    <div class="container-x">
      <p class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">
        <a href="/admin/seo" class="link-underline text-ink/70 hover:text-ink">← Admin SEO</a>
      </p>
      <span class="label mt-6 block">— Admin · Conexión Google</span>
      <h1 class="mt-4 font-display text-display-md leading-tight text-ink">
        Cuenta <em class="italic text-magenta">Google</em>.
      </h1>

      {noTokenConfigured && (
        <div class="mt-10 border-2 border-magenta bg-paper-warm p-6">
          <p class="font-display text-xl text-magenta">⚠ Falta <code class="font-mono">ADMIN_TOKEN</code> en Coolify.</p>
        </div>
      )}

      {!authed && !noTokenConfigured && (
        <form method="get" class="mt-10 max-w-md space-y-3">
          <p class="label">— Acceso</p>
          <input name="token" type="password" required placeholder="Token admin"
            class="w-full border border-ink bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40" />
          <button type="submit" class="btn">Entrar <span aria-hidden="true">→</span></button>
        </form>
      )}

      {authed && (
        <>
          {ok && (
            <div class="mt-8 border-2 border-magenta bg-paper-warm p-5">
              <p class="font-display text-lg text-ink">✅ Conectada la cuenta <strong>{justConnectedEmail}</strong>.</p>
            </div>
          )}
          {dbError && (
            <div class="mt-8 border-2 border-magenta bg-paper-warm p-5">
              <p class="font-display text-lg text-magenta">⚠ Error de DB</p>
              <pre class="mt-2 text-xs">{dbError}</pre>
            </div>
          )}

          <div class="mt-12 border-t border-ink/15 pt-8">
            {connections.length === 0 ? (
              <>
                <h2 class="font-display text-2xl text-ink">Sin cuentas conectadas</h2>
                <p class="mt-3 max-w-measure text-sm text-ink/75">
                  Conecta una cuenta de Google con permisos sobre las propiedades GA4 y Search Console que quieras leer. Solo lectura, scopes <code class="font-mono">analytics.readonly</code> y <code class="font-mono">webmasters.readonly</code>.
                </p>
                <div class="mt-6">
                  <a href="/admin/google/connect" class="btn">
                    Conectar cuenta Google
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </>
            ) : (
              <>
                <h2 class="font-display text-2xl text-ink">Cuentas conectadas</h2>
                <ul class="mt-6 divide-y divide-ink/10 border-y border-ink/10">
                  {connections.map((c) => (
                    <li class="grid grid-cols-12 gap-x-4 py-4">
                      <div class="col-span-12 md:col-span-7">
                        <p class="font-display text-lg text-ink">{c.google_account_email}</p>
                        <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink-mute">
                          Conectada {fmt(c.created_at)} · actualizada {fmt(c.updated_at)}
                        </p>
                      </div>
                      <div class="col-span-12 md:col-span-5 flex items-center justify-end gap-3">
                        <form method="POST" action="/admin/google/disconnect" class="inline">
                          <input type="hidden" name="connection_id" value={c.id} />
                          <button type="submit" class="font-mono text-[11px] uppercase tracking-widest text-magenta hover:text-ink"
                                  onclick="return confirm('¿Desconectar esta cuenta? Los tokens se revocan en Google.');">
                            Desconectar
                          </button>
                        </form>
                      </div>
                    </li>
                  ))}
                </ul>
                <div class="mt-8 flex flex-wrap gap-3">
                  <a href="/admin/google/connect" class="btn-ghost">
                    Conectar otra cuenta
                    <span aria-hidden="true">→</span>
                  </a>
                  <a href="/admin/seo/sync" class="btn">
                    Sincronizar ahora
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </>
            )}
          </div>

          <div class="mt-16 border-t border-ink/15 pt-6">
            <h3 class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">— Revocar acceso desde Google</h3>
            <p class="mt-3 max-w-measure text-sm text-ink/75">
              Para revocar todos los permisos manualmente: <a href="https://myaccount.google.com/permissions" target="_blank" rel="noopener" class="link-underline text-ink">myaccount.google.com/permissions</a> → busca "Startidea" → Quitar acceso. Después usa "Desconectar" arriba para limpiar la fila local.
            </p>
          </div>
        </>
      )}
    </div>
  </section>
</Base>
