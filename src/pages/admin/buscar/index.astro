---
import Base from '@/layouts/Base.astro';
import { isAdminLoggedIn } from '@/lib/admin-session';
import { listCRMContacts } from '@/lib/expedientes-db';
import { searchSolicitudes } from '@/lib/impulsa-db';

export const prerender = false;

if (!isAdminLoggedIn(Astro.cookies)) {
  return Astro.redirect('/admin/login?next=' + encodeURIComponent('/admin/buscar'));
}

const q = (Astro.url.searchParams.get('q') ?? '').trim();

let crm: ReturnType<typeof listCRMContacts>['items'] = [];
let impulsa: ReturnType<typeof searchSolicitudes> = [];
if (q.length >= 2) {
  try { crm = listCRMContacts({ q, limit: 30 }).items; } catch { /* sin tabla */ }
  try { impulsa = searchSolicitudes(q, 30); } catch { /* sin tabla */ }
}
const totalRes = crm.length + impulsa.length;
const fmt = (ms: number) => new Date(ms).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Base title="Admin · Buscador global" noindex={true}>
  <section class="bg-paper py-12">
    <div class="container-x">
      <a href="/admin" class="font-mono text-[11px] uppercase tracking-widest text-ink/40 hover:text-magenta">← Admin</a>
      <h1 class="mt-1 font-display text-3xl text-ink">Buscador global</h1>
      <p class="mt-2 text-sm text-ink/60">Cruza CRM (portal · copiloto · auto-copiloto · diagnósticos) y solicitudes de Startidea Impulsa por nombre, email o entidad.</p>

      <form method="get" action="/admin/buscar" class="mt-6 flex gap-3">
        <input type="search" name="q" value={q} placeholder="Nombre, email o entidad…" autofocus
               class="w-full border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none" />
        <button type="submit" class="btn">Buscar</button>
      </form>

      {q.length >= 2 && (
        <p class="mt-6 font-mono text-[11px] uppercase tracking-widest text-ink/50">{totalRes} resultado{totalRes !== 1 ? 's' : ''} para “{q}”</p>
      )}
      {q.length > 0 && q.length < 2 && (
        <p class="mt-6 text-sm text-ink/50">Escribe al menos 2 caracteres.</p>
      )}

      {crm.length > 0 && (
        <div class="mt-6">
          <h2 class="label">— CRM ({crm.length})</h2>
          <ul class="mt-3 divide-y divide-ink/10 border-y border-ink/10">
            {crm.map((c) => (
              <li>
                <a href={`/admin/crm/${encodeURIComponent(c.email)}`} class="flex flex-wrap items-center justify-between gap-2 py-3 hover:text-magenta">
                  <span>
                    <span class="font-display text-ink">{c.nombre || c.org_nombre || c.email}</span>
                    {c.org_nombre && c.nombre && <span class="text-ink/50"> · {c.org_nombre}</span>}
                    <span class="block font-mono text-xs text-ink/40">{c.email}{c.telefono ? ` · ${c.telefono}` : ''}</span>
                  </span>
                  <span class="font-mono text-[10px] uppercase tracking-widest text-ink/40">
                    {c.expedientes_count > 0 ? `${c.expedientes_count} exp.` : ''}{c.has_portal ? ' · portal' : ''}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {impulsa.length > 0 && (
        <div class="mt-8">
          <h2 class="label">— Startidea Impulsa ({impulsa.length})</h2>
          <ul class="mt-3 divide-y divide-ink/10 border-y border-ink/10">
            {impulsa.map((s) => (
              <li>
                <a href="/admin/impulsa" class="flex flex-wrap items-center justify-between gap-2 py-3 hover:text-magenta">
                  <span>
                    <span class="font-display text-ink">{s.org_nombre}</span>
                    <span class="text-ink/50"> · {s.org_tipo}</span>
                    <span class="block font-mono text-xs text-ink/40">{s.contacto_nombre} · {s.contacto_email}</span>
                  </span>
                  <span class="font-mono text-[10px] uppercase tracking-widest text-ink/40">{s.estado} · {fmt(s.created_at)}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {q.length >= 2 && totalRes === 0 && (
        <p class="mt-6 text-ink/60">Sin resultados. Prueba con parte del email o del nombre de la entidad.</p>
      )}
    </div>
  </section>
</Base>
