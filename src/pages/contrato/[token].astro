---
/**
 * /contrato/[token] — Página de aceptación del contrato por el cliente.
 *
 * Acceso público (cualquiera con el token puede verlo).
 * La aceptación queda registrada con timestamp + IP via POST /api/aceptar-contrato.
 */
import { getExpedienteByContratoToken } from '@/lib/expedientes-db';
import { STARTIDEA } from '@/lib/contrato-generator';

export const prerender = false;

const { token } = Astro.params;
const exp = token ? getExpedienteByContratoToken(token) : null;

if (!exp) {
  return new Response(null, { status: 404 });
}

const yaAceptado = !!exp.contrato_at;

function fmtDate(ts: number): string {
  return new Date(ts * 1000).toLocaleDateString('es-ES', {
    day: '2-digit', month: 'long', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

function esc(s: string): string {
  return s.replace(/[&<>"']/g, (c) =>
    ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!,
  );
}

const convNombre = exp.convocatoria_title ?? 'la convocatoria de subvención indicada en el expediente';
const fechaEnvio = exp.contrato_sent_at
  ? new Date(exp.contrato_sent_at * 1000).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })
  : new Date().toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' });
const comision = STARTIDEA.comisionPct;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Contrato de servicios · Exp. {exp.id} · Startidea</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Georgia, serif; font-size: 14px; line-height: 1.7; color: #1f1f22; background: #ffffff; }
    .wrap { max-width: 820px; margin: 0 auto; padding: 32px 24px 64px; }

    /* Banner de estado */
    .banner { display: flex; align-items: center; gap: 12px; padding: 14px 20px;
      border-radius: 0; margin-bottom: 32px; font-size: 14px; }
    .banner.ok { background: #ecfdf5; border: 1px solid #6ee7b7; color: #065f46; }
    .banner.pending { background: #fff7f8; border: 1px solid #fca5a5; color: #7f1d1d; }

    /* Cabecera */
    .logo { font-family: monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
      color: #888; margin-bottom: 20px; }
    .logo span { color: #e6356b; }
    h1 { font-size: 20px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
      text-align: center; margin-bottom: 4px; }
    h2.sub { font-size: 13px; font-weight: 400; text-align: center; color: #666; margin-bottom: 28px; }
    .ref { text-align: center; font-family: monospace; font-size: 12px; color: #999; margin-bottom: 36px; }

    /* Partes */
    .partes { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 28px 0; }
    .parte { border: 1px solid #ddd; padding: 16px 20px; background: #fff; }
    .parte-title { font-family: monospace; font-size: 10px; text-transform: uppercase;
      letter-spacing: 0.1em; color: #888; margin-bottom: 10px; }
    .parte dl { font-size: 13px; }
    .parte dt { color: #888; font-size: 12px; margin-top: 5px; }
    .parte dd { font-weight: 500; color: #1f1f22; }

    /* Cláusulas */
    h3.clausulas { font-size: 14px; letter-spacing: 0.06em; text-transform: uppercase;
      border-top: 2px solid #1f1f22; padding-top: 20px; margin: 28px 0 20px; }
    .clausula { margin-bottom: 20px; }
    .clausula-num { font-family: monospace; font-size: 11px; text-transform: uppercase;
      letter-spacing: 0.08em; font-weight: 700; color: #555; margin-bottom: 6px; }
    .clausula p { margin: 6px 0; font-size: 14px; }
    .highlight { background: #f9fafb; border-left: 3px solid #e6356b; padding: 10px 16px;
      margin: 10px 0; font-weight: 600; font-size: 14px; }
    ul.lista { padding-left: 20px; margin: 8px 0; }
    ul.lista li { margin: 4px 0; }

    /* CTA aceptación */
    .cta-box { background: #fff; border: 2px solid #e6356b; padding: 28px 24px; margin: 36px 0;
      text-align: center; }
    .cta-box h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .cta-box p { font-size: 13px; color: #666; margin-bottom: 20px; }
    #btn-aceptar { display: inline-block; background: #e6356b; color: #fff; border: none;
      padding: 14px 40px; font-family: monospace; font-size: 13px; font-weight: 700;
      letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; }
    #btn-aceptar:disabled { background: #ccc; cursor: not-allowed; }
    .legal-note { font-size: 11px; color: #aaa; margin-top: 12px; font-style: italic; }
    #acepta-msg { margin-top: 14px; font-size: 14px; display: none; }

    /* Pie */
    .pie { margin-top: 48px; border-top: 1px solid #ddd; padding-top: 16px;
      font-size: 11px; color: #aaa; text-align: center; }

    @media (max-width: 640px) {
      .partes { grid-template-columns: 1fr; }
    }
    @media print {
      .cta-box, .banner.pending { display: none; }
      .wrap { padding: 16px; }
    }
  </style>
</head>
<body>
<div class="wrap">

  <div class="logo">— <span>Startidea</span> · Contrato de servicios</div>

  {yaAceptado ? (
    <div class="banner ok">
      ✅ <strong>Contrato aceptado</strong> — Fecha: {fmtDate(exp.contrato_at!)}
      {exp.contrato_ip && ` · IP: ${exp.contrato_ip}`}
    </div>
  ) : (
    <div class="banner pending">
      ⏳ Pendiente de aceptación — Lee el contrato completo y acepta al final de la página.
    </div>
  )}

  <h1>Contrato de Prestación de Servicios</h1>
  <h2 class="sub">Modalidad Comisión a Éxito</h2>
  <div class="ref">
    Expediente nº {exp.id} · {fechaEnvio}
  </div>

  <p style="font-size:14px;margin-bottom:8px">
    En Granada, a {fechaEnvio}, las partes que se identifican a continuación, reconociéndose mutuamente
    capacidad legal suficiente para contratar y obligarse, acuerdan suscribir el presente contrato de
    prestación de servicios, que se regirá por las siguientes cláusulas:
  </p>

  <h3 class="clausulas">Partes contratantes</h3>

  <div class="partes">
    <div class="parte">
      <div class="parte-title">Prestador de servicios</div>
      <dl>
        <dt>Razón social</dt><dd>{STARTIDEA.razonSocial}</dd>
        <dt>CIF</dt><dd>{STARTIDEA.cif}</dd>
        <dt>Domicilio</dt><dd>{STARTIDEA.domicilio}, {STARTIDEA.cp} {STARTIDEA.ciudad}</dd>
        <dt>Email</dt><dd>{STARTIDEA.email}</dd>
        <dt>Web</dt><dd>{STARTIDEA.web}</dd>
      </dl>
    </div>
    <div class="parte">
      <div class="parte-title">Cliente (Solicitante)</div>
      <dl>
        <dt>Denominación</dt><dd>{exp.org_nombre}</dd>
        <dt>CIF/NIF</dt><dd>{exp.org_cif}</dd>
        <dt>Tipo entidad</dt><dd>{exp.org_tipo || '—'}</dd>
        <dt>Representante</dt><dd>{exp.representante}</dd>
        <dt>Email</dt><dd>{exp.email}</dd>
        {exp.telefono && <><dt>Teléfono</dt><dd>{exp.telefono}</dd></>}
        <dt>Domicilio</dt><dd>{exp.provincia}</dd>
      </dl>
    </div>
  </div>

  <h3 class="clausulas">Estipulaciones</h3>

  <div class="clausula">
    <div class="clausula-num">Primera. — Objeto del contrato</div>
    <p>El PRESTADOR se compromete a prestar al CLIENTE los servicios de tramitación, redacción de documentación,
    asesoramiento y gestión de la solicitud de la siguiente ayuda pública:</p>
    <div class="highlight">Convocatoria: {convNombre}</div>
    <p>Los servicios comprenden, sin carácter limitativo: análisis de elegibilidad, redacción de la memoria técnica
    y presupuesto, elaboración del checklist documental, orientación en la presentación telemática y seguimiento
    del expediente hasta resolución definitiva.</p>
  </div>

  <div class="clausula">
    <div class="clausula-num">Segunda. — Honorarios y forma de pago</div>
    <p>Los honorarios del PRESTADOR se articulan exclusivamente como comisión a éxito, sin que el CLIENTE deba
    abonar cantidad alguna en caso de resolución desestimatoria:</p>
    <div class="highlight">
      Comisión: <strong>{comision}% ({comision} por ciento)</strong> sobre el importe neto concedido
      y <strong>efectivamente cobrado</strong> por el CLIENTE, sin incluir IVA.
    </div>
    <p>El devengo de los honorarios se producirá en el momento en que el CLIENTE reciba el importe concedido
    en su cuenta bancaria. El CLIENTE deberá abonar la factura correspondiente en un plazo máximo de
    <strong>treinta (30) días naturales</strong> desde dicha fecha.</p>
    <p>El CLIENTE se compromete a comunicar al PRESTADOR la resolución de concesión, el importe definitivo y la
    fecha de cobro, dentro de los cinco (5) días hábiles siguientes a cada uno de dichos hitos.</p>
  </div>

  <div class="clausula">
    <div class="clausula-num">Tercera. — Exclusividad y no competencia</div>
    <p>Durante la vigencia del presente contrato, el CLIENTE no podrá encargar a ningún otro prestador de
    servicios la tramitación de esta misma convocatoria. En caso de incumplimiento, el CLIENTE deberá abonar
    al PRESTADOR una indemnización equivalente al {comision}% del importe máximo de la convocatoria.</p>
  </div>

  <div class="clausula">
    <div class="clausula-num">Cuarta. — Obligaciones del cliente</div>
    <p>El CLIENTE se compromete a:</p>
    <ul class="lista">
      <li>Facilitar al PRESTADOR, en tiempo y forma, toda la documentación e información necesarias para la tramitación.</li>
      <li>Revisar y validar los documentos generados, completando los campos marcados con [COMPLETAR] con datos reales y verificables.</li>
      <li>No presentar la solicitud con datos erróneos o documentación falsa.</li>
      <li>Comunicar al PRESTADOR cualquier requerimiento de subsanación por parte del organismo convocante.</li>
      <li>Notificar la resolución y el cobro en los plazos indicados en la cláusula Segunda.</li>
    </ul>
  </div>

  <div class="clausula">
    <div class="clausula-num">Quinta. — Vigencia</div>
    <p>El presente contrato entra en vigor en la fecha de aceptación por parte del CLIENTE y mantendrá su
    vigencia hasta la resolución definitiva del procedimiento y, en caso de concesión, hasta el pago íntegro
    de los honorarios.</p>
  </div>

  <div class="clausula">
    <div class="clausula-num">Sexta. — Confidencialidad y protección de datos</div>
    <p>Ambas partes se comprometen a mantener la más estricta confidencialidad sobre la información intercambiada.
    El tratamiento de datos de carácter personal se realizará de conformidad con el Reglamento (UE) 2016/679 (RGPD)
    y la Ley Orgánica 3/2018 (LOPDGDD).</p>
  </div>

  <div class="clausula">
    <div class="clausula-num">Séptima. — Limitación de responsabilidad</div>
    <p>El PRESTADOR no garantiza la concesión de la subvención, que depende de la decisión del organismo convocante.
    En ningún caso el PRESTADOR responderá por resoluciones desfavorables debidas a causas ajenas a su actuación
    (cambios normativos sobrevenidos, modificación de las bases, insuficiencia presupuestaria, etc.).</p>
  </div>

  <div class="clausula">
    <div class="clausula-num">Octava. — Jurisdicción y ley aplicable</div>
    <p>El presente contrato se rige por la legislación española. Para cualquier controversia, ambas partes se
    someten expresamente a los Juzgados y Tribunales de la ciudad de <strong>Granada</strong>, con renuncia a
    cualquier otro fuero que pudiera corresponderles.</p>
  </div>

  <!-- CTA de aceptación -->
  {yaAceptado ? (
    <div class="cta-box" style="border-color:#6ee7b7;background:#ecfdf5">
      <h3 style="color:#065f46">✅ Contrato aceptado</h3>
      <p style="color:#047857">
        La aceptación quedó registrada el {fmtDate(exp.contrato_at!)}.<br>
        Puedes descargar o imprimir esta página como justificante.
      </p>
      <button onclick="window.print()"
        style="background:#1f1f22;color:#fff;border:none;padding:10px 24px;font-family:monospace;font-size:12px;cursor:pointer;letter-spacing:0.08em;text-transform:uppercase;margin-top:8px">
        🖨 Imprimir / Guardar PDF
      </button>
    </div>
  ) : (
    <div class="cta-box">
      <h3>Aceptación electrónica del contrato</h3>
      <p>
        He leído las cláusulas anteriores y acepto los términos del contrato de prestación de servicios
        con <strong>{STARTIDEA.razonSocial}</strong> (comisión {comision}% a éxito).
      </p>
      <button id="btn-aceptar" type="button">
        ✅ Acepto las condiciones del contrato
      </button>
      <div id="acepta-msg"></div>
      <p class="legal-note">
        Al hacer clic, quedará registrada tu aceptación con fecha, hora y dirección IP.<br>
        Validez jurídica conforme al Art. 23 LSSI y Art. 1262 CC (contratación electrónica).
      </p>
    </div>
  )}

  <div class="pie">
    {STARTIDEA.razonSocial} · CIF {STARTIDEA.cif} · {STARTIDEA.domicilio}, {STARTIDEA.cp} {STARTIDEA.ciudad}
    · <a href={STARTIDEA.web} style="color:#aaa">{STARTIDEA.web}</a>
  </div>

</div>

{!yaAceptado && (
  <script define:vars={{ token: token }}>
    document.getElementById('btn-aceptar')?.addEventListener('click', async function () {
      const btn = this;
      const msg = document.getElementById('acepta-msg');
      btn.disabled = true;
      btn.textContent = '⏳ Procesando...';
      if (msg) { msg.style.display = 'block'; msg.textContent = ''; }

      try {
        const res = await fetch('/api/aceptar-contrato', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ token }),
        });
        const j = await res.json();
        if (j.ok) {
          btn.textContent = '✅ ¡Contrato aceptado!';
          btn.style.background = '#16a34a';
          if (msg) {
            msg.style.color = '#065f46';
            msg.textContent = 'Tu aceptación ha quedado registrada. Puedes cerrar esta página o guardarla como PDF.';
          }
          setTimeout(() => window.location.reload(), 2500);
        } else {
          btn.disabled = false;
          btn.textContent = '✅ Acepto las condiciones del contrato';
          if (msg) { msg.style.color = '#dc2626'; msg.textContent = `Error: ${j.error ?? 'inténtalo de nuevo'}. Escríbenos a hola@startidea.es si el problema persiste.`; }
        }
      } catch {
        btn.disabled = false;
        btn.textContent = '✅ Acepto las condiciones del contrato';
        if (msg) { msg.style.color = '#dc2626'; msg.textContent = 'Error de red. Inténtalo de nuevo.'; }
      }
    });
  </script>
)}
</body>
</html>
