---
import Base from '@/layouts/Base.astro';
import { faqPageSchema, breadcrumbList, localBusinessSchema, SITE_URL } from '@/lib/jsonld';

const faqs = [
  {
    q: '¿La llamada es gratuita?',
    a: 'Sí. 30 minutos sin compromiso, sin coste. Sirve para entender si hay encaje antes de que tú decidas invertir nada.',
  },
  {
    q: '¿Trabajáis con presupuestos pequeños?',
    a: 'Depende del problema. Hay proyectos de 3.000€ y proyectos de 300.000€. Lo que Startidea no hace es bajar la calidad para hacer caber un alcance grande en un presupuesto que no llega.',
  },
  {
    q: '¿Trabajáis solo en Granada?',
    a: 'No. Startidea opera desde Granada con clientes en toda España y proyectos europeos. Cerca cuando importa, lejos cuando hace falta.',
  },
  {
    q: '¿Hace falta que llegue a la llamada con un brief?',
    a: 'No. Una idea aproximada del reto basta. Si tienes un brief o una RFP, mejor — los leemos antes y la conversación rinde más.',
  },
];

const jsonLd = [
  faqPageSchema(faqs),
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Contacto', url: `${SITE_URL}/contacto` },
  ]),
  localBusinessSchema(),
];
---

<Base
  title="Contacto Startidea — 30 min sin coste para evaluar encaje"
  description="Punto de contacto de Startidea (Granada). 30 minutos sin coste para evaluar si hay encaje real. Si no lo hay, se orienta a quién sí. hola@startidea.es."
  ogSlug="page/contacto"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24 lg:py-28">
    <div class="container-x">
      <span class="label">— Hablemos</span>
      <h1 class="mt-4 font-display text-display-xl leading-[0.96] text-ink">
        Treinta minutos.<br/>
        <em class="italic text-magenta">Sin compromiso.</em>
      </h1>
      <p class="mt-8 max-w-measure text-lede text-ink/80">
        Una llamada de diagnóstico. Tú cuentas el reto y Startidea te dice honestamente si es el partner adecuado para resolverlo. Si no lo es, te orienta hacia quien sí — sin segundas intenciones.
      </p>
    </div>
  </section>

  <!-- Calendario embed + datos -->
  <section class="bg-paper py-20 md:py-28">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 gap-y-12 border-t border-ink/15 pt-8">
        <!-- Form de contacto directo (sustituye al embed Cal.com mientras se reactiva) -->
        <div class="col-span-12 lg:col-span-7">
          <span class="label">— Reserva directa</span>
          <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
            Cuéntalo en <em class="italic text-magenta">tres líneas</em>.
          </h2>
          <p class="mt-5 max-w-measure text-ink/80">
            Startidea te devuelve la llamada en las próximas 24 horas laborales por el medio que prefieras — Google Meet, teléfono o WhatsApp. Si necesitas algo más estructurado, empieza por el <a href="/diagnostico" class="link-underline text-ink">diagnóstico inicial</a> de 3 minutos.
          </p>

          <form id="contacto-form" class="mt-10 space-y-4" novalidate>
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="absolute -left-[9999px]" aria-hidden="true" />

            <div class="space-y-2">
              <label for="name" class="block text-sm font-medium text-ink">Tu nombre y organización</label>
              <input type="text" id="name" name="name" required minlength="2" maxlength="80"
                class="w-full border border-ink/30 bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/30" />
            </div>

            <div class="space-y-2">
              <label for="email" class="block text-sm font-medium text-ink">Email</label>
              <input type="email" id="email" name="email" required maxlength="120"
                class="w-full border border-ink/30 bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/30" />
            </div>

            <div class="space-y-2">
              <label for="message" class="block text-sm font-medium text-ink">En qué puede ayudarte Startidea</label>
              <textarea id="message" name="message" required minlength="20" maxlength="1500" rows="4"
                placeholder="Reto o pregunta concreta. Tres líneas bastan."
                class="w-full resize-y border border-ink/30 bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/30"></textarea>
            </div>

            <label class="flex items-start gap-3 pt-1 text-xs leading-relaxed text-ink/80">
              <input type="checkbox" name="consent" required
                class="mt-0.5 h-4 w-4 flex-shrink-0 border-ink text-magenta focus:ring-magenta" />
              <span>He leído y acepto la <a href="/privacidad" target="_blank" rel="noopener" class="link-underline text-ink">política de privacidad</a>. Tus datos se usan solo para responder a esta consulta.</span>
            </label>

            <div class="flex flex-wrap items-center gap-3 pt-2">
              <button type="submit" class="btn">
                Enviar y nos llamamos
                <span aria-hidden="true">→</span>
              </button>
              <a href="/diagnostico" class="btn-ghost">O empieza con un diagnóstico</a>
            </div>

            <p id="contacto-status" class="font-mono text-[11px] text-ink-mute" aria-live="polite"></p>
          </form>
        </div>

        <!-- Datos de contacto -->
        <div class="col-span-12 lg:col-span-4 lg:col-start-9">
          <span class="label">— Otras vías</span>

          <div class="mt-6 space-y-8">
            <div class="border-t border-ink/15 pt-5">
              <p class="label">Email general</p>
              <a href="mailto:hola@startidea.es" class="mt-2 block font-display text-2xl leading-tight text-ink hover:text-magenta">
                hola@startidea.es
              </a>
            </div>
            <div class="border-t border-ink/15 pt-5">
              <p class="label">Pedidos merchandising</p>
              <a href="mailto:pedidos@startidea.es" class="mt-2 block font-display text-2xl leading-tight text-ink hover:text-magenta">
                pedidos@startidea.es
              </a>
            </div>
            <div class="border-t border-ink/15 pt-5">
              <p class="label">Granada Social</p>
              <a href="mailto:redaccion@granadasocial.org" class="mt-2 block font-display text-2xl leading-tight text-ink hover:text-magenta">
                redaccion@granadasocial.org
              </a>
            </div>
            <div class="border-t border-ink/15 pt-5">
              <p class="label">Teléfono</p>
              <a href="tel:+34958045789" class="mt-2 block font-display text-2xl leading-tight text-ink hover:text-magenta">
                +34 958 045 789
              </a>
            </div>
            <div class="border-t border-ink/15 pt-5">
              <p class="label">WhatsApp</p>
              <a href="https://wa.me/34958045789" target="_blank" rel="noopener" class="mt-2 block font-display text-2xl leading-tight text-ink hover:text-magenta">
                Escribir por WhatsApp ↗
              </a>
            </div>
            <div class="border-t border-ink/15 pt-5">
              <p class="label">Dirección</p>
              <p class="mt-2 font-display text-xl leading-tight text-ink">
                C/ Conde Cifuentes, 33<br/>
                18005 Granada · España
              </p>
            </div>
            <div class="border-t border-ink/15 pt-5">
              <p class="label">Redes</p>
              <ul class="mt-3 space-y-1.5 text-sm text-ink/85">
                <li><a href="https://www.linkedin.com/company/agenciastartidea" class="link-underline">LinkedIn</a></li>
                <li><a href="https://www.instagram.com/agenciastartidea" class="link-underline">Instagram</a></li>
                <li><a href="https://www.facebook.com/agenciastartidea" class="link-underline">Facebook</a></li>
                <li><a href="https://x.com/startideasocial" class="link-underline">X (Twitter)</a></li>
                <li><a href="https://www.youtube.com/c/AgenciadeComunicaciónSocialSTARTIDEA" class="link-underline">YouTube</a></li>
                <li><a href="https://open.spotify.com/show/3c3Pm70Up3v1GOdYuSxj05" class="link-underline">Spotify</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ rápido -->
  <section class="bg-paper-warm py-20 md:py-24">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label">— Antes de hablar</span>
        </div>
        <div class="col-span-12 mt-6 lg:col-span-9 lg:mt-0">
          <h2 class="font-display text-display-md leading-tight text-ink">
            Lo que <em class="italic text-magenta">a veces preguntan</em>.
          </h2>

          <dl class="mt-12 divide-y divide-ink/15 border-y border-ink/15">
            <div class="grid grid-cols-12 gap-x-8 py-8">
              <dt class="col-span-12 font-display text-2xl text-ink lg:col-span-5">¿La llamada es gratuita?</dt>
              <dd class="col-span-12 mt-3 max-w-measure text-ink/80 lg:col-span-7 lg:mt-0">Sí. 30 minutos sin compromiso, sin coste. Sirve para entender si hay encaje antes de que tú decidas invertir nada.</dd>
            </div>
            <div class="grid grid-cols-12 gap-x-8 py-8">
              <dt class="col-span-12 font-display text-2xl text-ink lg:col-span-5">¿Trabajáis con presupuestos pequeños?</dt>
              <dd class="col-span-12 mt-3 max-w-measure text-ink/80 lg:col-span-7 lg:mt-0">Depende del problema. Hay proyectos de 3.000€ y proyectos de 300.000€. Lo que Startidea no hace es bajar la calidad para hacer caber un alcance grande en un presupuesto que no llega.</dd>
            </div>
            <div class="grid grid-cols-12 gap-x-8 py-8">
              <dt class="col-span-12 font-display text-2xl text-ink lg:col-span-5">¿Trabajáis solo en Granada?</dt>
              <dd class="col-span-12 mt-3 max-w-measure text-ink/80 lg:col-span-7 lg:mt-0">No. Startidea opera desde Granada con clientes en toda España y proyectos europeos. Cerca cuando importa, lejos cuando hace falta.</dd>
            </div>
            <div class="grid grid-cols-12 gap-x-8 py-8">
              <dt class="col-span-12 font-display text-2xl text-ink lg:col-span-5">¿Hace falta que llegue a la llamada con un brief?</dt>
              <dd class="col-span-12 mt-3 max-w-measure text-ink/80 lg:col-span-7 lg:mt-0">No. Una idea aproximada del reto basta. Si tienes un brief o una RFP, mejor — se leen antes y la conversación rinde más.</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    // Form de contacto directo — POST a /api/contacto (mismo endpoint que
    // usa el CTA de la home y los recursos). Si Resend/Telegram falla, el
    // form muestra error legible y Mario se entera por logs.
    (function () {
      var form = document.getElementById('contacto-form');
      if (!form) return;
      var status = document.getElementById('contacto-status');

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        btn.disabled = true;
        status.textContent = 'Enviando…';

        var data = new FormData(form);
        try {
          var r = await fetch('/api/contacto', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              name: (data.get('name') || '').toString().trim(),
              email: (data.get('email') || '').toString().trim(),
              message: (data.get('message') || '').toString().trim(),
              path: '/contacto',
              consent: data.get('consent') === 'on',
              website: (data.get('website') || '').toString(),
            }),
          });
          var json = await r.json().catch(function () { return { ok: false }; });
          if (r.ok && json.ok) {
            window.stTrack && window.stTrack('generate_lead', {
              method: 'contacto_form',
              page_path: '/contacto',
            });
            form.innerHTML = '<div class="border-2 border-magenta p-6"><p class="font-display text-2xl text-ink">Recibido. Te llamamos en menos de 24 horas laborales.</p><p class="mt-2 text-sm text-ink/70">Si es urgente, escríbenos directamente a <a href="mailto:hola@startidea.es" class="link-underline">hola@startidea.es</a>.</p></div>';
          } else {
            status.textContent =
              json.error === 'rate' ? 'Espera unos segundos antes de reenviar.' :
              json.error === 'consent' ? 'Marca la casilla de aceptación de la política de privacidad.' :
              json.error === 'email' ? 'El email no parece válido.' :
              json.error === 'fields' ? 'Faltan datos por rellenar.' :
              'No se pudo enviar. Escríbenos a hola@startidea.es y Startidea lo revisa.';
            btn.disabled = false;
          }
        } catch (err) {
          status.textContent = 'Sin conexión. Escríbenos a hola@startidea.es.';
          btn.disabled = false;
        }
      });
    })();
  </script>
</Base>
