---
import Base from '@/layouts/Base.astro';
import AudienciaDetalle from '@/components/AudienciaDetalle.astro';
import { getAudiencia } from '@/data/audiencias';

const a = getAudiencia('instituciones')!;
---

<Base
  title={a.metaTitle}
  description={a.metaDescription}
  ogSlug="page/para-quien-instituciones"
>
  <AudienciaDetalle audiencia={a} />
</Base>
