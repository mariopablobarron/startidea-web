---
import Base from '@/layouts/Base.astro';
import { gruposPublicos } from '@/data/servicios';

// El catálogo con precios vive en `src/data/servicios.ts` (server-only).
// Aquí sólo recibimos { id, nombre, href } — sin tarifas — para renderizar
// los checkboxes. El cliente nunca verá precios ni en HTML ni en DevTools.
// La suma se hace en `src/pages/api/presupuesto.ts` al recibir el form.
const grupos = gruposPublicos();

// ─── Briefing guiado: árbol de preguntas + respuestas ───
const briefingPasos = [
  {
    id: 'tipologia',
    pregunta: '¿Qué tipo de organización eres?',
    opciones: [
      { value: 'tercer-sector', label: 'Tercer sector — fundación, asociación, ONG' },
      { value: 'institucion', label: 'Institución pública o paraestatal' },
      { value: 'empresa-proposito', label: 'Empresa con propósito' },
      { value: 'iniciativa-propia', label: 'Iniciativa o proyecto propio sin entidad jurídica' },
    ],
  },
  {
    id: 'reto',
    pregunta: '¿Qué reto principal buscas resolver?',
    opciones: [
      { value: 'comunicar', label: 'Comunicar mejor lo que hago' },
      { value: 'captar', label: 'Captar más recursos / fondos / socios' },
      { value: 'plataforma', label: 'Construir o renovar mi web / plataforma' },
      { value: 'audiovisual', label: 'Producir vídeo o podcast con propósito' },
      { value: 'estrategia', label: 'Pensar la estrategia desde cero' },
      { value: 'no-se', label: 'Aún no lo tengo claro — necesito ordenar' },
    ],
  },
  {
    id: 'urgencia',
    pregunta: '¿Cuándo querrías empezar?',
    opciones: [
      { value: 'ya', label: 'Ya — tengo deadline en semanas' },
      { value: '1-3m', label: 'En el próximo trimestre' },
      { value: '3-6m', label: 'Más adelante, pero estoy explorando' },
      { value: 'explorando', label: 'Solo estoy explorando' },
    ],
  },
  {
    id: 'presupuesto',
    pregunta: '¿Tienes presupuesto orientativo?',
    opciones: [
      { value: 'menos-3k', label: 'Menos de 3.000 €' },
      { value: '3-10k', label: 'Entre 3.000 € y 10.000 €' },
      { value: '10-30k', label: 'Entre 10.000 € y 30.000 €' },
      { value: 'mas-30k', label: 'Más de 30.000 €' },
      { value: 'no-se', label: 'Aún no lo sé' },
    ],
  },
];
---

<Base
  title="Pedir presupuesto a medida · Startidea"
  description="Marca los servicios que se acercan a tu necesidad y responde un briefing breve. Startidea te envía un presupuesto detallado tras un diagnóstico inicial — sin tarifas públicas porque cada caso es distinto."
  ogSlug="page/presupuesto"
>
  <!-- Hero -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24">
    <div class="container-x">
      <span class="label">— Pedir presupuesto</span>
      <h1 class="mt-4 font-display text-display-xl leading-[0.96] text-ink">
        Marca lo que necesitas.<br/>
        <em class="italic text-magenta">El precio sale del diagnóstico.</em>
      </h1>
      <p class="mt-8 max-w-measure text-lede text-ink/80">
        Startidea trabaja con presupuestos a medida. Cada proyecto pide un alcance distinto, así que no hay tarifas públicas. Marca los servicios que te encajen, responde cuatro preguntas y Startidea te envía un presupuesto detallado con el diagnóstico inicial. Sin compromiso.
      </p>
    </div>
  </section>

  <!-- Calculadora -->
  <section class="bg-paper-warm py-16 md:py-20">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label">— Paso 1 · Selección</span>
          <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
            Lo que <em class="italic text-magenta">necesitas</em>.
          </h2>
          <p class="mt-4 text-sm text-ink/75">
            Marca los servicios o espacios que te encajen. Tantos como quieras. El precio se cierra en el diagnóstico, con alcance y plazos claros.
          </p>
        </div>

        <div class="col-span-12 mt-8 lg:col-span-9 lg:mt-0">
          <form id="calc-form" class="space-y-12">
            {grupos.map((g) => (
              <div>
                <div class="flex items-baseline justify-between gap-4 border-b border-ink/15 pb-2">
                  <h3 class="font-display text-xl leading-tight text-ink md:text-2xl">{g.nombre}</h3>
                  <a href={g.href} class="font-mono text-[11px] uppercase tracking-widest text-ink/60 hover:text-magenta">
                    Ver detalle →
                  </a>
                </div>
                <ul class="mt-3 divide-y divide-ink/10">
                  {g.items.map((it) => (
                    <li>
                      <label class="flex cursor-pointer items-baseline gap-4 py-3 transition-colors hover:bg-paper">
                        <input
                          type="checkbox"
                          class="calc-item h-5 w-5 flex-shrink-0 cursor-pointer accent-magenta"
                          data-id={it.id}
                          data-nombre={it.nombre}
                          data-grupo={g.nombre}
                        />
                        <span class="font-display text-base text-ink sm:text-lg">{it.nombre}</span>
                      </label>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky resumen de la selección -->
  <div id="calc-sticky" class="sticky bottom-0 z-30 border-t-2 border-ink bg-paper shadow-[0_-12px_40px_-16px_rgba(0,0,0,0.18)]">
    <div class="container-x py-4 md:py-5">
      <div class="grid grid-cols-12 items-center gap-x-4 gap-y-2">
        <div class="col-span-12 sm:col-span-7">
          <p class="label">— Tu selección</p>
          <p class="mt-1 font-display text-2xl leading-tight text-ink md:text-3xl">
            <span id="calc-count">Aún no has marcado nada</span>
          </p>
          <p class="mt-1 max-w-measure text-xs text-ink/65 md:text-sm">
            El precio se cierra en el diagnóstico, con alcance y plazos.
          </p>
        </div>
        <div class="col-span-12 sm:col-span-5 flex flex-wrap items-center justify-start gap-3 sm:justify-end">
          <a href="#briefing" class="btn !py-2.5 text-sm">
            Continuar con el briefing
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Briefing -->
  <section id="briefing" class="bg-paper py-20 md:py-28 scroll-mt-24">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-3">
          <span class="label">— Paso 2 · Briefing</span>
          <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
            Cuatro <em class="italic text-magenta">preguntas</em>.
          </h2>
          <p class="mt-4 text-sm text-ink/75">
            Lo mínimo para preparar una propuesta con sentido. Al terminar genera un diagnóstico inicial y Startidea te envía el presupuesto detallado por email.
          </p>
        </div>

        <div class="col-span-12 mt-8 lg:col-span-9 lg:mt-0">
          <div id="briefing-chat" class="border-2 border-ink/15 bg-paper-warm">
            <!-- Hilo conversacional -->
            <ol id="briefing-thread" class="divide-y divide-ink/10"></ol>

            <!-- Zona de input/opciones -->
            <div id="briefing-input" class="border-t border-ink/15 bg-paper p-5"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<!-- Configuración del briefing serializada para JS -->
<script id="briefing-config" type="application/json" set:html={JSON.stringify(briefingPasos)}></script>

<style>
  .calc-item:checked + span {
    @apply text-magenta;
  }
  .briefing-bubble {
    @apply px-5 py-4 text-sm leading-relaxed sm:text-base;
  }
  .briefing-bubble.agente {
    @apply bg-paper-warm text-ink;
  }
  .briefing-bubble.usuario {
    @apply bg-ink text-paper;
  }
  .briefing-option {
    @apply block w-full cursor-pointer border border-ink/30 px-4 py-3 text-left text-sm text-ink transition-colors hover:border-ink hover:bg-paper-warm;
  }
  .briefing-option + .briefing-option {
    @apply mt-2;
  }
</style>

<script>
  // ─── Selector de servicios ───────────────────────────────────────
  // Sin precios en cliente: sólo se cuentan los checks. La suma real
  // la hace el backend en /api/presupuesto al recibir los IDs.
  const items = document.querySelectorAll<HTMLInputElement>('.calc-item');
  const countLabel = document.getElementById('calc-count')!;

  function recalc() {
    let count = 0;
    items.forEach((el) => { if (el.checked) count++; });
    if (count === 0) {
      countLabel.textContent = 'Aún no has marcado nada';
    } else if (count === 1) {
      countLabel.textContent = '1 servicio marcado';
    } else {
      countLabel.textContent = `${count} servicios marcados`;
    }
  }
  items.forEach((el) => el.addEventListener('change', recalc));
  recalc();

  // ─── Briefing guiado ─────────────────────────────────────────────
  type Paso = {
    id: string;
    pregunta: string;
    opciones: { value: string; label: string }[];
  };
  const config: Paso[] = JSON.parse(
    document.getElementById('briefing-config')!.textContent || '[]'
  );
  const thread = document.getElementById('briefing-thread')!;
  const inputZone = document.getElementById('briefing-input')!;
  const respuestas: Record<string, string> = {};
  let pasoActual = 0;

  function bubble(text: string, who: 'agente' | 'usuario') {
    const li = document.createElement('li');
    li.className = `briefing-bubble ${who}`;
    li.textContent = text;
    thread.appendChild(li);
    li.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function siguientePaso() {
    inputZone.innerHTML = '';
    if (pasoActual >= config.length) {
      pedirContacto();
      return;
    }
    const paso = config[pasoActual];
    bubble(paso.pregunta, 'agente');
    paso.opciones.forEach((op) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'briefing-option';
      btn.textContent = op.label;
      btn.addEventListener('click', () => {
        respuestas[paso.id] = op.value;
        bubble(op.label, 'usuario');
        pasoActual++;
        siguientePaso();
      });
      inputZone.appendChild(btn);
    });
  }

  function pedirContacto() {
    bubble('Ya casi. ¿Tu nombre y a qué email mandar el diagnóstico y el presupuesto?', 'agente');
    const form = document.createElement('form');
    form.className = 'space-y-3';
    form.innerHTML = `
      <input name="nombre" required placeholder="Tu nombre y organización"
        class="w-full border border-ink bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40" />
      <input name="email" required type="email" placeholder="tu@email.com"
        class="w-full border border-ink bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40" />
      <textarea name="contexto" rows="3" placeholder="Una línea más de contexto si quieres (opcional)"
        class="w-full resize-none border border-ink bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"></textarea>
      <label class="flex items-start gap-3 pt-1 text-xs leading-relaxed text-ink/80">
        <input type="checkbox" name="consent" required
          class="mt-0.5 h-4 w-4 flex-shrink-0 border-ink text-magenta focus:ring-magenta" />
        <span>He leído y acepto la <a href="/privacidad" target="_blank" rel="noopener" class="link-underline text-ink">política de privacidad</a>. Tus datos se usan solo para responder a esta consulta.</span>
      </label>
      <button type="submit" class="btn w-full justify-center">
        Enviar y recibir diagnóstico
        <span aria-hidden="true">→</span>
      </button>
      <p id="briefing-status" class="font-mono text-[11px] text-ink-mute" aria-live="polite"></p>
    `;
    inputZone.appendChild(form);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const nombre = (data.get('nombre') as string || '').trim();
      const email = (data.get('email') as string || '').trim();
      const contexto = (data.get('contexto') as string || '').trim();
      const consent = data.get('consent') === 'on';
      const status = document.getElementById('briefing-status')!;
      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submit.disabled = true;
      status.textContent = 'Enviando…';

      // Sólo IDs de servicios marcados (sin precios — los conoce el backend)
      const serviciosIds: string[] = [];
      items.forEach((el) => {
        if (el.checked && el.dataset.id) serviciosIds.push(el.dataset.id);
      });

      try {
        const r = await fetch('/api/presupuesto', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            name: nombre,
            email,
            contexto,
            respuestas,
            servicios: serviciosIds,
            consent,
          }),
        });
        const json = await r.json().catch(() => ({ ok: false }));
        if (r.ok && json.ok) {
          (window as any).stTrack?.('generate_lead', {
            method: 'presupuesto',
            page_path: '/presupuesto',
          });
          inputZone.innerHTML = '';
          if (json.diagnostico) bubble(json.diagnostico, 'agente');
          bubble(
            `Recibido. Startidea revisa el briefing y te manda el presupuesto detallado a ${email} en las próximas 24 horas.`,
            'agente'
          );
        } else {
          status.textContent =
            json.error === 'rate' ? 'Espera unos segundos antes de reenviar.' :
            json.error === 'consent' ? 'Marca la casilla de aceptación de la política de privacidad.' :
            'No se pudo enviar. Escríbenos a hola@startidea.es.';
          submit.disabled = false;
        }
      } catch {
        status.textContent = 'Sin conexión. Escríbenos a hola@startidea.es.';
        submit.disabled = false;
      }
    });
  }

  siguientePaso();
</script>
