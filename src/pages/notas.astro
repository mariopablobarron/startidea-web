---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { breadcrumbList, SITE_URL } from '@/lib/jsonld';

const notas = await getCollection('notas', ({ data }) => !data.draft);
notas.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = new Intl.DateTimeFormat('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });

// Categorías en orden de presentación
const CATS = ['Comunicación', 'Financiación', 'Estrategia', 'Agencia'] as const;

// Agrupar por categoría
const byCategory: Record<string, typeof notas> = { Todas: notas };
for (const cat of CATS) {
  byCategory[cat] = notas.filter((n) => n.data.category === cat);
}

// Contadores
const counts: Record<string, number> = { Todas: notas.length };
for (const cat of CATS) counts[cat] = byCategory[cat].length;

// Audiencias (segunda dimensión de filtro). Las notas con audience 'Todas'
// (universales) cuentan y se muestran bajo cualquier audiencia concreta.
const AUDS = ['Tercer sector', 'Instituciones', 'Empresas con propósito'] as const;
const TODAS_AUD = 'Todas las audiencias';
const audCounts: Record<string, number> = { [TODAS_AUD]: notas.length };
for (const aud of AUDS) {
  audCounts[aud] = notas.filter((n) => n.data.audience === aud || n.data.audience === 'Todas').length;
}

const jsonLd = [
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Notas', url: `${SITE_URL}/notas` },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Notas de Startidea',
    description: 'Notas mensuales sobre comunicación, estrategia, financiación y producto digital con propósito.',
    url: `${SITE_URL}/notas`,
    blogPost: notas.slice(0, 20).map((n) => ({
      '@type': 'BlogPosting',
      headline: n.data.title,
      url: `${SITE_URL}/notas/${n.slug}`,
      datePublished: n.data.pubDate.toISOString().slice(0, 10),
      author: { '@type': 'Person', name: n.data.author },
    })),
  },
];
---

<Base
  title="Notas — Startidea"
  description="Notas mensuales sobre comunicación, estrategia, financiación y producto digital con propósito. Una al mes, cinco minutos, sin tracking pixels."
  ogSlug="page/notas"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24 lg:py-28">
    <div class="container-x">
      <span class="label">— Notas</span>
      <h1 class="mt-4 font-display text-display-xl leading-[0.96] text-ink">
        Una nota al mes.<br/>
        <em class="italic text-magenta">Cero ruido.</em>
      </h1>
      <p class="mt-8 max-w-measure text-lede text-ink/80">
        Notas editoriales sobre comunicación, financiación, estrategia y producto digital con propósito. Una al mes, leíble en cinco minutos, escritas en casa. Sin tracking pixels, sin "hacks", sin clickbait.
      </p>

      <!-- Pills de categoría -->
      <div class="mt-10 flex flex-wrap gap-2" role="group" aria-label="Filtrar por categoría">
        {(['Todas', ...CATS] as const).map((cat) => (
          <button
            type="button"
            data-cat={cat}
            class:list={[
              'cat-pill border px-4 py-2 font-mono text-[11px] uppercase tracking-widest transition-colors',
              cat === 'Todas'
                ? 'border-ink bg-ink text-paper'
                : 'border-ink/30 bg-paper text-ink/70 hover:border-ink hover:text-ink',
            ]}
            aria-pressed={cat === 'Todas' ? 'true' : 'false'}
          >
            {cat}
            <span class="ml-1.5 opacity-60">({counts[cat]})</span>
          </button>
        ))}
      </div>

      <!-- Pills de audiencia -->
      <div class="mt-3 flex flex-wrap gap-2" role="group" aria-label="Filtrar por audiencia">
        {([TODAS_AUD, ...AUDS] as const).map((aud) => (
          <button
            type="button"
            data-aud={aud}
            class:list={[
              'aud-pill border px-4 py-2 font-mono text-[11px] uppercase tracking-widest transition-colors',
              aud === TODAS_AUD
                ? 'border-magenta bg-magenta text-paper'
                : 'border-ink/30 bg-paper text-ink/70 hover:border-magenta hover:text-magenta',
            ]}
            aria-pressed={aud === TODAS_AUD ? 'true' : 'false'}
          >
            {aud === TODAS_AUD ? 'Toda audiencia' : aud}
            <span class="ml-1.5 opacity-60">({audCounts[aud]})</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Listado por categoría -->
  {notas.length > 0 ? (
    <section class="bg-paper py-16 md:py-24">
      <div class="container-x">

        {/* Secciones por categoría */}
        {(['Todas', ...CATS] as const).map((cat) => {
          const items = byCategory[cat];
          if (!items || items.length === 0) return null;
          return (
            <div
              data-section={cat}
              class:list={['cat-section', cat !== 'Todas' && 'hidden']}
            >
              {/* Header de categoría (solo cuando no es "Todas") */}
              {cat !== 'Todas' && (
                <div class="mb-10 border-t border-ink/15 pt-8">
                  <span class="label">— {cat}</span>
                  <p class="mt-1 font-mono text-[11px] uppercase tracking-wider text-ink/40">
                    {items.length} {items.length === 1 ? 'nota' : 'notas'}
                  </p>
                </div>
              )}

              {/* En modo "Todas": mostrar por sub-secciones de categoría */}
              {cat === 'Todas' ? (
                <div class="space-y-20">
                  {CATS.map((subCat) => {
                    const subItems = byCategory[subCat];
                    if (!subItems || subItems.length === 0) return null;
                    return (
                      <div class="sub-section" data-subcat={subCat}>
                        <div class="mb-8 grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
                          <div class="col-span-12 lg:col-span-3">
                            <button
                              type="button"
                              data-cat={subCat}
                              class="cat-pill-link label cursor-pointer text-left hover:text-magenta transition-colors"
                              aria-label={`Ver solo notas de ${subCat}`}
                            >
                              — {subCat}
                            </button>
                            <p class="mt-1 font-mono text-[10px] uppercase tracking-wider text-ink/40">
                              {subItems.length} {subItems.length === 1 ? 'nota' : 'notas'}
                            </p>
                          </div>
                        </div>
                        <ol class="nota-list divide-y divide-ink/15 border-b border-ink/15">
                          {subItems.map((nota) => {
                            const words = nota.body.trim().split(/\s+/).length;
                            const min = Math.max(1, Math.round(words / 200));
                            return (
                              <li class="nota-item" data-audience={nota.data.audience}>
                                <a
                                  href={`/notas/${nota.slug}`}
                                  class="reveal group grid grid-cols-12 gap-x-8 gap-y-4 py-8 transition-colors hover:bg-paper-warm"
                                >
                                  <div class="col-span-12 lg:col-span-3">
                                    <p class="font-mono text-[11px] uppercase tracking-widest text-ink/50">
                                      {fmt.format(nota.data.pubDate)}
                                    </p>
                                  </div>
                                  <div class="col-span-12 lg:col-span-7">
                                    <h3 class="font-display text-xl leading-tight text-ink transition-colors group-hover:text-magenta md:text-2xl">
                                      {nota.data.title}
                                    </h3>
                                    <p class="mt-2 max-w-measure text-sm text-ink/70">
                                      {nota.data.description}
                                    </p>
                                    <div class="mt-3 flex flex-wrap items-center gap-2">
                                      {nota.data.audience !== 'Todas' && (
                                        <span class="border border-magenta/40 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-magenta">
                                          {nota.data.audience}
                                        </span>
                                      )}
                                      {nota.data.tags.slice(0, 2).map((tag) => (
                                        <span class="border border-ink/20 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-ink/50">
                                          #{tag}
                                        </span>
                                      ))}
                                    </div>
                                  </div>
                                  <div class="col-span-12 lg:col-span-2 lg:text-right">
                                    <span class="font-mono text-[11px] uppercase tracking-widest text-ink/40">
                                      ~{min} min
                                    </span>
                                    <p class="mt-1 font-mono text-xs text-ink/60 transition-colors group-hover:text-magenta">
                                      Leer →
                                    </p>
                                  </div>
                                </a>
                              </li>
                            );
                          })}
                        </ol>
                      </div>
                    );
                  })}
                </div>
              ) : (
                /* Vista de categoría individual: lista simple */
                <ol class="nota-list divide-y divide-ink/15 border-y border-ink/15">
                  {items.map((nota) => {
                    const words = nota.body.trim().split(/\s+/).length;
                    const min = Math.max(1, Math.round(words / 200));
                    return (
                      <li class="nota-item" data-audience={nota.data.audience}>
                        <a
                          href={`/notas/${nota.slug}`}
                          class="reveal group grid grid-cols-12 gap-x-8 gap-y-4 py-8 transition-colors hover:bg-paper-warm"
                        >
                          <div class="col-span-12 lg:col-span-3">
                            <p class="font-mono text-[11px] uppercase tracking-widest text-ink/50">
                              {fmt.format(nota.data.pubDate)}
                            </p>
                          </div>
                          <div class="col-span-12 lg:col-span-7">
                            <h3 class="font-display text-xl leading-tight text-ink transition-colors group-hover:text-magenta md:text-2xl">
                              {nota.data.title}
                            </h3>
                            <p class="mt-2 max-w-measure text-sm text-ink/70">
                              {nota.data.description}
                            </p>
                            <div class="mt-3 flex flex-wrap items-center gap-2">
                              {nota.data.audience !== 'Todas' && (
                                <span class="border border-magenta/40 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-magenta">
                                  {nota.data.audience}
                                </span>
                              )}
                              {nota.data.tags.slice(0, 2).map((tag) => (
                                <span class="border border-ink/20 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-ink/50">
                                  #{tag}
                                </span>
                              ))}
                            </div>
                          </div>
                          <div class="col-span-12 lg:col-span-2 lg:text-right">
                            <span class="font-mono text-[11px] uppercase tracking-widest text-ink/40">
                              ~{min} min
                            </span>
                            <p class="mt-1 font-mono text-xs text-ink/60 transition-colors group-hover:text-magenta">
                              Leer →
                            </p>
                          </div>
                        </a>
                      </li>
                    );
                  })}
                </ol>
              )}
            </div>
          );
        })}

        {/* Estado vacío al combinar filtros (categoría + audiencia) */}
        <p data-empty class="hidden border-t border-ink/15 pt-8 font-display text-xl text-ink/60 md:text-2xl">
          No hay notas que combinen esa categoría y esa audiencia.{' '}
          <button type="button" data-reset class="italic text-magenta underline-offset-4 hover:underline">
            Quitar filtros
          </button>
        </p>
      </div>
    </section>
  ) : (
    <section class="bg-paper py-16 md:py-24">
      <div class="container-x">
        <p class="font-display text-2xl text-ink/60 md:text-3xl">
          Aún no hay notas publicadas. La primera saldrá pronto — suscríbete abajo para no perderla.
        </p>
      </div>
    </section>
  )}

  <!-- Suscripción -->
  <section class="border-t border-ink/15 bg-paper py-16 md:py-20">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-4">
          <span class="label">— Suscríbete</span>
          <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
            Tu email no va a <em class="italic text-magenta">ningún lado más</em>.
          </h2>
        </div>
        <div class="col-span-12 mt-6 lg:col-span-7 lg:col-start-6 lg:mt-0">
          <form
            class="flex flex-col gap-3 sm:flex-row sm:items-stretch"
            action="https://buttondown.email/api/emails/embed-subscribe/startidea"
            method="post"
            target="popupwindow"
            onsubmit="window.open('https://buttondown.email/startidea', 'popupwindow')"
          >
            <label class="sr-only" for="newsletter-email">Tu email</label>
            <input
              id="newsletter-email"
              type="email"
              name="email"
              required
              placeholder="tu@email.com"
              autocomplete="email"
              class="flex-1 border border-ink bg-paper px-5 py-3.5 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
            />
            <button type="submit" class="btn">
              Suscribirme <span aria-hidden="true">→</span>
            </button>
          </form>
          <p class="mt-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
            Sin tracking pixels. Privacidad real.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Por qué leer notas -->
  <section class="bg-ink py-20 text-paper md:py-24">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8">
        <div class="col-span-12 lg:col-span-9 lg:col-start-4">
          <span class="label !text-paper/60">— Por qué leerlas</span>
          <h2 class="mt-4 font-display text-display-md leading-tight text-paper">
            Tres reglas <em class="italic text-magenta">de la casa</em>.
          </h2>
          <ol class="mt-10 divide-y divide-paper/15 border-y border-paper/15">
            <li class="grid grid-cols-12 gap-x-8 py-6">
              <span class="col-span-12 font-display text-xl text-magenta sm:col-span-2">01</span>
              <p class="col-span-12 mt-1 sm:col-span-10 sm:mt-0 text-paper/85">
                <strong class="text-paper">Una nota al mes.</strong> Ni más, ni menos. Si no tenemos algo que valga la pena leer, ese mes no escribimos.
              </p>
            </li>
            <li class="grid grid-cols-12 gap-x-8 py-6">
              <span class="col-span-12 font-display text-xl text-magenta sm:col-span-2">02</span>
              <p class="col-span-12 mt-1 sm:col-span-10 sm:mt-0 text-paper/85">
                <strong class="text-paper">Cinco minutos de lectura.</strong> Si la idea no entra en cinco minutos, era un artículo, un libro o una llamada — no una nota.
              </p>
            </li>
            <li class="grid grid-cols-12 gap-x-8 py-6">
              <span class="col-span-12 font-display text-xl text-magenta sm:col-span-2">03</span>
              <p class="col-span-12 mt-1 sm:col-span-10 sm:mt-0 text-paper/85">
                <strong class="text-paper">Sin tracking pixels.</strong> No sabemos quién abre, quién no, ni cuántos clics. Solo sabemos quién está suscrito y quién pidió darse de baja. Privacidad real.
              </p>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  // Filtrado en dos dimensiones: categoría (alterna secciones) + audiencia
  // (oculta notas individuales). JS plano sin tipos (gotcha CLAUDE.md #2).
  const catPills = document.querySelectorAll('.cat-pill');
  const audPills = document.querySelectorAll('.aud-pill');
  const pillLinks = document.querySelectorAll('.cat-pill-link');
  const sections = document.querySelectorAll('.cat-section');
  const subSections = document.querySelectorAll('.sub-section');
  const notaLists = document.querySelectorAll('.nota-list');
  const emptyMsg = document.querySelector('[data-empty]');
  const resetBtn = document.querySelector('[data-reset]');

  const CATS = ['Comunicación', 'Financiación', 'Estrategia', 'Agencia'];
  const AUDS = ['Tercer sector', 'Instituciones', 'Empresas con propósito'];
  const TODAS_AUD = 'Todas las audiencias';

  let activeCat = 'Todas';
  let activeAud = TODAS_AUD;

  function audMatches(itemAud) {
    if (activeAud === TODAS_AUD) return true;
    // Las notas universales ('Todas') encajan en cualquier audiencia concreta.
    return itemAud === activeAud || itemAud === 'Todas';
  }

  function paintPills(pills, active, activeClasses, idleClasses) {
    pills.forEach((p) => {
      const isActive = (p.dataset.cat || p.dataset.aud) === active;
      p.setAttribute('aria-pressed', String(isActive));
      activeClasses.forEach((c) => p.classList.toggle(c, isActive));
      idleClasses.forEach((c) => p.classList.toggle(c, !isActive));
    });
  }

  function apply() {
    // 1. Categoría: solo la sección activa visible.
    sections.forEach((s) => s.classList.toggle('hidden', s.dataset.section !== activeCat));

    // 2. Audiencia: ocultar las notas que no encajan (en cualquier sección).
    document.querySelectorAll('.nota-item').forEach((li) => {
      li.classList.toggle('hidden', !audMatches(li.dataset.audience));
    });

    // 3. Colapsar listas y sub-secciones que se queden sin notas visibles.
    notaLists.forEach((ol) => ol.classList.toggle('hidden', !ol.querySelector('.nota-item:not(.hidden)')));
    subSections.forEach((sec) => sec.classList.toggle('hidden', !sec.querySelector('.nota-item:not(.hidden)')));

    // 4. Estado vacío si la combinación no deja ninguna nota.
    const anyVisible = document.querySelector('.cat-section:not(.hidden) .nota-item:not(.hidden)');
    if (emptyMsg) emptyMsg.classList.toggle('hidden', Boolean(anyVisible));

    // 5. Pintar ambas filas de pills.
    paintPills(catPills, activeCat, ['border-ink', 'bg-ink', 'text-paper'], ['border-ink/30', 'bg-paper', 'text-ink/70']);
    paintPills(audPills, activeAud, ['border-magenta', 'bg-magenta', 'text-paper'], ['border-ink/30', 'bg-paper', 'text-ink/70']);

    // 6. Sincronizar URL (?cat=&aud=) sin recargar.
    const url = new URL(window.location.href);
    if (activeCat === 'Todas') url.searchParams.delete('cat'); else url.searchParams.set('cat', activeCat);
    if (activeAud === TODAS_AUD) url.searchParams.delete('aud'); else url.searchParams.set('aud', activeAud);
    history.replaceState(null, '', url.toString());
  }

  catPills.forEach((p) => p.addEventListener('click', () => { activeCat = p.dataset.cat; apply(); }));
  pillLinks.forEach((p) => p.addEventListener('click', () => { activeCat = p.dataset.cat; apply(); }));
  audPills.forEach((p) => p.addEventListener('click', () => { activeAud = p.dataset.aud; apply(); }));
  if (resetBtn) resetBtn.addEventListener('click', () => { activeCat = 'Todas'; activeAud = TODAS_AUD; apply(); });

  // Estado inicial desde la URL (?cat=Financiación&aud=Tercer sector).
  const params = new URL(window.location.href).searchParams;
  const urlCat = params.get('cat');
  const urlAud = params.get('aud');
  if (urlCat && CATS.includes(urlCat)) activeCat = urlCat;
  if (urlAud && AUDS.includes(urlAud)) activeAud = urlAud;
  apply();
</script>
