---
import Base from '@/layouts/Base.astro';
import { breadcrumbList, SITE_URL } from '@/lib/jsonld';

const jsonLd = [
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Encuesta de financiación', url: `${SITE_URL}/encuesta-fundraising` },
  ]),
];

const selectCls =
  'mt-2 w-full border border-ink/20 bg-paper px-4 py-3 text-ink focus:border-magenta focus:outline-none';
const labelCls = 'block font-display text-lg text-ink';
const hintCls = 'mt-1 text-sm text-ink/75';
---

<Base
  title="Encuesta: ¿de qué depende la financiación de tu entidad? — Startidea"
  description="Encuesta anónima de 4 minutos sobre dependencia del dinero público en el tercer sector. Startidea publicará el informe agregado; quien participa lo recibe antes que nadie."
  ogSlug="page/encuesta-fundraising"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24">
    <div class="container-narrow">
      <span class="label">— Encuesta · 4 minutos · anónima</span>
      <h1 class="reveal mt-4 font-display text-display-lg leading-[1.0] text-ink md:text-display-xl">
        ¿De qué depende<br />
        <em class="italic text-magenta">tu financiación?</em>
      </h1>
      <p class="reveal reveal-slow mt-8 max-w-measure text-lede text-ink/80">
        Startidea está midiendo cuánto dependen del dinero público las entidades del tercer sector en España, y qué pasaría si perdieran su principal fuente. Son cuatro minutos, es anónima y el informe agregado se publicará abierto. Quien participa lo recibe antes que nadie.
      </p>
    </div>
  </section>

  <!-- Formulario -->
  <section class="bg-paper py-16 md:py-24">
    <div class="container-narrow">
      <form id="enc-form" class="space-y-10" novalidate>
        <!-- Honeypot -->
        <div class="hidden" aria-hidden="true">
          <label>No rellenar<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        </div>

        <!-- 1 -->
        <div>
          <label class={labelCls} for="tipo_entidad">1. Tipo de entidad *</label>
          <select id="tipo_entidad" name="tipo_entidad" class={selectCls} required>
            <option value="">Selecciona…</option>
            <option>Asociación</option>
            <option>Fundación</option>
            <option>Federación</option>
            <option>Cooperativa de iniciativa social</option>
            <option>Otra</option>
          </select>
        </div>

        <!-- 2 -->
        <div>
          <label class={labelCls} for="presupuesto">2. Presupuesto anual aproximado *</label>
          <select id="presupuesto" name="presupuesto" class={selectCls} required>
            <option value="">Selecciona…</option>
            <option value="<50k">Menos de 50.000 €</option>
            <option value="50-150k">50.000 – 150.000 €</option>
            <option value="150-300k">150.000 – 300.000 €</option>
            <option value="300k-1M">300.000 € – 1 M€</option>
            <option value=">1M">Más de 1 M€</option>
          </select>
        </div>

        <!-- 3 -->
        <div>
          <label class={labelCls} for="personas_contratadas">3. Personas contratadas</label>
          <select id="personas_contratadas" name="personas_contratadas" class={selectCls}>
            <option value="">Selecciona…</option>
            <option value="0">Ninguna (solo voluntariado)</option>
            <option value="1-3">1 – 3</option>
            <option value="4-10">4 – 10</option>
            <option value=">10">Más de 10</option>
          </select>
        </div>

        <!-- 4 -->
        <div>
          <label class={labelCls} for="pct_publico">4. ¿Qué % de tus ingresos viene de dinero público? (subvenciones, convenios, contratos)</label>
          <p class={hintCls}>Arrastra el control. Valor: <output id="pct_out" class="font-mono text-magenta">50</output>%</p>
          <input id="pct_publico" name="pct_publico" type="range" min="0" max="100" value="50" step="5" class="mt-3 w-full accent-magenta" />
        </div>

        <!-- 5 -->
        <div class="grid gap-6 sm:grid-cols-3">
          <div class="sm:col-span-2">
            <label class={labelCls} for="mayor_fuente">5. ¿Cuál es tu mayor fuente única de ingresos?</label>
            <input id="mayor_fuente" name="mayor_fuente" type="text" maxlength="120" placeholder="Ej. convenio con la Junta, cuotas de socios…" class={selectCls} />
          </div>
          <div>
            <label class={labelCls} for="mayor_fuente_pct">…y qué % representa</label>
            <input id="mayor_fuente_pct" name="mayor_fuente_pct" type="number" min="0" max="100" placeholder="%" class={selectCls} />
          </div>
        </div>

        <!-- 6 -->
        <div>
          <label class={labelCls} for="meses_aguante">6. Si perdieras tu mayor fuente este año, ¿cuántos meses aguantaría la organización?</label>
          <select id="meses_aguante" name="meses_aguante" class={selectCls}>
            <option value="">Selecciona…</option>
            <option value="<1">Menos de 1 mes</option>
            <option value="1-3">1 – 3 meses</option>
            <option value="3-6">3 – 6 meses</option>
            <option value="6-12">6 – 12 meses</option>
            <option value=">12">Más de 12 meses</option>
          </select>
        </div>

        <!-- 7 -->
        <div>
          <label class={labelCls}>7. ¿Tienes base social (socios con cuota recurrente)?</label>
          <div class="mt-3 flex flex-wrap items-center gap-6">
            <label class="flex items-center gap-2 text-ink/85"><input type="radio" name="base_social" value="si" class="accent-magenta" /> Sí</label>
            <label class="flex items-center gap-2 text-ink/85"><input type="radio" name="base_social" value="no" class="accent-magenta" /> No</label>
            <span id="base_num_wrap" class="hidden items-center gap-2">
              <label for="base_social_num" class="text-ink/70">¿Cuántos?</label>
              <input id="base_social_num" name="base_social_num" type="number" min="0" placeholder="nº socios" class="w-32 border border-ink/20 bg-paper px-3 py-2 focus:border-magenta focus:outline-none" />
            </span>
          </div>
        </div>

        <!-- 8 -->
        <div>
          <label class={labelCls} for="num_fuentes">8. ¿Cuántas fuentes de ingreso distintas tienes?</label>
          <select id="num_fuentes" name="num_fuentes" class={selectCls}>
            <option value="">Selecciona…</option>
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4+">4 o más</option>
          </select>
        </div>

        <!-- 9 -->
        <div>
          <label class={labelCls}>9. ¿Has tenido problemas de tesorería por retraso en el pago de la Administración en los últimos 2 años?</label>
          <div class="mt-3 flex flex-wrap items-center gap-6">
            <label class="flex items-center gap-2 text-ink/85"><input type="radio" name="problema_tesoreria" value="si" class="accent-magenta" /> Sí</label>
            <label class="flex items-center gap-2 text-ink/85"><input type="radio" name="problema_tesoreria" value="no" class="accent-magenta" /> No</label>
          </div>
        </div>

        <!-- 10 -->
        <div>
          <label class={labelCls} for="mayor_reto">10. ¿Cuál es tu mayor reto de financiación ahora mismo?</label>
          <textarea id="mayor_reto" name="mayor_reto" rows="3" maxlength="1000" class={selectCls} placeholder="En una o dos frases…"></textarea>
        </div>

        <!-- Email opcional -->
        <div class="border-t border-ink/15 pt-8">
          <label class={labelCls} for="email">Tu email (opcional)</label>
          <p class={hintCls}>Solo para enviarte el informe cuando se publique. No se comparte ni se usa para otra cosa.</p>
          <input id="email" name="email" type="email" maxlength="120" placeholder="hola@tuentidad.org" class={selectCls} />
        </div>

        <!-- Consentimiento -->
        <div>
          <label class="flex items-start gap-3 text-sm text-ink/80">
            <input type="checkbox" id="consent" name="consent" class="mt-1 accent-magenta" required />
            <span>Acepto que estos datos anónimos se usen en un informe agregado de Startidea y la <a href="/privacidad" class="link-underline text-ink">política de privacidad</a>. Si dejo mi email, acepto recibir el informe.</span>
          </label>
        </div>

        <div class="flex flex-wrap items-center gap-4">
          <button type="submit" id="enc-submit" class="btn">Enviar respuesta →</button>
          <p id="enc-msg" class="text-sm" role="status" aria-live="polite"></p>
        </div>
      </form>

      <!-- Estado de éxito -->
      <div id="enc-ok" class="hidden border-l-2 border-magenta bg-paper-warm p-8">
        <p class="label text-magenta">— Gracias</p>
        <p class="mt-3 max-w-measure text-lg text-ink/85">Respuesta registrada. Cuando el informe esté listo, se publicará abierto en startidea.es. Si dejaste tu email, lo recibirás antes que nadie.</p>
        <a href="/notas" class="btn-ghost mt-6 inline-block">Ver las notas mientras tanto</a>
      </div>
    </div>
  </section>
</Base>

<script>
  // JavaScript puro — sin tipos, sin casts, sin "!" (se emite literal al HTML).
  const form = document.getElementById('enc-form');
  const okBox = document.getElementById('enc-ok');
  const msg = document.getElementById('enc-msg');
  const submitBtn = document.getElementById('enc-submit');

  // Slider: actualizar el output
  const range = document.getElementById('pct_publico');
  const out = document.getElementById('pct_out');
  if (range && out) {
    range.addEventListener('input', () => { out.textContent = range.value; });
  }

  // Mostrar "¿cuántos?" si base social = sí
  const baseWrap = document.getElementById('base_num_wrap');
  document.querySelectorAll('input[name="base_social"]').forEach((el) => {
    el.addEventListener('change', () => {
      if (!baseWrap) return;
      const si = document.querySelector('input[name="base_social"][value="si"]');
      if (si && si.checked) {
        baseWrap.classList.remove('hidden');
        baseWrap.classList.add('inline-flex');
      } else {
        baseWrap.classList.add('hidden');
        baseWrap.classList.remove('inline-flex');
      }
    });
  });

  function radioVal(name) {
    const el = document.querySelector('input[name="' + name + '"]:checked');
    return el ? el.value : '';
  }

  function numOrNull(id) {
    const el = document.getElementById(id);
    if (!el || el.value === '') return null;
    const n = parseInt(el.value, 10);
    return Number.isNaN(n) ? null : n;
  }

  function val(id) {
    const el = document.getElementById(id);
    return el ? el.value : '';
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const consent = document.getElementById('consent');
      if (!consent || !consent.checked) {
        if (msg) { msg.textContent = 'Marca la casilla de consentimiento para enviar.'; msg.className = 'text-sm text-magenta'; }
        return;
      }
      if (!val('tipo_entidad') || !val('presupuesto')) {
        if (msg) { msg.textContent = 'Completa al menos el tipo de entidad y el presupuesto.'; msg.className = 'text-sm text-magenta'; }
        return;
      }

      const payload = {
        website: val('website'),
        tipo_entidad: val('tipo_entidad'),
        presupuesto: val('presupuesto'),
        personas_contratadas: val('personas_contratadas'),
        pct_publico: numOrNull('pct_publico'),
        mayor_fuente: val('mayor_fuente'),
        mayor_fuente_pct: numOrNull('mayor_fuente_pct'),
        meses_aguante: val('meses_aguante'),
        base_social: radioVal('base_social'),
        base_social_num: numOrNull('base_social_num'),
        num_fuentes: val('num_fuentes'),
        problema_tesoreria: radioVal('problema_tesoreria'),
        mayor_reto: val('mayor_reto'),
        email: val('email'),
        consent: true,
      };

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Enviando…'; }
      if (msg) { msg.textContent = ''; }

      try {
        const res = await fetch('/api/encuesta-fundraising', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (res.ok && data.ok) {
          form.classList.add('hidden');
          if (okBox) okBox.classList.remove('hidden');
          if (okBox) okBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          const map = { rate: 'Espera unos segundos antes de reenviar.', consent: 'Marca el consentimiento.', email: 'Revisa el email.', fields: 'Completa tipo de entidad y presupuesto.' };
          if (msg) { msg.textContent = map[data.error] || 'No se pudo enviar. Inténtalo de nuevo.'; msg.className = 'text-sm text-magenta'; }
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Enviar respuesta →'; }
        }
      } catch (err) {
        if (msg) { msg.textContent = 'Error de conexión. Inténtalo de nuevo.'; msg.className = 'text-sm text-magenta'; }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Enviar respuesta →'; }
      }
    });
  }
</script>
