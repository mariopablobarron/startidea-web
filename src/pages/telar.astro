---
/**
 * /telar — Landing de venta de Telar: plataforma de comunidad propia
 * gestionada (base: instancias vivas REDES / Comunidad Startidea / Esperanza).
 * Página empaquetada con planes. Borrador comercial para revisión.
 */
import Base from '@/layouts/Base.astro';
import { breadcrumbList, faqPageSchema, SITE_URL } from '@/lib/jsonld';

const faqs = [
  {
    q: '¿Y nuestro grupo de WhatsApp?',
    a: 'Se queda como canal rápido. Telar es la casa: ahí viven los datos, el histórico, la formación y el boletín. WhatsApp sirve para el aviso corto; Telar, para todo lo que quieres conservar.',
  },
  {
    q: '¿Dónde están los datos?',
    a: 'En infraestructura propia de Startidea en España/UE, en una instancia aislada solo tuya, con copia de seguridad diaria cifrada y vigilancia 24/7.',
  },
  {
    q: '¿Es difícil de usar para gente poco técnica?',
    a: 'Es una web sencilla, sin apps que instalar. La formación inicial de 2 horas está incluida y el soporte queda abierto. Está pensada para asociaciones con miembros de todas las edades.',
  },
  {
    q: '¿Podemos migrar o exportar si un día queremos?',
    a: 'Sí. Los datos son tuyos y exportables. Sin secuestro de información ni dependencia forzada.',
  },
  {
    q: '¿Se puede adaptar a lo que necesitamos?',
    a: 'Sí. Sobre la base común, Startidea ya tiene módulos probados (campañas y narrativas, donativos con remesa SEPA y modelo 182, agregador de noticias de entidades) y puede desarrollar los que pida tu red.',
  },
];

const jsonLd = [
  faqPageSchema(faqs),
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Telar', url: `${SITE_URL}/telar` },
  ]),
];

const planes = [
  {
    nombre: 'Comunidad',
    precio: '120',
    resumen: 'Tu comunidad propia, gestionada.',
    items: ['Plataforma completa', 'Hosting + backup cifrado + vigilancia', 'Soporte y actualizaciones'],
  },
  {
    nombre: 'Comunidad Plus',
    precio: '220',
    destacado: true,
    resumen: 'Con boletín y evolución a medida.',
    items: ['Todo lo de Comunidad', 'Boletín gestionado', '1 módulo a medida por trimestre'],
  },
];

const modulos = [
  { title: 'Muro y grupos', body: 'El día a día de la comunidad: publicaciones, conversación, grupos temáticos.' },
  { title: 'Proyectos y mapa de la red', body: 'Qué hace cada miembro, dónde, y cómo se conectan entre sí.' },
  { title: 'Campus y documentos', body: 'Formación interna y biblioteca compartida, versionada.' },
  { title: 'Boletín propio', body: 'Newsletter a tus miembros desde tu plataforma, no desde una red ajena.' },
  { title: 'Tareas y tablero', body: 'Coordinación de trabajo entre entidades o comisiones.' },
  { title: 'Módulos a medida', body: 'Donativos (SEPA + modelo 182), campañas, agregador de noticias… ya probados.' },
];
---

<Base
  title="Telar — plataforma de comunidad propia para entidades y redes | Startidea"
  description="Una plataforma de comunidad propia y gestionada: muro, grupos, proyectos, formación y boletín. Los datos son tuyos, alojados en España. Startidea la gestiona de punta a punta."
  ogSlug="page/telar"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24 lg:py-28">
    <div class="container-x">
      <span class="label">— Telar · comunidad digital</span>
      <h1 class="mt-4 font-display text-display-xl leading-[0.96] text-ink">
        Tu comunidad, en tu casa.<br/>
        <em class="italic text-magenta">No en la de Facebook.</em>
      </h1>
      <p class="mt-8 max-w-measure text-lede text-ink/80">
        Telar es una plataforma propia para tu red de personas o entidades: muro, grupos, proyectos, formación y boletín. Los datos son tuyos. La gestiona Startidea de principio a fin.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/contacto" class="btn" data-track="cta" data-track-id="telar_demo_hero">
          Ver una demo
          <span aria-hidden="true">→</span>
        </a>
        <a href="#planes" class="btn-ghost">Ver planes</a>
      </div>
    </div>
  </section>

  <!-- Problema -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-20">
    <div class="container-x grid grid-cols-12 gap-x-8">
      <div class="col-span-12 lg:col-span-8">
        <span class="label">— El problema</span>
        <p class="mt-6 font-display text-display-md leading-tight text-ink">
          Tu comunidad vive dispersa en grupos de WhatsApp y en una página que no controlas.
        </p>
        <p class="mt-6 max-w-measure text-lede text-ink/70">
          No tienes los datos, no puedes segmentar, el alcance lo decide un algoritmo ajeno y el histórico se pierde. Montar algo propio parece caro y complejo.
        </p>
      </div>
    </div>
  </section>

  <!-- Solución -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24">
    <div class="container-x">
      <span class="label">— La solución</span>
      <h2 class="mt-4 max-w-measure font-display text-display-md leading-tight text-ink">
        Una plataforma completa y <em class="italic text-magenta">tuya</em>. Gestionada por Startidea.
      </h2>
      <div class="mt-12 grid grid-cols-1 gap-x-8 gap-y-8 md:grid-cols-3">
        {modulos.map((m) => (
          <div class="border-t border-ink/20 pt-5">
            <h3 class="font-display text-xl text-ink">{m.title}</h3>
            <p class="mt-2 text-sm text-ink/70">{m.body}</p>
          </div>
        ))}
      </div>
      <p class="mt-10 max-w-measure text-ink/70">
        Alojada en infraestructura de Startidea en España, sin depender de redes de terceros. Tú no la administras: hosting, copias cifradas, vigilancia y soporte corren por cuenta de Startidea.
      </p>
    </div>
  </section>

  <!-- Caso real -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-20">
    <div class="container-x grid grid-cols-12 gap-x-8">
      <div class="col-span-12 lg:col-span-9">
        <span class="label">— Caso real</span>
        <p class="mt-6 font-display text-display-md leading-tight text-ink">
          <em class="italic text-magenta">56 entidades</em> coordinadas en una sola plataforma.
        </p>
        <p class="mt-6 max-w-measure text-lede text-ink/70">
          La red REDES ONGD usa Telar para coordinar a sus entidades socias: muro común, proyectos compartidos, boletín propio y un panel de salud de la red. Un caso vivo, no una maqueta.
        </p>
      </div>
    </div>
  </section>

  <!-- Planes -->
  <section id="planes" class="border-b border-ink/15 bg-paper py-16 md:py-24">
    <div class="container-x">
      <span class="label">— Planes</span>
      <h2 class="mt-4 font-display text-display-md leading-tight text-ink">Gestión completa, precio fijo.</h2>
      <div class="mt-12 grid grid-cols-1 gap-5 md:grid-cols-2 lg:max-w-3xl">
        {planes.map((plan) => (
          <div class={`flex flex-col rounded-lg border p-6 ${plan.destacado ? 'border-magenta bg-ink text-paper' : 'border-ink/20 bg-paper text-ink'}`}>
            <span class={`label ${plan.destacado ? '!text-magenta' : ''}`}>{plan.nombre}</span>
            <p class="mt-4 font-display text-5xl leading-none">
              {plan.precio}&nbsp;€
              <span class={`text-lg ${plan.destacado ? 'text-paper/60' : 'text-ink/50'}`}>/mes</span>
            </p>
            <p class={`mt-3 text-sm ${plan.destacado ? 'text-paper/70' : 'text-ink/60'}`}>{plan.resumen}</p>
            <ul class="mt-6 flex-1 space-y-2 text-sm">
              {plan.items.map((it) => (
                <li class="flex gap-2">
                  <span class="text-magenta" aria-hidden="true">→</span>
                  <span class={plan.destacado ? 'text-paper/90' : 'text-ink/80'}>{it}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contacto"
              class={`btn mt-8 ${plan.destacado ? '!bg-paper !text-ink !border-paper hover:!bg-magenta hover:!text-paper hover:!border-magenta' : ''}`}
              data-track="cta"
              data-track-id={`telar_plan_${plan.nombre.toLowerCase().replace(/\s+/g, '_')}`}
            >
              Solicitar propuesta
              <span aria-hidden="true">→</span>
            </a>
          </div>
        ))}
      </div>
      <p class="mt-6 text-sm text-ink/50">Puesta en marcha: 900–1.500&nbsp;€ (despliegue, tu marca y dominio, importación de miembros, formación de 2&nbsp;h). Según tamaño de la comunidad.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24">
    <div class="container-x">
      <span class="label">— Preguntas frecuentes</span>
      <div class="mt-10 max-w-measure divide-y divide-ink/15">
        {faqs.map((f) => (
          <details class="group py-5">
            <summary class="cursor-pointer list-none font-display text-xl text-ink">{f.q}</summary>
            <p class="mt-3 text-ink/70">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="bg-ink py-20 text-paper md:py-24">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8">
        <div class="col-span-12 lg:col-span-9">
          <span class="label !text-paper/60">— Telar</span>
          <h2 class="mt-4 font-display text-display-md leading-tight text-paper">
            Deja de alquilar tu comunidad<br/>
            <em class="italic text-magenta">a una red social.</em>
          </h2>
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="/contacto"
              class="btn !bg-paper !text-ink !border-paper hover:!bg-magenta hover:!text-paper hover:!border-magenta"
              data-track="cta" data-track-id="telar_demo_final"
            >
              Pedir demo de Telar
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
