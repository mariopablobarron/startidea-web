---
// /subvenciones/categoria/[categoria] — Landing SEO por finalidad
// (cultura, servicios sociales, educación, empleo, i+d+i...).
//
// 19 finalidades canónicas → 19 landings con título, descripción y top 50.

import Base from '@/layouts/Base.astro';
import SubsidyCard from '@/components/SubsidyCard.astro';
import { fetchSubsidies, FINALIDADES, finalidadLabel } from '@/lib/subsidies-api';
import { breadcrumbList, SITE_URL } from '@/lib/jsonld';

export async function getStaticPaths() {
  return FINALIDADES.map((f) => ({ params: { categoria: f.slug } }));
}

const { categoria } = Astro.params;
const label = finalidadLabel(categoria as string);

const data = await fetchSubsidies({
  status: 'abierto',
  finalidad: categoria as string,
  pageSize: 50,
  sort: 'recent',
});

const title = `Subvenciones de ${label} · Buscador Startidea`;
const description = `${data.total.toLocaleString('es-ES')} subvenciones abiertas de ${label} en España: estatales, autonómicas, locales y europeas. Listado actualizado diariamente desde BDNS.`;

const jsonLd = [
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Subvenciones', url: `${SITE_URL}/subvenciones` },
    { name: label, url: `${SITE_URL}/subvenciones/categoria/${categoria}` },
  ]),
];
---

<Base title={title} description={description} ogSlug="page/subvenciones" jsonLd={jsonLd}>
  <section class="border-b border-ink/15 bg-paper py-16 md:py-20">
    <div class="container-x">
      <nav aria-label="Breadcrumb" class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">
        <a href="/subvenciones" class="hover:text-magenta">← Buscador</a>
      </nav>
      <span class="label mt-4">— Categoría</span>
      <h1 class="mt-3 font-display text-display-xl leading-[0.96] text-ink">
        Subvenciones de<br />
        <em class="italic text-magenta">{label.toLowerCase()}</em>.
      </h1>
      <p class="mt-6 max-w-measure text-lede text-ink/80">
        {data.total.toLocaleString('es-ES')} convocatorias abiertas en España:
        estatales, autonómicas, diputaciones, ayuntamientos y universidades.
        Las leemos del BOE, BOJA y BDNS — y las filtramos editorialmente
        para que tengan sentido para el tercer sector.
      </p>
    </div>
  </section>

  <section class="bg-paper py-12 md:py-16">
    <div class="container-x">
      {data.items.length === 0 ? (
        <p class="py-16 text-center text-ink-mute">
          Sin convocatorias abiertas ahora mismo en {label}. Vuelve en unos días.
        </p>
      ) : (
        <div>
          {data.items.map((item) => <SubsidyCard item={item} />)}
        </div>
      )}

      {data.totalPages > 1 && (
        <div class="mt-10 text-center">
          <a href={`/subvenciones?finalidad=${categoria}`} class="btn">
            Ver todas las {data.total.toLocaleString('es-ES')} convocatorias →
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- CTA alerta -->
  <section class="bg-paper-warm py-12 md:py-16">
    <div class="container-x text-center">
      <span class="label">— Alerta</span>
      <h2 class="mt-3 font-display text-display-md leading-tight text-ink">
        Crea una alerta de <em class="italic text-magenta">{label.toLowerCase()}</em>.
      </h2>
      <p class="mx-auto mt-4 max-w-measure text-ink/75">
        Te avisamos por email cuando aparezca una nueva convocatoria de
        {' '}{label.toLowerCase()} que encaje con tu organización. Gratis.
      </p>
      <a
        href={`/subvenciones/crear-alerta?finalidad=${categoria}`}
        class="btn mt-6 inline-flex"
      >
        Crear alerta →
      </a>
    </div>
  </section>
</Base>
