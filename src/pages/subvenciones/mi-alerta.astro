---
// /subvenciones/mi-alerta?t=TOKEN — Permite ver/borrar la propia alerta
// sin necesidad de login (manage_token actúa como bearer).

import Base from '@/layouts/Base.astro';
---

<Base
  title="Mi alerta · Startidea"
  description="Gestiona tu alerta de subvenciones."
  ogSlug="page/subvenciones"
  noindex={true}
>
  <section class="border-b border-ink/15 bg-paper py-16 md:py-20">
    <div class="container-x">
      <nav aria-label="Breadcrumb" class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">
        <a href="/subvenciones" class="hover:text-magenta">← Buscador</a>
      </nav>
      <span class="label mt-4">— Mi alerta</span>
      <h1 class="mt-3 font-display text-display-lg leading-tight text-ink">
        Tu alerta activa.
      </h1>
    </div>
  </section>

  <section class="bg-paper py-12 md:py-16">
    <div class="container-x">
      <div id="mi-alerta-content" class="mx-auto max-w-2xl">
        <p class="text-ink-mute">Cargando…</p>
      </div>
    </div>
  </section>
</Base>

<script>
  const API_BASE =
    (import.meta as any).env?.PUBLIC_HUB_BASE_URL ?? 'https://hub.startidea.tech';
  const url = new URL(window.location.href);
  const token = url.searchParams.get('t');
  const root = document.getElementById('mi-alerta-content')!;

  if (!token) {
    root.innerHTML = `
      <p class="text-magenta">Falta el token. Usa el enlace que recibiste por email.</p>`;
  } else {
    void load(token);
  }

  async function load(t: string) {
    try {
      const res = await fetch(
        `${API_BASE}/api/public/subsidy-watch/${encodeURIComponent(t)}`,
      );
      if (!res.ok) {
        root.innerHTML = `
          <p class="text-magenta">No encontramos esa alerta. Tal vez ya la borraste.</p>`;
        return;
      }
      const j = await res.json();
      const w = j.watch;
      root.innerHTML = `
        <dl class="grid gap-3 border border-ink/15 bg-paper-warm/40 p-5 text-sm">
          <div><dt class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Nombre</dt><dd class="text-ink">${esc(w.name)}</dd></div>
          <div><dt class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Email</dt><dd class="text-ink">${esc(w.notify_recipient ?? '—')}</dd></div>
          <div><dt class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Palabras clave</dt><dd class="text-ink">${esc(w.keywords)}</dd></div>
          <div><dt class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Territorio</dt><dd class="text-ink">${esc(w.territory)}</dd></div>
          <div><dt class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Estado</dt><dd class="text-ink">${w.active ? 'Activa' : 'Inactiva'} · ${w.email_verified ? 'Email verificado' : 'Pendiente de verificar'}</dd></div>
        </dl>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/subvenciones/crear-alerta" class="btn">Crear otra alerta</a>
          <button id="del" type="button" class="border border-ink/25 px-4 py-2 font-mono text-xs uppercase tracking-widest text-magenta hover:bg-paper-warm">
            Borrar esta alerta
          </button>
        </div>
        <p id="del-result" class="mt-3 hidden text-xs"></p>`;
      document.getElementById('del')!.addEventListener('click', async () => {
        if (!confirm('¿Borrar esta alerta? No podrás recuperarla.')) return;
        try {
          const r = await fetch(
            `${API_BASE}/api/public/subsidy-watch/${encodeURIComponent(t)}`,
            { method: 'DELETE' },
          );
          const out = document.getElementById('del-result')!;
          out.classList.remove('hidden');
          if (r.ok) {
            out.textContent = 'Alerta borrada. Redirigiendo…';
            setTimeout(() => (window.location.href = '/subvenciones'), 1500);
          } else {
            out.textContent = 'No se pudo borrar.';
          }
        } catch {
          alert('Error de red.');
        }
      });
    } catch {
      root.innerHTML = `<p class="text-magenta">Error de red.</p>`;
    }
  }

  function esc(s: string): string {
    return String(s ?? '').replace(/[&<>"]/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!,
    );
  }
</script>
