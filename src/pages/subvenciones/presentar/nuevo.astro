---
import Base from '@/layouts/Base.astro';
import { breadcrumbList, SITE_URL } from '@/lib/jsonld';
import { listConvocatoriasActivas } from '@/lib/expedientes-db';

export const prerender = false;

// Parámetros de pre-selección desde landings BOJA o el buscador
const convSlugParam  = Astro.url.searchParams.get('slug')  ?? '';
const convTitleParam = Astro.url.searchParams.get('title') ?? '';

const jsonLd = [
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Subvenciones', url: `${SITE_URL}/subvenciones` },
    { name: 'Presentar subvención', url: `${SITE_URL}/subvenciones/presentar` },
    { name: 'Nuevo expediente', url: `${SITE_URL}/subvenciones/presentar/nuevo` },
  ]),
];

// ─── Catálogo de convocatorias activas — ahora viene de la BD ─────────────────
let CONV_DATA: ReturnType<typeof listConvocatoriasActivas> = [];
try { CONV_DATA = listConvocatoriasActivas(); } catch { CONV_DATA = []; }

---

<Base
  title="Nuevo expediente de subvención — Startidea"
  description="Elige la convocatoria, revisa los requisitos y envía el expediente. En 24–48h el equipo de Startidea te entrega el diagnóstico de encaje, la memoria técnica y el presupuesto."
  ogSlug="page/subvenciones-presentar"
  jsonLd={jsonLd}
>
  <section class="border-b border-ink/15 bg-paper-warm py-10 md:py-14">
    <div class="container-x">
      <span class="label">— Nuevo expediente</span>
      <h1 class="mt-3 font-display text-display-md leading-tight text-ink">
        Arranca el expediente.<br />
        <em class="text-magenta italic">Sin coste hasta que se concede.</em>
      </h1>
      <p class="mt-3 max-w-measure text-ink/70">
        Rellena los datos de tu entidad, elige la convocatoria que os interesa y sube lo que tengas. En 24–48h Startidea os envía el diagnóstico de encaje: si tiene sentido presentarse y qué documentación falta.
      </p>
    </div>
  </section>

  <section class="bg-paper py-12 md:py-20">
    <div class="container-x">
      <div class="mx-auto max-w-2xl">

        <!-- Indicador de pasos -->
        <div id="step-indicator" class="mb-10 flex items-center gap-0">
          {[
            { n: 1, label: 'La entidad' },
            { n: 2, label: 'Convocatoria' },
            { n: 3, label: 'Documentos' },
            { n: 4, label: 'Confirmar' },
          ].map((s, i) => (
            <>
              <div class="flex flex-col items-center" data-step-dot={s.n}>
                <div class="flex h-8 w-8 items-center justify-center border-2 border-ink/20 bg-paper font-mono text-sm text-ink/40 transition-colors" data-dot-circle>
                  {s.n}
                </div>
                <span class="mt-1 hidden font-mono text-[10px] uppercase tracking-wider text-ink/40 sm:block" data-dot-label>{s.label}</span>
              </div>
              {i < 3 && <div class="h-px flex-1 bg-ink/15" />}
            </>
          ))}
        </div>

        <!-- Formulario -->
        <form id="expediente-form" novalidate>

          <!-- Campos ocultos para la convocatoria seleccionada — se rellenan por JS -->
          <input type="hidden" name="convocatoriaSlug"  id="f-conv-slug"   value={convSlugParam} />
          <input type="hidden" name="convocatoriaNombre" id="f-conv-nombre" value={convTitleParam} />
          <input type="hidden" name="convocatoriaUrl"   id="f-conv-url"    value="" />
          <input type="hidden" name="tieneConvocatoria" id="f-tiene-conv"  value={convTitleParam ? 'si' : ''} />

          <!-- ═══════════════════════════════════════════════════════════════
               PASO 1: La entidad
          ═══════════════════════════════════════════════════════════════ -->
          <fieldset id="step-1" class="step-panel space-y-6">
            <legend class="font-display text-2xl text-ink">Tu entidad</legend>
            <p class="text-sm text-ink/60">Los datos del organismo que va a presentarse a la subvención.</p>

            <div class="space-y-1">
              <label for="orgName" class="label">Nombre de la organización <span class="text-magenta">*</span></label>
              <input type="text" id="orgName" name="orgName" required maxlength="200" placeholder="Fundación Ejemplo" class="form-input w-full" />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-1">
                <label for="cif" class="label">CIF / NIF <span class="text-magenta">*</span></label>
                <input type="text" id="cif" name="cif" required maxlength="20" placeholder="G12345678" class="form-input w-full" />
              </div>
              <div class="space-y-1">
                <label for="orgType" class="label">Tipo de entidad <span class="text-magenta">*</span></label>
                <select id="orgType" name="orgType" required class="form-input w-full">
                  <option value="">Selecciona…</option>
                  <option value="asociacion">Asociación</option>
                  <option value="fundacion">Fundación</option>
                  <option value="cooperativa">Cooperativa</option>
                  <option value="entidad-religiosa">Entidad religiosa</option>
                  <option value="entidad-local">Entidad local (ayuntamiento, diputación…)</option>
                  <option value="empresa">Empresa</option>
                  <option value="otro">Otro</option>
                </select>
              </div>
            </div>

            <div class="space-y-1">
              <label for="representante" class="label">Representante legal <span class="text-magenta">*</span></label>
              <input type="text" id="representante" name="representante" required maxlength="120" placeholder="Nombre y apellidos" class="form-input w-full" />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-1">
                <label for="email" class="label">Email de contacto <span class="text-magenta">*</span></label>
                <input type="email" id="email" name="email" required maxlength="120" placeholder="tu@entidad.org" class="form-input w-full" />
              </div>
              <div class="space-y-1">
                <label for="telefono" class="label">Teléfono</label>
                <input type="tel" id="telefono" name="telefono" maxlength="20" placeholder="600 000 000" class="form-input w-full" />
              </div>
            </div>

            <div class="space-y-1">
              <label for="provincia" class="label">Provincia / Comunidad Autónoma <span class="text-magenta">*</span></label>
              <input type="text" id="provincia" name="provincia" required maxlength="80" placeholder="Granada, Andalucía" class="form-input w-full" />
            </div>
          </fieldset>

          <!-- ═══════════════════════════════════════════════════════════════
               PASO 2: La convocatoria — selector tipo plataforma
          ═══════════════════════════════════════════════════════════════ -->
          <fieldset id="step-2" class="step-panel hidden space-y-6">
            <legend class="font-display text-2xl text-ink">Elige la subvención</legend>
            <p class="text-sm text-ink/60">
              Estas son las convocatorias activas que Startidea tramita ahora mismo. Haz clic en una para ver todos los detalles: quién puede pedir, qué gastos cubre, importe orientativo y plazo. Si ninguna encaja, usa las opciones del final.
            </p>

            <!-- Filtro por tipo de entidad -->
            <div class="flex flex-wrap items-center gap-2">
              <span class="font-mono text-[10px] uppercase tracking-widest text-ink/35">Ver:</span>
              <button type="button" data-conv-filter="all"     class="conv-filter-btn px-3 py-1.5 border font-mono text-[10px] uppercase tracking-wider transition-colors border-ink bg-ink text-paper">Todas ({CONV_DATA.length})</button>
              <button type="button" data-conv-filter="privada" class="conv-filter-btn px-3 py-1.5 border font-mono text-[10px] uppercase tracking-wider transition-colors border-ink/20 text-ink/60 hover:border-ink hover:text-ink">Tercer sector ({CONV_DATA.filter(c => c.beneficiario === 'privada').length})</button>
              <button type="button" data-conv-filter="local"   class="conv-filter-btn px-3 py-1.5 border font-mono text-[10px] uppercase tracking-wider transition-colors border-ink/20 text-ink/60 hover:border-ink hover:text-ink">Entidades locales ({CONV_DATA.filter(c => c.beneficiario === 'local').length})</button>
            </div>

            <!-- Widget de matching — perfil rápido de la entidad -->
            <div id="matching-widget" class="border border-ink/15 bg-paper p-4 space-y-4 transition-all">
              <div class="flex items-center justify-between gap-3 flex-wrap">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-widest text-ink/50 flex items-center gap-2">
                    <span class="text-magenta">🎯</span> ¿Cuál os encaja? — 2 preguntas rápidas
                  </p>
                  <p class="text-xs text-ink/40 mt-0.5">Las tarjetas se ordenan automáticamente según vuestro perfil.</p>
                </div>
                <button type="button" id="mw-reset" class="font-mono text-[9px] uppercase tracking-widest text-ink/30 hover:text-magenta hidden">
                  Borrar filtro ×
                </button>
              </div>

              <!-- Pregunta: Registro de Entidades de Servicios Sociales (privada) -->
              <div id="mw-row-registro" class="hidden">
                <p class="text-sm font-medium text-ink mb-2">
                  ¿Estáis inscritos en el <strong>Registro de Entidades de Servicios Sociales</strong> de la Junta de Andalucía?
                </p>
                <div class="flex flex-wrap gap-2" role="radiogroup">
                  {[
                    { val: 'si',    label: 'Sí, estamos inscritos' },
                    { val: 'no',    label: 'No estamos inscritos' },
                    { val: 'no_se', label: 'No lo sé' },
                  ].map(({ val, label }) => (
                    <label class="mw-chip-label cursor-pointer px-3 py-1.5 border border-ink/20 font-mono text-[10px] uppercase tracking-wider text-ink/60 hover:border-ink hover:text-ink transition-colors">
                      <input type="radio" name="mw_registro_ss" value={val} class="sr-only" />
                      {label}
                    </label>
                  ))}
                </div>
              </div>

              <!-- Pregunta: Al corriente AEAT / TGSS -->
              <div>
                <p class="text-sm font-medium text-ink mb-2">
                  ¿Estáis al corriente de obligaciones con <strong>Hacienda (AEAT) y Seguridad Social (TGSS)</strong>?
                </p>
                <div class="flex flex-wrap gap-2" role="radiogroup">
                  {[
                    { val: 'si', label: 'Sí, al corriente' },
                    { val: 'no', label: 'Tenemos alguna deuda o duda' },
                  ].map(({ val, label }) => (
                    <label class="mw-chip-label cursor-pointer px-3 py-1.5 border border-ink/20 font-mono text-[10px] uppercase tracking-wider text-ink/60 hover:border-ink hover:text-ink transition-colors">
                      <input type="radio" name="mw_corriente" value={val} class="sr-only" />
                      {label}
                    </label>
                  ))}
                </div>
              </div>

              <!-- Colectivos (solo para privada) -->
              <div id="mw-row-colectivos" class="hidden">
                <p class="text-sm font-medium text-ink mb-2">
                  ¿Con qué colectivos trabajáis? <span class="font-normal text-ink/40">(selecciona los que apliquen)</span>
                </p>
                <div class="flex flex-wrap gap-2">
                  {[
                    { val: 'todos',           label: 'Inclusión social general' },
                    { val: 'alimentario',     label: 'Emergencia alimentaria' },
                    { val: 'menores_verano',  label: 'Menores en verano' },
                    { val: 'mujer_joven',     label: 'Mujeres jóvenes ex-tuteladas' },
                    { val: 'comunidad_gitana',label: 'Comunidad Gitana' },
                    { val: 'inmigrantes',     label: 'Inmigrantes / Temporeros' },
                    { val: 'participacion',   label: 'Participación ciudadana' },
                  ].map(({ val, label }) => (
                    <label class="mw-chip-label cursor-pointer px-3 py-1.5 border border-ink/20 font-mono text-[10px] uppercase tracking-wider text-ink/60 hover:border-ink hover:text-ink transition-colors">
                      <input type="checkbox" name="mw_colectivo" value={val} class="sr-only" />
                      {label}
                    </label>
                  ))}
                </div>
              </div>
            </div>

            <!-- Aviso fuente -->
            <div class="flex items-start gap-2 text-xs text-ink/40">
              <span>📋</span>
              <span>Convocatorias del BOJA nº 99 (26 mayo 2026) — Consejería de Inclusión Social, Juventud, Familias e Igualdad. Plazo general hasta el 16 de junio de 2026.</span>
            </div>

            <!-- Grid de tarjetas de convocatoria -->
            <div id="conv-grid" class="space-y-2">
              {CONV_DATA.map(conv => (
                <div
                  class="conv-card border border-ink/15 bg-paper transition-all"
                  data-conv-slug={conv.slug}
                  data-conv-filter={conv.beneficiario}
                  data-conv-title={conv.tituloFull}
                  data-conv-url={conv.bojaUrl ?? ''}
                >
                  <!-- Cabecera de la tarjeta (siempre visible, clickable) -->
                  <button
                    type="button"
                    class="conv-card-header w-full text-left px-4 py-3.5 hover:bg-paper-warm/80 transition-colors"
                    aria-expanded="false"
                  >
                    <div class="flex items-start gap-3">
                      <!-- Badge ID -->
                      <span class="conv-id-badge shrink-0 flex items-center justify-center w-10 h-10 border border-magenta/30 font-mono text-xs font-bold text-magenta bg-magenta/5 mt-0.5 transition-colors">
                        {conv.codigo}
                      </span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                          <p class="font-medium text-ink text-sm leading-snug">{conv.titulo}</p>
                          <div class="shrink-0 text-right">
                            <span class="font-mono text-[10px] text-amber-600 whitespace-nowrap">⏰ {conv.deadlineShort}</span>
                            {conv.deadlineNote && <p class="text-[9px] text-amber-500 mt-0.5">{conv.deadlineNote}</p>}
                          </div>
                        </div>
                        <p class="mt-0.5 text-xs text-ink/50">{conv.beneficiarioLabel}</p>
                        <!-- Badge de encaje (rellena el motor de matching) -->
                        <span class="conv-match-badge hidden items-center gap-1 mt-1.5 px-2 py-0.5 font-mono text-[9px] uppercase tracking-widest border"></span>
                        <!-- 3 bullets resumen -->
                        <ul class="mt-2 space-y-0.5">
                          {conv.financiaResumen.map(b => (
                            <li class="flex items-start gap-1.5 text-xs text-ink/65">
                              <span class="shrink-0 text-green-600 mt-0.5 leading-none">▸</span>
                              <span>{b}</span>
                            </li>
                          ))}
                        </ul>
                        <p class="mt-2 font-mono text-[10px] text-ink/35">Importe orientativo: {conv.importeRange}</p>
                      </div>
                      <!-- Flecha expand/collapse -->
                      <span class="conv-arrow shrink-0 font-mono text-ink/25 mt-1 transition-transform duration-200 text-sm select-none">↓</span>
                    </div>
                  </button>

                  <!-- Banner de seleccionada (visible cuando está elegida) -->
                  <div class="conv-selected-banner hidden items-center gap-3 border-t border-magenta/30 bg-magenta/5 px-4 py-2.5">
                    <span class="text-magenta font-bold">✓</span>
                    <p class="text-sm font-medium text-ink flex-1">Convocatoria seleccionada</p>
                    <button type="button" class="conv-deselect-btn font-mono text-[10px] uppercase tracking-wider text-ink/45 hover:text-magenta shrink-0">
                      Cambiar →
                    </button>
                  </div>

                  <!-- Panel de detalles (expandible, oculto por defecto) -->
                  <div class="conv-details hidden border-t border-ink/10">
                    <div class="divide-y divide-ink/8">
                      <div class="bg-paper-warm/50 px-5 py-4">
                        <p class="font-mono text-[10px] uppercase tracking-widest text-magenta mb-2">Quién puede solicitarla</p>
                        <p class="text-sm text-ink/80 leading-relaxed">{conv.tipoEntidades}</p>
                      </div>
                      <div class="bg-paper-warm/50 px-5 py-4">
                        <p class="font-mono text-[10px] uppercase tracking-widest text-ink/45 mb-2">✅ Qué se puede subvencionar</p>
                        <ul class="space-y-1">
                          {conv.gastosOk.map(g => (
                            <li class="flex items-start gap-2 text-sm text-ink/75">
                              <span class="mt-0.5 text-green-600 shrink-0 text-xs leading-none">▸</span>
                              <span>{g}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                      <div class="bg-paper-warm/50 px-5 py-4">
                        <p class="font-mono text-[10px] uppercase tracking-widest text-ink/45 mb-2">❌ Qué NO cubre</p>
                        <ul class="space-y-1">
                          {conv.gastosNo.map(g => (
                            <li class="flex items-start gap-2 text-sm text-ink/60">
                              <span class="mt-0.5 text-red-400 shrink-0 text-xs leading-none">✗</span>
                              <span>{g}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                      <div class="bg-paper-warm/50 px-5 py-4">
                        <p class="font-mono text-[10px] uppercase tracking-widest text-ink/45 mb-1.5">€ Orientación de importe</p>
                        <p class="text-sm text-ink/75 leading-relaxed">{conv.importe}</p>
                      </div>
                      <div class="bg-paper-warm/50 px-5 py-4">
                        <p class="font-mono text-[10px] uppercase tracking-widest text-ink/45 mb-2">Condiciones para poder solicitar</p>
                        <ul class="space-y-1">
                          {conv.requisitos.map(r => (
                            <li class="flex items-start gap-2 text-sm text-ink/75">
                              <span class="mt-0.5 text-magenta shrink-0 leading-none">·</span>
                              <span>{r}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                      <div class="bg-amber-50 px-5 py-3">
                        <p class="text-sm font-semibold text-amber-800">⏰ Plazo: {conv.deadline}</p>
                        {conv.nota && <p class="mt-1 text-xs text-amber-700">{conv.nota}</p>}
                      </div>
                    </div>
                    <!-- CTA dentro del panel de detalles -->
                    <div class="border-t border-magenta/20 bg-magenta/5 px-5 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                      <p class="text-xs text-ink/60 leading-relaxed">
                        Startidea verifica el encaje real en el diagnóstico (24–48h). Si no encaja al 100 %, te lo decimos antes de seguir.
                      </p>
                      <button type="button" class="conv-select-btn shrink-0 btn text-sm">
                        Me interesa — continuar →
                      </button>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Error si no se ha seleccionado nada -->
            <div id="conv-error" class="hidden border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700">
              Selecciona una convocatoria de la lista, indica la tuya en la sección de abajo, o elige "Que Startidea lo analice".
            </div>

            <!-- Alternativas -->
            <div class="space-y-3 border-t border-ink/10 pt-4">
              <p class="font-mono text-[10px] uppercase tracking-widest text-ink/35">¿Ninguna de las anteriores?</p>

              <!-- Mi convocatoria es diferente -->
              <details class="border border-ink/15" id="other-conv-panel">
                <summary class="cursor-pointer select-none flex items-center gap-3 px-4 py-3 hover:bg-paper-warm">
                  <span class="font-mono text-[11px] uppercase tracking-wider text-ink/60">
                    Tengo una convocatoria diferente o que no está en la lista
                  </span>
                  <span class="ml-auto font-mono text-xs text-ink/30">↓</span>
                </summary>
                <div class="space-y-4 border-t border-ink/8 p-4">
                  <div class="space-y-1">
                    <label for="other-nombre" class="label">Nombre de la subvención</label>
                    <input
                      type="text"
                      id="other-nombre"
                      maxlength="300"
                      placeholder="Ej: Subvenciones acción social Diputación de Granada 2026"
                      class="form-input w-full"
                    />
                  </div>
                  <div class="space-y-1">
                    <label for="other-url" class="label">Enlace (si lo tienes)</label>
                    <input
                      type="url"
                      id="other-url"
                      maxlength="500"
                      placeholder="https://… (BOE, BOJA, sede electrónica…)"
                      class="form-input w-full"
                    />
                    <p class="text-xs text-ink/35">No obligatorio. Con el nombre es suficiente para localizarla.</p>
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                      <label for="plazo" class="label">Fecha límite</label>
                      <input type="date" id="plazo" name="plazo" class="form-input w-full" />
                    </div>
                    <div class="space-y-1">
                      <label for="importeSolicitado" class="label">¿Cuánto queréis solicitar?</label>
                      <input type="text" id="importeSolicitado" name="importeSolicitado" maxlength="30" placeholder="Ej: 20.000 €" class="form-input w-full" />
                    </div>
                  </div>
                  <div id="other-conv-confirm" class="hidden border border-magenta/30 bg-magenta/5 p-3 text-sm text-ink">
                    <span class="text-magenta font-bold mr-2">✓</span>Convocatoria manual registrada.
                    <button type="button" id="btn-clear-other" class="ml-2 font-mono text-[10px] text-ink/40 hover:text-magenta uppercase">Limpiar</button>
                  </div>
                </div>
              </details>

              <!-- No sé cuál me interesa -->
              <label class="flex cursor-pointer items-start gap-3 border border-ink/15 p-4 hover:border-ink/30 has-[:checked]:border-magenta has-[:checked]:bg-magenta/5">
                <input type="radio" id="conv-no-se" name="conv-no-se-radio" value="no-se" class="accent-magenta mt-0.5 shrink-0" />
                <div>
                  <p class="font-mono text-[11px] uppercase tracking-wider text-ink/65">Que Startidea lo analice y encuentre la convocatoria</p>
                  <p class="mt-1 text-xs text-ink/50 leading-relaxed">
                    Con la descripción de vuestra actividad y necesidades, Startidea identifica las convocatorias con mejor encaje y os las presenta en el diagnóstico. Sin coste.
                  </p>
                </div>
              </label>

              <!-- Importe estimado (solo para "no sé") -->
              <div id="no-se-importe" class="hidden space-y-1 pl-7">
                <label for="importeEstimado" class="label">¿Cuánta financiación necesitáis?</label>
                <input type="text" id="importeEstimado" name="importeEstimado" maxlength="30" placeholder="Ej: 30.000 €" class="form-input w-full" />
              </div>
            </div>

            <!-- ─── Descripción del proyecto ─────────────────────────────────── -->
            <div class="space-y-2 border-t border-ink/10 pt-6">
              <label for="descripcionProyecto" class="label text-base">
                ¿Qué hace vuestra entidad y para qué necesitáis la subvención?
                <span class="text-magenta">*</span>
              </label>
              <p class="text-xs text-ink/50 leading-relaxed">
                No tiene que ser perfecto — Startidea lo refinará. Con 3–4 frases es suficiente para arrancar.
              </p>
              <textarea
                id="descripcionProyecto"
                name="descripcionProyecto"
                rows="5"
                required
                maxlength="2000"
                placeholder="Ej: Somos una asociación de atención a personas mayores en Granada. Llevamos 15 años gestionando el centro de día y el servicio de ayuda a domicilio. Queremos financiar la ampliación del servicio a 20 personas más en 2026, incluyendo personal de atención y material adaptado."
                class="form-input w-full resize-none"
              ></textarea>
              <details class="text-xs">
                <summary class="cursor-pointer text-ink/40 hover:text-ink/70">¿No sé qué escribir? Ver guía rápida</summary>
                <div class="mt-2 space-y-1 border border-ink/10 bg-paper-warm p-3 text-ink/60">
                  <p><strong>Responde estas 3 preguntas:</strong></p>
                  <p>1. ¿A quién ayuda vuestra entidad y cómo? (colectivo y tipo de servicio)</p>
                  <p>2. ¿Qué proyecto o programa queréis hacer con la subvención?</p>
                  <p>3. ¿Cuántas personas se beneficiarán y en qué plazo?</p>
                  <p class="mt-2 text-ink/40">No hace falta que sea largo. Si luego necesitamos más datos, os los pedimos.</p>
                </div>
              </details>
              <p class="text-xs text-ink/30">Máximo 2000 caracteres. <span id="chars-left">2000</span> restantes.</p>
            </div>

            <!-- ─── Datos de impacto (accordion opcional) ─────────────────── -->
            <details class="border border-ink/10">
              <summary class="cursor-pointer select-none px-4 py-3 font-mono text-xs uppercase tracking-wider text-ink/60 hover:bg-paper-warm">
                + Datos de impacto de la organización
                <span class="text-magenta">(mejora mucho los documentos generados)</span>
              </summary>
              <div class="space-y-4 border-t border-ink/10 p-4">
                <p class="text-xs text-ink/50">El equipo usa estos datos para cuantificar la memoria técnica. Rellena solo lo que sepas, no es obligatorio.</p>
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <label for="beneficiariosAnuales" class="label">Personas atendidas al año</label>
                    <input type="number" id="beneficiariosAnuales" name="beneficiariosAnuales" min="0" max="9999999" class="form-input w-full" placeholder="340" />
                  </div>
                  <div class="space-y-1">
                    <label for="presupuestoAnual" class="label">Presupuesto anual (aprox.)</label>
                    <input type="text" id="presupuestoAnual" name="presupuestoAnual" maxlength="40" class="form-input w-full" placeholder="120.000 €" />
                  </div>
                </div>
                <div class="space-y-1">
                  <label for="logrosDestacados" class="label">Logros e indicadores destacados</label>
                  <textarea id="logrosDestacados" name="logrosDestacados" rows="3" maxlength="500" class="form-input w-full resize-none" placeholder="Ej: 340 jóvenes formados en 2023 (75% insertados laboralmente). 18 pisos tutelados activos. Premio X al mejor proyecto social 2022…"></textarea>
                </div>
                <div class="space-y-1">
                  <label for="subvencionesAnteriores" class="label">Subvenciones recibidas anteriormente (referencias)</label>
                  <textarea id="subvencionesAnteriores" name="subvencionesAnteriores" rows="3" maxlength="500" class="form-input w-full resize-none" placeholder="Ej: Junta de Andalucía 2022: 45.000€ programa empleo. Diputación Granada 2023: 15.000€ atención domiciliaria…"></textarea>
                </div>
              </div>
            </details>

            <!-- ─── Experiencia previa ────────────────────────────────────── -->
            <div class="space-y-2">
              <p class="label">¿Tiene la entidad experiencia previa en subvenciones?</p>
              <div class="flex flex-wrap gap-4">
                {['Nunca hemos pedido', 'Alguna vez', 'Tenemos varias concedidas', 'Somos veteranos'].map(v => (
                  <label class="flex cursor-pointer items-center gap-2">
                    <input type="radio" name="experiencia" value={v} class="accent-magenta" />
                    <span class="text-sm text-ink">{v}</span>
                  </label>
                ))}
              </div>
            </div>

            <!-- ─── Presentación electrónica ──────────────────────────────── -->
            <div class="space-y-3">
              <p class="label">¿Cómo queréis gestionar la presentación electrónica?</p>
              <p class="text-xs text-ink/50">En ningún caso Startidea utiliza ni solicita vuestro certificado digital. Siempre permanece bajo vuestro control.</p>
              <div class="grid gap-3 sm:grid-cols-2">
                <label class="flex cursor-pointer items-start gap-3 border border-ink/15 p-3 hover:border-magenta/40 has-[:checked]:border-magenta has-[:checked]:bg-magenta/5">
                  <input type="radio" name="apoderamiento" value="si" class="accent-magenta mt-0.5 shrink-0" />
                  <div>
                    <span class="text-sm font-medium text-ink">Otorgamos apoderamiento a Startidea</span>
                    <p class="mt-0.5 text-xs text-ink/55 leading-relaxed">Startidea presenta en vuestro nombre usando su propio certificado. Vosotros solo otorgáis el permiso en la sede electrónica (5 minutos).</p>
                  </div>
                </label>
                <label class="flex cursor-pointer items-start gap-3 border border-ink/15 p-3 hover:border-magenta/40 has-[:checked]:border-magenta has-[:checked]:bg-magenta/5">
                  <input type="radio" name="apoderamiento" value="no" class="accent-magenta mt-0.5 shrink-0" />
                  <div>
                    <span class="text-sm font-medium text-ink">Preferimos firmar nosotros</span>
                    <p class="mt-0.5 text-xs text-ink/55 leading-relaxed">Startidea prepara el expediente completo. Cuando dais el visto bueno, os enviamos las instrucciones para que firmáis y presentéis con vuestro certificado (menos de 10 minutos).</p>
                  </div>
                </label>
              </div>
            </div>
          </fieldset>

          <!-- ═══════════════════════════════════════════════════════════════
               PASO 3: Documentos
          ═══════════════════════════════════════════════════════════════ -->
          <fieldset id="step-3" class="step-panel hidden space-y-6">
            <legend class="font-display text-2xl text-ink">Documentos disponibles</legend>
            <p class="text-sm text-ink/60">
              Sube los documentos que ya tengas preparados. No es obligatorio tenerlos todos — en el diagnóstico te decimos qué falta y cómo conseguirlo.
            </p>

            <!-- ─── Generador IA de memoria técnica ───────────────────── -->
            <div class="border-2 border-magenta/40 bg-paper">
              <div class="border-b border-magenta/20 bg-magenta/5 px-5 py-4">
                <div class="flex items-start justify-between gap-3 flex-wrap">
                  <div>
                    <p class="font-mono text-[10px] uppercase tracking-widest text-magenta">✦ Nuevo — IA</p>
                    <h3 class="mt-0.5 font-display text-xl text-ink">Borrador de memoria técnica</h3>
                    <p class="mt-1 text-sm text-ink/60 leading-relaxed">
                      Con los datos que has introducido, la IA genera un borrador estructurado (8 secciones)
                      adaptado a la convocatoria elegida. Tarda 20–30 segundos.
                    </p>
                  </div>
                  <span class="shrink-0 font-mono text-[9px] uppercase tracking-widest border border-magenta/30 text-magenta px-2 py-1">
                    Gratis
                  </span>
                </div>
              </div>

              <div class="px-5 py-5 space-y-4">
                <!-- Estado de generación -->
                <div id="gen-mem-status" class="hidden border border-ink/10 bg-paper-warm px-4 py-3">
                  <p id="gen-mem-status-msg" class="text-sm text-ink/60 animate-pulse">Conectando con el modelo de IA…</p>
                </div>

                <!-- Botón principal -->
                <button
                  type="button"
                  id="btn-gen-memoria"
                  class="btn w-full sm:w-auto"
                >
                  ✦ Generar borrador de memoria técnica
                </button>
                <p class="text-xs text-ink/35">Requiere haber descrito el proyecto en el paso anterior.</p>

                <!-- Resultado generado -->
                <div id="gen-mem-result" class="hidden space-y-3 border-t border-ink/10 pt-4">
                  <div class="flex items-center justify-between gap-3 flex-wrap">
                    <p class="font-mono text-[10px] uppercase tracking-widest text-green-700">✓ Borrador generado</p>
                    <div class="flex items-center gap-2">
                      <button
                        type="button"
                        id="btn-copy-memoria"
                        class="font-mono text-[10px] uppercase tracking-widest border border-ink/20 px-3 py-1.5 text-ink/60 hover:border-magenta hover:text-magenta transition-colors"
                      >
                        Copiar
                      </button>
                      <button
                        type="button"
                        id="btn-download-memoria"
                        class="font-mono text-[10px] uppercase tracking-widest border border-ink/20 px-3 py-1.5 text-ink/60 hover:border-magenta hover:text-magenta transition-colors"
                      >
                        Descargar .txt
                      </button>
                    </div>
                  </div>
                  <textarea
                    id="gen-mem-textarea"
                    rows="22"
                    readonly
                    spellcheck="false"
                    class="form-input w-full resize-y font-mono text-xs text-ink/80 leading-relaxed bg-paper-warm"
                  ></textarea>
                  <p class="text-[11px] text-ink/35 leading-relaxed">
                    ⚠ Borrador orientativo generado por IA. Los corchetes [COMPLETAR] marcan datos que debes añadir.
                    Startidea revisará y completará la memoria definitiva durante la elaboración del expediente.
                  </p>
                  <button
                    type="button"
                    id="btn-regen-memoria"
                    class="font-mono text-[10px] uppercase tracking-widest text-ink/40 hover:text-magenta"
                  >
                    ↺ Regenerar
                  </button>
                </div>
              </div>
            </div>

            <div class="border border-magenta/30 bg-magenta/5 p-4">
              <p class="font-mono text-xs uppercase tracking-widest text-magenta">⚡ Cuanto más, mejor</p>
              <p class="mt-1.5 text-sm text-ink/70">
                Si subes tu <strong>memoria de actividades del año anterior</strong> o tus <strong>estatutos</strong>,
                el equipo los usa para personalizar la documentación con información real de tu organización.
                El resultado es significativamente mejor que sin documentos.
              </p>
            </div>

            <div class="space-y-4">
              {[
                { id: 'doc-memoria-anual',  name: 'docMemoriaAnual',  label: '⭐ Memoria de actividades del año anterior',          hint: 'El documento más valioso para el expediente. Permite incluir tu historial, indicadores de impacto, beneficiarios y proyectos.', badge: 'MUY RECOMENDADO' },
                { id: 'doc-estatutos',      name: 'docEstatutos',     label: '⭐ Estatutos de la entidad',                          hint: 'Permite verificar que el objeto social encaja con la convocatoria y documentar la presentación. Con sello de inscripción.', badge: 'MUY RECOMENDADO' },
                { id: 'doc-memoria',        name: 'docMemoria',       label: 'Borrador de memoria técnica del proyecto',           hint: 'Si tienes un borrador, el equipo lo mejora y adapta a la convocatoria. Si no tienes, lo elaboramos desde cero.' },
                { id: 'doc-presupuesto',    name: 'docPresupuesto',   label: 'Presupuesto estimado del proyecto',                  hint: 'Si tienes un presupuesto previo (Word, Excel o PDF), el equipo lo reformatea según las partidas que pide la convocatoria.' },
                { id: 'doc-hacienda',       name: 'docHacienda',      label: 'Certificado AEAT (Hacienda)',                        hint: 'Al corriente de obligaciones tributarias. Válido 6 meses desde la fecha de emisión.' },
                { id: 'doc-ss',             name: 'docSS',            label: 'Certificado TGSS (Seguridad Social)',                hint: 'Al corriente de pagos a la Seguridad Social. Válido 6 meses. Se puede solicitar justo antes de presentar.' },
                { id: 'doc-otros',          name: 'docOtros',         label: 'Otros documentos relevantes',                       hint: 'Actas, informes de auditoría, premios, publicaciones… Cualquier documento que acredite la trayectoria o capacidad técnica.', multiple: true },
              ].map(doc => (
                <div class:list={['border p-4', doc.badge ? 'border-magenta/30 bg-magenta/3' : 'border-ink/10']}>
                  <label for={doc.id} class="block cursor-pointer">
                    <div class="flex items-start justify-between gap-3">
                      <p class="font-mono text-sm text-ink">{doc.label}</p>
                      {doc.badge && <span class="shrink-0 font-mono text-[9px] uppercase tracking-widest text-magenta">{doc.badge}</span>}
                    </div>
                    <p class="mt-0.5 text-xs text-ink/50">{doc.hint}</p>
                    <div class="mt-3 flex items-center gap-3">
                      <span class="border border-ink px-3 py-1.5 font-mono text-[11px] uppercase tracking-wider text-ink hover:bg-paper-warm">Seleccionar archivo</span>
                      <span class="text-xs text-ink/40" id={`${doc.id}-name`}>Sin archivo seleccionado</span>
                    </div>
                  </label>
                  <input type="file" id={doc.id} name={doc.name} multiple={doc.multiple} accept=".pdf,.doc,.docx,.xls,.xlsx,.odt,.ods,.txt" class="sr-only" data-file-label={`${doc.id}-name`} />
                </div>
              ))}
            </div>

            <div class="border border-ink/10 bg-paper-warm p-3 font-mono text-[10px] uppercase tracking-wider text-ink/40">
              Formatos: PDF, Word (.doc/.docx), Excel (.xls/.xlsx), OpenDocument, TXT · Máx. 20 MB por archivo
            </div>
          </fieldset>

          <!-- ═══════════════════════════════════════════════════════════════
               PASO 4: Confirmar
          ═══════════════════════════════════════════════════════════════ -->
          <fieldset id="step-4" class="step-panel hidden space-y-6">
            <legend class="font-display text-2xl text-ink">Confirmar y enviar</legend>
            <p class="text-sm text-ink/60">Revisa el resumen y confirma el envío.</p>

            <div id="resumen" class="space-y-3 border border-ink/15 bg-paper-warm p-5">
              <h3 class="font-mono text-xs uppercase tracking-wider text-ink/50">Resumen del expediente</h3>
              <dl class="space-y-2 text-sm">
                <div class="flex gap-2"><dt class="w-32 shrink-0 text-ink/50">Entidad</dt><dd id="resumen-entidad" class="text-ink"></dd></div>
                <div class="flex gap-2"><dt class="w-32 shrink-0 text-ink/50">CIF</dt><dd id="resumen-cif" class="text-ink"></dd></div>
                <div class="flex gap-2"><dt class="w-32 shrink-0 text-ink/50">Email</dt><dd id="resumen-email" class="text-ink"></dd></div>
                <div class="flex gap-2"><dt class="w-32 shrink-0 text-ink/50">Convocatoria</dt><dd id="resumen-convocatoria" class="text-ink"></dd></div>
                <div class="flex gap-2"><dt class="w-32 shrink-0 text-ink/50">Documentos</dt><dd id="resumen-docs" class="text-ink"></dd></div>
              </dl>
            </div>

            <div class="space-y-1">
              <label for="comentarios" class="label">Comentarios adicionales (opcional)</label>
              <textarea id="comentarios" name="comentarios" rows="3" maxlength="800" placeholder="Cualquier cosa que sea relevante y que no hayas podido explicar antes." class="form-input w-full resize-none"></textarea>
            </div>

            <div class="space-y-1">
              <label for="como-conocio" class="label">¿Cómo has conocido este servicio?</label>
              <select id="como-conocio" name="comoConocio" class="form-input w-full">
                <option value="">Selecciona…</option>
                <option value="buscador">Buscador (Google, etc.)</option>
                <option value="recomendacion">Recomendación de alguien</option>
                <option value="buscador-subvenciones">Buscador de subvenciones de Startidea</option>
                <option value="redes">Redes sociales</option>
                <option value="nota">Una nota o artículo</option>
                <option value="ya-cliente">Ya soy cliente de Startidea</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <input type="text" name="website" class="sr-only" tabindex="-1" autocomplete="off" />

            <div class="flex items-start gap-3">
              <input type="checkbox" id="rgpd" name="rgpd" required class="mt-0.5 accent-magenta" />
              <label for="rgpd" class="text-sm text-ink/70">
                Acepto que Startidea use mis datos para gestionar este expediente y me contacte con el diagnóstico de encaje. Al enviar se crea automáticamente mi acceso al portal de clientes (sin contraseña). Todo de acuerdo con la{' '}
                <a href="/privacidad" class="underline hover:text-magenta">política de privacidad</a>.
              </label>
            </div>

            <div id="form-error" class="hidden border border-red-300 bg-red-50 p-4 text-sm text-red-700"></div>
          </fieldset>

          <!-- Botones de navegación -->
          <div class="mt-10 flex items-center justify-between border-t border-ink/10 pt-6">
            <button type="button" id="btn-prev" class="btn-ghost hidden" aria-label="Paso anterior">← Atrás</button>
            <button type="button" id="btn-next" class="btn ml-auto">Siguiente →</button>
            <button type="submit"  id="btn-submit" class="btn ml-auto hidden">Enviar expediente →</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .form-input {
    @apply border border-ink/20 bg-paper px-4 py-2.5 text-sm text-ink outline-none transition-colors focus:border-ink focus:ring-1 focus:ring-ink;
  }
  .form-input:invalid:not(:placeholder-shown) { @apply border-red-400; }

  /* Tarjetas de convocatoria */
  .conv-card.is-selected {
    @apply ring-2 ring-magenta ring-offset-1;
  }
  .conv-card.is-selected .conv-id-badge {
    @apply bg-magenta text-paper border-magenta;
  }
  .conv-card.is-open .conv-arrow {
    transform: rotate(180deg);
  }

  /* Filtro activo */
  .conv-filter-btn.is-active {
    @apply border-ink bg-ink text-paper;
  }

  /* Estados de matching */
  .conv-card.match-si {
    @apply ring-2 ring-green-400 ring-offset-1;
  }
  .conv-card.match-revisar {
    @apply ring-1 ring-amber-300 ring-offset-1;
  }
  .conv-card.match-no {
    @apply opacity-40;
  }

  /* Chip seleccionado en el widget de matching */
  .mw-chip-label:has(input:checked) {
    @apply border-magenta bg-magenta text-paper;
  }
</style>

<script define:vars={{ convSlugParam, convTitleParam }}>
  const TOTAL_STEPS = 4;
  let currentStep = 1;

  const form   = document.getElementById('expediente-form');
  const btnPrev   = document.getElementById('btn-prev');
  const btnNext   = document.getElementById('btn-next');
  const btnSubmit = document.getElementById('btn-submit');

  // ── Helpers campos ocultos de convocatoria ────────────────────────────────
  const fSlug   = () => document.getElementById('f-conv-slug');
  const fNombre = () => document.getElementById('f-conv-nombre');
  const fUrl    = () => document.getElementById('f-conv-url');
  const fTiene  = () => document.getElementById('f-tiene-conv');

  function setConvFields(slug, nombre, url, tiene) {
    fSlug().value   = slug;
    fNombre().value = nombre;
    fUrl().value    = url;
    fTiene().value  = tiene;
  }

  // ── Selector de convocatorias ─────────────────────────────────────────────
  let selectedSlug = '';

  function selectCard(slug) {
    // Desmarcar anterior
    if (selectedSlug) {
      const prev = document.querySelector(`[data-conv-slug="${selectedSlug}"]`);
      if (prev) {
        prev.classList.remove('is-selected');
        prev.querySelector('.conv-selected-banner')?.classList.add('hidden');
      }
    }
    selectedSlug = slug;
    const card = document.querySelector(`[data-conv-slug="${slug}"]`);
    if (!card) return;

    // Marcar nueva
    card.classList.add('is-selected');
    const banner = card.querySelector('.conv-selected-banner');
    if (banner) {
      banner.classList.remove('hidden');
      banner.style.display = 'flex';
    }

    // Cerrar panel de detalles
    collapseCard(slug);

    // Rellenar campos ocultos
    const titulo = card.getAttribute('data-conv-title') ?? '';
    const url    = card.getAttribute('data-conv-url')   ?? '';
    setConvFields(slug, titulo, url, 'si');

    // Limpiar "no sé" radio y sección de otra conv
    const noSeRadio = document.getElementById('conv-no-se');
    if (noSeRadio) noSeRadio.checked = false;
    document.getElementById('no-se-importe')?.classList.add('hidden');
    document.getElementById('conv-error')?.classList.add('hidden');

    // Scroll suave al área de descripción
    setTimeout(() => {
      document.getElementById('descripcionProyecto')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 150);
  }

  function deselectCard() {
    if (!selectedSlug) return;
    const card = document.querySelector(`[data-conv-slug="${selectedSlug}"]`);
    if (card) {
      card.classList.remove('is-selected');
      const banner = card.querySelector('.conv-selected-banner');
      if (banner) { banner.classList.add('hidden'); banner.style.display = ''; }
    }
    selectedSlug = '';
    setConvFields('', '', '', '');
  }

  function expandCard(slug) {
    const card = document.querySelector(`[data-conv-slug="${slug}"]`);
    if (!card) return;

    // Colapsar otras tarjetas abiertas
    document.querySelectorAll('.conv-card.is-open').forEach(c => {
      if (c !== card) collapseCard(c.getAttribute('data-conv-slug'));
    });

    card.classList.add('is-open');
    card.querySelector('.conv-details')?.classList.remove('hidden');
    card.querySelector('.conv-card-header')?.setAttribute('aria-expanded', 'true');
  }

  function collapseCard(slug) {
    const card = document.querySelector(`[data-conv-slug="${slug}"]`);
    if (!card) return;
    card.classList.remove('is-open');
    card.querySelector('.conv-details')?.classList.add('hidden');
    card.querySelector('.conv-card-header')?.setAttribute('aria-expanded', 'false');
  }

  function toggleCard(slug) {
    const card = document.querySelector(`[data-conv-slug="${slug}"]`);
    if (!card) return;
    if (card.classList.contains('is-open')) collapseCard(slug);
    else expandCard(slug);
  }

  // Cabecera clickable
  document.querySelectorAll('.conv-card-header').forEach(header => {
    header.addEventListener('click', () => {
      const card = header.closest('[data-conv-slug]');
      const slug = card?.getAttribute('data-conv-slug') ?? '';
      if (slug === selectedSlug) return; // ya seleccionada, no hacer nada
      toggleCard(slug);
    });
  });

  // Botón "Deseleccionar"
  document.querySelectorAll('.conv-deselect-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const card = btn.closest('[data-conv-slug]');
      const slug = card?.getAttribute('data-conv-slug') ?? '';
      deselectCard();
      expandCard(slug); // abrir el panel para que pueda comparar
    });
  });

  // Botón "Me interesa — continuar"
  document.querySelectorAll('.conv-select-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const card = btn.closest('[data-conv-slug]');
      const slug = card?.getAttribute('data-conv-slug') ?? '';
      selectCard(slug);
    });
  });

  // Filtros por tipo de entidad
  document.querySelectorAll('.conv-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-conv-filter') ?? 'all';
      document.querySelectorAll('.conv-filter-btn').forEach(b =>
        b.classList.toggle('is-active', b.getAttribute('data-conv-filter') === filter)
      );
      document.querySelectorAll('[data-conv-slug]').forEach(card => {
        const cardType = card.getAttribute('data-conv-filter') ?? '';
        card.style.display = (filter === 'all' || cardType === filter) ? '' : 'none';
      });
    });
  });

  // Sección "otra convocatoria" — sincronizar con campos ocultos en tiempo real
  const otherNombre = document.getElementById('other-nombre');
  const otherUrl    = document.getElementById('other-url');
  const otherConfirm = document.getElementById('other-conv-confirm');

  function syncOtherConv() {
    const nombre = otherNombre?.value?.trim() ?? '';
    const url    = otherUrl?.value?.trim()    ?? '';
    if (nombre || url) {
      if (selectedSlug) deselectCard();
      const noSeRadio = document.getElementById('conv-no-se');
      if (noSeRadio) noSeRadio.checked = false;
      document.getElementById('no-se-importe')?.classList.add('hidden');
      setConvFields('', nombre, url, nombre || url ? 'si' : '');
      if (otherConfirm) otherConfirm.classList.remove('hidden');
      document.getElementById('conv-error')?.classList.add('hidden');
    } else {
      setConvFields('', '', '', '');
      if (otherConfirm) otherConfirm.classList.add('hidden');
    }
  }
  otherNombre?.addEventListener('input', syncOtherConv);
  otherUrl?.addEventListener('input', syncOtherConv);

  // Limpiar conv manual
  document.getElementById('btn-clear-other')?.addEventListener('click', () => {
    if (otherNombre) otherNombre.value = '';
    if (otherUrl)    otherUrl.value    = '';
    if (otherConfirm) otherConfirm.classList.add('hidden');
    setConvFields('', '', '', '');
    document.getElementById('other-conv-panel')?.removeAttribute('open');
  });

  // "No sé cuál" radio
  document.getElementById('conv-no-se')?.addEventListener('change', e => {
    if (e.target.checked) {
      deselectCard();
      if (otherNombre) otherNombre.value = '';
      if (otherUrl)    otherUrl.value    = '';
      if (otherConfirm) otherConfirm.classList.add('hidden');
      setConvFields('', '', '', 'no');
      document.getElementById('no-se-importe')?.classList.remove('hidden');
      document.getElementById('conv-error')?.classList.add('hidden');
    }
  });

  // ── Motor de matching ────────────────────────────────────────────────────────

  // Colectivos que financia cada convocatoria (por slug estable)
  const CONV_COLECTIVOS_MAP = {
    'boja-2026-inclusion-l10': ['todos'],
    'boja-2026-inclusion-l11': ['todos'],
    'boja-2026-inclusion-l7':  ['alimentario', 'menores_verano'],
    'boja-2026-inclusion-l16': ['mujer_joven'],
    'boja-2026-inclusion-l4':  ['comunidad_gitana'],
    'boja-2026-inclusion-l6':  ['inmigrantes'],
    'boja-2026-inclusion-l9':  ['participacion'],
  };

  function getOrgBeneficiario() {
    const orgType = document.querySelector('[name="orgType"]')?.value ?? '';
    const privadas = ['asociacion', 'fundacion', 'entidad-religiosa'];
    const locales  = ['entidad-local'];
    if (privadas.includes(orgType)) return 'privada';
    if (locales.includes(orgType))  return 'local';
    return '';
  }

  function getMatchProfile() {
    const beneficiario  = getOrgBeneficiario();
    const registroSS    = document.querySelector('[name="mw_registro_ss"]:checked')?.value ?? '';
    const alCorriente   = document.querySelector('[name="mw_corriente"]:checked')?.value ?? '';
    const colectivos    = Array.from(document.querySelectorAll('[name="mw_colectivo"]:checked')).map(el => el.value);
    return { beneficiario, registroSS, alCorriente, colectivos };
  }

  function scoreCard(slug, cardFilter, profile) {
    // Sin perfil = neutro
    const hasProfile = profile.beneficiario || profile.registroSS || profile.alCorriente || profile.colectivos.length > 0;
    if (!hasProfile) return { encaje: null, motivos: [] };

    // Tipo de entidad: mismatch → inelegible
    if (profile.beneficiario && cardFilter !== 'all' && cardFilter !== profile.beneficiario) {
      return { encaje: 'no', motivos: ['Tu tipo de entidad no es beneficiaria de esta convocatoria'] };
    }

    const motivos = [];
    let encaje = 'si';

    // Registro Servicios Sociales (solo para convocatorias privadas)
    if (cardFilter === 'privada' && profile.beneficiario === 'privada') {
      if (profile.registroSS === 'no') {
        encaje = 'revisar';
        motivos.push('Requiere inscripción en el Registro de Entidades de Servicios Sociales de la Junta');
      } else if (profile.registroSS === 'no_se') {
        encaje = 'revisar';
        motivos.push('Hay que verificar la inscripción en el Registro de Entidades de SS');
      }
    }

    // Al corriente AEAT/TGSS
    if (profile.alCorriente === 'no') {
      if (encaje === 'si') encaje = 'revisar';
      motivos.push('Se requiere estar al corriente de AEAT y TGSS para poder concurrir');
    }

    // Colectivos (solo penaliza si la conv es específica y no coincide)
    const convColectivos = CONV_COLECTIVOS_MAP[slug] ?? ['todos'];
    if (profile.colectivos.length > 0 && !convColectivos.includes('todos')) {
      const hasMatch = profile.colectivos.some(c => convColectivos.includes(c));
      if (!hasMatch && encaje === 'si') {
        encaje = 'revisar';
        motivos.push('Esta línea financia colectivos distintos a los que seleccionaste');
      }
    }

    return { encaje, motivos };
  }

  function updateMatching() {
    const profile  = getMatchProfile();
    const hasProfile = profile.beneficiario || profile.registroSS || profile.alCorriente || profile.colectivos.length > 0;

    const resetBtn = document.getElementById('mw-reset');
    if (resetBtn) resetBtn.classList.toggle('hidden', !hasProfile);

    const siCards      = [];
    const revisarCards = [];
    const noCards      = [];

    document.querySelectorAll('.conv-card').forEach(card => {
      const slug       = card.dataset.convSlug ?? '';
      const cardFilter = card.dataset.convFilter ?? '';
      const result     = scoreCard(slug, cardFilter, profile);
      const badge      = card.querySelector('.conv-match-badge');

      card.classList.remove('match-si', 'match-revisar', 'match-no');

      if (!result.encaje) {
        // Neutro: sin perfil
        if (badge) { badge.className = 'conv-match-badge hidden items-center gap-1 mt-1.5 px-2 py-0.5 font-mono text-[9px] uppercase tracking-widest border'; }
        return;
      }

      if (result.encaje === 'si') {
        card.classList.add('match-si');
        if (badge) {
          badge.className = 'conv-match-badge flex items-center gap-1 mt-1.5 px-2 py-0.5 font-mono text-[9px] uppercase tracking-widest border bg-green-50 text-green-700 border-green-300';
          badge.textContent = '✓ Encaja';
          badge.title = '';
        }
        siCards.push(card);
      } else if (result.encaje === 'revisar') {
        card.classList.add('match-revisar');
        if (badge) {
          badge.className = 'conv-match-badge flex items-center gap-1 mt-1.5 px-2 py-0.5 font-mono text-[9px] uppercase tracking-widest border bg-amber-50 text-amber-700 border-amber-200';
          badge.textContent = '⚠ Revisable';
          badge.title = result.motivos.join(' · ');
        }
        revisarCards.push(card);
      } else {
        card.classList.add('match-no');
        if (badge) {
          badge.className = 'conv-match-badge flex items-center gap-1 mt-1.5 px-2 py-0.5 font-mono text-[9px] uppercase tracking-widest border bg-red-50 text-red-400 border-red-200';
          badge.textContent = '✗ No elegible';
          badge.title = result.motivos.join(' · ');
        }
        noCards.push(card);
      }
    });

    // Reordenar: encaja → revisable → no elegible
    const grid = document.getElementById('conv-grid');
    if (grid && hasProfile) {
      [...siCards, ...revisarCards, ...noCards].forEach(c => grid.appendChild(c));
    }
  }

  // Inicializar widget de matching: mostrar/ocultar preguntas según org tipo
  function initMatchingWidget() {
    const orgBenef = getOrgBeneficiario();
    const rowRegistro   = document.getElementById('mw-row-registro');
    const rowColectivos = document.getElementById('mw-row-colectivos');
    if (rowRegistro)   rowRegistro.classList.toggle('hidden', orgBenef !== 'privada' && orgBenef !== '');
    if (rowColectivos) rowColectivos.classList.toggle('hidden', orgBenef !== 'privada');
  }

  // Escuchar cambios en el widget de matching
  document.getElementById('matching-widget')?.addEventListener('change', () => {
    updateMatching();
  });

  // Botón de reset del matching
  document.getElementById('mw-reset')?.addEventListener('click', () => {
    document.querySelectorAll('[name^="mw_"]').forEach(el => {
      if (el.type === 'radio' || el.type === 'checkbox') el.checked = false;
    });
    updateMatching();
  });

  // Auto-seleccionar si viene desde landing BOJA con ?slug=
  if (convSlugParam) {
    const matchCard = document.querySelector(`[data-conv-slug="${convSlugParam}"]`);
    if (matchCard) {
      selectCard(convSlugParam);
    } else if (convTitleParam) {
      // Slug desconocido pero hay título — conv externa
      setConvFields(convSlugParam, convTitleParam, '', 'si');
      if (otherNombre) otherNombre.value = convTitleParam;
      document.getElementById('other-conv-panel')?.setAttribute('open', '');
      if (otherConfirm) otherConfirm.classList.remove('hidden');
    }
  }

  // ── Navegación por pasos ──────────────────────────────────────────────────
  function getPanel(n) { return document.getElementById(`step-${n}`); }

  function updateUI() {
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      getPanel(i)?.classList.toggle('hidden', i !== currentStep);
    }
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      const dot = document.querySelector(`[data-step-dot="${i}"] [data-dot-circle]`);
      if (!dot) continue;
      if (i < currentStep) {
        dot.className = 'flex h-8 w-8 items-center justify-center border-2 border-ink bg-ink font-mono text-sm text-paper transition-colors';
        dot.textContent = '✓';
      } else if (i === currentStep) {
        dot.className = 'flex h-8 w-8 items-center justify-center border-2 border-magenta bg-magenta font-mono text-sm text-paper transition-colors';
        dot.textContent = String(i);
      } else {
        dot.className = 'flex h-8 w-8 items-center justify-center border-2 border-ink/20 bg-paper font-mono text-sm text-ink/40 transition-colors';
        dot.textContent = String(i);
      }
    }
    btnPrev.classList.toggle('hidden', currentStep === 1);
    btnNext.classList.toggle('hidden', currentStep === TOTAL_STEPS);
    btnSubmit.classList.toggle('hidden', currentStep !== TOTAL_STEPS);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function validateStep(n) {
    const panel = getPanel(n);
    const required = panel.querySelectorAll('[required]');
    let valid = true;
    for (const el of required) {
      const isEmpty = el.type === 'checkbox' ? !el.checked : !el.value.trim();
      if (isEmpty) {
        if (el.type !== 'checkbox') el.focus();
        el.classList.add('border-red-400', 'ring-1', 'ring-red-400');
        valid = false;
        break;
      } else {
        el.classList.remove('border-red-400', 'ring-1', 'ring-red-400');
      }
    }
    // Paso 2: verificar que haya una convocatoria seleccionada
    if (n === 2) {
      const tiene = fTiene()?.value ?? '';
      const nombre = fNombre()?.value ?? '';
      const slug   = fSlug()?.value   ?? '';
      if (!tiene && !nombre && !slug) {
        valid = false;
        document.getElementById('conv-error')?.classList.remove('hidden');
        document.getElementById('conv-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    return valid;
  }

  function updateResumen() {
    const orgName    = document.getElementById('orgName')?.value ?? '';
    const cif        = document.getElementById('cif')?.value     ?? '';
    const email      = document.getElementById('email')?.value   ?? '';
    const convoNombre = fNombre()?.value ?? '';
    const convoUrl    = fUrl()?.value    ?? '';
    const necesidad   = document.getElementById('descripcionProyecto')?.value ?? '';
    const fileInputs  = form.querySelectorAll('input[type="file"]');
    const docs = [];
    fileInputs.forEach(fi => {
      if (fi.files && fi.files.length > 0) docs.push(`${fi.files.length} archivo(s) en ${fi.name}`);
    });
    document.getElementById('resumen-entidad').textContent     = orgName || '—';
    document.getElementById('resumen-cif').textContent         = cif     || '—';
    document.getElementById('resumen-email').textContent       = email   || '—';
    document.getElementById('resumen-convocatoria').textContent = convoNombre || convoUrl || necesidad.slice(0, 80) || '—';
    document.getElementById('resumen-docs').textContent        = docs.length ? docs.join(', ') : 'Ninguno (se puede completar más adelante)';
  }

  btnNext.addEventListener('click', () => {
    if (!validateStep(currentStep)) return;
    if (currentStep === TOTAL_STEPS - 1) updateResumen();
    currentStep = Math.min(currentStep + 1, TOTAL_STEPS);
    updateUI();
    // Al llegar al paso 2: inicializar widget de matching
    if (currentStep === 2) {
      initMatchingWidget();
      updateMatching();
    }
  });
  btnPrev.addEventListener('click', () => {
    currentStep = Math.max(currentStep - 1, 1);
    updateUI();
  });

  // Contador de caracteres descripción
  const descArea  = document.getElementById('descripcionProyecto');
  const charsLeft = document.getElementById('chars-left');
  descArea?.addEventListener('input', () => {
    charsLeft.textContent = String(2000 - descArea.value.length);
  });

  // File input labels
  document.querySelectorAll('input[type="file"]').forEach(input => {
    input.addEventListener('change', () => {
      const labelId = input.dataset.fileLabel;
      if (!labelId) return;
      const label = document.getElementById(labelId);
      if (!label) return;
      if (input.files && input.files.length > 0) {
        const names = Array.from(input.files).map(f => f.name).join(', ');
        label.textContent = names.length > 50 ? names.slice(0, 47) + '…' : names;
        label.classList.add('text-ink'); label.classList.remove('text-ink/40');
      } else {
        label.textContent = 'Sin archivo seleccionado';
        label.classList.remove('text-ink'); label.classList.add('text-ink/40');
      }
    });
  });

  // Submit
  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (!validateStep(TOTAL_STEPS)) return;

    const errDiv = document.getElementById('form-error');
    errDiv.classList.add('hidden');
    btnSubmit.disabled = true;
    btnSubmit.textContent = 'Enviando…';

    // Combinar datos de impacto en comentarios
    const benef    = document.getElementById('beneficiariosAnuales')?.value?.trim();
    const ppto     = document.getElementById('presupuestoAnual')?.value?.trim();
    const logros   = document.getElementById('logrosDestacados')?.value?.trim();
    const subvPrev = document.getElementById('subvencionesAnteriores')?.value?.trim();
    const comentariosEl = form.querySelector('#comentarios');
    const ctxLines = [];
    if (benef)    ctxLines.push(`Personas atendidas al año: ${benef}`);
    if (ppto)     ctxLines.push(`Presupuesto anual: ${ppto}`);
    if (logros)   ctxLines.push(`Logros e indicadores:\n${logros}`);
    if (subvPrev) ctxLines.push(`Subvenciones anteriores:\n${subvPrev}`);
    if (ctxLines.length > 0) {
      const ctxBlock = `[Datos de la organización]\n${ctxLines.join('\n')}`;
      const existing = comentariosEl.value.trim();
      comentariosEl.value = existing ? `${ctxBlock}\n---\nComentarios: ${existing}` : ctxBlock;
    }

    const data = new FormData(form);

    try {
      const res = await fetch('/api/expediente', { method: 'POST', body: data });
      let json = null;
      try { json = await res.json(); } catch {}

      if (json?.ok) { window.location.href = '/subvenciones/presentar/gracias'; return; }

      if (json?.error === 'fields')      errDiv.textContent = 'Faltan datos obligatorios. Revisa los pasos anteriores.';
      else if (json?.error === 'email')  errDiv.textContent = 'El email introducido no tiene un formato válido.';
      else if (!res.ok)                  errDiv.textContent = `Error del servidor (${res.status}). Escríbenos a hola@startidea.es indicando que el formulario no funciona.`;
      else                               errDiv.textContent = 'Ha habido un problema al enviar el formulario. Escríbenos directamente a hola@startidea.es.';
      errDiv.classList.remove('hidden');
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Enviar expediente →';
    } catch {
      errDiv.textContent = 'No se pudo conectar con el servidor. Comprueba tu conexión e inténtalo de nuevo. Si persiste: hola@startidea.es.';
      errDiv.classList.remove('hidden');
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Enviar expediente →';
    }
  });

  // ── Generador IA de memoria técnica ──────────────────────────────────────

  async function runGenerarMemoria() {
    const slug        = (fSlug()?.value ?? '').trim();
    const convNombre  = (fNombre()?.value ?? '').trim();
    const orgName     = (document.getElementById('orgName') as HTMLInputElement)?.value?.trim() ?? '';
    const orgType     = (document.getElementById('orgType') as HTMLSelectElement)?.value ?? '';
    const descripcion = (document.getElementById('descripcionProyecto') as HTMLTextAreaElement)?.value?.trim() ?? '';
    const beneficiariosAnuales = (document.getElementById('beneficiariosAnuales') as HTMLInputElement)?.value?.trim() ?? '';
    const presupuestoAnual     = (document.getElementById('presupuestoAnual') as HTMLInputElement)?.value?.trim() ?? '';
    const logros               = (document.getElementById('logrosDestacados') as HTMLTextAreaElement)?.value?.trim() ?? '';

    const statusDiv   = document.getElementById('gen-mem-status');
    const statusMsg   = document.getElementById('gen-mem-status-msg');
    const resultDiv   = document.getElementById('gen-mem-result');
    const textarea    = document.getElementById('gen-mem-textarea') as HTMLTextAreaElement;
    const btnGen      = document.getElementById('btn-gen-memoria') as HTMLButtonElement;
    const btnRegen    = document.getElementById('btn-regen-memoria') as HTMLButtonElement;

    if (!descripcion) {
      alert('Describe el proyecto en el paso anterior para poder generar la memoria técnica.');
      return;
    }

    // UI: loading
    if (btnGen)    { btnGen.disabled  = true;  btnGen.textContent  = '⟳ Generando (~30s)…'; }
    if (btnRegen)  { btnRegen.disabled = true; }
    if (statusDiv) statusDiv.classList.remove('hidden');
    if (statusMsg) statusMsg.textContent = 'La IA está redactando el borrador. Esto puede tardar hasta 30 segundos…';
    if (resultDiv) resultDiv.classList.add('hidden');

    try {
      const res = await fetch('/api/generar-memoria', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          slug,
          conv_nombre:          convNombre,
          nombre_entidad:       orgName,
          org_type:             orgType,
          descripcion_proyecto: descripcion,
          beneficiarios_anuales: beneficiariosAnuales,
          presupuesto_anual:    presupuestoAnual,
          logros,
        }),
      });

      const data = await res.json() as { ok: boolean; memoria?: string; error?: string; message?: string };

      if (data.ok && data.memoria) {
        if (textarea)  textarea.value = data.memoria;
        if (resultDiv) resultDiv.classList.remove('hidden');
        if (statusDiv) statusDiv.classList.add('hidden');
        // Scroll al resultado
        setTimeout(() => resultDiv?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
      } else {
        const errMsg = data.error === 'rate_limited'
          ? 'Demasiadas generaciones seguidas. Espera un minuto.'
          : data.error === 'missing_descripcion'
          ? 'Describe el proyecto en el paso 2 antes de generar.'
          : `Error al generar (${data.error ?? 'desconocido'}). Startidea elaborará la memoria durante el diagnóstico.`;
        if (statusMsg) { statusMsg.textContent = errMsg; statusMsg.classList.remove('animate-pulse'); }
      }
    } catch {
      if (statusMsg) {
        statusMsg.textContent = 'Sin conexión con el servidor de IA. Startidea elaborará la memoria durante el diagnóstico.';
        statusMsg.classList.remove('animate-pulse');
      }
    } finally {
      if (btnGen)  { btnGen.disabled  = false; btnGen.textContent  = '✦ Generar borrador de memoria técnica'; }
      if (btnRegen){ btnRegen.disabled = false; }
    }
  }

  document.getElementById('btn-gen-memoria')?.addEventListener('click',  () => runGenerarMemoria());
  document.getElementById('btn-regen-memoria')?.addEventListener('click', () => runGenerarMemoria());

  // Copiar al portapapeles
  document.getElementById('btn-copy-memoria')?.addEventListener('click', async () => {
    const ta  = document.getElementById('gen-mem-textarea') as HTMLTextAreaElement;
    const btn = document.getElementById('btn-copy-memoria') as HTMLButtonElement;
    if (!ta?.value) return;
    try {
      await navigator.clipboard.writeText(ta.value);
      const orig = btn.textContent;
      btn.textContent = '✓ Copiado';
      setTimeout(() => { btn.textContent = orig; }, 2000);
    } catch {
      ta.select();
      document.execCommand('copy');
    }
  });

  // Descargar como .txt
  document.getElementById('btn-download-memoria')?.addEventListener('click', () => {
    const ta      = document.getElementById('gen-mem-textarea') as HTMLTextAreaElement;
    const orgName = (document.getElementById('orgName') as HTMLInputElement)?.value?.trim() ?? 'entidad';
    if (!ta?.value) return;
    const blob = new Blob([ta.value], { type: 'text/plain;charset=utf-8' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    const slug = orgName.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/\s+/g, '-').slice(0, 40);
    a.href     = url;
    a.download = `memoria-tecnica-borrador-${slug}.txt`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // Init
  updateUI();
</script>
