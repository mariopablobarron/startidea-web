---
import Base from '@/layouts/Base.astro';
import { breadcrumbList, SITE_URL } from '@/lib/jsonld';

export const prerender = false;

// Convocatoria pre-seleccionada desde la ficha del buscador o landing BOJA
const convSlug  = Astro.url.searchParams.get('slug')  ?? '';
const convTitle = Astro.url.searchParams.get('title') ?? '';
const convHint  = Astro.url.searchParams.get('hint')  ?? ''; // Descripción corta de qué financia

const jsonLd = [
  breadcrumbList([
    { name: 'Inicio', url: `${SITE_URL}/` },
    { name: 'Subvenciones', url: `${SITE_URL}/subvenciones` },
    { name: 'Presentar subvención', url: `${SITE_URL}/subvenciones/presentar` },
    { name: 'Nuevo expediente', url: `${SITE_URL}/subvenciones/presentar/nuevo` },
  ]),
];
---

<Base
  title="Nuevo expediente de subvención — Startidea"
  description="Rellena el formulario con los datos de tu entidad y la convocatoria. En 24–48h el equipo de Startidea te entrega la memoria técnica, el presupuesto y la guía de presentación."
  ogSlug="page/subvenciones-presentar"
  jsonLd={jsonLd}
>
  {convTitle && (
    <div class="bg-magenta/10 border-b border-magenta/20 py-3">
      <div class="container-x flex items-center justify-between gap-4">
        <p class="text-sm text-ink">
          <span class="font-mono text-[10px] uppercase tracking-widest text-magenta mr-2">Convocatoria seleccionada</span>
          <strong>{convTitle}</strong>
        </p>
        <a href={`/subvenciones/${convSlug}`} class="shrink-0 font-mono text-[11px] uppercase tracking-widest text-ink/50 hover:text-magenta">
          Ver ficha →
        </a>
      </div>
    </div>
  )}

  <section class="border-b border-ink/15 bg-paper-warm py-10 md:py-14">
    <div class="container-x">
      <span class="label">— Nuevo expediente</span>
      <h1 class="mt-3 font-display text-display-md leading-tight text-ink">
        {convTitle ? 'Un paso más para solicitar la ayuda.' : 'Arranca el expediente.'}
      </h1>
      <p class="mt-3 max-w-measure text-ink/70">
        Completar este formulario lleva unos 10 minutos. El equipo de Startidea prepara la memoria técnica, el presupuesto y la guía de presentación adaptados a esta convocatoria.
      </p>
    </div>
  </section>

  <section class="bg-paper py-12 md:py-20">
    <div class="container-x">
      <div class="mx-auto max-w-2xl">

        <!-- Indicador de pasos -->
        <div id="step-indicator" class="mb-10 flex items-center gap-0">
          {[
            { n: 1, label: 'La entidad' },
            { n: 2, label: 'Convocatoria' },
            { n: 3, label: 'Documentos' },
            { n: 4, label: 'Confirmar' },
          ].map((s, i) => (
            <>
              <div class="flex flex-col items-center" data-step-dot={s.n}>
                <div class="flex h-8 w-8 items-center justify-center border-2 border-ink/20 bg-paper font-mono text-sm text-ink/40 transition-colors" data-dot-circle>
                  {s.n}
                </div>
                <span class="mt-1 hidden font-mono text-[10px] uppercase tracking-wider text-ink/40 sm:block" data-dot-label>{s.label}</span>
              </div>
              {i < 3 && <div class="h-px flex-1 bg-ink/15" />}
            </>
          ))}
        </div>

        <!-- Formulario -->
        <form id="expediente-form" novalidate>
          <!-- Campos ocultos: convocatoria pre-seleccionada -->
          <input type="hidden" name="convocatoriaSlug" value={convSlug} />
          {convTitle && <input type="hidden" name="convocatoriaNombre" id="conv-nombre-hidden" value={convTitle} />}
          <!-- PASO 1: La entidad -->
          <fieldset id="step-1" class="step-panel space-y-6">
            <legend class="font-display text-2xl text-ink">Tu entidad</legend>
            <p class="text-sm text-ink/60">Los datos del organismo que va a presentarse a la subvención.</p>

            <div class="space-y-1">
              <label for="orgName" class="label">Nombre de la organización <span class="text-magenta">*</span></label>
              <input
                type="text"
                id="orgName"
                name="orgName"
                required
                maxlength="200"
                placeholder="Fundación Ejemplo"
                class="form-input w-full"
              />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-1">
                <label for="cif" class="label">CIF / NIF <span class="text-magenta">*</span></label>
                <input
                  type="text"
                  id="cif"
                  name="cif"
                  required
                  maxlength="20"
                  placeholder="G12345678"
                  class="form-input w-full"
                />
              </div>
              <div class="space-y-1">
                <label for="orgType" class="label">Tipo de entidad <span class="text-magenta">*</span></label>
                <select id="orgType" name="orgType" required class="form-input w-full">
                  <option value="">Selecciona…</option>
                  <option value="fundacion">Fundación</option>
                  <option value="asociacion">Asociación</option>
                  <option value="cooperativa">Cooperativa</option>
                  <option value="empresa">Empresa</option>
                  <option value="entidad-publica">Entidad pública</option>
                  <option value="otro">Otro</option>
                </select>
              </div>
            </div>

            <div class="space-y-1">
              <label for="representante" class="label">Representante legal <span class="text-magenta">*</span></label>
              <input
                type="text"
                id="representante"
                name="representante"
                required
                maxlength="120"
                placeholder="Nombre y apellidos"
                class="form-input w-full"
              />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-1">
                <label for="email" class="label">Email de contacto <span class="text-magenta">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  maxlength="120"
                  placeholder="tu@entidad.org"
                  class="form-input w-full"
                />
              </div>
              <div class="space-y-1">
                <label for="telefono" class="label">Teléfono</label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  maxlength="20"
                  placeholder="600 000 000"
                  class="form-input w-full"
                />
              </div>
            </div>

            <div class="space-y-1">
              <label for="provincia" class="label">Provincia / Comunidad Autónoma <span class="text-magenta">*</span></label>
              <input
                type="text"
                id="provincia"
                name="provincia"
                required
                maxlength="80"
                placeholder="Granada, Andalucía"
                class="form-input w-full"
              />
            </div>
          </fieldset>

          <!-- PASO 2: La convocatoria y el proyecto -->
          <fieldset id="step-2" class="step-panel hidden space-y-6">
            <legend class="font-display text-2xl text-ink">La subvención</legend>
            <p class="text-sm text-ink/60">Cuéntanos a qué subvención queréis presentaros y qué hace vuestra entidad.</p>

            {convTitle ? (
              /* ── Convocatoria ya preseleccionada desde la landing ── */
              <div class="space-y-4">
                <input type="hidden" name="tieneConvocatoria" value="si" />

                {/* Confirmación de la convocatoria */}
                <div class="flex items-start gap-3 border border-magenta/30 bg-magenta/5 p-4">
                  <span class="mt-0.5 text-magenta font-bold text-lg leading-none shrink-0">✓</span>
                  <div class="min-w-0">
                    <p class="font-mono text-[10px] uppercase tracking-widest text-magenta mb-1">Subvención seleccionada</p>
                    <p class="font-medium text-ink text-sm leading-snug">{convTitle}</p>
                    {convHint && (
                      <p class="mt-2 text-xs text-ink/60 leading-relaxed">{convHint}</p>
                    )}
                    <p class="mt-2 text-xs text-ink/40">
                      ¿No es esta?{' '}
                      <a href="/subvenciones/presentar/nuevo" class="text-magenta hover:underline">
                        Cambiar →
                      </a>
                    </p>
                  </div>
                </div>

                {/* Plazo e importe */}
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <label for="plazo" class="label">Fecha límite</label>
                    <input type="date" id="plazo" name="plazo" class="form-input w-full" />
                  </div>
                  <div class="space-y-1">
                    <label for="importeSolicitado" class="label">¿Cuánto queréis solicitar?</label>
                    <input
                      type="text"
                      id="importeSolicitado"
                      name="importeSolicitado"
                      maxlength="30"
                      placeholder="Ej: 20.000 €"
                      class="form-input w-full"
                    />
                  </div>
                </div>
              </div>
            ) : (
              /* ── Flujo estándar: el usuario indica su convocatoria ── */
              <div class="space-y-4" id="conv-selector">
                <div class="space-y-2">
                  <p class="label">¿Ya sabéis a qué subvención queréis presentaros? <span class="text-magenta">*</span></p>
                  <div class="grid gap-3 sm:grid-cols-2">
                    <label class="flex cursor-pointer items-start gap-3 border border-ink/15 p-3 hover:border-magenta/40 has-[:checked]:border-magenta has-[:checked]:bg-magenta/5">
                      <input type="radio" name="tieneConvocatoria" value="si" required class="accent-magenta mt-0.5 shrink-0" />
                      <div>
                        <span class="text-sm font-medium text-ink">Sí, ya la tenemos identificada</span>
                        <p class="mt-0.5 text-xs text-ink/50">Tenemos el nombre o el enlace a la convocatoria.</p>
                      </div>
                    </label>
                    <label class="flex cursor-pointer items-start gap-3 border border-ink/15 p-3 hover:border-magenta/40 has-[:checked]:border-magenta has-[:checked]:bg-magenta/5">
                      <input type="radio" name="tieneConvocatoria" value="no" class="accent-magenta mt-0.5 shrink-0" />
                      <div>
                        <span class="text-sm font-medium text-ink">No, necesitamos ayuda para encontrarla</span>
                        <p class="mt-0.5 text-xs text-ink/50">Startidea identifica las convocatorias que mejor encajan con vuestro proyecto.</p>
                      </div>
                    </label>
                  </div>
                </div>

                {/* Si tiene convocatoria */}
                <div id="has-convocatoria" class="space-y-4" style="display:none">
                  <div class="space-y-1">
                    <label for="convocatoriaNombre" class="label">Nombre de la subvención <span class="text-magenta">*</span></label>
                    <input
                      type="text"
                      id="convocatoriaNombre"
                      name="convocatoriaNombre"
                      maxlength="300"
                      placeholder="Ej: Subvenciones acción social Junta de Andalucía 2026"
                      class="form-input w-full"
                    />
                  </div>
                  <div class="space-y-1">
                    <label for="convocatoriaUrl" class="label">Enlace a la convocatoria (si lo tienes)</label>
                    <input
                      type="url"
                      id="convocatoriaUrl"
                      name="convocatoriaUrl"
                      maxlength="500"
                      placeholder="https://www.juntadeandalucia.es/… o enlace del BOE/BOJA"
                      class="form-input w-full"
                    />
                    <p class="text-xs text-ink/40">No es obligatorio. Con el nombre es suficiente para que Startidea localice la convocatoria.</p>
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                      <label for="plazo" class="label">Fecha límite</label>
                      <input type="date" id="plazo" name="plazo" class="form-input w-full" />
                    </div>
                    <div class="space-y-1">
                      <label for="importeSolicitado" class="label">¿Cuánto queréis solicitar?</label>
                      <input
                        type="text"
                        id="importeSolicitado"
                        name="importeSolicitado"
                        maxlength="30"
                        placeholder="Ej: 20.000 €"
                        class="form-input w-full"
                      />
                    </div>
                  </div>
                </div>

                {/* Si no tiene convocatoria */}
                <div id="no-convocatoria" class="space-y-4" style="display:none">
                  <div class="border border-ink/10 bg-paper-warm p-4 text-sm text-ink/70">
                    Sin problema. Con la descripción de vuestro proyecto Startidea identifica las convocatorias más adecuadas y os presenta las opciones en el diagnóstico.
                  </div>
                  <div class="space-y-1">
                    <label for="importeEstimado" class="label">¿Cuánta financiación necesitáis?</label>
                    <input
                      type="text"
                      id="importeEstimado"
                      name="importeEstimado"
                      maxlength="30"
                      placeholder="Ej: 30.000 €"
                      class="form-input w-full"
                    />
                  </div>
                </div>
              </div>
            )}

            {/* Campo de descripción — siempre visible, lenguaje simplificado */}
            <div class="space-y-2">
              <label for="descripcionProyecto" class="label">
                ¿Qué hace vuestra entidad y para qué necesitáis la subvención?
                <span class="text-magenta">*</span>
              </label>
              <p class="text-xs text-ink/50 leading-relaxed">
                No tiene que ser perfecto — Startidea lo refinará. Con 3-4 frases es suficiente para arrancar.
              </p>
              <textarea
                id="descripcionProyecto"
                name="descripcionProyecto"
                rows="5"
                required
                maxlength="2000"
                placeholder="Ej: Somos una asociación de atención a personas mayores en Granada. Llevamos 15 años gestionando el centro de día y el servicio de ayuda a domicilio. Queremos financiar la ampliación del servicio a 20 personas más en 2026, incluyendo personal de atención y material adaptado."
                class="form-input w-full resize-none"
              ></textarea>
              <details class="text-xs">
                <summary class="cursor-pointer text-ink/40 hover:text-ink/70">¿No sé qué escribir? Ver guía rápida</summary>
                <div class="mt-2 space-y-1 border border-ink/10 bg-paper-warm p-3 text-ink/60">
                  <p><strong>Responde estas 3 preguntas:</strong></p>
                  <p>1. ¿A quién ayuda vuestra entidad y cómo? (colectivo y tipo de servicio)</p>
                  <p>2. ¿Qué proyecto o programa queréis hacer con la subvención?</p>
                  <p>3. ¿Cuántas personas se beneficiarán y en qué plazo?</p>
                  <p class="mt-2 text-ink/40">No hace falta que sea largo. Si luego necesitamos más datos, os los pedimos.</p>
                </div>
              </details>
              <p class="text-xs text-ink/30">Máximo 2000 caracteres. <span id="chars-left">2000</span> restantes.</p>
            </div>

            <details class="border border-ink/10">
              <summary class="cursor-pointer select-none px-4 py-3 font-mono text-xs uppercase tracking-wider text-ink/60 hover:bg-paper-warm">
                + Datos de impacto de la organización
                <span class="text-magenta">(mejora mucho los documentos generados)</span>
              </summary>
              <div class="space-y-4 border-t border-ink/10 p-4">
                <p class="text-xs text-ink/50">El equipo usa estos datos para cuantificar la memoria técnica. Rellena solo lo que sepas, no es obligatorio.</p>
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <label for="beneficiariosAnuales" class="label">Personas atendidas al año</label>
                    <input
                      type="number"
                      id="beneficiariosAnuales"
                      name="beneficiariosAnuales"
                      min="0"
                      max="9999999"
                      class="form-input w-full"
                      placeholder="340"
                    />
                  </div>
                  <div class="space-y-1">
                    <label for="presupuestoAnual" class="label">Presupuesto anual (aprox.)</label>
                    <input
                      type="text"
                      id="presupuestoAnual"
                      name="presupuestoAnual"
                      maxlength="40"
                      class="form-input w-full"
                      placeholder="120.000 €"
                    />
                  </div>
                </div>
                <div class="space-y-1">
                  <label for="logrosDestacados" class="label">Logros e indicadores destacados</label>
                  <textarea
                    id="logrosDestacados"
                    name="logrosDestacados"
                    rows="3"
                    maxlength="500"
                    class="form-input w-full resize-none"
                    placeholder="Ej: 340 jóvenes formados en 2023 (75% insertados laboralmente). 18 pisos tutelados activos. Premio X al mejor proyecto social 2022…"
                  ></textarea>
                </div>
                <div class="space-y-1">
                  <label for="subvencionesAnteriores" class="label">Subvenciones recibidas anteriormente (referencias)</label>
                  <textarea
                    id="subvencionesAnteriores"
                    name="subvencionesAnteriores"
                    rows="3"
                    maxlength="500"
                    class="form-input w-full resize-none"
                    placeholder="Ej: Junta de Andalucía 2022: 45.000€ programa empleo. Diputación Granada 2023: 15.000€ atención domiciliaria…"
                  ></textarea>
                </div>
              </div>
            </details>

            <div class="space-y-2">
              <p class="label">¿Tiene la entidad experiencia previa en subvenciones?</p>
              <div class="flex flex-wrap gap-4">
                {['Nunca hemos pedido', 'Alguna vez', 'Tenemos varias concedidas', 'Somos veteranos'].map(v => (
                  <label class="flex cursor-pointer items-center gap-2">
                    <input type="radio" name="experiencia" value={v} class="accent-magenta" />
                    <span class="text-sm text-ink">{v}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="space-y-3">
              <p class="label">¿Cómo queréis gestionar la presentación electrónica?</p>
              <p class="text-xs text-ink/50">En ningún caso Startidea utiliza ni solicita vuestro certificado digital. Siempre permanece bajo vuestro control.</p>
              <div class="grid gap-3 sm:grid-cols-2">
                <label class="flex cursor-pointer items-start gap-3 border border-ink/15 p-3 hover:border-magenta/40 has-[:checked]:border-magenta has-[:checked]:bg-magenta/5">
                  <input type="radio" name="apoderamiento" value="si" class="accent-magenta mt-0.5 shrink-0" />
                  <div>
                    <span class="text-sm font-medium text-ink">Otorgamos apoderamiento a Startidea</span>
                    <p class="mt-0.5 text-xs text-ink/55 leading-relaxed">Startidea presenta en vuestro nombre usando su propio certificado como representante autorizado. Vosotros solo otorgáis el permiso en la sede electrónica (5 minutos).</p>
                  </div>
                </label>
                <label class="flex cursor-pointer items-start gap-3 border border-ink/15 p-3 hover:border-magenta/40 has-[:checked]:border-magenta has-[:checked]:bg-magenta/5">
                  <input type="radio" name="apoderamiento" value="no" class="accent-magenta mt-0.5 shrink-0" />
                  <div>
                    <span class="text-sm font-medium text-ink">Preferimos firmar nosotros</span>
                    <p class="mt-0.5 text-xs text-ink/55 leading-relaxed">Startidea prepara y entrega el expediente completo. Cuando dais el visto bueno, os enviamos las instrucciones para que firmáis y presentéis vosotros con vuestro certificado (menos de 10 minutos).</p>
                  </div>
                </label>
              </div>
            </div>
          </fieldset>

          <!-- PASO 3: Documentos -->
          <fieldset id="step-3" class="step-panel hidden space-y-6">
            <legend class="font-display text-2xl text-ink">Documentos disponibles</legend>
            <p class="text-sm text-ink/60">
              Sube los documentos que ya tengas preparados. No es obligatorio tenerlos todos — en el diagnóstico te decimos qué falta y cómo conseguirlo.
            </p>

            <!-- Banner documentos -->
            <div class="border border-magenta/30 bg-magenta/5 p-4">
              <p class="font-mono text-xs uppercase tracking-widest text-magenta">⚡ Cuanto más, mejor</p>
              <p class="mt-1.5 text-sm text-ink/70">
                Si subes tu <strong>memoria de actividades del año anterior</strong> o tus <strong>estatutos</strong>,
                el equipo los usa para personalizar la documentación con información real de tu organización.
                El resultado es significativamente mejor que sin documentos.
              </p>
            </div>

            <div class="space-y-4">
              {[
                {
                  id: 'doc-memoria-anual',
                  name: 'docMemoriaAnual',
                  label: '⭐ Memoria de actividades del año anterior',
                  hint: 'El documento más valioso para el expediente. Permite incluir tu historial, indicadores de impacto, beneficiarios y proyectos.',
                  badge: 'MUY RECOMENDADO',
                },
                {
                  id: 'doc-estatutos',
                  name: 'docEstatutos',
                  label: '⭐ Estatutos de la entidad',
                  hint: 'Permite verificar que el objeto social encaja con la convocatoria y documentar la presentación. Con sello de inscripción.',
                  badge: 'MUY RECOMENDADO',
                },
                {
                  id: 'doc-memoria',
                  name: 'docMemoria',
                  label: 'Borrador de memoria técnica del proyecto',
                  hint: 'Si tienes un borrador, el equipo lo mejora y adapta a la convocatoria. Si no tienes, lo elaboramos desde cero.',
                },
                {
                  id: 'doc-presupuesto',
                  name: 'docPresupuesto',
                  label: 'Presupuesto estimado del proyecto',
                  hint: 'Si tienes un presupuesto previo (Word, Excel o PDF), el equipo lo reformatea según las partidas que pide la convocatoria.',
                },
                {
                  id: 'doc-hacienda',
                  name: 'docHacienda',
                  label: 'Certificado AEAT (Hacienda)',
                  hint: 'Al corriente de obligaciones tributarias. Válido 6 meses desde la fecha de emisión.',
                },
                {
                  id: 'doc-ss',
                  name: 'docSS',
                  label: 'Certificado TGSS (Seguridad Social)',
                  hint: 'Al corriente de pagos a la Seguridad Social. Válido 6 meses. Si no lo tienes aún, se puede solicitar justo antes de presentar.',
                },
                {
                  id: 'doc-otros',
                  name: 'docOtros',
                  label: 'Otros documentos relevantes',
                  hint: 'Actas, informes de auditoría, premios, publicaciones… Cualquier documento que acredite la trayectoria o capacidad técnica.',
                  multiple: true,
                },
              ].map(doc => (
                <div class:list={['border p-4', doc.badge ? 'border-magenta/30 bg-magenta/3' : 'border-ink/10']}>
                  <label for={doc.id} class="block cursor-pointer">
                    <div class="flex items-start justify-between gap-3">
                      <p class="font-mono text-sm text-ink">{doc.label}</p>
                      {doc.badge && (
                        <span class="shrink-0 font-mono text-[9px] uppercase tracking-widest text-magenta">
                          {doc.badge}
                        </span>
                      )}
                    </div>
                    <p class="mt-0.5 text-xs text-ink/50">{doc.hint}</p>
                    <div class="mt-3 flex items-center gap-3">
                      <span class="border border-ink px-3 py-1.5 font-mono text-[11px] uppercase tracking-wider text-ink hover:bg-paper-warm">
                        Seleccionar archivo
                      </span>
                      <span class="text-xs text-ink/40" id={`${doc.id}-name`}>Sin archivo seleccionado</span>
                    </div>
                  </label>
                  <input
                    type="file"
                    id={doc.id}
                    name={doc.name}
                    multiple={doc.multiple}
                    accept=".pdf,.doc,.docx,.xls,.xlsx,.odt,.ods,.txt"
                    class="sr-only"
                    data-file-label={`${doc.id}-name`}
                  />
                </div>
              ))}
            </div>

            <div class="border border-ink/10 bg-paper-warm p-3 font-mono text-[10px] uppercase tracking-wider text-ink/40">
              Formatos: PDF, Word (.doc/.docx), Excel (.xls/.xlsx), OpenDocument, TXT · Máx. 20 MB por archivo
            </div>
          </fieldset>

          <!-- PASO 4: Confirmar -->
          <fieldset id="step-4" class="step-panel hidden space-y-6">
            <legend class="font-display text-2xl text-ink">Confirmar y enviar</legend>
            <p class="text-sm text-ink/60">Revisa el resumen y confirma el envío.</p>

            <!-- Resumen -->
            <div id="resumen" class="space-y-3 border border-ink/15 bg-paper-warm p-5">
              <h3 class="font-mono text-xs uppercase tracking-wider text-ink/50">Resumen del expediente</h3>
              <dl class="space-y-2 text-sm">
                <div class="flex gap-2">
                  <dt class="w-32 shrink-0 text-ink/50">Entidad</dt>
                  <dd id="resumen-entidad" class="text-ink"></dd>
                </div>
                <div class="flex gap-2">
                  <dt class="w-32 shrink-0 text-ink/50">CIF</dt>
                  <dd id="resumen-cif" class="text-ink"></dd>
                </div>
                <div class="flex gap-2">
                  <dt class="w-32 shrink-0 text-ink/50">Email</dt>
                  <dd id="resumen-email" class="text-ink"></dd>
                </div>
                <div class="flex gap-2">
                  <dt class="w-32 shrink-0 text-ink/50">Convocatoria</dt>
                  <dd id="resumen-convocatoria" class="text-ink"></dd>
                </div>
                <div class="flex gap-2">
                  <dt class="w-32 shrink-0 text-ink/50">Documentos</dt>
                  <dd id="resumen-docs" class="text-ink"></dd>
                </div>
              </dl>
            </div>

            <div class="space-y-1">
              <label for="comentarios" class="label">Comentarios adicionales (opcional)</label>
              <textarea
                id="comentarios"
                name="comentarios"
                rows="3"
                maxlength="800"
                placeholder="Cualquier cosa que sea relevante y que no hayas podido explicar antes."
                class="form-input w-full resize-none"
              ></textarea>
            </div>

            <div class="space-y-1">
              <label for="como-conocio" class="label">¿Cómo has conocido este servicio?</label>
              <select id="como-conocio" name="comoConocio" class="form-input w-full">
                <option value="">Selecciona…</option>
                <option value="buscador">Buscador (Google, etc.)</option>
                <option value="recomendacion">Recomendación de alguien</option>
                <option value="buscador-subvenciones">Buscador de subvenciones de Startidea</option>
                <option value="redes">Redes sociales</option>
                <option value="nota">Una nota o artículo</option>
                <option value="ya-cliente">Ya soy cliente de Startidea</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <!-- Campo honeypot anti-spam -->
            <input type="text" name="website" class="sr-only" tabindex="-1" autocomplete="off" />

            <div class="flex items-start gap-3">
              <input type="checkbox" id="rgpd" name="rgpd" required class="mt-0.5 accent-magenta" />
              <label for="rgpd" class="text-sm text-ink/70">
                Acepto que Startidea use mis datos para gestionar este expediente y me contacte con el diagnóstico de encaje. Al enviar se crea automáticamente mi acceso al portal de clientes (sin contraseña). Todo de acuerdo con la{' '}
                <a href="/privacidad" class="underline hover:text-magenta">política de privacidad</a>.
              </label>
            </div>

            <!-- Estado del envío -->
            <div id="form-error" class="hidden border border-red-300 bg-red-50 p-4 text-sm text-red-700"></div>
          </fieldset>

          <!-- Botones de navegación -->
          <div class="mt-10 flex items-center justify-between border-t border-ink/10 pt-6">
            <button
              type="button"
              id="btn-prev"
              class="btn-ghost hidden"
              aria-label="Paso anterior"
            >
              ← Atrás
            </button>
            <button
              type="button"
              id="btn-next"
              class="btn ml-auto"
            >
              Siguiente →
            </button>
            <button
              type="submit"
              id="btn-submit"
              class="btn ml-auto hidden"
            >
              Enviar expediente →
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .form-input {
    @apply border border-ink/20 bg-paper px-4 py-2.5 text-sm text-ink outline-none transition-colors focus:border-ink focus:ring-1 focus:ring-ink;
  }
  .form-input:invalid:not(:placeholder-shown) {
    @apply border-red-400;
  }
</style>

<script>
  const TOTAL_STEPS = 4;
  let currentStep = 1;

  const form = document.getElementById('expediente-form') as HTMLFormElement;
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

  function getPanel(n: number) {
    return document.getElementById(`step-${n}`) as HTMLElement;
  }

  function getDotCircle(n: number) {
    const dot = document.querySelector(`[data-step-dot="${n}"] [data-dot-circle]`) as HTMLElement;
    return dot;
  }

  function updateUI() {
    // Paneles
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      getPanel(i)?.classList.toggle('hidden', i !== currentStep);
    }

    // Dots
    for (let i = 1; i <= TOTAL_STEPS; i++) {
      const dot = getDotCircle(i);
      if (!dot) continue;
      if (i < currentStep) {
        dot.className = 'flex h-8 w-8 items-center justify-center border-2 border-ink bg-ink font-mono text-sm text-paper transition-colors';
        dot.textContent = '✓';
      } else if (i === currentStep) {
        dot.className = 'flex h-8 w-8 items-center justify-center border-2 border-magenta bg-magenta font-mono text-sm text-paper transition-colors';
        dot.textContent = String(i);
      } else {
        dot.className = 'flex h-8 w-8 items-center justify-center border-2 border-ink/20 bg-paper font-mono text-sm text-ink/40 transition-colors';
        dot.textContent = String(i);
      }
    }

    // Botones
    btnPrev.classList.toggle('hidden', currentStep === 1);
    btnNext.classList.toggle('hidden', currentStep === TOTAL_STEPS);
    btnSubmit.classList.toggle('hidden', currentStep !== TOTAL_STEPS);

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function validateStep(n: number): boolean {
    const panel = getPanel(n);
    const required = panel.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[required]');
    let valid = true;
    for (const el of required) {
      if (!el.value.trim()) {
        el.focus();
        el.classList.add('border-red-400');
        valid = false;
        break;
      } else {
        el.classList.remove('border-red-400');
      }
    }
    // Validar radios requeridos en paso 2.
    // Si convocatoria ya está preseleccionada, el campo es un hidden input
    // (no un radio), así que `:checked` no aplica — se omite la validación.
    if (n === 2) {
      const hiddenTiene = form.querySelector<HTMLInputElement>(
        'input[name="tieneConvocatoria"][type="hidden"]'
      );
      if (!hiddenTiene) {
        const radioTiene = form.querySelector<HTMLInputElement>(
          'input[name="tieneConvocatoria"]:checked'
        );
        if (!radioTiene) {
          valid = false;
          const group = form.querySelector('[name="tieneConvocatoria"]')?.closest('.space-y-2');
          group?.classList.add('ring-1', 'ring-red-400', 'ring-offset-2');
        }
      }
    }
    return valid;
  }

  function updateResumen() {
    const orgName = (form.querySelector('#orgName') as HTMLInputElement).value;
    const cif = (form.querySelector('#cif') as HTMLInputElement).value;
    const email = (form.querySelector('#email') as HTMLInputElement).value;
    const convoUrl = (form.querySelector('#convocatoriaUrl') as HTMLInputElement).value;
    const convoNombre = (form.querySelector('#convocatoriaNombre') as HTMLInputElement).value;
    const necesidad = (form.querySelector('#descripcionProyecto') as HTMLTextAreaElement).value;
    const fileInputs = form.querySelectorAll<HTMLInputElement>('input[type="file"]');

    const docs: string[] = [];
    fileInputs.forEach(fi => {
      if (fi.files && fi.files.length > 0) {
        docs.push(`${fi.files.length} archivo(s) en ${fi.name}`);
      }
    });

    (document.getElementById('resumen-entidad') as HTMLElement).textContent = orgName || '—';
    (document.getElementById('resumen-cif') as HTMLElement).textContent = cif || '—';
    (document.getElementById('resumen-email') as HTMLElement).textContent = email || '—';
    (document.getElementById('resumen-convocatoria') as HTMLElement).textContent = convoNombre || convoUrl || necesidad.slice(0, 80) || '—';
    (document.getElementById('resumen-docs') as HTMLElement).textContent = docs.length ? docs.join(', ') : 'Ninguno (se puede completar más adelante)';
  }

  btnNext.addEventListener('click', () => {
    if (!validateStep(currentStep)) return;
    if (currentStep === TOTAL_STEPS - 1) updateResumen();
    currentStep = Math.min(currentStep + 1, TOTAL_STEPS);
    updateUI();
  });

  btnPrev.addEventListener('click', () => {
    currentStep = Math.max(currentStep - 1, 1);
    updateUI();
  });

  // Toggle convocatoria sections
  form.querySelectorAll('input[name="tieneConvocatoria"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const val = (form.querySelector('input[name="tieneConvocatoria"]:checked') as HTMLInputElement)?.value;
      (document.getElementById('has-convocatoria') as HTMLElement).style.display = val === 'si' ? 'block' : 'none';
      (document.getElementById('no-convocatoria') as HTMLElement).style.display = val === 'no' ? 'block' : 'none';
    });
  });

  // Contador de caracteres descripción
  const descArea = document.getElementById('descripcionProyecto') as HTMLTextAreaElement;
  const charsLeft = document.getElementById('chars-left') as HTMLElement;
  descArea?.addEventListener('input', () => {
    charsLeft.textContent = String(2000 - descArea.value.length);
  });

  // File input labels
  document.querySelectorAll<HTMLInputElement>('input[type="file"]').forEach(input => {
    input.addEventListener('change', () => {
      const labelId = input.dataset.fileLabel;
      if (!labelId) return;
      const label = document.getElementById(labelId);
      if (!label) return;
      if (input.files && input.files.length > 0) {
        const names = Array.from(input.files).map(f => f.name).join(', ');
        label.textContent = names.length > 50 ? names.slice(0, 47) + '…' : names;
        label.classList.add('text-ink');
        label.classList.remove('text-ink/40');
      } else {
        label.textContent = 'Sin archivo seleccionado';
        label.classList.remove('text-ink');
        label.classList.add('text-ink/40');
      }
    });
  });

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateStep(TOTAL_STEPS)) return;

    const errDiv = document.getElementById('form-error') as HTMLElement;
    errDiv.classList.add('hidden');
    btnSubmit.disabled = true;
    btnSubmit.textContent = 'Enviando…';

    // Combinar datos de impacto de la organización en el campo comentarios
    // para que el motor IA los reciba como contexto estructurado
    const benef = (form.querySelector('#beneficiariosAnuales') as HTMLInputElement)?.value?.trim();
    const ppto = (form.querySelector('#presupuestoAnual') as HTMLInputElement)?.value?.trim();
    const logros = (form.querySelector('#logrosDestacados') as HTMLTextAreaElement)?.value?.trim();
    const subvPrev = (form.querySelector('#subvencionesAnteriores') as HTMLTextAreaElement)?.value?.trim();
    const comentariosEl = form.querySelector('#comentarios') as HTMLTextAreaElement;

    const ctxLines: string[] = [];
    if (benef) ctxLines.push(`Personas atendidas al año: ${benef}`);
    if (ppto) ctxLines.push(`Presupuesto anual: ${ppto}`);
    if (logros) ctxLines.push(`Logros e indicadores:\n${logros}`);
    if (subvPrev) ctxLines.push(`Subvenciones anteriores:\n${subvPrev}`);

    if (ctxLines.length > 0) {
      const ctxBlock = `[Datos de la organización]\n${ctxLines.join('\n')}`;
      const existingComments = comentariosEl.value.trim();
      comentariosEl.value = existingComments
        ? `${ctxBlock}\n---\nComentarios: ${existingComments}`
        : ctxBlock;
    }

    const data = new FormData(form);

    try {
      const res = await fetch('/api/expediente', { method: 'POST', body: data });
      const json = await res.json();
      if (json.ok) {
        window.location.href = '/subvenciones/presentar/gracias';
      } else {
        errDiv.textContent = 'Ha habido un error al enviar el formulario. Escríbenos a hola@startidea.es directamente.';
        errDiv.classList.remove('hidden');
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Enviar expediente →';
      }
    } catch {
      errDiv.textContent = 'Error de conexión. Comprueba tu internet e inténtalo de nuevo.';
      errDiv.classList.remove('hidden');
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Enviar expediente →';
    }
  });

  // Init
  updateUI();
</script>
