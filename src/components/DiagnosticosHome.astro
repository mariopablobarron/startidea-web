---
// Bloque para la home: 3 diagnósticos más recientes del Laboratorio.
// Si no hay ninguno publicado, no se renderiza nada.
import { getCollection } from 'astro:content';

const all = await getCollection('diagnosticos', ({ data }) => !data.draft);
all.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const top = all.slice(0, 3);

const fmt = new Intl.DateTimeFormat('es-ES', { year: 'numeric', month: 'long' });
---

{top.length > 0 && (
  <section class="bg-paper py-20 md:py-28">
    <div class="container-x">
      <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
        <div class="col-span-12 lg:col-span-4">
          <span class="label">— Laboratorio · Fundraising</span>
          <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
            Diagnósticos <em class="italic text-magenta">públicos</em>.
          </h2>
          <p class="mt-5 max-w-measure text-ink/80">
            Una selección anonimizada de los diagnósticos que Startidea hace a entidades del Tercer Sector. Para que veas cómo se piensa antes de proponer.
          </p>
          <div class="mt-8">
            <a href="/laboratorio/fundraising" class="btn-ghost">
              Ver todos los diagnósticos
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="col-span-12 mt-8 lg:col-span-8 lg:mt-0">
          <ol class="divide-y divide-ink/15 border-y border-ink/15">
            {top.map((d, i) => (
              <li>
                <a href={`/laboratorio/fundraising/${d.slug}`} class="group grid grid-cols-12 gap-x-6 gap-y-3 py-7 transition-colors hover:bg-paper-warm">
                  <div class="col-span-12 sm:col-span-2">
                    <span class="num-edit text-3xl">{String(i + 1).padStart(2, '0')}</span>
                    <p class="mt-2 font-mono text-[10px] uppercase tracking-widest text-ink-mute">
                      {fmt.format(d.data.pubDate)}
                    </p>
                  </div>
                  <div class="col-span-12 sm:col-span-10">
                    <h3 class="font-display text-xl leading-tight text-ink transition-colors group-hover:text-magenta md:text-2xl">
                      {d.data.title}
                    </h3>
                    <p class="mt-2 line-clamp-2 max-w-measure text-sm text-ink/75">
                      {d.data.description}
                    </p>
                    <div class="mt-3 flex flex-wrap items-center gap-2 font-mono text-[10px] uppercase tracking-wider">
                      <span class="border border-magenta/40 px-2 py-0.5 text-magenta">{d.data.sector}</span>
                      <span class="border border-ink/30 px-2 py-0.5 text-ink/70">{d.data.geografia}</span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>
)}
