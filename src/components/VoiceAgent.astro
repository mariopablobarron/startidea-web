---
// Asistente Startidea — botón flotante + modal dual VOZ/TEXTO.
//
// Dos pipelines comparten chatAndSpeak():
//   VOZ:   mic push-to-talk → MediaRecorder webm
//          → POST /api/public/voice/transcribe → texto
//          → chatAndSpeak(texto, { speak: true })
//   TEXTO: input.value → chatAndSpeak(texto, { speak: false })
//
// chatAndSpeak() hace:
//   1. POST /api/public/voice/chat (LLM + tools) → respuesta texto
//   2. Si speak=true → POST /api/public/voice/speak → audio MP3 → reproduce
//
// Botón "■ Stop" en el header: corta el audio TTS en curso (audio.pause()).
//
// RGPD: consent banner ANTES de pedir permiso del micrófono.
// Privacy-first: no graba en silencio (push-to-talk), no guarda audio
// en servidor (solo transcripción).
---

<!-- Botón flotante "Hablar". Convive con el AsistenteIA (texto) — éste
     va a su izquierda en desktop, encima en mobile. -->
<button
  type="button"
  id="voice-chip"
  class="fixed bottom-6 right-[200px] z-40 hidden md:inline-flex items-center gap-2 border-2 border-magenta bg-paper px-5 py-3 font-mono text-[12px] uppercase tracking-widest text-magenta shadow-[0_8px_24px_-8px_rgba(0,0,0,0.35)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-magenta hover:text-paper"
  aria-haspopup="dialog"
  aria-controls="voice-panel"
  aria-expanded="false"
>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"></path>
    <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
    <line x1="12" y1="19" x2="12" y2="22"></line>
  </svg>
  <span>Hablar</span>
</button>

<button
  type="button"
  id="voice-chip-mobile"
  class="fixed bottom-[80px] right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full border-2 border-magenta bg-paper text-magenta shadow-[0_8px_24px_-8px_rgba(0,0,0,0.35)] transition-colors hover:bg-magenta hover:text-paper md:hidden"
  aria-haspopup="dialog"
  aria-controls="voice-panel"
  aria-expanded="false"
  aria-label="Abrir agente de voz"
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"></path>
    <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
    <line x1="12" y1="19" x2="12" y2="22"></line>
  </svg>
</button>

<div
  id="voice-panel"
  class="fixed inset-x-4 bottom-20 z-50 hidden max-h-[85vh] flex-col overflow-hidden border-2 border-ink bg-paper shadow-[0_24px_48px_-16px_rgba(0,0,0,0.35)] sm:right-6 sm:left-auto sm:bottom-24 sm:w-[460px] md:max-h-[640px]"
  role="dialog"
  aria-modal="false"
  aria-labelledby="voice-title"
>
  <!-- Header -->
  <div class="flex items-center justify-between border-b-2 border-ink bg-magenta px-5 py-3 text-paper">
    <div>
      <p id="voice-title" class="font-mono text-[11px] uppercase tracking-widest">— Asistente · Startidea</p>
      <p id="voice-subtitle" class="mt-0.5 font-mono text-[10px] tracking-wider text-paper/75">Habla o escribe lo que necesites</p>
    </div>
    <div class="flex items-center gap-3">
      <button
        type="button"
        id="voice-stop-speech"
        class="hidden font-mono text-[10px] uppercase tracking-widest text-paper bg-ink/40 hover:bg-ink/60 px-2 py-1"
        aria-label="Parar voz"
        title="Parar voz que está sonando"
      >■ Stop</button>
      <button
        type="button"
        id="voice-close"
        class="font-mono text-[11px] uppercase tracking-widest text-paper/85 hover:text-paper"
        aria-label="Cerrar"
      >Cerrar ✕</button>
    </div>
  </div>

  <!-- Cuerpo (3 estados: consent / chat / lead-ok) -->
  <div id="voice-body" class="flex-1 overflow-y-auto p-5">

    <!-- ESTADO 1: CONSENT RGPD (genérico — detalles técnicos en /privacidad) -->
    <div id="voice-consent" class="space-y-4">
      <p class="font-display text-lg text-ink">
        Antes de empezar.
      </p>
      <ul class="space-y-2 text-sm text-ink/85">
        <li class="flex gap-2"><span class="text-magenta">·</span> La voz se graba <strong>solo</strong> mientras mantengas el botón del micrófono pulsado.</li>
        <li class="flex gap-2"><span class="text-magenta">·</span> El audio se transcribe y se descarta. Solo se conserva el texto.</li>
        <li class="flex gap-2"><span class="text-magenta">·</span> Si dejas tu email, el equipo Startidea te contacta. Sin spam, sin cesión a terceros.</li>
      </ul>
      <p class="text-[11px] text-ink-mute">
        Tratamiento de datos detallado en
        <a href="/privacidad" class="underline hover:text-magenta">/privacidad</a>.
      </p>
      <div class="border-t border-ink/15 pt-4 flex gap-3">
        <button type="button" id="voice-consent-ok" class="bg-ink px-4 py-2.5 font-mono text-[11px] uppercase tracking-widest text-paper hover:bg-magenta">
          Acepto y continuar
        </button>
        <button type="button" id="voice-consent-no" class="font-mono text-[11px] uppercase tracking-widest text-ink/65 hover:text-magenta">
          Mejor no
        </button>
      </div>
    </div>

    <!-- ESTADO 2: CHAT ACTIVO -->
    <div id="voice-chat" class="hidden">
      <div id="voice-transcript" class="space-y-3 min-h-[200px]" aria-live="polite">
        <!-- mensajes injectados aquí -->
        <div class="border-l-2 border-magenta pl-3 py-1">
          <p class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Startidea</p>
          <p class="mt-1 text-sm text-ink">Hola. Cuéntame qué necesitas. Puedes hablar (mantén el micrófono pulsado) o escribir abajo.</p>
        </div>
      </div>

      <!-- Sugerencias de subvenciones inyectadas dinámicamente -->
      <div id="voice-suggestions" class="hidden mt-4 border-t border-ink/15 pt-3 space-y-2"></div>

      <!-- Lead confirmation -->
      <div id="voice-lead-ok" class="hidden mt-4 border-2 border-magenta bg-magenta/5 p-4">
        <p class="font-mono text-[10px] uppercase tracking-widest text-magenta">— Apuntado</p>
        <p class="mt-2 text-sm text-ink">El equipo Startidea te contacta en menos de 24h laborables.</p>
      </div>
    </div>

  </div>

  <!-- Footer dual: voz (push-to-talk) + texto (input) -->
  <div id="voice-footer" class="hidden border-t-2 border-ink bg-paper-warm/40 p-4 space-y-3">
    <!-- Push-to-talk (voz) -->
    <button
      type="button"
      id="voice-talk"
      class="w-full inline-flex flex-col items-center gap-2 border-2 border-ink bg-paper px-4 py-4 font-mono text-[11px] uppercase tracking-widest text-ink transition-all select-none active:scale-[0.98] hover:border-magenta hover:text-magenta"
      aria-label="Mantén pulsado para hablar"
      data-talk-state="idle"
    >
      <div class="relative">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"></path>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
          <line x1="12" y1="19" x2="12" y2="22"></line>
        </svg>
        <span id="voice-pulse" class="hidden absolute -inset-2 rounded-full border-2 border-magenta animate-ping"></span>
      </div>
      <span id="voice-talk-label">Mantén para hablar</span>
    </button>

    <!-- Nota sobre cómo cortar la voz -->
    <p class="text-center font-mono text-[10px] tracking-wider text-ink-mute">
      Mientras Startidea hable, pulsa <span class="text-magenta">■ Stop</span> arriba para cortar.
    </p>

    <!-- Separador visual -->
    <div class="flex items-center gap-2 text-[10px] font-mono uppercase tracking-widest text-ink-mute">
      <span class="flex-1 h-px bg-ink/15"></span>
      <span>o escribe</span>
      <span class="flex-1 h-px bg-ink/15"></span>
    </div>

    <!-- Input texto alternativo -->
    <form id="voice-text-form" class="flex items-stretch gap-2">
      <label class="sr-only" for="voice-text-input">Tu mensaje</label>
      <input
        type="text"
        id="voice-text-input"
        name="message"
        autocomplete="off"
        maxlength="500"
        placeholder="Escribe tu mensaje y pulsa enviar…"
        class="flex-1 border border-ink/30 bg-paper px-3 py-2 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none"
      />
      <button
        type="submit"
        id="voice-text-send"
        class="border-2 border-ink bg-ink text-paper px-4 font-mono text-[11px] uppercase tracking-widest hover:bg-magenta hover:border-magenta disabled:opacity-50"
        aria-label="Enviar mensaje"
      >Enviar →</button>
    </form>

    <p id="voice-status" class="text-center font-mono text-[10px] tracking-widest text-ink-mute h-4"></p>
  </div>
</div>

<!-- playsinline + webkit-playsinline: evita fullscreen takeover en iOS Safari.
     muted al precargar para permitir un primer play() "silencioso" que
     desbloquee el audio context (workaround autoplay policy iOS/Safari). -->
<audio id="voice-audio" preload="auto" playsinline webkit-playsinline class="hidden"></audio>

<script>
  // ─── State ──────────────────────────────────────────────────────────
  const HUB_API =
    (import.meta as any).env?.PUBLIC_HUB_BASE_URL ?? 'https://hub.startidea.tech';

  type Msg = { role: 'system' | 'user' | 'assistant'; content: string };
  type State = {
    messages: Msg[];
    recording: boolean;
    busy: boolean;
    consent: boolean;
    mediaRecorder: MediaRecorder | null;
    chunks: BlobPart[];
    stream: MediaStream | null;
  };
  const state: State = {
    messages: [],
    recording: false,
    busy: false,
    consent: false,
    mediaRecorder: null,
    chunks: [],
    stream: null,
  };

  // ─── DOM refs ───────────────────────────────────────────────────────
  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id);
  const chip = $('voice-chip');
  const chipMobile = $('voice-chip-mobile');
  const panel = $('voice-panel');
  const closeBtn = $('voice-close');
  const stopSpeechBtn = $('voice-stop-speech');
  const consentDiv = $('voice-consent');
  const consentOk = $('voice-consent-ok');
  const consentNo = $('voice-consent-no');
  const chatDiv = $('voice-chat');
  const transcript = $('voice-transcript');
  const suggestionsDiv = $('voice-suggestions');
  const leadOk = $('voice-lead-ok');
  const footer = $('voice-footer');
  const talkBtn = $('voice-talk');
  const talkLabel = $('voice-talk-label');
  const textForm = $('voice-text-form');
  const textInput = $('voice-text-input');
  const textSendBtn = $('voice-text-send');
  const statusEl = $('voice-status');
  const audio = $('voice-audio');
  const pulse = $('voice-pulse');

  // ─── Open / close ───────────────────────────────────────────────────
  // Refs a los chips del AsistenteIA (texto) — los ocultamos cuando el
  // modal de voz está abierto para evitar la pila de botones flotantes
  // en móvil que ya está apretada con la MobileCtaBar.
  const aiChip = document.getElementById('ai-chip');
  const aiChipMobile = document.getElementById('ai-chip-mobile');

  function open() {
    panel.classList.remove('hidden');
    panel.classList.add('flex');
    chip?.setAttribute('aria-expanded', 'true');
    chipMobile?.setAttribute('aria-expanded', 'true');
    aiChip?.classList.add('!hidden');
    aiChipMobile?.classList.add('!hidden');
  }
  function close() {
    panel.classList.add('hidden');
    panel.classList.remove('flex');
    chip?.setAttribute('aria-expanded', 'false');
    chipMobile?.setAttribute('aria-expanded', 'false');
    aiChip?.classList.remove('!hidden');
    aiChipMobile?.classList.remove('!hidden');
    // Si había stream activo, liberar mic
    if (state.stream) {
      state.stream.getTracks().forEach((t) => t.stop());
      state.stream = null;
    }
    state.recording = false;
    // Si había audio sonando, cortar
    if (!audio.paused) {
      audio.pause();
      audio.currentTime = 0;
    }
  }
  chip?.addEventListener('click', open);
  chipMobile?.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panel.classList.contains('hidden')) close();
  });

  // ─── Consent ────────────────────────────────────────────────────────
  // El click DEL USUARIO en "Acepto" es el momento ideal para:
  //   1. Desbloquear el HTMLAudioElement en iOS Safari (autoplay policy):
  //      reproducir 1 frame de audio silencioso "consume" el gesture token
  //      → audio.play() posterior (tras await del LLM) ya no es bloqueado.
  //   2. Pedir permiso del micrófono dentro del propio gesture, evitando
  //      el fallo iOS de getUserMedia() async fuera de touch context.
  consentOk.addEventListener('click', async () => {
    state.consent = true;
    consentDiv.classList.add('hidden');
    chatDiv.classList.remove('hidden');
    footer.classList.remove('hidden');

    // 1. Audio unlock (iOS Safari)
    try {
      audio.muted = true;
      // Data URI de 1 frame MP3 silencioso (44 bytes)
      audio.src = 'data:audio/mpeg;base64,';
      const p = audio.play();
      if (p) await p.catch(() => {/* fallback al play real */});
      audio.pause();
      audio.muted = false;
      audio.src = '';
    } catch {/* ignore */}

    // 2. Mic permission upfront (iOS Safari gesture requirement)
    // No bloqueamos si falla — el user puede usar el campo de texto.
    ensureMicStream().catch(() => {
      setStatus('Mic no disponible. Usa el campo de texto.');
    });
  });
  consentNo.addEventListener('click', () => {
    close();
  });

  // ─── Render helpers ─────────────────────────────────────────────────
  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]!,
    );
  }
  function addMessage(role: 'user' | 'assistant', text: string) {
    const div = document.createElement('div');
    if (role === 'user') {
      div.className = 'border-l-2 border-ink/40 pl-3 py-1';
      div.innerHTML = `
        <p class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Tú</p>
        <p class="mt-1 text-sm text-ink/85">${escapeHtml(text)}</p>`;
    } else {
      div.className = 'border-l-2 border-magenta pl-3 py-1';
      div.innerHTML = `
        <p class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">Startidea</p>
        <p class="mt-1 text-sm text-ink">${escapeHtml(text)}</p>`;
    }
    transcript.appendChild(div);
    transcript.scrollTop = transcript.scrollHeight;
  }

  function setStatus(msg: string) {
    statusEl.textContent = msg;
  }
  function setBusy(busy: boolean, label?: string) {
    state.busy = busy;
    talkBtn.disabled = busy;
    talkBtn.classList.toggle('opacity-50', busy);
    if (label) talkLabel.textContent = label;
    else if (!busy) talkLabel.textContent = 'Mantén para hablar';
  }

  // ─── Push-to-talk ───────────────────────────────────────────────────
  async function ensureMicStream(): Promise<MediaStream | null> {
    if (state.stream) return state.stream;
    try {
      const s = await navigator.mediaDevices.getUserMedia({ audio: true });
      state.stream = s;
      return s;
    } catch (err) {
      setStatus('No se pudo activar el micrófono.');
      return null;
    }
  }

  async function startRecording() {
    if (state.busy || state.recording) return;
    const stream = await ensureMicStream();
    if (!stream) return;
    state.chunks = [];
    const mime = MediaRecorder.isTypeSupported('audio/webm')
      ? 'audio/webm'
      : 'audio/mp4';
    try {
      state.mediaRecorder = new MediaRecorder(stream, { mimeType: mime });
    } catch {
      state.mediaRecorder = new MediaRecorder(stream);
    }
    state.mediaRecorder.ondataavailable = (e) => {
      if (e.data.size > 0) state.chunks.push(e.data);
    };
    state.mediaRecorder.onstop = () => void onRecordingDone();
    state.mediaRecorder.start();
    state.recording = true;
    talkBtn.dataset.talkState = 'recording';
    talkBtn.classList.add('!border-magenta', '!text-magenta', 'bg-magenta/5');
    pulse.classList.remove('hidden');
    talkLabel.textContent = 'Te escucho…';
    setStatus('');
  }

  function stopRecording() {
    if (!state.recording) return;
    state.recording = false;
    talkBtn.dataset.talkState = 'idle';
    talkBtn.classList.remove('!border-magenta', '!text-magenta', 'bg-magenta/5');
    pulse.classList.add('hidden');
    try {
      state.mediaRecorder?.stop();
    } catch {
      // ignore
    }
  }

  // Eventos pointer (cubre mouse + touch unificado modernos)
  talkBtn.addEventListener('pointerdown', (e) => {
    e.preventDefault();
    void startRecording();
  });
  talkBtn.addEventListener('pointerup', stopRecording);
  talkBtn.addEventListener('pointerleave', stopRecording);
  talkBtn.addEventListener('pointercancel', stopRecording);

  // Fallback touch redundante para iOS Safari antiguo donde pointerleave
  // se comporta de forma errática (no se dispara aunque salgas del botón).
  talkBtn.addEventListener('touchend', (e) => {
    e.preventDefault();
    stopRecording();
  });
  talkBtn.addEventListener('touchcancel', () => stopRecording());

  // Teclado virtual: cuando el user hace focus en el input texto, iOS
  // levanta el teclado y puede tapar el modal. Hacemos scroll del input
  // a la vista tras un pequeño delay (el teclado tarda 200-400ms en
  // animar). Sin esto, el input queda detrás del teclado en móviles.
  textInput.addEventListener('focus', () => {
    setTimeout(() => {
      textInput.scrollIntoView({ block: 'center', behavior: 'smooth' });
    }, 350);
  });

  // ─── Pipeline VOZ: transcribe → chatAndSpeak ────────────────────────
  async function onRecordingDone() {
    if (state.chunks.length === 0) {
      setStatus('No se grabó audio.');
      return;
    }
    setBusy(true, 'Transcribiendo…');
    setStatus('Transcribiendo…');
    const blobMime = state.mediaRecorder?.mimeType ?? 'audio/webm';
    const blob = new Blob(state.chunks, { type: blobMime });
    if (blob.size < 1500) {
      setStatus('Demasiado corto — vuelve a hablar.');
      setBusy(false);
      return;
    }

    let userText = '';
    try {
      const fd = new FormData();
      // Extensión coherente con el MIME real (iOS Safari → mp4, resto → webm).
      // Whisper detecta por header magic bytes pero el filename ayuda a debug.
      const ext = blobMime.includes('mp4')
        ? 'm4a'
        : blobMime.includes('webm')
          ? 'webm'
          : 'audio';
      fd.append('audio', blob, `utterance.${ext}`);
      const res = await fetch(`${HUB_API}/api/public/voice/transcribe`, {
        method: 'POST',
        body: fd,
      });
      // El HUB puede devolver HTML de nginx ante errores upstream (503, 502...).
      // Parsear como JSON sin verificar content-type tiraba al catch genérico,
      // mostrando "Error de red" engañoso al usuario. Discriminamos primero:
      const ct = res.headers.get('content-type') ?? '';
      if (!ct.includes('application/json')) {
        // Respuesta no-JSON = upstream caído o mal configurado en el HUB
        setStatus(`Servicio de transcripción no disponible (${res.status}). Usa el campo de texto.`);
        setBusy(false);
        return;
      }
      const j = await res.json();
      if (!res.ok || !j.ok) {
        setStatus(j.error === 'voice_not_configured'
          ? 'Voz no configurada — usa el campo de texto.'
          : `Error transcribiendo (${j.error ?? res.status}). Usa el campo de texto.`);
        setBusy(false);
        return;
      }
      userText = (j.text ?? '').trim();
    } catch (err) {
      // Solo cae aquí en error de red real (offline, DNS, TLS, abort).
      console.error('[VoiceAgent] transcribe network error:', err);
      setStatus('Error de red al transcribir. Usa el campo de texto.');
      setBusy(false);
      return;
    }

    if (!userText) {
      setStatus('No te entendí. Vuelve a intentar.');
      setBusy(false);
      return;
    }
    await chatAndSpeak(userText, { speak: true });
  }

  // ─── Pipeline TEXTO: submit del input → chatAndSpeak (sin TTS) ──────
  textForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const value = textInput.value.trim();
    if (!value || state.busy) return;
    textInput.value = '';
    // El input texto NO sintetiza voz por defecto (más rápido, menos coste).
    // Si el usuario quiere oír la respuesta, puede preguntar en voz.
    void chatAndSpeak(value, { speak: false });
  });

  // ─── Núcleo común: enviar mensaje → LLM → (opcional TTS) ────────────
  async function chatAndSpeak(userText: string, opts: { speak: boolean }) {
    addMessage('user', userText);
    state.messages.push({ role: 'user', content: userText });

    setBusy(true, 'Pensando…');
    setStatus('Pensando…');
    let answerText = '';
    let leadCaptured = false;
    let diagnosticSubmitted = false;
    let suggestSubsidies: Array<{ slug: string; title: string; organization?: string | null; deadline?: string | null }> | undefined;
    try {
      const res = await fetch(`${HUB_API}/api/public/voice/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages: state.messages,
          sourceUrl: window.location.href,
        }),
      });
      const j = await res.json();
      if (!res.ok || !j.ok) {
        const friendly = j.error === 'credit_exhausted'
          ? 'Saldo IA agotado momentáneamente. Inténtalo más tarde o escribe a hola@startidea.es.'
          : j.error === 'rate_limit'
            ? 'Demasiadas conversaciones simultáneas. Espera 1 minuto.'
            : j.error === 'llm_not_configured'
              ? 'Agente no configurado.'
              : `Error del agente (${j.error ?? res.status}).`;
        setStatus(friendly);
        setBusy(false);
        return;
      }
      answerText = (j.text ?? '').trim();
      leadCaptured = !!j.leadCaptured;
      diagnosticSubmitted = !!j.diagnosticSubmitted;
      suggestSubsidies = j.suggestSubsidies;
    } catch {
      setStatus('Error de red al consultar al agente.');
      setBusy(false);
      return;
    }

    if (!answerText) {
      // El LLM puede no devolver texto si solo hizo tool calls — sintetizamos
      // un breve mensaje de cierre para que la conversación no se pare seca.
      answerText = leadCaptured
        ? 'Apuntado. El equipo te contacta pronto.'
        : diagnosticSubmitted
          ? 'Diagnóstico enviado. Te contactan en menos de 24 horas.'
          : 'Listo. ¿Algo más?';
    }
    addMessage('assistant', answerText);
    state.messages.push({ role: 'assistant', content: answerText });

    if (leadCaptured || diagnosticSubmitted) {
      leadOk.classList.remove('hidden');
      // GA4: conversión vía agente de voz
      if (typeof (window as any).stTrack === 'function') {
        (window as any).stTrack('generate_lead', {
          method: diagnosticSubmitted ? 'voice_agent_diagnostico' : 'voice_agent_lead',
          lead_source: 'voice_agent',
          page_path: window.location.pathname,
          value: 1,
          currency: 'EUR',
        });
      }
    }
    if (suggestSubsidies && suggestSubsidies.length > 0) {
      renderSuggestions(suggestSubsidies);
    }

    if (!opts.speak) {
      // Solo texto: terminamos aquí sin llamar a TTS.
      setStatus('');
      setBusy(false);
      return;
    }

    // → TTS
    setBusy(true, 'Hablando…');
    setStatus('Hablando…');
    try {
      const res = await fetch(`${HUB_API}/api/public/voice/speak`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: answerText }),
      });
      if (!res.ok) {
        setStatus('Voz no disponible (texto OK).');
        setBusy(false);
        return;
      }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      audio.src = url;
      audio.onplay = () => stopSpeechBtn.classList.remove('hidden');
      audio.onended = () => {
        URL.revokeObjectURL(url);
        stopSpeechBtn.classList.add('hidden');
        setStatus('');
        setBusy(false);
      };
      audio.onpause = () => {
        // Si pausamos manualmente (botón Stop), liberar como si terminara
        if (!audio.ended) {
          URL.revokeObjectURL(url);
          stopSpeechBtn.classList.add('hidden');
          setStatus('Voz cortada.');
          setBusy(false);
        }
      };
      audio.play().catch(() => {
        setStatus('Click para activar el audio en tu navegador.');
        setBusy(false);
      });
    } catch {
      setStatus('Error TTS.');
      setBusy(false);
    }
  }

  // ─── Botón Stop: corta el TTS en curso ──────────────────────────────
  stopSpeechBtn.addEventListener('click', () => {
    if (!audio.paused) {
      audio.pause();
      audio.currentTime = 0;
    }
  });

  function renderSuggestions(items: Array<{ slug: string; title: string; organization?: string | null }>) {
    suggestionsDiv.innerHTML = `
      <p class="font-mono text-[10px] uppercase tracking-widest text-ink-mute mb-2">— Convocatorias relacionadas</p>
      ${items.slice(0, 3).map((it) => `
        <a href="/subvenciones/${escapeHtml(it.slug)}" class="block py-1.5 text-sm text-ink hover:text-magenta">
          <span class="text-magenta">→</span> ${escapeHtml(it.title.slice(0, 90))}
          ${it.organization ? `<span class="block ml-4 text-xs text-ink-mute italic">${escapeHtml(it.organization.slice(0, 80))}</span>` : ''}
        </a>
      `).join('')}
    `;
    suggestionsDiv.classList.remove('hidden');
  }
</script>
