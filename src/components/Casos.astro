---
import { casos } from '@/data/casos';
import Popover from '@/components/Popover.astro';
---

<section id="casos" class="relative bg-paper py-24 md:py-32">
  <div class="container-x">
    <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
      <div class="col-span-12 lg:col-span-3">
        <span class="label">— Casos</span>
      </div>
      <div class="col-span-12 mt-6 lg:col-span-9 md:mt-0">
        <h2 class="font-display text-display-lg leading-[0.98] text-ink">
          Lo que hacemos.
          <span class="block italic text-ink/55">No lo que decimos.</span>
        </h2>
        <p class="mt-6 max-w-measure text-lede text-ink/80">
          Selección de casos publicados con autorización de cada cliente. Startidea trabaja con organizaciones reales en problemas reales — y aquí están con su nombre. <span class="font-mono text-xs text-ink/55">Pasa el ratón sobre el número de cada caso para ver detalles rápidos.</span>
        </p>
      </div>
    </div>

    <div class="mt-16 divide-y divide-ink/15 border-y border-ink/15">
      {casos.map((caso) => {
        // Construimos las piezas del popover solo si hay info enriquecida
        const hasExtra =
          (caso.metrics && caso.metrics.length > 0) ||
          (caso.timeline && caso.timeline.length > 0) ||
          !!caso.testimonial;
        return (
          <a href={`/casos/${caso.slug}`} class="reveal group grid grid-cols-12 gap-x-8 gap-y-6 py-12 transition-colors hover:bg-paper-warm lg:py-14">
            <div class="col-span-12 lg:col-span-3">
              <div class="flex items-baseline gap-4">
                {hasExtra ? (
                  <Popover placement="right" maxWidth={360}>
                    <span slot="trigger" class="num-edit text-6xl md:text-7xl">
                      {caso.num}
                    </span>
                    <div slot="content">
                      <p class="label">— {caso.cliente}</p>
                      <p class="mt-2 font-display text-lg leading-tight text-ink">
                        {caso.year} · {caso.duration}
                      </p>

                      {caso.metrics && caso.metrics.length > 0 && (
                        <ul class="mt-4 space-y-2.5 border-t border-ink/15 pt-3">
                          {caso.metrics.slice(0, 3).map((m) => (
                            <li class="flex items-baseline gap-3">
                              <span class="font-display text-base font-bold text-magenta">{m.value}</span>
                              <span class="text-xs text-ink/70">{m.label}</span>
                            </li>
                          ))}
                        </ul>
                      )}

                      {caso.timeline && caso.timeline.length > 0 && (
                        <div class="mt-4 border-t border-ink/15 pt-3">
                          <p class="label mb-2">— Hitos</p>
                          <ol class="space-y-1.5">
                            {caso.timeline.slice(0, 3).map((h) => (
                              <li class="flex items-baseline gap-2 text-xs">
                                <span class="font-mono text-[10px] uppercase tracking-widest text-ink-mute">
                                  {h.date}
                                </span>
                                <span class="text-ink/80">{h.label}</span>
                              </li>
                            ))}
                          </ol>
                        </div>
                      )}

                      {caso.testimonial && (
                        <blockquote class="mt-4 border-t border-ink/15 pt-3">
                          <p class="text-xs italic leading-snug text-ink/75">"{caso.testimonial.quote.slice(0, 140)}{caso.testimonial.quote.length > 140 ? '…' : ''}"</p>
                          <footer class="mt-2 font-mono text-[10px] uppercase tracking-widest text-ink-mute">
                            — {caso.testimonial.author}
                          </footer>
                        </blockquote>
                      )}

                      <p class="mt-4 font-mono text-[10px] uppercase tracking-widest text-magenta">
                        Click · ver caso completo →
                      </p>
                    </div>
                  </Popover>
                ) : (
                  <span class="num-edit text-6xl md:text-7xl">{caso.num}</span>
                )}
              </div>
              <div class="mt-4">
                <p class="font-display text-2xl leading-tight text-ink md:text-3xl">{caso.cliente}</p>
                <span class="mt-2 block label">{caso.sector}</span>
                <p class="mt-2 font-mono text-xs text-ink/60">{caso.intervention}</p>
                {caso.kind === 'propio' && (
                  <span class="mt-3 inline-block border border-magenta px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-magenta">
                    · Iniciativa propia
                  </span>
                )}
              </div>
            </div>

            <div class="col-span-12 lg:col-span-6">
              <h3 class="font-display text-2xl leading-tight text-ink transition-colors group-hover:text-magenta md:text-3xl">
                {caso.title}
              </h3>
              <p class="mt-4 max-w-measure text-ink/75">
                {caso.body}
              </p>
              <span class="mt-5 inline-flex items-center gap-2 text-sm text-ink/70 transition-colors group-hover:text-magenta">
                Ver caso completo
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </div>

            <div class="col-span-12 lg:col-span-3 lg:border-l lg:border-ink/15 lg:pl-8">
              <span class="label">Resultado</span>
              <p class="mt-3 font-display text-4xl text-magenta md:text-5xl">
                {caso.metric.value}
              </p>
              <p class="mt-2 max-w-[14rem] text-sm text-ink/70">
                {caso.metric.label}
              </p>
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-12 grid grid-cols-12 gap-x-8">
      <div class="col-span-12 max-w-measure lg:col-span-9 lg:col-start-4">
        <p class="font-mono text-xs leading-relaxed text-ink-mute">
          ↗ Startidea también trabaja con organizaciones cuyas marcas no aparecen aquí por política interna o discreción acordada. Si quieres conocer la lista completa,
          <a href="/contacto" class="link-underline text-ink">reserva 30 minutos</a>.
        </p>
      </div>
    </div>
  </div>
</section>
