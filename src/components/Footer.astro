---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const cols = [
  {
    title: 'Disciplinas',
    links: [
      { label: 'Consultoría', href: '/consultoria' },
      { label: 'Comunicación', href: '/comunicacion' },
      { label: 'Audiovisual', href: '/audiovisual' },
      { label: 'Tecnología', href: '/tecnologia' },
      { label: 'Fundraising', href: '/fundraising' },
    ],
  },
  {
    title: 'Propiedades',
    links: [
      { label: 'Hub Startidea', href: '/hub' },
      { label: 'Merchandising', href: '/merchandising' },
      { label: 'Granada Social ↗', href: 'https://granadasocial.org', external: true },
    ],
  },
  {
    title: 'Casa',
    links: [
      { label: 'Sobre Startidea', href: '/sobre' },
      { label: 'Manifiesto', href: '/manifiesto' },
      { label: 'Notas mensuales', href: '/notas' },
      { label: 'Casos', href: '/casos' },
      { label: 'Prensa', href: '/prensa' },
      { label: 'Asistente IA', href: '/asistente' },
      { label: 'Changelog', href: '/changelog' },
    ],
  },
  {
    title: 'Hablar',
    links: [
      { label: 'Reservar diagnóstico', href: '/contacto' },
      { label: 'Pedir presupuesto', href: '/presupuesto' },
      { label: 'hola@startidea.es', href: 'mailto:hola@startidea.es' },
      { label: 'pedidos@startidea.es', href: 'mailto:pedidos@startidea.es' },
      { label: '+34 958 045 789', href: 'tel:+34958045789' },
    ],
  },
];

const redes = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/agenciastartidea' },
  { label: 'Instagram', href: 'https://www.instagram.com/agenciastartidea' },
  { label: 'Facebook', href: 'https://www.facebook.com/agenciastartidea' },
  { label: 'X', href: 'https://x.com/startideasocial' },
  { label: 'YouTube', href: 'https://www.youtube.com/c/AgenciadeComunicaciónSocialSTARTIDEA' },
  { label: 'Spotify', href: 'https://open.spotify.com/show/3c3Pm70Up3v1GOdYuSxj05' },
];
---

<footer class="mt-20 border-t border-ink/15 bg-paper-warm pt-20 pb-10">
  <div class="container-x">
    <!-- Bloque newsletter inline -->
    <div class="mb-16 grid grid-cols-12 gap-x-8 border-b border-ink/15 pb-16">
      <div class="col-span-12 lg:col-span-5">
        <span class="label">— Una nota al mes</span>
        <p class="mt-4 font-display text-3xl font-extrabold leading-[1.05] tracking-tight text-ink md:text-4xl">
          Lectura corta sobre propósito. <em class="italic text-magenta">Cero ruido</em>.
        </p>
      </div>
      <div class="col-span-12 mt-6 lg:col-span-7 lg:mt-2">
        <form
          class="flex flex-col gap-3"
          action="https://buttondown.email/api/emails/embed-subscribe/startidea"
          method="post"
          target="popupwindow"
          onsubmit="window.stTrack && window.stTrack('newsletter_subscribe', { placement: 'footer', page_path: location.pathname }); window.open('https://buttondown.email/startidea', 'popupwindow')"
        >
          <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch">
            <label class="sr-only" for="footer-newsletter-email">Tu email</label>
            <input
              id="footer-newsletter-email"
              type="email"
              name="email"
              required
              placeholder="tu@email.com"
              autocomplete="email"
              class="flex-1 border border-ink bg-paper px-4 py-3 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
            />
            <button type="submit" class="btn">
              Suscribirme
              <span aria-hidden="true">→</span>
            </button>
          </div>
          <label class="flex items-start gap-3 text-xs leading-relaxed text-ink/80">
            <input type="checkbox" name="consent" required
              class="mt-0.5 h-4 w-4 flex-shrink-0 border-ink text-magenta focus:ring-magenta" />
            <span>Acepto recibir la newsletter mensual y la <a href="/privacidad" class="link-underline text-ink">política de privacidad</a>. Te puedes dar de baja en cualquier momento desde el propio email.</span>
          </label>
        </form>
        <p class="mt-3 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
          Sin tracking pixels. Servicio: Buttondown. <a href="/privacidad" class="link-underline text-ink">Más detalles</a>.
        </p>
      </div>
    </div>

    <!-- Línea editorial superior — Diego v60: logo más grande (similar al
         del header) y bloque editorial centrado verticalmente con los
         títulos de las columnas Disciplinas/Propiedades/etc. -->
    <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-4 flex flex-col items-start">
        <Logo class="h-20 sm:h-24 md:h-28 lg:h-32 xl:h-36" />
        <p class="mt-8 max-w-md font-display text-3xl font-extrabold leading-[1.05] tracking-tight text-ink md:text-4xl">
          Innovación social <em class="italic text-magenta">que se nota</em>.
        </p>
        <p class="mt-5 max-w-md text-sm leading-relaxed text-ink/70">
          Estrategia, comunicación y herramientas para organizaciones que existen para algo más.
        </p>
        <div class="mt-8">
          <a href="/contacto" class="btn-ghost">
            Reservar 30 min
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div class="lg:col-span-8 grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4">
        {cols.map((col) => (
          <div>
            <h3 class="label">— {col.title}</h3>
            <ul class="mt-5 space-y-3">
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="link-underline text-sm text-ink/85 hover:text-ink"
                    {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Redes sociales -->
    <div class="mt-12 border-t border-ink/15 pt-8">
      <div class="grid grid-cols-12 gap-x-8 gap-y-4 md:items-baseline">
        <div class="col-span-12 md:col-span-3">
          <span class="label">— Redes</span>
        </div>
        <ul class="col-span-12 flex flex-wrap gap-x-6 gap-y-2 md:col-span-9 font-mono text-[11px] uppercase tracking-widest">
          {redes.map((r) => (
            <li>
              <a href={r.href} target="_blank" rel="noopener" class="text-ink/70 hover:text-ink">
                {r.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Línea legal inferior -->
    <div class="mt-10 flex flex-col gap-3 border-t border-ink/15 pt-8 md:flex-row md:items-center md:justify-between">
      <p class="font-mono text-[11px] uppercase tracking-widest text-ink-mute">
        © {year} Startidea · CIF B19583632 · C/ Conde Cifuentes, 33 · Granada
      </p>
      <div class="flex flex-wrap gap-6 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
        <a href="/aviso-legal" class="hover:text-ink">Aviso legal</a>
        <a href="/privacidad" class="hover:text-ink">Privacidad</a>
        <a href="/cookies" class="hover:text-ink">Cookies</a>
      </div>
    </div>
  </div>
</footer>
