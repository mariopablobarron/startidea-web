---
import { Image } from 'astro:assets';
// Lazos SOLOS (sin wordmark) — el asset icon-only de verdad. Antes se usaba
// logo-isotipo-only.png que, pese al nombre, incluía el wordmark "startidea" →
// con el <span>Startidea</span> de abajo salía DOBLE (Mario 2026-06-21).
import isotipo from '@/assets/brand/isotipo-lazos.png';

interface Props {
  class?: string;
  variant?: 'default' | 'inverse';
  /** Si true, oculta el wordmark "Startidea" y deja solo el isotipo. */
  iconOnly?: boolean;
}
const { class: className = '', variant = 'default', iconOnly = false } = Astro.props;

// El logo es ahora una composición HTML: isotipo (PNG) + wordmark de texto.
// Antes era un único PNG con isotipo + nombre + tagline "Agencia de innovación
// social" todo dentro, que (a) era demasiado alto, (b) tenía un tagline
// ilegible en mobile, y (c) bloqueaba al header en 100-200px de altura.
// Esta versión es compacta, escalable y mantiene la jerarquía visual.

const wordmarkColor = variant === 'inverse' ? 'text-paper' : 'text-ink';
---

<a
  href="/"
  class={`group inline-flex items-center gap-2.5 transition-transform duration-200 ease-out hover:-translate-y-0.5 sm:gap-3 ${className}`}
  aria-label="Startidea — inicio"
>
  <Image
    src={isotipo}
    alt=""
    width={120}
    height={120}
    densities={[1, 2]}
    format="webp"
    quality={92}
    class="h-full w-auto shrink-0 transition-opacity duration-200 group-hover:opacity-90"
  />
  {!iconOnly && (
    <span class={`font-display text-xl leading-none tracking-tight sm:text-2xl md:text-[26px] lg:text-[28px] ${wordmarkColor}`}>
      Startidea
    </span>
  )}
</a>
