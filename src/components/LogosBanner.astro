---
// Banda horizontal de logos de clientes reconocibles — social proof
// inmediato, justo después del Hero. Sin texto, los logos hablan solos…
// hasta que el visitante hace hover y aparece un popover con quién es
// cada organización y qué se hizo con ella.

import Popover from '@/components/Popover.astro';

const logos = [
  {
    name: 'Cruz Roja Española',
    src: '/clientes/cruz-roja.png',
    sector: 'ONG sociosanitaria de referencia',
    context: 'Colaboración en comunicación y formación de equipos territoriales en Andalucía oriental.',
  },
  {
    name: 'Save the Children',
    src: '/clientes/save-the-children.png',
    sector: 'ONG internacional de infancia',
    context: 'Acompañamiento en campañas de captación y materiales de incidencia a nivel autonómico.',
  },
  {
    name: 'Acción Contra el Hambre',
    src: '/clientes/accion-contra-el-hambre.png',
    sector: 'ONG humanitaria internacional',
    context: 'Producciones audiovisuales y comunicación de programas en territorio.',
  },
  {
    name: 'YMCA España',
    src: '/clientes/ymca.png',
    sector: 'Federación de programas socioeducativos',
    context: 'Estrategia digital y formación de equipos en comunicación social.',
  },
  {
    name: 'Proyecto Solidario',
    src: '/clientes/proyecto-solidario.png',
    sector: 'ONG de cooperación al desarrollo',
    context: 'Memoria anual, fundraising y comunicación institucional.',
  },
  {
    name: 'Diputación de Granada',
    src: '/clientes/diputacion-granada.png',
    sector: 'Institución pública provincial',
    context: 'Apoyo a programas territoriales y comunicación de iniciativas sociales.',
  },
  {
    name: 'Ayuntamiento de Granada',
    src: '/clientes/ayuntamiento-granada.png',
    sector: 'Institución pública local',
    context: 'Colaboraciones en proyectos sociales y comunicación de programas municipales.',
  },
];
---

<section
  id="logos-banner"
  aria-label="Organizaciones que han confiado en Startidea"
  class="border-b border-ink/15 bg-paper-warm py-10 md:py-12"
>
  <div class="container-x">
    <p class="text-center font-mono text-[11px] uppercase tracking-widest text-ink/75 md:text-xs">
      Han confiado en Startidea
    </p>

    <!-- Desktop: grid estático centrado -->
    <ul class="mt-7 hidden flex-wrap items-center justify-center gap-x-10 gap-y-6 md:flex lg:gap-x-14">
      {logos.map((l) => (
        <li>
          <Popover placement="bottom" maxWidth={280}>
            <img
              slot="trigger"
              src={l.src}
              alt={l.name}
              loading="lazy"
              decoding="async"
              width="140"
              height="48"
              class="h-12 w-auto max-w-[140px] object-contain opacity-80 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0 lg:h-14"
            />
            <div slot="content">
              <p class="font-display text-base font-bold leading-tight text-ink">{l.name}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-magenta">{l.sector}</p>
              <p class="mt-3 text-xs leading-relaxed text-ink/75">{l.context}</p>
            </div>
          </Popover>
        </li>
      ))}
    </ul>

    <!-- Mobile: marquee continuo (más logos en menos espacio) -->
    <div class="mt-6 md:hidden">
      <div class="logos-marquee">
        <ul class="logos-marquee-track flex items-center gap-10">
          {[...logos, ...logos].map((l) => (
            <li class="shrink-0">
              <img
                src={l.src}
                alt={l.name}
                loading="lazy"
                decoding="async"
                width="120"
                height="44"
                class="h-11 w-auto max-w-[120px] object-contain opacity-85 grayscale"
              />
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .logos-marquee {
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent);
  }
  .logos-marquee-track {
    width: max-content;
    animation: logos-marquee-slide 28s linear infinite;
  }
  @keyframes logos-marquee-slide {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .logos-marquee-track { animation: none; }
    .logos-marquee { overflow-x: auto; }
  }
</style>
