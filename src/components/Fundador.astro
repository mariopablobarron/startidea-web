---
import { Picture } from 'astro:assets';
import marioPortrait from '@/assets/brand/mario-fundador.jpg';
---

<section id="fundador" class="relative bg-paper py-24 md:py-32">
  <div class="container-x">
    <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
      <div class="col-span-12 lg:col-span-3">
        <span class="label">— Fundador</span>
      </div>

      <div class="col-span-12 lg:col-span-9">
        <div class="grid grid-cols-12 gap-x-8 gap-y-10">
          <!-- Retrato -->
          <div class="col-span-12 sm:col-span-5 lg:col-span-4">
            <div class="group aspect-[4/5] w-full overflow-hidden border border-ink/15 bg-paper-warm">
              <Picture
                src={marioPortrait}
                alt="Mario Pablo Sánchez Barrón, fundador de Startidea"
                widths={[400, 600, 800, 1200]}
                sizes="(min-width: 1024px) 320px, (min-width: 640px) 40vw, 100vw"
                formats={['avif', 'webp']}
                fallbackFormat="jpg"
                quality={82}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              />
            </div>
            <p class="mt-4 font-mono text-[11px] uppercase tracking-widest text-ink-mute">
              Mario Pablo Sánchez Barrón · fundador
            </p>
            <a
              href="https://mariopablo.es"
              target="_blank"
              rel="noopener"
              class="mt-2 inline-flex items-center gap-1.5 text-xs text-ink/60 transition-colors hover:text-magenta"
              aria-label="Web personal de Mario Pablo Sánchez Barrón — mariopablo.es"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9" />
                <path d="M3 12h18" />
                <path d="M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18" />
              </svg>
              mariopablo.es
            </a>
          </div>

          <!-- Cita y bio -->
          <div class="col-span-12 sm:col-span-7 lg:col-span-8">
            <p class="font-display text-display-md italic font-bold leading-[1.05] text-ink">
              "Llevo 15 años trabajando con organizaciones con propósito. La conclusión no la he cambiado: lo que la gente recuerda es cómo se lo contaste."
            </p>
            <p class="mt-8 max-w-measure text-ink/85">
              Mario Pablo Sánchez Barrón fundó Startidea en Granada en febrero de 2011. Su trabajo se ha centrado en la comunicación estratégica de instituciones del tercer sector, plataformas confesionales y entidades con base ética. Combina formación en consultoría con producción digital y editorial.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-6">
              <a href="/sobre" class="btn-ghost">
                Ver biografía completa
                <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
              </a>
              <a href="https://www.linkedin.com/in/mariopablobarron/" target="_blank" rel="noopener" class="link-underline text-sm text-ink/85">
                LinkedIn ↗
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
