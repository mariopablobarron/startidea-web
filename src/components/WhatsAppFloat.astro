---
// Botón flotante WhatsApp — visible solo en desktop (md+).
// En móvil ya existe en MobileCtaBar como tercera columna.
//
// Lógica:
//  - Posicionado en bottom-24 right-6 (encima del chip AsistenteIA, que
//    vive en bottom-6 right-6). z-40 para que el panel del asistente
//    (z-50) lo cubra cuando se abre.
//  - Mensaje pre-rellenado contextual según la ruta actual.
//  - Oculto en rutas donde el visitante ya está en flujo de conversión
//    (/contacto, /diagnostico, /presupuesto).
//  - Tracking via [data-track="cta"] consumido por AnalyticsTracker.

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const messages: Record<string, string> = {
  '/proteccion-digital':    'Hola, quería preguntar por Protección Digital (ciberseguridad / RGPD).',
  '/fundraising':           'Hola, quería preguntar por Fundraising y alianzas.',
  '/comunicacion':          'Hola, quería preguntar por Comunicación Estratégica.',
  '/consultoria':           'Hola, quería preguntar por Consultoría e Innovación Social.',
  '/audiovisual':           'Hola, quería preguntar por Producción Audiovisual / Podcast.',
  '/tecnologia':            'Hola, quería preguntar por Tecnología y plataformas.',
  '/financiacion-empresas': 'Hola, quería preguntar por Financiación Pública.',
  '/merchandising':         'Hola, quería preguntar por Merchandising.',
  '/subvenciones':          'Hola, quería preguntar por subvenciones.',
  '/notas':                 'Hola, leí vuestras notas y quería preguntar.',
  '/casos':                 'Hola, vi vuestros casos y quería preguntar por un proyecto.',
  '/sobre':                 'Hola, vi vuestra web y quería preguntar.',
  '/que-hacemos':           'Hola, vi vuestros servicios y quería preguntar.',
  '/manifiesto':            'Hola, leí vuestro manifiesto y quería preguntar.',
};

// Prefijos especiales (notas individuales, casos individuales, etc.)
let message: string;
if (messages[pathname]) {
  message = messages[pathname];
} else if (pathname.startsWith('/notas/')) {
  message = 'Hola, leí una de vuestras notas y quería preguntar.';
} else if (pathname.startsWith('/casos/')) {
  message = 'Hola, vi uno de vuestros casos y quería preguntar.';
} else {
  message = 'Hola, quería preguntar por Startidea.';
}

// Rutas en las que el botón NO aparece: el visitante ya está en flujo
// de conversión o en zona admin/legal donde un CTA flotante distrae.
const hiddenPrefixes = [
  '/contacto',
  '/diagnostico',
  '/presupuesto',
  '/admin',
  '/aviso-legal',
  '/privacidad',
  '/cookies',
  '/404',
  '/500',
];
const shouldShow = !hiddenPrefixes.some(
  (p) => pathname === p || pathname.startsWith(p + '/')
);

const slugId =
  pathname === '/' ? 'home' : pathname.slice(1).replace(/\//g, '_');

const waUrl = `https://wa.me/34958045789?text=${encodeURIComponent(message)}`;
---

{shouldShow && (
  <a
    href={waUrl}
    target="_blank"
    rel="noopener"
    data-track="cta"
    data-track-id={`float_whatsapp_${slugId}`}
    data-track-text="WhatsApp"
    aria-label="Hablar con Startidea por WhatsApp"
    class="group fixed bottom-24 right-6 z-40 hidden md:inline-flex items-center gap-2 border-2 border-ink bg-paper px-5 py-3 font-mono text-[12px] uppercase tracking-widest text-ink shadow-[0_8px_24px_-8px_rgba(0,0,0,0.25)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-magenta hover:text-paper hover:border-magenta"
  >
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      class="text-magenta group-hover:text-paper"
    >
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
    </svg>
    <span>WhatsApp</span>
    <span class="font-mono text-[10px] normal-case tracking-normal text-ink-mute group-hover:text-paper/70">
      &middot; Respuesta rápida
    </span>
  </a>
)}
