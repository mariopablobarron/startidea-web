---
// Chip flotante de contacto rápido — envía a Telegram a través de /api/contacto.
// Sin scripts de terceros, sin cookies adicionales.
---

<button
  type="button"
  id="chat-chip"
  class="fixed bottom-6 right-6 z-40 hidden md:inline-flex items-center gap-2 border-2 border-ink bg-ink px-5 py-3 font-mono text-[12px] uppercase tracking-widest text-paper shadow-[0_8px_24px_-8px_rgba(0,0,0,0.35)] transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-magenta hover:border-magenta"
  aria-haspopup="dialog"
  aria-controls="chat-panel"
  aria-expanded="false"
>
  <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-magenta"></span>
  <span>Pregúntanos</span>
</button>

<button
  type="button"
  id="chat-chip-mobile"
  class="fixed bottom-5 right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full border-2 border-ink bg-ink text-paper shadow-[0_8px_24px_-8px_rgba(0,0,0,0.35)] transition-colors hover:bg-magenta hover:border-magenta md:hidden"
  aria-haspopup="dialog"
  aria-controls="chat-panel"
  aria-expanded="false"
  aria-label="Abrir chat"
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<div
  id="chat-panel"
  class="fixed inset-x-4 bottom-20 z-50 hidden max-h-[80vh] overflow-auto border-2 border-ink bg-paper shadow-[0_24px_48px_-16px_rgba(0,0,0,0.35)] sm:right-6 sm:left-auto sm:bottom-24 sm:w-[380px]"
  role="dialog"
  aria-modal="false"
  aria-labelledby="chat-title"
>
  <div class="flex items-center justify-between border-b-2 border-ink bg-ink px-5 py-3 text-paper">
    <p id="chat-title" class="font-mono text-[11px] uppercase tracking-widest">— Pregúntanos directo</p>
    <button
      type="button"
      id="chat-close"
      class="font-mono text-[11px] uppercase tracking-widest text-paper/70 hover:text-paper"
      aria-label="Cerrar"
    >
      Cerrar
    </button>
  </div>

  <div class="px-5 py-5">
    <p class="font-display text-xl leading-tight text-ink">
      Cuéntanos en una línea. <em class="italic text-magenta">Startidea te responde al rato</em>.
    </p>
    <p class="mt-2 text-xs leading-relaxed text-ink-mute">
      Llega directo al Telegram de Startidea. Sin tracking. Sin cookies de terceros.
    </p>

    <form id="chat-form" class="mt-4 space-y-3" novalidate>
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
        aria-hidden="true"
      />
      <div>
        <label class="sr-only" for="chat-name">Nombre</label>
        <input
          id="chat-name"
          name="name"
          type="text"
          required
          maxlength="80"
          placeholder="Tu nombre"
          autocomplete="name"
          class="w-full border border-ink bg-paper px-3 py-2.5 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
        />
      </div>
      <div>
        <label class="sr-only" for="chat-email">Email</label>
        <input
          id="chat-email"
          name="email"
          type="email"
          required
          maxlength="120"
          placeholder="tu@email.com"
          autocomplete="email"
          class="w-full border border-ink bg-paper px-3 py-2.5 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
        />
      </div>
      <div>
        <label class="sr-only" for="chat-message">Mensaje</label>
        <textarea
          id="chat-message"
          name="message"
          required
          maxlength="2000"
          rows="4"
          placeholder="¿En qué puede ayudarte Startidea?"
          class="w-full resize-none border border-ink bg-paper px-3 py-2.5 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
        ></textarea>
      </div>
      <label class="flex items-start gap-3 text-xs leading-relaxed text-ink/80">
        <input type="checkbox" name="consent" required
          class="mt-0.5 h-4 w-4 flex-shrink-0 border-ink text-magenta focus:ring-magenta" />
        <span>He leído y acepto la <a href="/privacidad" target="_blank" rel="noopener" class="link-underline text-ink">política de privacidad</a>.</span>
      </label>
      <button id="chat-submit" type="submit" class="btn w-full justify-center">
        Enviar
        <span aria-hidden="true">→</span>
      </button>
      <p id="chat-status" class="min-h-[16px] font-mono text-[11px] leading-relaxed text-ink-mute" aria-live="polite"></p>
    </form>
  </div>
</div>

<script is:inline>
  (function () {
    var chip = document.getElementById('chat-chip');
    var chipMobile = document.getElementById('chat-chip-mobile');
    var panel = document.getElementById('chat-panel');
    var close = document.getElementById('chat-close');
    var form = document.getElementById('chat-form');
    var status = document.getElementById('chat-status');
    var submit = document.getElementById('chat-submit');
    if (!panel || !form) return;

    function setOpen(open) {
      if (open) {
        panel.classList.remove('hidden');
        chip && chip.setAttribute('aria-expanded', 'true');
        chipMobile && chipMobile.setAttribute('aria-expanded', 'true');
        var n = document.getElementById('chat-name');
        n && n.focus();
      } else {
        panel.classList.add('hidden');
        chip && chip.setAttribute('aria-expanded', 'false');
        chipMobile && chipMobile.setAttribute('aria-expanded', 'false');
      }
    }

    function toggle() {
      setOpen(panel.classList.contains('hidden'));
    }

    chip && chip.addEventListener('click', toggle);
    chipMobile && chipMobile.addEventListener('click', toggle);
    close && close.addEventListener('click', function () { setOpen(false); });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) setOpen(false);
    });

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      status.textContent = 'Enviando…';
      status.style.color = '';
      submit.setAttribute('disabled', 'true');

      var data = new FormData(form);
      var payload = {
        website: data.get('website') || '',
        name: data.get('name') || '',
        email: data.get('email') || '',
        message: data.get('message') || '',
        path: window.location.pathname + window.location.search,
        consent: data.get('consent') === 'on',
      };

      try {
        var r = await fetch('/api/contacto', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var json = await r.json().catch(function () { return { ok: false }; });
        if (r.ok && json.ok) {
          form.reset();
          status.style.color = '#1a7f37';
          status.textContent = 'Enviado. Startidea te contesta al rato por email.';
          setTimeout(function () { setOpen(false); status.textContent = ''; }, 2500);
        } else {
          var msg = 'No se pudo enviar. Escríbenos a hola@startidea.es.';
          if (json.error === 'rate') msg = 'Espera unos segundos antes de reenviar.';
          if (json.error === 'email') msg = 'Revisa el email.';
          if (json.error === 'fields') msg = 'Rellena todos los campos.';
          if (json.error === 'consent') msg = 'Marca la casilla de aceptación de la política de privacidad.';
          status.style.color = '#b42318';
          status.textContent = msg;
        }
      } catch (_) {
        status.style.color = '#b42318';
        status.textContent = 'Sin conexión. Escríbenos a hola@startidea.es.';
      } finally {
        submit.removeAttribute('disabled');
      }
    });
  })();
</script>
