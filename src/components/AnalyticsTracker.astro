---
/**
 * Sistema de tracking de eventos al dataLayer (GA4 vía GTM).
 *
 * Expone window.stTrack(event, params) para llamadas programáticas
 * (chat, form submit, etc.) y monta listeners que disparan
 * automáticamente:
 *
 *   - cta_click       en cualquier elemento con [data-track="cta"]
 *                     y opcional data-track-id="..." data-track-text="..."
 *   - file_download   en <a> con [data-track="download"]
 *                     leyendo file_name y file_extension del href
 *
 * Si el usuario rechaza cookies, GTM no se carga y los push al dataLayer
 * caen al vacío (window.dataLayer existe pero nadie lo lee). Es seguro.
 */
---

<script is:inline>
  (function () {
    window.dataLayer = window.dataLayer || [];

    window.stTrack = function (event, params) {
      try {
        window.dataLayer.push(Object.assign({ event: event }, params || {}));
      } catch (_) { /* no-op */ }
    };

    // ── Atribución first-touch: se captura UNA vez (primer aterrizaje) y persiste.
    //    Cierra el embudo: un lead/venta se traza a la página y fuente que lo trajo.
    try {
      var ATTR_KEY = 'st_attribution';
      if (!localStorage.getItem(ATTR_KEY)) {
        var p = new URLSearchParams(location.search);
        localStorage.setItem(ATTR_KEY, JSON.stringify({
          utm_source: p.get('utm_source') || '',
          utm_medium: p.get('utm_medium') || '',
          utm_campaign: p.get('utm_campaign') || '',
          utm_content: p.get('utm_content') || '',
          utm_term: p.get('utm_term') || '',
          landing_page: location.pathname,
          referrer: document.referrer || '',
        }));
      }
    } catch (_) { /* localStorage puede no estar disponible */ }

    // Devuelve la atribución guardada (objeto plano; {} si no hay/falla).
    window.stAttribution = function () {
      try { return JSON.parse(localStorage.getItem('st_attribution') || '{}'); }
      catch (_) { return {}; }
    };

    // ── view_service: dispara al cargar una ficha de servicio (centralizado, sin
    //    tocar cada página). Mide qué servicios se ven, no solo los que convierten.
    var SERVICES = ['/comunicacion', '/redes-sociales-granada', '/publicidad', '/consultoria', '/audiovisual', '/tecnologia',
      '/mantenimiento-web', '/fundraising', '/proteccion-digital', '/google-ad-grants', '/hub', '/merchandising'];
    if (SERVICES.indexOf(location.pathname) !== -1) {
      window.stTrack('view_service', { service: location.pathname.slice(1), page_path: location.pathname });
    }

    // ── form_start: primer foco en un campo de cualquier <form>, una vez por form.
    //    Revela dónde fuga el embudo (hoy solo se medía el submit final).
    var formsStarted = {};
    document.addEventListener('focusin', function (e) {
      var form = e.target.closest && e.target.closest('form');
      if (!form) return;
      var id = form.getAttribute('id') || form.getAttribute('data-form') || form.getAttribute('action') || 'form';
      if (formsStarted[id]) return;
      formsStarted[id] = true;
      window.stTrack('form_start', { form_id: id, page_path: location.pathname });
    }, { capture: true });

    // CTA clicks delegated
    document.addEventListener('click', function (e) {
      var el = e.target.closest && e.target.closest('[data-track]');
      if (!el) return;
      var kind = el.getAttribute('data-track');

      if (kind === 'cta') {
        window.stTrack('cta_click', {
          cta_id: el.getAttribute('data-track-id') || '',
          cta_text: (el.getAttribute('data-track-text') || el.textContent || '').trim().slice(0, 80),
          page_path: location.pathname,
        });
        return;
      }

      if (kind === 'download') {
        var href = el.getAttribute('href') || '';
        var name = href.split('/').pop() || '';
        var ext = name.includes('.') ? name.split('.').pop().toLowerCase() : '';
        window.stTrack('file_download', {
          file_name: name,
          file_extension: ext,
          link_url: href,
          page_path: location.pathname,
        });
        return;
      }
    }, { capture: true });
  })();
</script>
