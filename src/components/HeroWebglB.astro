---
// HeroWebglB — Concepto B: hilo / ADN 3D cinematográfico (WebGL).
//
// Rendimiento y accesibilidad:
//  - El canvas vive detrás del contenido; el contenido es legible siempre.
//  - Three.js se carga vía CDN e INICIA tras el primer paint (requestIdleCallback)
//    para no penalizar el LCP.
//  - Si hay prefers-reduced-motion o pantalla pequeña, NO se inicia WebGL:
//    queda el degradado oscuro + la copy (fallback elegante).
//  - Para la versión final se puede empaquetar Three en el bundle en vez de CDN.
---

<section class="hero-b">
  <canvas id="hero-b-canvas" aria-hidden="true"></canvas>
  <div class="hero-b__inner">
    <div class="hero-b__glass">
      <p class="hero-b__eyebrow">Agencia de comunicación e innovación social</p>
      <h1 class="hero-b__title">El <em>hilo</em> que<br />conecta.</h1>
      <p class="hero-b__lede">
        Startidea acompaña al tercer sector, las instituciones y las empresas con
        propósito a comunicar mejor, captar recursos y construir herramientas
        digitales que no envejecen.
      </p>
      <div class="hero-b__cta">
        <a class="hero-b__btn hero-b__btn--p" href="/contacto">Hablar con Startidea</a>
        <a class="hero-b__btn hero-b__btn--s" href="/casos">Ver el trabajo</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-b {
    position: relative;
    min-height: 100svh;
    color: #fff;
    overflow: hidden;
    background: radial-gradient(120% 120% at 70% 18%, #241016 0%, #161416 45%, #0e0d0e 100%);
  }
  #hero-b-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .hero-b__inner {
    position: relative; z-index: 2; min-height: 100svh; display: flex; align-items: center;
    padding: clamp(24px, 6vw, 96px);
  }
  .hero-b__glass {
    max-width: 640px; padding: clamp(24px, 3vw, 44px); border-radius: 24px;
    background: rgba(255, 255, 255, 0.06); backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px); border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4);
  }
  .hero-b__eyebrow {
    font-size: 13px; letter-spacing: 0.28em; text-transform: uppercase;
    color: #e6356b; font-weight: 700; margin-bottom: 16px;
  }
  .hero-b__title {
    font-family: var(--font-startidea-alt, inherit);
    font-size: clamp(38px, 6.5vw, 84px); line-height: 1; font-weight: 800; letter-spacing: -0.02em;
  }
  .hero-b__title em { color: #e6356b; font-style: italic; }
  .hero-b__lede {
    margin-top: 22px; max-width: 46ch; font-size: clamp(15px, 1.3vw, 19px); line-height: 1.55;
    color: rgba(255, 255, 255, 0.72);
  }
  .hero-b__cta { margin-top: 32px; display: flex; flex-wrap: wrap; gap: 14px; }
  .hero-b__btn {
    padding: 14px 26px; border-radius: 999px; font-weight: 700; font-size: 15px;
    text-decoration: none; transition: transform 0.2s;
  }
  .hero-b__btn:hover { transform: translateY(-2px); }
  .hero-b__btn--p { background: #e6356b; color: #fff; box-shadow: 0 10px 30px rgba(230, 53, 107, 0.4); }
  .hero-b__btn--s { border: 1.5px solid rgba(255, 255, 255, 0.3); color: #fff; }
</style>

<script>
  // Astro empaqueta Three (import dinámico → chunk propio, code-split y cargado
  // tras el LCP). Servido desde 'self' → cumple la CSP del sitio (unpkg está
  // bloqueado por la Content-Security-Policy).
  const canvas = document.getElementById('hero-b-canvas');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const small = window.innerWidth < 760;
  // Fallback: sin WebGL queda el degradado oscuro + la copy.
  if (canvas && !reduce && !small) {
    const start = async () => {
      const THREE = await import('three');
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      const scene = new THREE.Scene();
      scene.fog = new THREE.Fog(0x0e0d0e, 30, 90);
      const cam = new THREE.PerspectiveCamera(55, 1, 0.1, 200);
      cam.position.set(0, 0, 46);

      const makeCurve = (off) => {
        const pts = [];
        for (let i = 0; i <= 160; i++) {
          const t = i / 160;
          pts.push(new THREE.Vector3((t - 0.5) * 70,
            Math.sin(t * Math.PI * 4 + off) * 8 + Math.cos(t * Math.PI * 2) * 3,
            Math.cos(t * Math.PI * 3 + off) * 8));
        }
        return new THREE.CatmullRomCurve3(pts);
      };
      const tube1 = new THREE.Mesh(new THREE.TubeGeometry(makeCurve(0), 220, 0.7, 16, false),
        new THREE.MeshStandardMaterial({ color: 0xe6356b, emissive: 0xe6356b, emissiveIntensity: 0.55, roughness: 0.3, metalness: 0.5 }));
      const tube2 = new THREE.Mesh(new THREE.TubeGeometry(makeCurve(Math.PI), 220, 0.32, 12, false),
        new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0x888888, emissiveIntensity: 0.2, roughness: 0.5, metalness: 0.3 }));
      const group = new THREE.Group();
      group.add(tube1, tube2);
      scene.add(group);

      const bc = makeCurve(0), bc2 = makeCurve(Math.PI), bpos = [];
      for (let i = 0; i <= 160; i += 4) {
        const t = i / 160, a = bc.getPoint(t), b = bc2.getPoint(t);
        for (let k = 0; k <= 6; k++) { const f = k / 6; bpos.push(a.x + (b.x - a.x) * f, a.y + (b.y - a.y) * f, a.z + (b.z - a.z) * f); }
      }
      const bg = new THREE.BufferGeometry();
      bg.setAttribute('position', new THREE.Float32BufferAttribute(bpos, 3));
      group.add(new THREE.Points(bg, new THREE.PointsMaterial({ color: 0xe6356b, size: 0.45, transparent: true, opacity: 0.6, depthWrite: false })));

      scene.add(new THREE.AmbientLight(0xffffff, 0.5));
      const key = new THREE.PointLight(0xe6356b, 2.2, 120); key.position.set(20, 18, 30); scene.add(key);
      const fill = new THREE.PointLight(0x6688ff, 1.0, 120); fill.position.set(-25, -10, 20); scene.add(fill);

      const mouse = { x: 0, y: 0 };
      addEventListener('pointermove', (e) => { mouse.x = e.clientX / innerWidth - 0.5; mouse.y = e.clientY / innerHeight - 0.5; });
      const resize = () => { const w = innerWidth, h = innerHeight; renderer.setSize(w, h); cam.aspect = w / h; cam.updateProjectionMatrix(); };
      addEventListener('resize', resize); resize();

      let t = 0, paused = false;
      document.addEventListener('visibilitychange', () => { paused = document.hidden; });
      const frame = () => {
        if (!paused) {
          t += 0.004;
          group.rotation.z = t * 0.6;
          group.rotation.x = -0.2 + mouse.y * 0.3;
          group.rotation.y += (mouse.x * 0.5 - group.rotation.y) * 0.05;
          cam.position.x += (mouse.x * 8 - cam.position.x) * 0.04;
          cam.position.y += (-mouse.y * 6 - cam.position.y) * 0.04;
          cam.lookAt(0, 0, 0);
          renderer.render(scene, cam);
        }
        requestAnimationFrame(frame);
      };
      frame();
    };
    if ('requestIdleCallback' in window) requestIdleCallback(() => start(), { timeout: 800 });
    else setTimeout(start, 200);
  }
</script>
