---
/**
 * NotasRelacionadas.astro
 * Muestra hasta 3 notas de la misma categoría, por RELEVANCIA (solape de tags
 * con la nota actual) y no solo por recencia — antes solo enlazaba las 3 más
 * recientes de cada categoría, dejando a la mayoría de notas sin ningún enlace
 * interno automático (auditoría 2026-07). Con `tags`, cada nota enlaza a sus
 * vecinas temáticas; sin `tags` (landings de servicio), rota de forma
 * determinista con el mes para repartir enlazado interno entre todas.
 *
 * Props:
 *   category  — categoría a mostrar ('Comunicación' | 'Financiación' | 'Estrategia' | 'Agencia')
 *   exclude   — slug a excluir (cuando se usa dentro de una nota para no mostrarse a sí misma)
 *   limit     — número máximo de notas a mostrar (default 3)
 *   tags      — tags de la nota actual, para priorizar por afinidad temática
 */
import { getCollection } from 'astro:content';

interface Props {
  category: 'Comunicación' | 'Financiación' | 'Estrategia' | 'Agencia';
  exclude?: string;
  limit?: number;
  tags?: string[];
}

const { category, exclude, limit = 3, tags = [] } = Astro.props;

const allNotas = await getCollection('notas', ({ data }) => !data.draft && data.category === category);
allNotas.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const candidatas = allNotas.filter((n) => n.slug !== exclude);

let notas: typeof candidatas;
if (tags.length > 0) {
  // Relevancia: nº de tags compartidos (desc); recencia como desempate (el
  // sort de arriba ya deja las recientes primero y el sort es estable).
  const tagSet = new Set(tags.map((t) => t.toLowerCase()));
  notas = candidatas
    .map((n) => ({ n, score: (n.data.tags ?? []).filter((t) => tagSet.has(t.toLowerCase())).length }))
    .sort((a, b) => b.score - a.score)
    .slice(0, limit)
    .map(({ n }) => n);
} else {
  // Sin tags de referencia (landings): rotación determinista mensual — ventana
  // que se desplaza con el mes para que TODAS las notas reciban enlaces internos
  // a lo largo del tiempo (el build corre en cada deploy, ≥1/mes de sobra).
  const monthIdx = new Date().getFullYear() * 12 + new Date().getMonth();
  const start = candidatas.length > limit ? monthIdx % candidatas.length : 0;
  notas = Array.from({ length: Math.min(limit, candidatas.length) }, (_, i) => candidatas[(start + i) % candidatas.length]);
}

const fmt = new Intl.DateTimeFormat('es-ES', { year: 'numeric', month: 'short' });

// Etiquetas de categoría → URL del filtro
const catUrl = `/notas?cat=${encodeURIComponent(category)}`;
---

{notas.length >= 1 && (
  <section class="border-t border-ink/15 bg-paper-warm py-16 md:py-20">
    <div class="container-x">
      <div class="mb-8 flex items-end justify-between border-t border-ink/15 pt-8">
        <div>
          <span class="label">— Notas · {category}</span>
          <h2 class="mt-2 font-display text-2xl leading-tight text-ink md:text-3xl">
            Más sobre <em class="italic text-magenta">{category.toLowerCase()}</em>.
          </h2>
        </div>
        <a
          href={catUrl}
          class="hidden shrink-0 font-mono text-[11px] uppercase tracking-widest text-ink/75 underline-offset-4 hover:text-magenta hover:underline sm:block"
        >
          Ver todas →
        </a>
      </div>

      <ol class="divide-y divide-ink/15 border-y border-ink/15">
        {notas.map((nota) => {
          const words = nota.body.trim().split(/\s+/).length;
          const min = Math.max(1, Math.round(words / 200));
          return (
            <li>
              <a
                href={`/notas/${nota.slug}`}
                class="group grid grid-cols-12 gap-x-8 gap-y-3 py-7 transition-colors hover:bg-paper"
              >
                <div class="col-span-12 lg:col-span-2">
                  <p class="font-mono text-[11px] uppercase tracking-widest text-ink/75">
                    {fmt.format(nota.data.pubDate)}
                  </p>
                </div>
                <div class="col-span-12 lg:col-span-8">
                  <h3 class="font-display text-lg leading-snug text-ink transition-colors group-hover:text-magenta md:text-xl">
                    {nota.data.title}
                  </h3>
                  <p class="mt-1.5 text-sm text-ink/75 line-clamp-2">
                    {nota.data.description}
                  </p>
                </div>
                <div class="col-span-12 lg:col-span-2 lg:text-right">
                  <span class="font-mono text-[11px] uppercase tracking-widest text-ink/75">
                    ~{min} min
                  </span>
                  <p class="mt-1 font-mono text-xs text-ink/75 transition-colors group-hover:text-magenta">
                    Leer →
                  </p>
                </div>
              </a>
            </li>
          );
        })}
      </ol>

      <div class="mt-6 sm:hidden">
        <a href={catUrl} class="btn-ghost w-full text-center text-sm">
          Ver todas las notas de {category} →
        </a>
      </div>
    </div>
  </section>
)}
