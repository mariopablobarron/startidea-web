---
// "Ventana al medio" — escaparate de las últimas noticias del medio
// editorial Granada Social (creado por Startidea) dentro del home de
// startidea.es. Refuerza la línea de "innovación social aplicada":
// la agencia no solo lo dice, lo está produciendo cada semana.
//
// Cómo funciona:
//   - SSR: en build/dev hace fetch al feed RSS de granadasocial.org/feed.xml
//   - Parse simple con regex (no necesita librería externa)
//   - Cache 1 hora con revalidate del propio Astro
//   - Si el feed falla (timeout, red), el bloque se oculta — nunca rompe el home

interface Articulo {
  title: string;
  link: string;
  description: string;
  author: string;
  date: string | null;
}

const FEED_URL = 'https://granadasocial.org/feed.xml';
const MAX_ITEMS = 4;
const TIMEOUT_MS = 6000;

function stripCData(s: string): string {
  return s.replace(/<!\[CDATA\[(.*?)\]\]>/gs, '$1').trim();
}

function parseRss(xml: string): Articulo[] {
  const itemPattern = /<item>([\s\S]*?)<\/item>/g;
  const items: Articulo[] = [];
  let m: RegExpExecArray | null;
  while ((m = itemPattern.exec(xml)) !== null && items.length < MAX_ITEMS) {
    const block = m[1];
    const get = (tag: string) => {
      const re = new RegExp(`<${tag}(?:\\s[^>]*)?>([\\s\\S]*?)<\\/${tag}>`);
      const r = re.exec(block);
      return r ? stripCData(r[1]) : '';
    };
    items.push({
      title: get('title'),
      link: get('link'),
      description: get('description'),
      author: get('dc:creator'),
      date: get('pubDate') || null,
    });
  }
  return items;
}

let articulos: Articulo[] = [];
try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), TIMEOUT_MS);
  const res = await fetch(FEED_URL, {
    signal: controller.signal,
    headers: { 'user-agent': 'startidea-web/1.0 (https://startidea.es)' },
  });
  clearTimeout(timeout);
  if (res.ok) {
    const xml = await res.text();
    articulos = parseRss(xml);
  }
} catch (err) {
  // Silencioso: si el feed no responde no rompemos el home, solo no se renderiza.
  console.warn('[GranadaSocialFeed] feed fetch fail:', (err as Error)?.message);
}

function fmtDate(s: string | null): string {
  if (!s) return '';
  try {
    const d = new Date(s);
    return d.toLocaleDateString('es-ES', { day: '2-digit', month: 'short' });
  } catch {
    return '';
  }
}

function truncate(s: string, n: number): string {
  const clean = s.replace(/<[^>]+>/g, '').trim();
  return clean.length > n ? clean.slice(0, n).trim() + '…' : clean;
}
---

{articulos.length > 0 && (
  <section
    id="granada-social-feed"
    class="relative overflow-hidden bg-ink py-20 text-paper md:py-28"
    aria-label="Últimas noticias de Granada Social"
  >
    <div class="container-x">
      <!-- Encabezado tipo "TV channel preview" -->
      <div class="grid grid-cols-12 gap-x-8 gap-y-6 border-t-2 border-magenta/60 pt-8">
        <div class="col-span-12 lg:col-span-4">
          <div class="flex items-center gap-3">
            <span class="relative inline-flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-magenta opacity-60"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-magenta"></span>
            </span>
            <span class="label !text-magenta">— En directo · Granada Social</span>
          </div>
          <h2 class="mt-5 font-display text-display-md leading-[1.02] text-paper">
            Lo que <em class="italic text-magenta">se cuece</em><br/>en Granada.
          </h2>
        </div>

        <div class="col-span-12 lg:col-span-7 lg:col-start-6">
          <p class="max-w-measure text-lede text-paper/85">
            Granada Social es el medio editorial creado por Startidea. Da voz a las entidades, eventos y proyectos sociales de la ciudad. Esto es lo que se ha publicado esta semana.
          </p>
          <a
            href="https://granadasocial.org"
            target="_blank"
            rel="noopener"
            data-track="cta"
            data-track-id="home_granadasocial_portal"
            class="mt-6 inline-flex items-center gap-2 border-b border-paper/40 pb-1 text-sm text-paper transition-colors hover:border-magenta hover:text-magenta"
          >
            Entrar al medio
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <!-- Grid de noticias — primera ocupa doble en desktop -->
      <ol class="mt-14 grid grid-cols-1 gap-px border-2 border-paper/10 bg-paper/10 md:grid-cols-2 lg:grid-cols-4">
        {articulos.map((art, i) => (
          <li class={i === 0 ? 'bg-ink p-7 md:col-span-2 md:row-span-1 lg:col-span-2 lg:row-span-1 md:p-9' : 'bg-ink p-7'}>
            <a
              href={art.link}
              target="_blank"
              rel="noopener"
              data-track="cta"
              data-track-id={`home_granadasocial_article_${i}`}
              class="group block h-full"
            >
              <div class="flex items-center justify-between gap-3">
                <span class="font-mono text-[10px] uppercase tracking-widest text-paper/55">
                  {i === 0 ? 'Destacado' : 'Reciente'}
                </span>
                {art.date && (
                  <time class="font-mono text-[10px] uppercase tracking-widest text-paper/45">
                    {fmtDate(art.date)}
                  </time>
                )}
              </div>
              <h3 class={
                i === 0
                  ? 'mt-5 font-display text-2xl leading-tight text-paper transition-colors group-hover:text-magenta md:text-3xl'
                  : 'mt-5 font-display text-lg leading-tight text-paper transition-colors group-hover:text-magenta md:text-xl'
              }>
                {art.title}
              </h3>
              {art.description && (
                <p class={
                  i === 0
                    ? 'mt-4 text-sm leading-relaxed text-paper/70 md:text-base'
                    : 'mt-3 hidden text-sm leading-relaxed text-paper/65 md:block'
                }>
                  {truncate(art.description, i === 0 ? 220 : 100)}
                </p>
              )}
              <div class="mt-6 flex items-center justify-between gap-3">
                {art.author && (
                  <span class="font-mono text-[10px] uppercase tracking-widest text-paper/45">
                    {truncate(art.author, 30)}
                  </span>
                )}
                <span
                  aria-hidden="true"
                  class="text-paper/55 transition-transform group-hover:translate-x-1 group-hover:text-magenta"
                >→</span>
              </div>
            </a>
          </li>
        ))}
      </ol>

      <!-- Pie con CTA al portal completo -->
      <div class="mt-10 flex flex-wrap items-baseline justify-between gap-4 border-t border-paper/10 pt-6">
        <p class="font-mono text-[11px] uppercase tracking-widest text-paper/55">
          Refrescado el {new Date().toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}
          {' · '}
          <span class="text-paper/40">fuente: granadasocial.org</span>
        </p>
        <a
          href="https://granadasocial.org"
          target="_blank"
          rel="noopener"
          data-track="cta"
          data-track-id="home_granadasocial_portal_footer"
          class="text-sm text-paper hover:text-magenta"
        >
          Ver todas las noticias →
        </a>
      </div>
    </div>
  </section>
)}
