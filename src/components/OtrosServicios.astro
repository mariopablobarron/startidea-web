---
// Menú flotante al final de cada página de servicio:
// 3 servicios "hermanos" + CTA reservar diagnóstico.
// Marca el actual (slug) para no listarlo.
interface Props {
  current: string;
}
const { current } = Astro.props;

const servicios = [
  { slug: 'consultoria',   nombre: 'Consultoría',   tag: 'Innovación social',          href: '/consultoria' },
  { slug: 'comunicacion',  nombre: 'Comunicación',  tag: 'Estratégica · Marketing',    href: '/comunicacion' },
  { slug: 'audiovisual',   nombre: 'Audiovisual',   tag: 'Vídeo · Podcast · Estudio',  href: '/audiovisual' },
  { slug: 'tecnologia',    nombre: 'Tecnología',    tag: 'Plataformas · Producto · IA',href: '/tecnologia' },
  { slug: 'fundraising',       nombre: 'Fundraising',        tag: 'Captación · Alianzas',         href: '/fundraising' },
  { slug: 'proteccion-digital', nombre: 'Protección digital', tag: 'Ciberseguridad · RGPD',        href: '/proteccion-digital' },
  { slug: 'hub',               nombre: 'Hub Startidea',      tag: 'Coworking · Estudio',          href: '/hub' },
  { slug: 'merchandising',     nombre: 'Merchandising',      tag: 'Productos con propósito',      href: '/merchandising' },
];

const otros = servicios.filter((s) => s.slug !== current).slice(0, 7);
---

<!-- Bloque al pie: lista completa de otros servicios + CTA -->
<section class="border-t border-ink/15 bg-paper-warm py-20 md:py-28">
  <div class="container-x">
    <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
      <div class="col-span-12 lg:col-span-4">
        <span class="label">— Sigue explorando</span>
        <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
          Otros <em class="italic text-magenta">servicios</em>.
        </h2>
        <p class="mt-5 max-w-measure text-ink/80">
          Las disciplinas se contratan juntas o por separado. Si no tienes claro cuál encaja con tu reto, lo aclaramos en la llamada de diagnóstico.
        </p>
        <div class="mt-8">
          <a href="/contacto" class="btn">
            Reservar 30 min
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <div class="col-span-12 mt-8 lg:col-span-8 lg:mt-0">
        <ul class="grid gap-px border-2 border-ink/15 bg-ink/15 sm:grid-cols-2 lg:grid-cols-3">
          {otros.map((s) => (
            <li>
              <a
                href={s.href}
                class="group flex h-full flex-col justify-between bg-paper-warm p-6 transition-colors hover:bg-paper"
              >
                <div>
                  <span class="label">{s.tag}</span>
                  <p class="mt-3 font-display text-2xl leading-tight text-ink transition-colors group-hover:text-magenta">
                    {s.nombre}
                  </p>
                </div>
                <span aria-hidden="true" class="mt-6 font-mono text-sm text-ink/50 transition-transform group-hover:translate-x-1 group-hover:text-magenta">
                  /{s.slug} →
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Chip flotante (solo en desktop, esquina inferior izquierda para no chocar con el chat) -->
<aside
  id="servicios-float"
  class="fixed bottom-6 left-6 z-30 hidden lg:block"
  aria-label="Acceso rápido a otros servicios"
>
  <details class="group relative">
    <summary class="flex cursor-pointer list-none items-center gap-2 border-2 border-ink bg-paper px-4 py-3 font-mono text-[11px] uppercase tracking-widest text-ink shadow-[0_8px_24px_-8px_rgba(0,0,0,0.18)] transition-colors hover:bg-ink hover:text-paper">
      <span aria-hidden="true">⊞</span>
      <span>Otros servicios</span>
      <span aria-hidden="true" class="transition-transform group-open:rotate-180">▾</span>
    </summary>
    <div class="absolute bottom-full left-0 mb-3 w-72 border-2 border-ink bg-paper shadow-[0_24px_48px_-16px_rgba(0,0,0,0.25)]">
      <ul class="divide-y divide-ink/10">
        {otros.slice(0, 5).map((s) => (
          <li>
            <a href={s.href} class="block px-4 py-3 transition-colors hover:bg-paper-warm">
              <p class="font-display text-base leading-tight text-ink">{s.nombre}</p>
              <p class="mt-0.5 font-mono text-[10px] uppercase tracking-widest text-ink-mute">{s.tag}</p>
            </a>
          </li>
        ))}
      </ul>
      <div class="border-t-2 border-ink bg-ink p-3">
        <a href="/contacto" class="block text-center font-mono text-[11px] uppercase tracking-widest text-paper hover:text-magenta">
          Reservar diagnóstico →
        </a>
      </div>
    </div>
  </details>
</aside>
