---
// HeroImmersive — "la huella", versión cine inmersivo (CLARO).
//
// El isotipo se forma con una NUBE DE PARTÍCULAS 3D con profundidad real
// (varias capas en Z), niebla para dar sensación de escena, y una cámara
// cinematográfica: órbita lenta + parallax con el cursor + ACERCAMIENTO al
// hacer scroll (la cámara entra en la nube → inmersión).
//
// Fondo claro → encaja con la Nav blanca (sin costura).
// Rendimiento: Three empaquetado, import dinámico tras el LCP, pausa con la
// pestaña oculta, versión ligera en móvil, fallback estático con reduce-motion.
---

<section class="hero-im" data-hero-im>
  <canvas id="hero-im-canvas" aria-hidden="true"></canvas>
  <div class="hero-im__inner container-x">
    <div class="hero-im__top">
      <span class="label">— Agencia de comunicación e innovación social</span>
      <span class="label hidden md:inline">Granada · España · Est. 2011</span>
    </div>

    <h1 class="hero-im__title font-display text-display-xl text-ink">
      Innovación social<br />que <em class="italic text-magenta">se nota</em>.
    </h1>

    <div class="hero-im__row">
      <p class="hero-im__lede font-display text-lede text-ink/85 md:text-2xl md:leading-snug">
        Startidea ayuda a entidades del tercer sector, instituciones y empresas con
        propósito a <strong class="font-semibold text-ink">comunicar mejor, captar más
        recursos y construir herramientas digitales</strong> que no envejecen.
      </p>
      <div class="hero-im__cta">
        <a href="/contacto" class="btn">Reserva una llamada de diagnóstico <span aria-hidden="true">→</span></a>
        <p class="text-sm text-ink/75">30 minutos. Sin compromiso.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-im {
    position: relative; min-height: 100svh; overflow: hidden;
    background:
      radial-gradient(60% 60% at 72% 42%, rgba(230,53,107,0.06), transparent 70%),
      radial-gradient(120% 90% at 50% 0%, #ffffff 0%, #f4f2ef 60%, #efece7 100%);
    color: #2a2a2a;
  }
  #hero-im-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; z-index: 0; }
  .hero-im__inner { position: relative; z-index: 2; min-height: 100svh; display: flex;
    flex-direction: column; justify-content: center; gap: clamp(28px, 4vh, 56px);
    padding-top: 96px; padding-bottom: 64px; }
  .hero-im__top { display: flex; align-items: center; justify-content: space-between; }
  .hero-im__title { max-width: 16ch; }
  .hero-im__row { display: grid; grid-template-columns: 1fr; gap: 28px; }
  @media (min-width: 1024px) {
    .hero-im__row { grid-template-columns: 1.2fr 0.8fr; align-items: end; }
  }
  .hero-im__lede { max-width: 46ch; }
  .hero-im__cta { display: flex; flex-direction: column; align-items: flex-start; gap: 14px; }
  /* En móvil, una capa para garantizar legibilidad del texto sobre la nube. */
  @media (max-width: 759px) {
    .hero-im__inner { background: linear-gradient(180deg, transparent 0%, rgba(247,246,243,0.55) 38%, rgba(247,246,243,0.85) 100%); }
  }
</style>

<script>
  const canvas = document.getElementById('hero-im-canvas');
  const section = document.querySelector('[data-hero-im]');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (canvas && section && !reduce) {
    const start = async () => {
      const small = window.innerWidth < 760;
      const THREE = await import('three');
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: !small, alpha: true });
      renderer.setPixelRatio(Math.min(devicePixelRatio, small ? 1.4 : 2));
      const BG = 0xf4f2ef;
      const scene = new THREE.Scene();
      scene.fog = new THREE.FogExp2(BG, small ? 0.020 : 0.013); // profundidad/atmósfera
      const baseZ = 48;
      const cam = new THREE.PerspectiveCamera(58, 1, 0.1, 200);
      cam.position.z = baseZ;

      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.src = '/brand/isotipo-lazos.png';
      img.onload = () => {
        const S = 200;
        const cv = document.createElement('canvas'); cv.width = cv.height = S;
        const ctx = cv.getContext('2d'); ctx.drawImage(img, 0, 0, S, S);
        const data = ctx.getImageData(0, 0, S, S).data;

        // Nube VOLUMÉTRICA: el isotipo replicado en varias capas de profundidad.
        // Nube que FORMA el logo: pocas capas y dispersión mínima → el isotipo
        // se reconoce con nitidez, manteniendo profundidad y aire de nebulosa.
        const layers = small ? 2 : 3;
        const step = small ? 2 : 1;     // más densidad → forma definida
        const SP = small ? 42 : 46;     // tamaño del isotipo (protagonista)
        const OX = small ? 0 : 13;
        const OY = small ? 8 : 2;
        const DEPTH = small ? 6 : 9;    // espesor fino → la silueta se lee
        const JIT = 0.45;               // dispersión mínima
        const pts3 = [];
        for (let l = 0; l < layers; l++) {
          const z = layers === 1 ? 0 : (l / (layers - 1) - 0.5) * DEPTH;
          for (let y = 0; y < S; y += step) for (let x = 0; x < S; x += step) {
            if (data[(y * S + x) * 4 + 3] > 90) {
              pts3.push(
                (x / S - 0.5) * SP + OX + (Math.random() - 0.5) * JIT,
                -(y / S - 0.5) * SP + OY + (Math.random() - 0.5) * JIT,
                z + (Math.random() - 0.5) * (DEPTH / layers) * 0.5,
              );
            }
          }
        }
        const N = pts3.length / 3;
        const pos = new Float32Array(N * 3), tgt = new Float32Array(pts3);
        for (let i = 0; i < N * 3; i += 3) {
          pos[i] = (Math.random() - 0.5) * 160;
          pos[i + 1] = (Math.random() - 0.5) * 160;
          pos[i + 2] = (Math.random() - 0.5) * 120;
        }
        // tamaños variables por partícula (sparkle / profundidad)
        const sizes = new Float32Array(N);
        for (let i = 0; i < N; i++) sizes[i] = (small ? 0.22 : 0.26) + Math.random() * 0.22;
        const geo = new THREE.BufferGeometry();
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        geo.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

        // Material de puntos con tamaño por-partícula + atenuación por distancia.
        const mat = new THREE.ShaderMaterial({
          transparent: true, depthWrite: false,
          uniforms: { uColor: { value: new THREE.Color(0xe6356b) }, uOpacity: { value: small ? 0.62 : 0.95 } },
          vertexShader: `
            attribute float size; varying float vFade;
            void main(){
              vec4 mv = modelViewMatrix * vec4(position,1.0);
              gl_PointSize = size * (300.0 / -mv.z);
              vFade = clamp(1.0 - (-mv.z - 20.0) / 70.0, 0.15, 1.0);
              gl_Position = projectionMatrix * mv;
            }`,
          fragmentShader: `
            precision mediump float; uniform vec3 uColor; uniform float uOpacity; varying float vFade;
            void main(){
              vec2 c = gl_PointCoord - 0.5;
              float d = dot(c,c);
              if (d > 0.25) discard;            // punto redondo
              float a = smoothstep(0.25, 0.0, d) * uOpacity * vFade;
              gl_FragColor = vec4(uColor, a);
            }`,
        });
        const cloud = new THREE.Points(geo, mat);
        scene.add(cloud);

        const mouse = { x: 0, y: 0 };
        addEventListener('pointermove', (e) => { mouse.x = e.clientX / innerWidth - 0.5; mouse.y = e.clientY / innerHeight - 0.5; });

        // Progreso de scroll dentro del hero → la cámara entra en la nube.
        let prog = 0;
        const onScroll = () => {
          const r = section.getBoundingClientRect();
          prog = Math.min(1, Math.max(0, -r.top / (r.height || innerHeight)));
        };
        addEventListener('scroll', onScroll, { passive: true }); onScroll();

        const resize = () => { const w = innerWidth, h = innerHeight; renderer.setSize(w, h); cam.aspect = w / h; cam.updateProjectionMatrix(); };
        addEventListener('resize', resize); resize();

        let t = 0, paused = false, assemble = 0;
        document.addEventListener('visibilitychange', () => { paused = document.hidden; });
        const frame = () => {
          if (!paused) {
            t += 0.01;
            assemble = Math.min(1, assemble + 0.012);
            const p = geo.attributes.position.array;
            const k = 0.04 + assemble * 0.04;
            for (let i = 0; i < N * 3; i++) p[i] += (tgt[i] - p[i]) * k;
            geo.attributes.position.needsUpdate = true;
            // Órbita cinematográfica + parallax con cursor
            cloud.rotation.y = Math.sin(t * 0.12) * 0.35 + mouse.x * 0.5;
            cloud.rotation.x = mouse.y * 0.25;
            // Acercamiento al hacer scroll (inmersión) + leve dolly de respiración
            cam.position.z = baseZ - prog * 26 - Math.sin(t * 0.4) * 0.6;
            cam.position.x += (mouse.x * 6 - cam.position.x) * 0.04;
            cam.lookAt(0, 0, 0);
            renderer.render(scene, cam);
          }
          requestAnimationFrame(frame);
        };
        frame();
      };
    };
    if ('requestIdleCallback' in window) requestIdleCallback(() => start(), { timeout: 800 });
    else setTimeout(start, 200);
  }
</script>
