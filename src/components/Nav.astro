---
import Logo from './Logo.astro';
import { bookingHref, hasBooking } from '@/data/booking';

// CTA "Reservar diagnóstico": abre el calendario externo si está configurado
// (pestaña nueva), si no cae al formulario de /contacto.
const reservaHref = bookingHref();
const reservaExt = hasBooking() ? { target: '_blank', rel: 'noopener' } : {};

// `desktop: false` → fuera del bar inline de escritorio (cabe en portátiles
// 13-14" sin solapar el logo, fix Mario 2026-06-21); siguen en el menú
// móvil/desplegable y en el footer.
const links = [
  { label: 'Para quién', href: '/para-quien' },
  { label: 'Qué hacemos', href: '/que-hacemos' },
  { label: 'Casos', href: '/casos' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Laboratorio', href: '/laboratorio', desktop: false },
  // Financiación apunta a la landing maestra que agrega las 5 fuentes
  // (BDNS + CDTI + IDAE + ENISA + Andalucía TRADE). Desde ahí el visitante
  // entra al buscador /subvenciones o lee las guías editoriales.
  // Renombrado de "Subvenciones" a "Financiación" en 2026-05-26 para
  // reflejar el alcance real del servicio (subvenciones + préstamos
  // participativos + créditos blandos + misiones comerciales).
  { label: 'Financiación', href: '/financiacion-empresas' },
  { label: 'Notas', href: '/notas', desktop: false },
];

// Líneas editoriales / propiedades de Startidea.
// Merchandising se añadió al dropdown 2026-05-19 porque ya es producto B2B
// maduro online con tráfico real; meterlo en Propiedades (junto a Hub y
// Granada Social) lo visibiliza sin meterlo en el nav principal que mantiene
// la línea editorial de innovación social.
const propiedades = [
  { label: 'Hub Startidea', href: 'https://hubstartidea.es', tag: 'Coworking · Estudio' },
  { label: 'Comunidad Startidea', href: 'https://comunidad.hubstartidea.es', tag: 'Red online de la agencia' },
  { label: 'TodoMerchandising', href: 'https://merchandising.hubstartidea.es', tag: 'Catálogo B2B online · Online ahora', highlight: true },
  { label: 'Granada Social', href: 'https://granadasocial.org', tag: 'Medio sociocultural' },
];
---

<header class="sticky top-0 z-50 border-b border-ink/15 bg-paper/95 backdrop-blur supports-[backdrop-filter]:bg-paper/85">
  <div class="container-x flex items-center justify-between gap-4 py-2 md:py-2.5 lg:py-3">
    <Logo class="h-10 sm:h-11 md:h-12 lg:h-14" />

    <!-- Nav desktop — bar inline a partir de 1360px, donde caben todos los
         enlaces sin solapar el logo. PENDIENTE (auditoría UX 14-jun): por
         debajo (portátiles 13-14") solo se ve "Menú"; bajar el breakpoint
         exige reducir el contenido del nav (demotar 1-2 ítems a un
         desplegable) — decisión de IA, no un quick win. Gap reducido a gap-3. -->
    <nav class="hidden min-[1180px]:block" aria-label="Principal">
      <ul class="flex items-center gap-3">
        {links.filter((l) => l.desktop !== false).map((l) => (
          <li>
            <a href={l.href} class="link-underline whitespace-nowrap text-sm text-ink/85 hover:text-ink">
              {l.label}
            </a>
          </li>
        ))}

        <!-- Dropdown Propiedades -->
        <li class="relative group">
          <button
            type="button"
            class="link-underline flex items-center gap-1 whitespace-nowrap text-sm text-ink/85 hover:text-ink"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Propiedades
            <span aria-hidden="true" class="text-xs">↗</span>
          </button>
          <div class="invisible absolute right-0 top-full z-10 mt-3 w-72 border border-ink bg-paper opacity-0 shadow-[0_24px_48px_-16px_rgba(0,0,0,0.18)] transition-all duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
            <ul class="divide-y divide-ink/10">
              {propiedades.map((p) => (
                <li class:list={[p.highlight && 'bg-magenta/5']}>
                  <a href={p.href} target="_blank" rel="noopener" class="block px-5 py-4 transition-colors hover:bg-paper-warm">
                    <p class="font-display text-lg leading-tight text-ink">
                      {p.label}
                      <span aria-hidden="true" class="ml-1 text-magenta">↗</span>
                    </p>
                    <p class="mt-1 font-mono text-[10px] uppercase tracking-widest text-ink-mute">{p.tag}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>

        <li class="ml-2 flex items-center gap-3">
          <a href="/presupuesto" class="btn-ghost whitespace-nowrap !py-2.5 !px-4 text-[13px]">
            Presupuesto
          </a>
          <a href="/contacto" class="btn-ghost whitespace-nowrap !py-2.5 !px-4 text-[13px] !border-magenta !text-magenta hover:!bg-magenta hover:!text-paper">
            Contacto
          </a>
          <a href={reservaHref} {...reservaExt} class="btn whitespace-nowrap !py-2.5 !px-4 text-[13px]">
            Reservar diagnóstico
            <span aria-hidden="true">→</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Burger (mobile + tablet + small desktop) -->
    <button
      type="button"
      id="nav-toggle"
      class="min-[1180px]:hidden border border-ink px-3 py-2 font-mono text-[11px] uppercase tracking-wider"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      Menú
    </button>
  </div>

  <!-- Mobile / tablet / small desktop fullscreen menu -->
  <div id="nav-mobile" class="hidden border-t border-ink/15 bg-paper min-[1180px]:hidden">
    <div class="container-x py-5">
      <ul class="flex flex-col">
        {links.map((l) => (
          <li class="border-b border-ink/10">
            <a href={l.href} class="block py-2.5 font-display text-lg text-ink hover:text-magenta sm:text-xl">
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-5 border-t-2 border-ink/15 pt-3">
        <span class="label">— Propiedades de Startidea</span>
        <ul class="mt-2 divide-y divide-ink/10 border-y border-ink/10">
          {propiedades.map((p) => (
            <li class:list={[p.highlight && 'bg-magenta/5 px-2 -mx-2']}>
              <a
                href={p.href}
                target="_blank"
                rel="noopener"
                class="flex items-center justify-between gap-3 py-2.5 hover:text-magenta"
              >
                <div>
                  <p class="font-display text-base leading-tight text-ink sm:text-lg">
                    {p.label}
                  </p>
                  <p class="mt-0.5 font-mono text-[10px] uppercase tracking-widest text-ink-mute">{p.tag}</p>
                </div>
                <span aria-hidden="true" class="text-magenta">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-5 flex flex-col gap-2">
        <a href="/portal" class="block py-2 text-center font-mono text-[11px] uppercase tracking-widest text-ink/75 hover:text-magenta">
          Acceso clientes →
        </a>
        <a href="/presupuesto" class="btn-ghost w-full !py-2.5 text-sm text-center">
          Pedir presupuesto
        </a>
        <a href="/contacto" class="btn-ghost w-full !py-2.5 text-sm text-center !border-magenta !text-magenta">
          Contacto
        </a>
        <a href={reservaHref} {...reservaExt} class="btn w-full !py-2.5 text-sm">
          Reservar diagnóstico →
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    const isHidden = mobile?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isHidden));
    toggle.textContent = isHidden ? 'Menú' : 'Cerrar';
  });

  // Cerrar menú móvil al navegar a un ancla en la misma página
  document.querySelectorAll('#nav-mobile a').forEach((a) => {
    a.addEventListener('click', () => {
      mobile?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      if (toggle) toggle.textContent = 'Menú';
    });
  });
</script>
