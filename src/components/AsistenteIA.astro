---
// Asistente conversacional IA flotante.
// Conectado a /api/chat (OpenRouter) con streaming SSE.
// Si no hay API key configurada, muestra fallback con email/Telegram.
---

<!-- Botón flotante (chip texto en xl+, círculo en mobile/tablet) -->
<button
  type="button"
  id="ai-chip"
  data-track="cta"
  data-track-id="ai_chip_open_desktop"
  data-track-text="Pregunta lo que sea"
  class="hidden"
  aria-haspopup="dialog"
  aria-controls="ai-panel"
  aria-expanded="false"
>
  <span class="flex items-center gap-2">
    <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-magenta group-hover:bg-paper"></span>
    <span>Pregunta lo que sea</span>
    <span aria-hidden="true">→</span>
  </span>
  <span class="font-mono text-[9px] normal-case tracking-normal text-paper/65">
    Te responde el equipo · con IA
  </span>
</button>

<button
  type="button"
  id="ai-chip-mobile"
  data-track="cta"
  data-track-id="ai_chip_open_mobile"
  data-track-text="Pregunta lo que sea"
  class="hidden"
  aria-haspopup="dialog"
  aria-controls="ai-panel"
  aria-expanded="false"
  aria-label="Pregunta lo que sea — Asistente Startidea"
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<div
  id="ai-panel"
  class="fixed inset-x-4 bottom-20 z-50 hidden max-h-[85vh] flex-col overflow-hidden border-2 border-ink bg-paper shadow-[0_24px_48px_-16px_rgba(0,0,0,0.35)] sm:right-6 sm:left-auto sm:bottom-24 sm:w-[420px] md:max-h-[600px]"
  role="dialog"
  aria-modal="false"
  aria-labelledby="ai-title"
>
  <!-- Header -->
  <div class="flex items-center justify-between border-b-2 border-ink bg-ink px-5 py-3 text-paper">
    <div>
      <p id="ai-title" class="font-mono text-[11px] uppercase tracking-widest">— Pregunta lo que sea</p>
      <p class="mt-0.5 font-mono text-[10px] tracking-wider text-paper/55">Te responde el equipo · con IA</p>
    </div>
    <div class="flex items-center gap-3">
      <button
        type="button"
        id="ai-send-team"
        class="font-mono text-[10px] uppercase tracking-widest text-magenta hover:text-paper"
        title="Enviar la conversación al equipo humano"
      >
        Pasar al equipo
      </button>
      <button
        type="button"
        id="ai-close"
        class="font-mono text-[11px] uppercase tracking-widest text-paper/70 hover:text-paper"
        aria-label="Cerrar"
      >
        Cerrar
      </button>
    </div>
  </div>

  <!-- Hilo -->
  <div id="ai-thread" class="flex-1 overflow-y-auto bg-paper-warm px-4 py-4 text-sm leading-relaxed"></div>

  <!-- Input -->
  <form id="ai-form" class="flex items-end gap-2 border-t-2 border-ink bg-paper p-3">
    <textarea
      id="ai-input"
      rows="2"
      maxlength="1500"
      placeholder="Escribe tu pregunta…"
      class="flex-1 resize-none border border-ink bg-paper px-3 py-2.5 font-mono text-sm text-ink placeholder:text-ink/40 focus:border-magenta focus:outline-none focus:ring-2 focus:ring-magenta/40"
    ></textarea>
    <button
      type="submit"
      id="ai-submit"
      class="border-2 border-ink bg-ink px-4 py-2.5 font-mono text-[11px] uppercase tracking-widest text-paper transition-colors hover:bg-magenta hover:border-magenta disabled:opacity-50"
    >
      Enviar
    </button>
  </form>
</div>

<style>
  .ai-bubble {
    @apply mb-3 max-w-[85%] px-4 py-2.5 text-sm leading-relaxed;
  }
  .ai-bubble.assistant {
    @apply mr-auto bg-paper border border-ink/15 text-ink;
  }
  .ai-bubble.user {
    @apply ml-auto bg-ink text-paper;
  }
  .ai-bubble.error {
    @apply mr-auto bg-paper border border-magenta text-magenta;
  }
  .ai-bubble p { @apply mb-1.5; }
  .ai-bubble p:last-child { @apply mb-0; }
  .ai-bubble strong { @apply font-bold; }
  .ai-bubble code {
    @apply rounded bg-ink/10 px-1 py-0.5 font-mono text-[12px];
  }
  .ai-typing {
    @apply inline-block h-2 w-2 animate-pulse rounded-full bg-magenta;
  }
</style>

<script>
  // Antes era <script is:inline> — el JS quedaba pegado en el HTML como
  // bytes síncronos en TODAS las páginas, sumando al fold inicial sin
  // necesidad real (este código solo configura listeners de chat).
  //
  // Ahora Astro lo bundle como módulo ESM con defer implícito: descarga
  // en paralelo al HTML pero no bloquea parse ni LCP. Comportamiento
  // funcional idéntico para el usuario.
  (function () {
    var chip = document.getElementById('ai-chip');
    var chipMobile = document.getElementById('ai-chip-mobile');
    var panel = document.getElementById('ai-panel');
    var closeBtn = document.getElementById('ai-close');
    var form = document.getElementById('ai-form');
    var input = document.getElementById('ai-input');
    var submit = document.getElementById('ai-submit');
    var thread = document.getElementById('ai-thread');
    var sendTeam = document.getElementById('ai-send-team');
    if (!panel || !form) return;

    // El chip flotante móvil aparece solo tras superar el hero, para no
    // solaparse con el CTA del hero (misma esquina inferior-derecha).
    // IntersectionObserver (no scroll listener): el sitio usa <body> como
    // contenedor de scroll, así que window.scrollY no sirve aquí.
    if (chipMobile) {
      chipMobile.style.transition = 'opacity .25s ease, transform .25s ease';
      var setChip = function (show) {
        chipMobile.style.opacity = show ? '1' : '0';
        chipMobile.style.transform = show ? 'translateY(0)' : 'translateY(10px)';
        chipMobile.style.pointerEvents = show ? 'auto' : 'none';
      };
      var hero = document.querySelector('main section') || document.querySelector('section');
      if (hero && 'IntersectionObserver' in window) {
        setChip(false);
        new IntersectionObserver(function (entries) {
          setChip(!entries[0].isIntersecting);
        }, { threshold: 0 }).observe(hero);
      } else {
        setChip(true);
      }
    }

    var history = [];
    var isStreaming = false;
    var welcomed = false;

    var trackedOpen = false;
    function setOpen(open) {
      panel.style.display = open ? 'flex' : 'none';
      panel.classList.toggle('hidden', !open);
      [chip, chipMobile].forEach(function (b) { b && b.setAttribute('aria-expanded', String(open)); });
      if (open) {
        if (!welcomed) saludarInicio();
        if (!trackedOpen) {
          trackedOpen = true;
          window.stTrack && window.stTrack('chat_open', { page_path: location.pathname });
        }
        setTimeout(function () { input && input.focus(); }, 100);
      }
    }

    function toggle() { setOpen(panel.classList.contains('hidden')); }
    chip && chip.addEventListener('click', toggle);
    chipMobile && chipMobile.addEventListener('click', toggle);
    closeBtn && closeBtn.addEventListener('click', function () { setOpen(false); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) setOpen(false);
    });

    function appendBubble(role, text) {
      var div = document.createElement('div');
      div.className = 'ai-bubble ' + role;
      div.textContent = text || '';
      thread.appendChild(div);
      thread.scrollTop = thread.scrollHeight;
      return div;
    }

    function saludarInicio() {
      welcomed = true;
      appendBubble('assistant', 'Hola, soy el asistente de Startidea. Puedo orientarte sobre servicios, precios orientativos, casos publicados y cómo arrancar un diagnóstico. ¿Qué te trae por aquí?');
    }

    async function enviarMensaje(texto) {
      if (!texto || isStreaming) return;
      appendBubble('user', texto);
      history.push({ role: 'user', content: texto });
      var userTurns = history.filter(function (m) { return m.role === 'user'; }).length;
      window.stTrack && window.stTrack('chat_message_sent', {
        turn: userTurns,
        page_path: location.pathname,
      });
      input.value = '';
      input.style.height = '';
      isStreaming = true;
      submit.disabled = true;

      var bubble = appendBubble('assistant', '');
      var typing = document.createElement('span');
      typing.className = 'ai-typing';
      bubble.appendChild(typing);

      try {
        var resp = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            messages: history,
            meta: window.location.pathname,
          }),
        });

        if (!resp.ok) {
          var err = await resp.json().catch(function () { return { message: 'Error del servidor' }; });
          bubble.className = 'ai-bubble error';
          bubble.textContent = err.message || 'No se pudo procesar la respuesta. Escribe a hola@startidea.es y te respondemos en horas.';
          return;
        }

        bubble.textContent = '';
        var reader = resp.body.getReader();
        var decoder = new TextDecoder('utf-8');
        var buffer = '';
        var fullText = '';

        while (true) {
          var chunk = await reader.read();
          if (chunk.done) break;
          buffer += decoder.decode(chunk.value, { stream: true });
          var lines = buffer.split('\n');
          buffer = lines.pop() || '';
          for (var i = 0; i < lines.length; i++) {
            var line = lines[i].trim();
            if (!line || !line.startsWith('data:')) continue;
            var data = line.slice(5).trim();
            if (data === '[DONE]') break;
            try {
              var json = JSON.parse(data);
              var delta = json.choices && json.choices[0] && json.choices[0].delta && json.choices[0].delta.content;
              if (delta) {
                fullText += delta;
                bubble.textContent = fullText;
                thread.scrollTop = thread.scrollHeight;
              }
            } catch (_) {}
          }
        }

        if (fullText) history.push({ role: 'assistant', content: fullText });
      } catch (e) {
        bubble.className = 'ai-bubble error';
        bubble.textContent = 'Sin conexión con el modelo. Inténtalo en un minuto o escribe a hola@startidea.es.';
      } finally {
        isStreaming = false;
        submit.disabled = false;
      }
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var t = (input.value || '').trim();
      if (!t) return;
      enviarMensaje(t);
    });

    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.dispatchEvent(new Event('submit'));
      }
    });

    // "Pasar al equipo" — pide email y manda toda la conversación a Telegram
    sendTeam && sendTeam.addEventListener('click', function () {
      if (history.length === 0) {
        alert('Cuéntame primero algo y luego paso la conversación al equipo.');
        return;
      }
      var email = prompt('¿A qué email te responde Startidea? (opcional, deja vacío para enviar sin contacto)');
      var ok = confirm('Esta conversación se enviará al equipo de Startidea para responderte. Tus datos se tratan según la política de privacidad (https://startidea.es/privacidad). ¿Continuar?');
      if (!ok) return;
      var transcript = history
        .map(function (m) { return (m.role === 'user' ? '> ' : '') + m.content; })
        .join('\n\n');
      fetch('/api/contacto', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          name: email ? 'Visitante (' + email + ')' : 'Visitante anónimo',
          email: email || 'sin-email@startidea.local',
          message: 'Conversacion con asistente IA:\n\n' + transcript,
          path: window.location.pathname,
          consent: true,
        }),
      })
        .then(function (r) { return r.json(); })
        .then(function (j) {
          if (j.ok) {
            window.stTrack && window.stTrack('chat_send_to_team', {
              has_email: Boolean(email),
              page_path: location.pathname,
            });
            window.stTrack && window.stTrack('generate_lead', {
              method: 'chat_ia',
              page_path: location.pathname,
            });
            appendBubble('assistant', 'He pasado la conversación al equipo. Si dejaste email, te contestan en las próximas 24h.');
          } else {
            appendBubble('error', 'No se pudo enviar. Escribe a hola@startidea.es directamente.');
          }
        })
        .catch(function () {
          appendBubble('error', 'No se pudo enviar. Escribe a hola@startidea.es directamente.');
        });
    });
  })();
</script>
