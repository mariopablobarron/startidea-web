---
// HeroJourney — home como VIAJE inmersivo (Plan A).
//
// Estructura "capa fija + espaciador de scroll": el viaje es una capa
// position:fixed a pantalla completa (cubre TODO, incluida la Nav, sin costuras
// ni huecos). El <section> mide 320vh y solo sirve de espacio de scroll. Al
// hacer scroll la cámara vuela por el campo de partículas 3D y al final del
// viaje llega al isotipo + el titular. Cuando el viaje termina, la capa se
// desvanece y aparece el contenido normal de la home debajo.
//
// SEO: el H1 real ("Innovación social que se nota") vive en la llegada (DOM
// siempre presente). Reduce-motion: hero estático con el H1, sin viaje.
---

<section class="jny" data-jny>
  <div class="jny__layer" data-jny-layer>
    <canvas id="jny-canvas" aria-hidden="true"></canvas>
    <video id="jny-bg" class="jny__bg" muted loop playsinline preload="none" poster="/hero/hero-poster.jpg" aria-hidden="true">
      <source src="/hero/hero-loop.mp4" type="video/mp4" />
    </video>
    <div class="jny__scrim" aria-hidden="true"></div>
    <div class="jny__vignette"></div>

    <div class="jny__overlay container-x">
      <div class="jny__stage jny__intro" data-stage="intro">
        <p class="jny__eyebrow">Startidea · innovación social</p>
        <p class="jny__lead">Entra en la <em>idea</em>.</p>
      </div>
      <div class="jny__stage jny__mid" data-stage="mid">
        <p class="jny__midtext">Comunicación, recursos y tecnología que <em>no envejecen</em>.</p>
      </div>
      <div class="jny__stage jny__end" data-stage="end">
        <p class="jny__eyebrow">— Agencia de comunicación e innovación social</p>
        <h1 class="jny__h1">Innovación social<br />que <em>se nota</em>.</h1>
        <div class="jny__cta"><a href="/contacto" class="btn" data-track="cta" data-track-id="hero_journey_diagnostico">Reserva una llamada de diagnóstico →</a></div>
        <div class="jny__cta-secondary">
          <span class="jny__cta-label">o directo —</span>
          <a
            href="https://wa.me/34958045789?text=Hola%2C%20quer%C3%ADa%20preguntar%20por%20Startidea."
            target="_blank"
            rel="noopener"
            data-track="cta"
            data-track-id="hero_journey_whatsapp"
            data-track-text="Hero WhatsApp"
            class="jny__cta-link"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/></svg>
            <span>WhatsApp</span>
          </a>
          <a
            href="tel:+34958045789"
            data-track="cta"
            data-track-id="hero_journey_llamar"
            data-track-text="Hero Llamar"
            class="jny__cta-link"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>958 045 789</span>
          </a>
        </div>
      </div>
    </div>

    <div class="jny__hint" data-hint>Scroll ↓</div>
  </div>
</section>

<style>
  .jny { position: relative; height: 320vh; }
  /* Visitas siguientes en la misma sesión: viaje corto (no forzar scroll largo). */
  .jny.is-quick { height: 130vh; }
  .jny__layer {
    position: fixed; inset: 0; z-index: 60; overflow: hidden; color: #fff;
    background: #08070a; transition: opacity .4s ease;
  }
  #jny-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; z-index: 0; }
  .jny__vignette { position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: radial-gradient(70% 70% at 50% 50%, transparent 55%, rgba(0,0,0,.6) 100%); }
  /* Fondo de vídeo (marca de agua) — solo en el hero asentado/estático. Durante
     el viaje 3D está oculto (display:none, preload:none → no carga). */
  .jny__bg { position: absolute; inset: 0; z-index: 0; width: 100%; height: 100%;
    object-fit: cover; display: none; opacity: 0; pointer-events: none;
    transition: opacity 1s ease; }
  .jny__scrim { position: absolute; inset: 0; z-index: 1; pointer-events: none;
    opacity: 0; transition: opacity 1s ease;
    background: linear-gradient(95deg, rgba(8,7,10,.94) 0%, rgba(8,7,10,.82) 38%, rgba(8,7,10,.5) 72%, rgba(8,7,10,.35) 100%); }
  .jny.is-arrived .jny__bg, .jny.is-static .jny__bg { display: block; opacity: .7; }
  .jny.is-arrived .jny__scrim, .jny.is-static .jny__scrim { opacity: 1; }
  .jny__overlay { position: absolute; inset: 0; z-index: 2; }
  .jny__stage { position: absolute; left: 0; right: 0; padding-left: clamp(24px,6vw,96px); padding-right: clamp(24px,6vw,96px);
    top: 50%; transform: translateY(-50%); opacity: 0; transition: opacity .5s ease; pointer-events: none; }
  .jny__stage.show { opacity: 1; }
  .jny__stage .btn { pointer-events: auto; }
  .jny__eyebrow { font-size: 12px; letter-spacing: .3em; text-transform: uppercase; color: #e6356b; font-weight: 700; margin-bottom: 16px; }
  .jny__lead { font-family: var(--font-startidea-alt, inherit); font-size: clamp(40px,8vw,104px); line-height: .95; font-weight: 800; letter-spacing: -.02em; }
  .jny__lead em { color: #e6356b; font-style: italic; }
  .jny__mid { text-align: center; }
  .jny__midtext { font-size: clamp(22px,3.4vw,46px); font-weight: 700; max-width: 18ch; margin: 0 auto; line-height: 1.15; }
  .jny__midtext em { color: #e6356b; font-style: normal; }
  .jny__h1 { font-family: var(--font-startidea-alt, inherit); font-size: clamp(40px,7vw,96px); line-height: .96; font-weight: 800; letter-spacing: -.02em; }
  .jny__h1 em { color: #e6356b; font-style: italic; }
  .jny__cta { margin-top: 30px; }
  .jny__cta-secondary { margin-top: 18px; display: flex; flex-wrap: wrap; align-items: center;
    gap: 8px 20px; font-family: ui-monospace, monospace; font-size: 11px; text-transform: uppercase;
    letter-spacing: .22em; }
  .jny__cta-label { color: rgba(255,255,255,.45); }
  .jny__cta-link { display: inline-flex; align-items: center; gap: 6px; color: rgba(255,255,255,.85);
    text-decoration: none; transition: color .2s ease; }
  .jny__cta-link:hover, .jny__cta-link:focus-visible { color: #e6356b; outline: none; }
  .jny__end .jny__eyebrow { color: rgba(255,255,255,.55); }
  .jny__hint { position: absolute; bottom: 26px; left: 50%; transform: translateX(-50%); z-index: 3;
    font-size: 11px; letter-spacing: .25em; text-transform: uppercase; color: rgba(255,255,255,.55); transition: opacity .4s; }

  /* Reduce-motion / sin WebGL: hero estático con el H1, en flujo normal.
     is-arrived: mismo estado limpio, al que se "asienta" el hero tras
     completar el viaje una vez (ver script — evita el túnel vacío al subir). */
  .jny.is-static, .jny.is-arrived { height: auto; }
  /* z-index: 0 (no 60) para que la Nav sticky (z-50) quede por encima del hero
     ya asentado / estático — si no, la capa taparía la barra de navegación. */
  .jny.is-static .jny__layer, .jny.is-arrived .jny__layer { position: relative; z-index: 0; min-height: 100svh; display: flex; align-items: center; opacity: 1 !important; }
  .jny.is-static #jny-canvas, .jny.is-static .jny__intro, .jny.is-static .jny__mid, .jny.is-static .jny__hint,
  .jny.is-arrived #jny-canvas, .jny.is-arrived .jny__intro, .jny.is-arrived .jny__mid, .jny.is-arrived .jny__hint { display: none; }
  .jny.is-static .jny__end, .jny.is-arrived .jny__end { position: relative; opacity: 1; transform: none; }
</style>

<style is:global>
  /* Mientras el viaje ocupa la pantalla, ocultamos el chrome del sitio (Nav,
     chips flotantes) para inmersión total. La capa fija ya tapa la barra CTA
     móvil. Reaparece al llegar al contenido. */
  html.journey-immersive header,
  html.journey-immersive #ai-chip,
  html.journey-immersive a[data-track-id^='float_whatsapp'] {
    opacity: 0 !important;
    pointer-events: none !important;
    transition: opacity .45s ease;
  }
</style>

<script>
  const section = document.querySelector('[data-jny]');
  const layer = document.querySelector('[data-jny-layer]');
  const canvas = document.getElementById('jny-canvas');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const setChrome = (active) => document.documentElement.classList.toggle('journey-immersive', active);

  if (!section || !canvas || !layer) {
    // nada
  } else if (reduce) {
    section.classList.add('is-static');
  } else {
    // Once-per-session: la 1ª visita ve el viaje completo; las siguientes una
    // versión corta (is-quick) para no forzar el scroll largo cada vez.
    const KEY = 'startidea:journeySeen';
    let seen = false; try { seen = !!sessionStorage.getItem(KEY); } catch (_) {}
    try { sessionStorage.setItem(KEY, '1'); } catch (_) {}
    if (seen) section.classList.add('is-quick');

    const progAt = () => {
      const denom = section.offsetHeight - innerHeight;
      return denom > 0 ? Math.min(1, Math.max(0, scrollY - section.offsetTop) / denom) : 0;
    };

    const start = async () => {
      const small = window.innerWidth < 760;
      let THREE;
      try { THREE = await import('three'); } catch { section.classList.add('is-static'); return; }

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: !small });
      renderer.setPixelRatio(Math.min(devicePixelRatio, small ? 1.5 : 2));
      renderer.setClearColor(0x08070a, 1);
      const scene = new THREE.Scene();
      scene.fog = new THREE.FogExp2(0x08070a, 0.0016);
      const cam = new THREE.PerspectiveCamera(70, 1, 0.1, 3000);

      const COUNT = small ? 2400 : 5500;
      const FAR = -1500;
      const fpos = new Float32Array(COUNT * 3), fcol = new Float32Array(COUNT * 3);
      const cMag = new THREE.Color(0xe6356b), cW = new THREE.Color(0xffffff), cG = new THREE.Color(0x8a8a93);
      for (let i = 0; i < COUNT; i++) {
        const z = 60 - Math.random() * (60 - FAR);
        const r = 24 + Math.random() * 120, a = Math.random() * Math.PI * 2;
        fpos[i*3] = Math.cos(a)*r; fpos[i*3+1] = Math.sin(a)*r*0.7; fpos[i*3+2] = z;
        const c = Math.random() < 0.6 ? cMag : (Math.random() < 0.5 ? cW : cG);
        fcol[i*3]=c.r; fcol[i*3+1]=c.g; fcol[i*3+2]=c.b;
      }
      const fgeo = new THREE.BufferGeometry();
      fgeo.setAttribute('position', new THREE.BufferAttribute(fpos, 3));
      fgeo.setAttribute('color', new THREE.BufferAttribute(fcol, 3));
      const field = new THREE.Points(fgeo, new THREE.PointsMaterial({ size: small ? 1.1 : 0.9, vertexColors: true, transparent: true, opacity: 0.9, depthWrite: false }));
      scene.add(field);

      const ISO_Z = FAR + 60; const isoArr = [];
      await new Promise((res) => {
        const img = new Image(); img.crossOrigin = 'anonymous'; img.src = '/brand/isotipo-lazos.png';
        img.onload = () => { const S=160, cv=document.createElement('canvas'); cv.width=cv.height=S;
          const x2=cv.getContext('2d'); x2.drawImage(img,0,0,S,S); const d=x2.getImageData(0,0,S,S).data; const st=small?2:1;
          for (let y=0;y<S;y+=st) for (let x=0;x<S;x+=st) if (d[(y*S+x)*4+3]>90) isoArr.push((x/S-0.5)*90,-(y/S-0.5)*90,ISO_Z+(Math.random()-0.5)*6);
          res(); };
        img.onerror = () => res();
      });
      const igeo = new THREE.BufferGeometry();
      igeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(isoArr), 3));
      const iso = new THREE.Points(igeo, new THREE.PointsMaterial({ color: 0xe6356b, size: 1.1, transparent: true, opacity: 0, depthWrite: false }));
      scene.add(iso);

      const resize = () => { const w=innerWidth,h=innerHeight; renderer.setSize(w,h); cam.aspect=w/h; cam.updateProjectionMatrix(); };
      addEventListener('resize', resize); resize();

      const stages = [...section.querySelectorAll('.jny__stage')];
      const hint = section.querySelector('[data-hint]');
      const show = (n, on) => { const e = stages.find(s => s.dataset.stage === n); if (e) e.classList.toggle('show', on); };

      let prog = 0, target = 0, t = 0, paused = false, done = false, completedOnce = false, settled = false;

      // Tras completar el viaje UNA vez, cuando el usuario ya ha pasado el hero
      // entero hacia el contenido, el hero se "asienta" en su estado limpio
      // (igual que reduce-motion: H1 + identidad + CTA, nav visible). Así, al
      // volver arriba NO reaparece el túnel vacío "Entra en la idea". Sin salto:
      // el hero queda por encima del viewport y compensamos el scroll al colapsar.
      const settle = () => {
        if (settled) return;
        settled = true; done = true;
        const before = section.offsetHeight;
        section.classList.add('is-arrived');
        const after = section.offsetHeight;
        const html = document.documentElement;
        const prevSB = html.style.scrollBehavior;
        html.style.scrollBehavior = 'auto';
        scrollBy(0, after - before); // colapso compensado: el contenido no se mueve
        html.style.scrollBehavior = prevSB;
        setChrome(false); // nav y chips vuelven
        // Fondo de vídeo: solo se reproduce en desktop (en móvil queda el poster
        // estático, para no gastar datos). small = innerWidth < 760 (arriba).
        const bg = document.getElementById('jny-bg');
        if (bg && !small) bg.play().catch(function () {});
      };

      const onScroll = () => {
        target = progAt();
        if (completedOnce && !settled && scrollY > section.offsetHeight + 1) settle();
      };
      addEventListener('scroll', onScroll, { passive: true }); onScroll();
      document.addEventListener('visibilitychange', () => { paused = document.hidden; });

      const loop = () => {
        if (done) return;
        if (!paused) {
          t += 0.016; prog += (target - prog) * 0.08;
          cam.position.z = 60 + prog * (ISO_Z - 60 + 30);
          cam.position.x = Math.sin(t*0.2)*3 + Math.sin(prog*6)*4;
          cam.position.y = Math.cos(t*0.17)*2;
          cam.rotation.z = Math.sin(t*0.1)*0.04;
          cam.lookAt(0, 0, cam.position.z - 100);
          field.rotation.z = prog * 0.6;
          const fp = fgeo.attributes.position.array;
          for (let i = 2; i < fp.length; i += 3) if (fp[i] > cam.position.z + 30) fp[i] -= (60 - FAR);
          fgeo.attributes.position.needsUpdate = true;
          iso.material.opacity = Math.max(0, (prog - 0.74) / 0.26);
          iso.rotation.z = (1 - prog) * 1.2;
          show('intro', prog < 0.16);
          show('mid', prog > 0.34 && prog < 0.6);
          show('end', prog > 0.82);
          if (prog > 0.98) completedOnce = true;
          if (hint) hint.style.opacity = prog > 0.05 ? '0' : '0.55';
          // Capa: visible durante el viaje, se desvanece al llegar al contenido.
          const fade = prog < 0.86 ? 1 : Math.max(0, (1 - prog) / 0.14);
          layer.style.opacity = String(fade);
          // No bloquear clics del contenido en cuanto el viaje está por acabar.
          layer.style.pointerEvents = prog > 0.95 ? 'none' : '';
          setChrome(prog < 0.92);
          renderer.render(scene, cam);
        }
        requestAnimationFrame(loop);
      };
      show('intro', true);
      setChrome(true);
      loop();
    };
    if ('requestIdleCallback' in window) requestIdleCallback(() => start(), { timeout: 800 });
    else setTimeout(start, 200);
  }
</script>
