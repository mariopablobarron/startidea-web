---
// Splash screen — sólo primera visita por sesión, sólo en desktop.
//
// Cambio 15-may para arreglar LCP: el preload="auto" anterior descargaba
// 405KB de MP4 antes del Hero, lo que metía 2-3s extra en LCP según
// Lighthouse (modo "primera visita" emulado). Ahora:
//   - preload="none" → el browser NO toca el video hasta que JS decide
//   - Se omite en mobile (<768px) donde el coste relativo es mayor
//   - Se omite si la sesión ya lo vio o si reduce-motion está activo
//   - El src se inyecta tras LCP via requestIdleCallback para garantizar
//     que el critical path inicial no incluye el video
---

<div
  id="splash"
  class="fixed inset-0 z-[100] flex items-center justify-center bg-paper transition-opacity duration-700 ease-out"
  style="opacity:0; pointer-events:none;"
  aria-hidden="true"
>
  <video
    id="splash-video"
    class="h-full w-full object-cover"
    muted
    playsinline
    preload="none"
    data-src="/brand/logo-animado.mp4"
  ></video>
</div>

<script>
  const splash = document.getElementById('splash') as HTMLDivElement | null;
  const video = document.getElementById('splash-video') as HTMLVideoElement | null;

  function teardown() {
    if (splash) splash.remove();
    document.documentElement.style.overflow = '';
  }

  if (!splash || !video) {
    // nada
  } else {
    const KEY = 'startidea:splashShown';
    const shown = sessionStorage.getItem(KEY);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth < 768;

    // Skip splash en mobile, sesiones repetidas o reduce-motion
    if (shown || reduce || isMobile) {
      teardown();
      try { sessionStorage.setItem(KEY, '1'); } catch (_) {}
    } else {
      // Diferir descarga + reproducción hasta después del LCP
      const start = () => {
        const src = video.dataset.src;
        if (!src) { teardown(); return; }

        // Crear <source> dinámicamente para que el browser empiece a descargar AHORA
        const source = document.createElement('source');
        source.src = src;
        source.type = 'video/mp4';
        video.appendChild(source);
        video.load();

        splash.style.opacity = '1';
        splash.style.pointerEvents = 'auto';
        document.documentElement.style.overflow = 'hidden';

        video.play().catch(() => {
          teardown();
          try { sessionStorage.setItem(KEY, '1'); } catch (_) {}
        });

        const finish = () => {
          if (!splash) return;
          splash.style.opacity = '0';
          document.documentElement.style.overflow = '';
          try { sessionStorage.setItem(KEY, '1'); } catch (_) {}
          setTimeout(() => splash.remove(), 800);
        };

        video.addEventListener('ended', finish);
        setTimeout(finish, 5000);
      };

      // requestIdleCallback ejecuta cuando el browser está libre — después
      // de paint inicial y LCP. Fallback a setTimeout en navegadores viejos.
      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(start, { timeout: 1200 });
      } else {
        setTimeout(start, 200);
      }
    }
  }
</script>
