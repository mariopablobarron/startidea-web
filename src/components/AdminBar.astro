---
// AdminBar — Barra superior solo visible si la cookie de admin es válida.
//
// Se renderiza en SSR (server-only) leyendo Astro.cookies. Si no hay sesión,
// el componente devuelve nada y no añade markup ni JS.
//
// El contexto editorial (qué editar) se calcula a partir del path actual:
//   /              → KPIs + accesos rápidos al HUB
//   /notas/<slug>  → botón "Editar nota" en HUB
//   /casos/<slug>  → botón "Editar caso" (todavía no hay admin de casos)
//   /subvenciones* → link al admin de subvenciones del HUB
//   /diagnostico   → link a leads del diagnóstico

import { isAdminLoggedIn } from "@/lib/admin-session";

const isAdmin = isAdminLoggedIn(Astro.cookies);

if (!isAdmin) {
  // No renderiza nada para usuarios anónimos
}

const currentPath = Astro.url.pathname;

let contextLabel = "Home";
let editLabel: string | null = null;
let editUrl: string | null = null;

if (currentPath.startsWith("/notas/")) {
  const slug = currentPath.replace("/notas/", "").replace(/\/$/, "");
  if (slug && slug !== "") {
    contextLabel = `Nota · ${slug}`;
    editLabel = "Editar en HUB";
    editUrl = `https://hub.startidea.tech/startidea/admin/notas/${slug}`;
  } else {
    contextLabel = "Listado de notas";
    editUrl = `https://hub.startidea.tech/startidea/admin/notas`;
    editLabel = "Gestionar en HUB";
  }
} else if (currentPath.startsWith("/casos/")) {
  const slug = currentPath.replace("/casos/", "").replace(/\/$/, "");
  contextLabel = slug && slug !== "" ? `Caso · ${slug}` : "Listado de casos";
  editLabel = "Gestionar contenido";
  editUrl = `https://hub.startidea.tech/startidea/admin/notas`;
} else if (currentPath.startsWith("/subvenciones")) {
  contextLabel = "Subvenciones";
  editLabel = "Admin subvenciones";
  editUrl = `https://hub.startidea.tech/startidea/admin/subsidies`;
} else if (currentPath.startsWith("/diagnostico")) {
  contextLabel = "Diagnóstico";
  editLabel = "Ver leads";
  editUrl = `/admin/leads?kind=diagnostico`;
} else if (currentPath.startsWith("/presupuesto")) {
  contextLabel = "Presupuesto";
  editLabel = "Ver leads";
  editUrl = `/admin/leads?kind=presupuesto`;
} else if (currentPath.startsWith("/admin/leads")) {
  contextLabel = "Admin · Leads";
} else if (currentPath.startsWith("/admin")) {
  contextLabel = "Admin";
} else if (currentPath.startsWith("/laboratorio")) {
  contextLabel = "Laboratorio";
} else if (currentPath === "/") {
  contextLabel = "Home";
} else {
  contextLabel = currentPath;
}

const HUB_DASHBOARD = "https://hub.startidea.tech/startidea";
---

{isAdmin && (
  <>
    <div
      id="admin-bar"
      class="fixed left-0 right-0 top-0 z-[100] flex h-[38px] items-center gap-3 border-b border-magenta bg-ink px-4 text-paper font-mono text-[10px] uppercase tracking-widest sm:gap-4 sm:px-5 sm:text-[11px]"
      role="region"
      aria-label="Barra de administrador"
    >
      <!-- Marca + contexto -->
      <a
        href={HUB_DASHBOARD}
        target="_blank"
        rel="noopener"
        class="flex shrink-0 items-center gap-2 hover:text-magenta"
      >
        <span class="text-magenta">●</span>
        <span class="opacity-90">Startidea Admin</span>
      </a>

      <span class="hidden opacity-30 sm:inline">/</span>

      <span
        id="admin-context"
        class="hidden truncate text-paper/70 sm:inline"
        title={contextLabel}
      >
        {contextLabel}
      </span>

      {editUrl && (
        <a
          href={editUrl}
          target="_blank"
          rel="noopener"
          class="hidden shrink-0 text-magenta hover:underline md:inline"
        >
          {editLabel} ↗
        </a>
      )}

      <!-- Spacer -->
      <span class="flex-1"></span>

      <!-- KPIs ligeros -->
      <span
        id="admin-kpis"
        class="hidden text-paper/55 lg:inline"
        aria-live="polite"
      >
        cargando…
      </span>

      <!-- Notificaciones -->
      <button
        id="admin-notif-btn"
        type="button"
        class="relative shrink-0 hover:text-magenta"
        title="Notificaciones"
        aria-haspopup="true"
        aria-expanded="false"
      >
        <span aria-hidden="true">🔔</span>
        <span
          id="admin-notif-badge"
          class="absolute -right-2 -top-1.5 hidden min-w-[15px] rounded-full bg-magenta px-1 text-center text-[9px] font-bold leading-[15px] text-paper"
        >0</span>
      </button>

      <!-- Quick links -->
      <a
        href="/admin/leads"
        class="shrink-0 hover:text-magenta"
        title="Leads capturados (diagnóstico + presupuesto)"
      >
        Leads
      </a>

      <a
        href={`${HUB_DASHBOARD}/admin/subsidies`}
        target="_blank"
        rel="noopener"
        class="shrink-0 hover:text-magenta"
        title="Admin subvenciones (HUB)"
      >
        HUB ↗
      </a>

      <a
        href="/admin/logout"
        class="shrink-0 hover:text-magenta"
        title="Cerrar sesión admin"
      >
        Salir
      </a>
    </div>

    <!-- Panel de notificaciones -->
    <div
      id="admin-notif-panel"
      class="fixed right-2 top-[42px] z-[101] hidden w-[340px] max-w-[92vw] border border-magenta bg-ink text-paper shadow-2xl"
      role="dialog"
      aria-label="Notificaciones"
    >
      <div class="border-b border-paper/15 px-4 py-2 font-mono text-[10px] uppercase tracking-widest text-paper/60">
        Notificaciones
      </div>
      <ul id="admin-notif-list" class="max-h-[60vh] overflow-y-auto">
        <li class="px-4 py-3 text-[11px] text-paper/50">Cargando…</li>
      </ul>
    </div>

    <style is:global>
      /* Empuja todo el contenido y los headers sticky 38px hacia abajo. */
      body { padding-top: 38px; }
      body header.sticky { top: 38px !important; }
      html { scroll-padding-top: 118px !important; } /* 38 + 80 del nav */
    </style>

    <script>
      // Toggle del panel de notificaciones (funciona aunque el fetch tarde).
      const notifBtn = document.getElementById("admin-notif-btn");
      const notifPanel = document.getElementById("admin-notif-panel");
      notifBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        const open = notifPanel?.classList.toggle("hidden") === false;
        notifBtn.setAttribute("aria-expanded", open ? "true" : "false");
      });
      document.addEventListener("click", (e) => {
        if (!notifPanel || notifPanel.classList.contains("hidden")) return;
        if (notifPanel.contains(e.target as Node) || notifBtn?.contains(e.target as Node)) return;
        notifPanel.classList.add("hidden");
        notifBtn?.setAttribute("aria-expanded", "false");
      });

      const esc = (s: unknown) =>
        String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c] as string));

      // Carga KPIs + notificaciones en background. Si falla, la barra sigue útil.
      (async () => {
        try {
          const r = await fetch("/api/admin/bar-data", { credentials: "same-origin" });
          if (!r.ok) {
            const el = document.getElementById("admin-kpis");
            if (el) el.textContent = "kpis: —";
            return;
          }
          const data = await r.json();
          const el = document.getElementById("admin-kpis");
          if (el) {
            const parts: string[] = [];
            if (data.leads_new != null) parts.push(`Nuevos ${data.leads_new}`);
            if (data.leads_7d != null) parts.push(`Leads 7d ${data.leads_7d}`);
            if (data.subsidies_total != null)
              parts.push(`Subv ${data.subsidies_total.toLocaleString("es-ES")}`);
            el.textContent = parts.length ? parts.join(" · ") : "kpis: —";
          }

          // Notificaciones
          const notifs = Array.isArray(data.notifications) ? data.notifications : [];
          const badge = document.getElementById("admin-notif-badge");
          if (badge && notifs.length > 0) {
            badge.textContent = notifs.length > 99 ? "99+" : String(notifs.length);
            badge.classList.remove("hidden");
          }
          const list = document.getElementById("admin-notif-list");
          if (list) {
            list.innerHTML = notifs.length
              ? notifs
                  .map(
                    (it: { icon: string; text: string; href: string }) =>
                      `<li><a href="${esc(it.href)}" class="flex items-start gap-2 border-b border-paper/10 px-4 py-2.5 text-[11px] leading-snug text-paper/85 hover:bg-paper/5 hover:text-magenta"><span>${esc(it.icon)}</span><span>${esc(it.text)}</span></a></li>`,
                  )
                  .join("")
              : `<li class="px-4 py-3 text-[11px] text-paper/50">Sin notificaciones. Todo al día ✅</li>`;
          }
        } catch {
          const el = document.getElementById("admin-kpis");
          if (el) el.textContent = "kpis: —";
        }
      })();
    </script>
  </>
)}
