---
// Han confiado — pared de marcas con las que Startidea ha trabajado.
// Si existe un archivo en /public/clientes/<slug>.png se muestra el logo;
// si no, el wordmark editorial cumple su función (también queda bien).
//
// Para añadir un logo nuevo: poner PNG transparente (preferentemente cuadrado
// o casi cuadrado, ~512x512px) en /public/clientes/<slug>.png y referenciar
// el slug aquí.
// Cuando el archivo no es .png, se especifica el nombre completo (jpg, svg).
const grupos = [
  {
    label: 'Tercer sector · estatal',
    clientes: [
      { name: 'Cruz Roja Española', logo: 'cruz-roja.png' },
      { name: 'Fundación Save the Children', logo: 'save-the-children.png' },
      { name: 'Fundación Acción Contra el Hambre', logo: 'accion-contra-el-hambre.png' },
      { name: 'YMCA España', logo: 'ymca.png' },
      { name: 'Fundación Proyecto Solidario por la Infancia', logo: 'proyecto-solidario.png' },
      { name: 'Asociación Provivienda', logo: 'provivienda.png' },
      { name: 'Fundación Nantik Lum' },
      { name: 'Asociación Católica de Propagandistas' },
      { name: 'Fundación Foro NESI' },
    ],
  },
  {
    label: 'Tercer sector · proximidad',
    clientes: [
      { name: 'Down Granada', logo: 'down-granada.png' },
      { name: 'Proyecto Hombre Granada', logo: 'proyecto-hombre-granada.png' },
      { name: 'Fundación UAPO', logo: 'uapo.png' },
      { name: 'Aspaym Granada', logo: 'aspaym-granada.jpg' },
      { name: 'Aldaima' },
      { name: 'Arrabal-AID' },
      { name: 'Tres Mil Millones de Latidos' },
    ],
  },
  {
    label: 'Educación con propósito',
    clientes: [
      { name: 'Fundación Maristas Ibérica' },
      { name: 'Fundación Educativa Escolapias', logo: 'escolapias.png' },
      { name: 'Fundación Marcelino Champagnat' },
      { name: 'Fundación Enrique de Ossó' },
      { name: 'CONFER' },
      { name: 'Fundación Santa María la Real', logo: 'santa-maria-la-real.png' },
    ],
  },
  {
    label: 'Instituciones públicas',
    clientes: [
      { name: 'Diputación de Granada', logo: 'diputacion-granada.png' },
      { name: 'Ayuntamiento de Granada', logo: 'ayuntamiento-granada.png' },
      { name: 'Universidad de Granada', logo: 'universidad-granada.jpg' },
      { name: 'Fundación Pública Andaluza Progreso y Salud' },
      { name: 'Ayuntamiento de Vila-real' },
    ],
  },
  {
    label: 'Empresa con propósito',
    clientes: [
      { name: 'Clínica Dental Arturo Baca' },
      { name: 'Fundación Espadafor', logo: 'espadafor.png' },
    ],
  },
  {
    label: 'Iniciativas propias',
    clientes: [
      { name: 'Granada Social', logo: 'granada-social.svg' },
      { name: '#HamadaYJavi' },
      { name: 'Granadown Report' },
    ],
  },
] satisfies Array<{
  label: string;
  clientes: Array<{ name: string; logo?: string }>;
}>;
---

<section class="relative bg-paper-warm py-20 md:py-28">
  <div class="container-x">
    <!-- Encabezado -->
    <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
      <div class="col-span-12 lg:col-span-4">
        <span class="label">— Han confiado</span>
        <h2 class="mt-4 font-display text-display-md leading-tight text-ink">
          Organizaciones que <em class="italic text-magenta">cuentan con Startidea</em>.
        </h2>
      </div>
      <div class="col-span-12 mt-6 lg:col-span-7 lg:col-start-6 lg:mt-0">
        <p class="max-w-measure text-ink/80">
          Cada relación se abre con una llamada de diagnóstico de 30 minutos. Si encajamos, nos quedamos años. La selección que sigue son organizaciones reales, agrupadas por el tipo de conversación que tenemos con cada una — hay más cuya discreción es parte del acuerdo.
        </p>
      </div>
    </div>

    <!-- Grupos editoriales -->
    <div class="mt-16 space-y-12">
      {grupos.map((grupo) => (
        <div class="grid grid-cols-12 gap-x-8 border-t border-ink/15 pt-8">
          <div class="col-span-12 lg:col-span-3">
            <span class="label">— {grupo.label}</span>
          </div>
          <div class="col-span-12 mt-4 lg:col-span-9 lg:mt-0">
            <ul class="grid grid-cols-2 gap-px border-2 border-ink/15 bg-ink/15 sm:grid-cols-3 lg:grid-cols-3">
              {grupo.clientes.map((c) => (
                <li class="group flex aspect-[3/2] items-center justify-center bg-paper p-6 text-center transition-colors hover:bg-paper-warm">
                  {c.logo ? (
                    <img
                      src={`/clientes/${c.logo}`}
                      alt={c.name}
                      loading="lazy"
                      class="max-h-16 max-w-[78%] w-auto h-auto object-contain opacity-70 grayscale transition-all duration-300 group-hover:opacity-100 group-hover:grayscale-0 sm:max-h-20"
                    />
                  ) : (
                    <p class="font-display text-lg leading-tight text-ink transition-colors group-hover:text-magenta md:text-xl">
                      {c.name}
                    </p>
                  )}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
