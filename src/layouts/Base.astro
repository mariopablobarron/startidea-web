---
import '@/styles/global.css';
// Self-host de fonts variable (un solo woff2 por familia para
// todos los pesos 100-900, con subsets latin + latin-ext).
// Reemplaza la petición a fonts.googleapis.com — más rápido y mejor RGPD.
import '@fontsource-variable/montserrat';
import '@fontsource-variable/montserrat/wght-italic.css';
import '@fontsource-variable/jetbrains-mono';

// URLs hashed de los woff2 críticos del fold inicial — Astro las resuelve
// en build para usar en <link rel="preload">. Sin preload, el browser
// solo descubre estos archivos tras parsear el CSS principal, lo que
// retrasa el render del <h1> del Hero y empuja el LCP a 4-5s.
// Con preload, descargan en paralelo y el LCP cae sub-3s.
import montserratLatin from '@fontsource-variable/montserrat/files/montserrat-latin-wght-normal.woff2?url';
import montserratLatinItalic from '@fontsource-variable/montserrat/files/montserrat-latin-wght-italic.woff2?url';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import Splash from '@/components/Splash.astro';
import CookieBanner from '@/components/CookieBanner.astro';
import AsistenteIA from '@/components/AsistenteIA.astro';
import VoiceAgent from '@/components/VoiceAgent.astro';
import MobileCtaBar from '@/components/MobileCtaBar.astro';
import WhatsAppFloat from '@/components/WhatsAppFloat.astro';
import GoogleTagManager from '@/components/GoogleTagManager.astro';
import AnalyticsTracker from '@/components/AnalyticsTracker.astro';
import MicrosoftClarity from '@/components/MicrosoftClarity.astro';
import JsonLd from '@/components/JsonLd.astro';
import AdminBar from '@/components/AdminBar.astro';

interface Props {
  title?: string;
  description?: string;
  ogSlug?: string;  // ej. 'home', 'page/manifiesto', 'casos/down-granada'
  noindex?: boolean;
  jsonLd?: unknown | unknown[];
}

const {
  title = 'Startidea — Innovación social que cambia la conversación',
  description = 'Agencia de innovación social en Granada. Comunicación, consultoría, fundraising y producción audiovisual al servicio de organizaciones con propósito.',
  ogSlug = 'home',
  noindex = false,
  jsonLd = null,
} = Astro.props;

const SITE_URL = Astro.site?.toString().replace(/\/$/, '') || 'https://startidea.es';
const ogImageUrl = `${SITE_URL}/og/${ogSlug}.png`;
// Canonical sin trailing slash — convención del repo (ver redirects en
// astro.config.mjs). Astro 5 con trailingSlash:'ignore' sirve la misma
// página con y sin slash; sin normalizar, el canonical se auto-referencia
// distinto según cómo se entre, creando duplicados a ojos de Google.
const canonicalPath = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');
const canonicalUrl = new URL(canonicalPath, SITE_URL).toString();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload fuentes críticas del fold (Montserrat latin) — sin esto el
         browser solo descubre el woff2 después de parsear el CSS, lo que
         retrasaba LCP del <h1> hasta 4-5s. Con preload bajamos a ~2s. -->
    <link rel="preload" href={montserratLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={montserratLatinItalic} as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf8f5" />
    <link rel="alternate" type="application/rss+xml" title="Startidea — Notas" href="/rss.xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Startidea" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <GoogleTagManager />
    <AnalyticsTracker />
    <MicrosoftClarity />
    {jsonLd && <JsonLd data={jsonLd} />}
    <!-- Umami analytics (privacy-first) -->
    <script defer src="https://analytics.hubstartidea.es/script.js" data-website-id="3535ee03-30aa-4c5c-a74e-4650ed465c21"></script>
  </head>
  <body class="overflow-x-hidden pb-[72px] xl:pb-0">
    <AdminBar />
    <Splash />
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
    <AsistenteIA />
    <VoiceAgent />
    <MobileCtaBar />
    <CookieBanner />

    <script>
      // Reveal-on-scroll v2 (Sprint editorial 2026-05-19)
      // - Observer único para .reveal / .reveal-zoom / .reveal-stagger
      // - Threshold variable: imágenes y bloques grandes con threshold más
      //   bajo (aparecen antes); cifras grandes con threshold más alto
      //   (esperan a estar centradas) → sensación cinematográfica.
      // - Parallax ligero en [data-parallax] sin librerías (rAF + getBoundingClientRect)
      // - Respeta prefers-reduced-motion: salta TODA la animación.

      const prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;

      if (prefersReducedMotion) {
        // Marca todo como visible sin animación
        document
          .querySelectorAll('.reveal, .reveal-zoom, .reveal-stagger')
          .forEach((el) => el.classList.add('is-visible'));
      } else {
        // Observer único con threshold variable por contexto
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          {
            threshold: [0.08, 0.18, 0.4],
            rootMargin: '0px 0px -40px 0px',
          }
        );

        document
          .querySelectorAll('.reveal, .reveal-zoom, .reveal-stagger')
          .forEach((el) => io.observe(el));

        // Parallax sutil para [data-parallax="X"] (X = factor 0.05-0.3)
        // Aplica translate3d proporcional al scroll. Vanilla + rAF para no
        // bloquear el main thread. Ignoramos si no hay elementos parallax.
        const parallaxEls = document.querySelectorAll('[data-parallax]');
        if (parallaxEls.length > 0) {
          let ticking = false;
          const updateParallax = () => {
            const vh = window.innerHeight;
            parallaxEls.forEach((el) => {
              const rect = el.getBoundingClientRect();
              if (rect.bottom < 0 || rect.top > vh) return; // fuera viewport
              const factor = parseFloat(el.dataset.parallax || '0.15');
              // Posición relativa al centro del viewport: -1 (top) → +1 (bottom)
              const center = rect.top + rect.height / 2;
              const relative = (center - vh / 2) / vh;
              const offset = relative * -40 * factor;
              el.style.transform = `translate3d(0, ${offset.toFixed(1)}px, 0)`;
            });
            ticking = false;
          };
          window.addEventListener(
            'scroll',
            () => {
              if (!ticking) {
                requestAnimationFrame(updateParallax);
                ticking = true;
              }
            },
            { passive: true }
          );
          updateParallax(); // run inicial
        }
      }
    </script>
  </body>
</html>
