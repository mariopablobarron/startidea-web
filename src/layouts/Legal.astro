---
import Base from '@/layouts/Base.astro';

interface Props {
  title: string;
  description?: string;
  updated: string;
}
const { title, description, updated } = Astro.props;
---

<Base title={`${title} — Startidea`} description={description}>
  <section class="border-b border-ink/15 bg-paper py-16 md:py-24 lg:py-28">
    <div class="container-narrow">
      <span class="label">— Información legal</span>
      <h1 class="mt-4 font-display text-display-lg leading-[0.96] text-ink">
        {title}
      </h1>
      <p class="mt-8 font-mono text-xs uppercase tracking-widest text-ink-mute">
        Última actualización: {updated}
      </p>
    </div>
  </section>

  <article class="bg-paper py-16 md:py-24">
    <div class="container-narrow">
      <div class="prose-legal space-y-8 text-base leading-relaxed text-ink/85">
        <slot />
      </div>
    </div>
  </article>
</Base>

<style is:global>
  .prose-legal h2 {
    @apply mt-12 mb-4 font-display font-extrabold text-2xl text-ink md:text-3xl;
    letter-spacing: -0.025em;
  }
  .prose-legal h3 {
    @apply mt-8 mb-3 font-display font-bold text-xl text-ink md:text-2xl;
    letter-spacing: -0.02em;
  }
  .prose-legal p { @apply leading-relaxed; }
  .prose-legal ul { @apply list-disc pl-6 space-y-2; }
  .prose-legal a { @apply text-ink underline decoration-ink/30 underline-offset-4 hover:text-magenta hover:decoration-magenta; }
  .prose-legal strong { @apply text-ink; }
  .prose-legal table { @apply w-full border-t border-ink/15; }
  .prose-legal td { @apply border-b border-ink/15 py-2 pr-4 align-top; }
</style>
