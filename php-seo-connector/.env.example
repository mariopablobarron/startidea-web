GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://startidea.es/admin/google/callback

DB_HOST=127.0.0.1
DB_NAME=startidea_seo
DB_USER=startidea_seo
DB_PASS=

# Generate with: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
APP_ENCRYPTION_KEY=

# Protects /admin/* routes. Pass it as ?token=... or set cookie from status page.
ADMIN_TOKEN=

# Optional defaults
APP_URL=https://startidea.es
SEO_DEFAULT_START_DATE=-28 days
SEO_DEFAULT_END_DATE=yesterday
