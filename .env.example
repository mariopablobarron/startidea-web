# Telegram bot — chip "Pasar al equipo" del asistente
TELEGRAM_BOT_TOKEN=tu_token_de_botfather_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# OpenRouter — asistente IA en /api/chat
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_MAX_TOKENS=600

# Admin de la knowledge base + conector SEO
# String largo aleatorio. Acceso en /admin/knowledge?token=...
ADMIN_TOKEN=cambia_esto_por_un_string_largo_aleatorio

# Google OAuth — conector GA4 + Search Console (/admin/google/*)
# Crear en https://console.cloud.google.com/ con Authorized redirect URI =
#   https://startidea.es/admin/google/callback
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://startidea.es/admin/google/callback

# Cifrado AES-256-GCM de refresh_token. Generar con:
#   openssl rand -base64 32
# Si la cambias, los tokens existentes se invalidan (hay que reconectar).
APP_ENCRYPTION_KEY=

# Ruta del fichero SQLite (opcional, default ./data/seo.db)
# En Coolify monta un Persistent Volume en /app/data y deja:
# SEO_DB_PATH=/app/data/seo.db

# Google Tag Manager / verificación Search Console (públicas, build-time)
PUBLIC_GTM_ID=GTM-N3SR8J
PUBLIC_GOOGLE_SITE_VERIFICATION=
